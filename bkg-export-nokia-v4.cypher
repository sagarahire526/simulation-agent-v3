LLC.\\",\\n    \\"gc_assigned_date\\": null,\\n    \\"civil_only_flag\\": \\"no\\",\\n    \\"secondary_gc_or_ci_gc\\": \\"nokia\\"\\n  },\\n  {\\n    \\"pj_project_id\\": \\"HT10017D-0002000017\\",\\n    \\"s_site_id\\": \\"HT10017D\\",\\n    \\"m_market\\": \\"HOUSTON\\",\\n    \\"m_area\\": \\"TEXAS\\",\\n    \\"rgn_region\\": \\"SOUTH\\",\\n    \\"gc_assigned\\": \\"VERICORE LLC.\\",\\n    \\"gc_assigned_date\\": \\"2024-12-08 03:07:05\\",\\n    \\"civil_only_flag\\": \\"yes\\",\\n    \\"secondary_gc_or_ci_gc\\": \\"nokia\\"\\n  },\\n  {\\n    \\"pj_project_id\\": \\"AU10018B-0002000018\\",\\n    \\"s_site_id\\": \\"AU10018B\\",\\n    \\"m_market\\": \\"AUSTIN\\",\\n    \\"m_area\\": \\"TEXAS\\",\\n    \\"rgn_region\\": \\"SOUTH\\",\\n    \\"gc_assigned\\": \\"CLEARPATH TELECOM LLC.\\",\\n    \\"gc_assigned_date\\": null,\\n    \\"civil_only_flag\\": null,\\n    \\"secondary_gc_or_ci_gc\\": \\"nokia\\"\\n  },\\n  {\\n    \\"pj_project_id\\": \\"SA10019E-0002000019\\",\\n    \\"s_site_id\\": \\"SA10019E\\",\\n    \\"m_market\\": \\"SAN ANTONIO\\",\\n    \\"m_area\\": \\"TEXAS\\",\\n    \\"rgn_region\\": \\"SOUTH\\",\\n    \\"gc_assigned\\": \\"SUMMIT WIRELESS LLC.\\",\\n    \\"gc_assigned_date\\": null,\\n    \\"civil_only_flag\\": null,\\n    \\"secondary_gc_or_ci_gc\\": \\"nokia\\"\\n  }\\n]\\n```", "timestamp": "2026-03-05T13:05:05.522642+00:00", "updates_applied": ["label_column", "sql_template", "reasoning_summary", "python_function", "sample_data"]}], "contract": {"function_name": "get_general_contractor_assignment", "node_type": "core", "node_id": "general_contractor_assignment", "node_label": "General Contractor Assignment", "description": "Query General Contractor Assignment data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "id", "type": "number", "description": "Filter by id", "required": false, "sample_values": ["30000", "30001", "30002"]}, {"name": "m_area", "type": "string", "description": "Filter by m_area", "required": false, "sample_values": ["GREAT LAKES"]}, {"name": "m_market", "type": "string", "description": "Filter by m_market", "required": false, "sample_values": ["CHICAGO", "DETROIT", "INDIANAPOLIS"]}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj_general_contractor", "required": false, "sample_values": ["impirium", "telcom construction", "hampton enterprises"]}, {"name": "pj_por_count", "type": "string", "description": "Filter by pj_por_count", "required": false, "sample_values": []}, {"name": "pj_program_name", "type": "string", "description": "Filter by pj_program_name", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj_project_id (primary key)", "required": false, "sample_values": ["CH10000A-0002000000", "DE10001A-0002000001", "IN10002A-0002000002"]}, {"name": "pj_project_name", "type": "string", "description": "Filter by pj_project_name", "required": false, "sample_values": []}, {"name": "pj_project_status", "type": "string", "description": "Filter by pj_project_status", "required": false, "sample_values": []}, {"name": "pj_project_type", "type": "string", "description": "Filter by pj_project_type", "required": false, "sample_values": []}], "output_columns": [{"name": "id", "type": "number", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "pj_por_count", "type": "string", "nullable": false}, {"name": "pj_program_name", "type": "string", "nullable": false}, {"name": "pj_project_id", "type": "string", "nullable": false}, {"name": "pj_project_name", "type": "string", "nullable": false}, {"name": "pj_project_status", "type": "string", "nullable": false}, {"name": "pj_project_type", "type": "string", "nullable": false}], "sample_output": [{"id": 30000, "pj_project_id": "CH10000A-0002000000", "s_site_id": "CH10000A", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "rgn_region": "CENTRAL", "construction_gc": "IMPIRIUM LLC.", "ci_gc": null, "pj_general_contractor": "impirium", "construction_gc_assigned_date": null, "por_hc_type_civil_only": "yes"}, {"id": 30001, "pj_project_id": "DE10001A-0002000001", "s_site_id": "DE10001A", "m_area": "GREAT LAKES", "m_market": "DETROIT", "rgn_region": "CENTRAL", "construction_gc": "TELCOM CONSTRUCTION LLC.", "ci_gc": "nokia", "pj_general_contractor": "telcom construction", "construction_gc_assigned_date": null, "por_hc_type_civil_only": "yes"}, {"id": 30002, "pj_project_id": "IN10002A-0002000002", "s_site_id": "IN10002A", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "rgn_region": "CENTRAL", "construction_gc": "HAMPTON ENTERPRISES LLC.", "ci_gc": null, "pj_general_contractor": "hampton enterprises", "construction_gc_assigned_date": null, "por_hc_type_civil_only": null}], "row_count": 3}}', skip_reason: ''});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'd7ffcd7d-93e1-4c31-a9f2-b430e2843f28', name: 'd7ffcd7d-93e1-4c31-a9f2-b430e2843f28', label: 'On-Air Cycle Time', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "On-Air Cycle Time = average over projects/sites of (earliest non-null On-Air finish milestone date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish), optionally filtered by date range (on_air_date preferred), site_code, market, and GC."}', nl_description: 'On-Air Cycle Time = average over projects/sites of (earliest non-null On-Air finish milestone date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish), optionally filtered by date range (on_air_date preferred), site_code, market, and GC.', nl_business_rule: '', kpi_json: '{"kpi_id": "d7ffcd7d-93e1-4c31-a9f2-b430e2843f28", "name": "On-Air Cycle Time", "description": "Average end-to-end delivery time from construction start to first On-Air. Formula: f(Project, Site)=avg(pj_a_4225_construction_start_finish - min(non-null pj_*_onair_finish)). Accepts filters: [date_range by on_air_date or start_date, site_code, market, gc].", "related_core_node_ids": ["project", "site"], "relationship_type": "DERIVED_FROM", "python_function": "def get_on_air_cycle_time(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"On-Air Cycle Time (days) = avg( on_air_date - construction_start_date )\\n\\n    construction_start_date := pj_a_4225_construction_start_finish\\n    on_air_date := MIN(non-null pj_*_onair_finish) across all columns matching \'*onair_finish*\'\\n\\n    Filters accepted (best-effort): start_date/end_date applied to on_air_date if present, else construction_start_date.\\n    Also supports site_code, market, gc.\\n    \\"\\"\\"\\n\\n    def _to_date_str(v):\\n        if v is None:\\n            return None\\n        s = str(v).strip()\\n        return s[:10] if len(s) >= 10 else s\\n\\n    def _parse_yyyy_mm_dd(v):\\n        s = _to_date_str(v)\\n        if not s or len(s) < 10:\\n            return None\\n        try:\\n            y = int(s[0:4]); m = int(s[5:7]); d = int(s[8:10])\\n            # return ordinal to compute day-diffs without imports\\n            # algorithm: days from civil (Howard Hinnant)\\n            a = (14 - m) // 12\\n            y2 = y + 4800 - a\\n            m2 = m + 12 * a - 3\\n            jdn = d + ((153 * m2 + 2) // 5) + 365 * y2 + (y2 // 4) - (y2 // 100) + (y2 // 400) - 32045\\n            return jdn\\n        except Exception:\\n            return None\\n\\n    def _min_non_null_date_from_row(row, key_substr):\\n        best = None\\n        for k, v in row.items():\\n            if v is None:\\n                continue\\n            k_l = str(k).lower()\\n            if key_substr in k_l:\\n                j = _parse_yyyy_mm_dd(v)\\n                if j is None:\\n                    continue\\n                if best is None or j < best:\\n                    best = j\\n        return best\\n\\n    filters = filters or {}\\n    start_date = _parse_yyyy_mm_dd(filters.get(\'start_date\'))\\n    end_date = _parse_yyyy_mm_dd(filters.get(\'end_date\'))\\n\\n    # Build a base filter set for Tier-1 accessor. Note: accessor may ignore unknown keys;\\n    # we keep only common attributes that are known to exist on the wide table.\\n    base_filters = {}\\n    if filters.get(\'site_code\'):\\n        # most tables use s_site_id as the site code; accessor returns it as site_code\\n        base_filters[\'s_site_id\'] = filters.get(\'site_code\')\\n    if filters.get(\'market\'):\\n        base_filters[\'m_market\'] = filters.get(\'market\')\\n    if filters.get(\'gc\'):\\n        # prefer construction_gc if present, else pj_general_contractor\\n        base_filters[\'construction_gc\'] = filters.get(\'gc\')\\n\\n    # We need milestone columns (pj_a_4225... and pj_*_onair_finish) which are not included\\n    # in the Project node\'s returned columns. Use raw SQL against the wide table.\\n    where_parts = []\\n    if base_filters.get(\'s_site_id\'):\\n        esc = str(base_filters[\'s_site_id\']).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"s_site_id = \'{esc}\'\\")\\n    if base_filters.get(\'m_market\'):\\n        esc = str(base_filters[\'m_market\']).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"m_market = \'{esc}\'\\")\\n    if base_filters.get(\'construction_gc\'):\\n        esc = str(base_filters[\'construction_gc\']).replace(\\"\'\\", \\"\'\'\\")\\n        # match either construction_gc or pj_general_contractor (free-text duplicates)\\n        where_parts.append(f\\"(construction_gc = \'{esc}\' OR pj_general_contractor = \'{esc}\')\\")\\n\\n    where_sql = (\\"WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    sql = (\\n        \\"SELECT * \\"\\n        \\"FROM public.stg_ndpd_mbt_tmobile_macro_combined \\"\\n        f\\"{where_sql}\\"\\n    )\\n    rows = execute_query(sql)\\n\\n    total_days = 0\\n    n = 0\\n\\n    for r in rows:\\n        site_code = r.get(\'s_site_id\')\\n        market = r.get(\'m_market\')\\n        gc = r.get(\'construction_gc\') or r.get(\'pj_general_contractor\')\\n        project_id = r.get(\'pj_project_id\')\\n\\n        construction_start = _parse_yyyy_mm_dd(r.get(\'pj_a_4225_construction_start_finish\'))\\n        # heuristic: any column containing \'onair_finish\' is considered an on-air completion timestamp\\n        on_air = _min_non_null_date_from_row(r, \'onair_finish\')\\n\\n        if construction_start is None or on_air is None:\\n            continue\\n\\n        # Apply date range filter: prefer on_air date; if missing (shouldn\'t happen), fallback to construction_start\\n        anchor = on_air if on_air is not None else construction_start\\n        if start_date is not None and anchor < start_date:\\n            continue\\n        if end_date is not None and anchor > end_date:\\n            continue\\n\\n        cycle_days = on_air - construction_start\\n        # ignore negative durations (bad data)\\n        if cycle_days is None or cycle_days < 0:\\n            continue\\n\\n        total_days += cycle_days\\n        n += 1\\n\\n    avg_days = (total_days / n) if n else None\\n\\n    return [\\n        {\\n            \'kpi\': \'On-Air Cycle Time\',\\n            \'avg_cycle_time_days\': avg_days,\\n            \'projects_count\': n,\\n            \'filters_applied\': {\\n                \'start_date\': _to_date_str(filters.get(\'start_date\')),\\n                \'end_date\': _to_date_str(filters.get(\'end_date\')),\\n                \'site_code\': filters.get(\'site_code\'),\\n                \'market\': filters.get(\'market\'),\\n                \'gc\': filters.get(\'gc\')\\n            }\\n        }\\n    ]\\n", "formula_description": "On-Air Cycle Time = average over projects/sites of (earliest non-null On-Air finish milestone date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish), optionally filtered by date range (on_air_date preferred), site_code, market, and GC.", "caveats": ["This KPI requires milestone columns (pj_a_4225_construction_start_finish and pj_*_onair_finish) that are not exposed by the Tier-1 Project/Site accessors, so it falls back to raw SQL selecting from the wide combined table.", "The \'min(non-null pj_*_onair_finish)\' is implemented via a substring match on column names containing \'onair_finish\'; if the source uses different naming (e.g., \'on_air_finish\' or \'first_onair\'), this logic must be updated.", "GC values are free-text and may not match consistently (casing/suffix differences), so filtering by gc may under/over-include without normalization.", "Rows with missing dates or negative cycle times are excluded from the average."], "evidence": {"sample_data": [{"kpi": "On-Air Cycle Time", "avg_cycle_time_days": 62.14035087719298, "projects_count": 57, "filters_applied": "{\'start_date\': None, \'end_date\': None, \'site_code\': None, \'market\': None, \'gc\': None}"}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T08:56:13.408381+00:00", "contract": {"function_name": "get_on_air_cycle_time", "node_type": "kpi", "node_id": "d7ffcd7d-93e1-4c31-a9f2-b430e2843f28", "node_label": "On-Air Cycle Time", "description": "Average end-to-end delivery time from construction start to first On-Air. Formula: f(Project, Site)=avg(pj_a_4225_construction_start_finish - min(non-null pj_*_onair_finish)). Accepts filters: [date_range by on_air_date or start_date, site_code, market, gc].", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "site_code", "type": "string", "description": "Filter by site code", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "gc", "type": "string", "description": "Filter by gc", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}], "output_columns": [{"name": "kpi", "type": "string", "nullable": false}, {"name": "avg_cycle_time_days", "type": "number", "nullable": false}, {"name": "projects_count", "type": "number", "nullable": false}, {"name": "filters_applied", "type": "string", "nullable": false}], "sample_output": [{"kpi": "On-Air Cycle Time", "avg_cycle_time_days": 62.14035087719298, "projects_count": 57, "filters_applied": "{\'start_date\': None, \'end_date\': None, \'site_code\': None, \'market\': None, \'gc\': None}"}], "row_count": 1}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '0a6abf62-5092-40a1-89b0-4f74894cfde3', name: '0a6abf62-5092-40a1-89b0-4f74894cfde3', label: 'Swap FTR %', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Measures First-Time-Right success rate of swap execution at the site level.\\n\\nCalculation:\\n- Identify swap attempts from pm_tracker as rows where swap_actual_date IS NOT NULL.\\n- Denominator (Total Swaps Attempted): count of distinct sites (site_id/site_code) that have >= 1 swap attempt (>= 1 pm_tracker row with non-null swap_actual_date) within the selected reporting period.\\n- Numerator (First-Time-Right Sites): count of distinct sites that have exactly 1 swap attempt (exactly 1 pm_tracker row with non-null swap_actual_date) AND that single attempt has call_test = \'passed\' (normalized for case/variants).\\n- FTR % = (Numerator / Denominator) * 100.\\n\\nJoin/dimensions:\\n- Join pm_tracker to tmo_retro_mbt_tracker on site identifier (site_id/site_code) to attribute each site to market, area, and region; aggregate FTR % by these dimensions.\\n\\nExclusions/notes:\\n- Sites with 2+ swap attempts (2+ non-null swap_actual_date records) are considered not FTR regardless of whether the latest attempt passed.\\n- tmo_hse_supervision is not part of the core KPI; it can be optionally joined (via site_id and/or ndpd_project_id as available) for drill-down classification of non-FTR sites (e.g., HSE-related rework vs technical)."}', nl_description: 'Measures First-Time-Right success rate of swap execution at the site level.\n\nCalculation:\n- Identify swap attempts from pm_tracker as rows where swap_actual_date IS NOT NULL.\n- Denominator (Total Swaps Attempted): count of distinct sites (site_id/site_code) that have >= 1 swap attempt (>= 1 pm_tracker row with non-null swap_actual_date) within the selected reporting period.\n- Numerator (First-Time-Right Sites): count of distinct sites that have exactly 1 swap attempt (exactly 1 pm_tracker row with non-null swap_actual_date) AND that single attempt has call_test = \'passed\' (normalized for case/variants).\n- FTR % = (Numerator / Denominator) * 100.\n\nJoin/dimensions:\n- Join pm_tracker to tmo_retro_mbt_tracker on site identifier (site_id/site_code) to attribute each site to market, area, and region; aggregate FTR % by these dimensions.\n\nExclusions/notes:\n- Sites with 2+ swap attempts (2+ non-null swap_actual_date records) are considered not FTR regardless of whether the latest attempt passed.\n- tmo_hse_supervision is not part of the core KPI; it can be optionally joined (via site_id and/or ndpd_project_id as available) for drill-down classification of non-FTR sites (e.g., HSE-related rework vs technical).', nl_business_rule: '', kpi_json: '{"kpi_id": "0a6abf62-5092-40a1-89b0-4f74894cfde3", "name": "Swap FTR %", "description": "Measures First-Time-Right success rate of swap execution at the site level.\\n\\nCalculation:\\n- Identify swap attempts from pm_tracker as rows where swap_actual_date IS NOT NULL.\\n- Denominator (Total Swaps Attempted): count of distinct sites (site_id/site_code) that have >= 1 swap attempt (>= 1 pm_tracker row with non-null swap_actual_date) within the selected reporting period.\\n- Numerator (First-Time-Right Sites): count of distinct sites that have exactly 1 swap attempt (exactly 1 pm_tracker row with non-null swap_actual_date) AND that single attempt has call_test = \'passed\' (normalized for case/variants).\\n- FTR % = (Numerator / Denominator) * 100.\\n\\nJoin/dimensions:\\n- Join pm_tracker to tmo_retro_mbt_tracker on site identifier (site_id/site_code) to attribute each site to market, area, and region; aggregate FTR % by these dimensions.\\n\\nExclusions/notes:\\n- Sites with 2+ swap attempts (2+ non-null swap_actual_date records) are considered not FTR regardless of whether the latest attempt passed.\\n- tmo_hse_supervision is not part of the core KPI; it can be optionally joined (via site_id and/or ndpd_project_id as available) for drill-down classification of non-FTR sites (e.g., HSE-related rework vs technical).", "related_core_node_ids": [], "relationship_type": "", "python_function": "", "formula_description": "", "caveats": ["pm_tracker and tmo_retro_mbt_tracker are referenced as raw tables (Tier 2) because no core node accessors were provided; column names (site_id/site_code, swap_actual_date, call_test) are assumed per KPI definition and may require alignment to the physical schema.", "Call test normalization treats several common truthy/pass variants as passed; adjust the accepted set if the source uses different statuses (e.g., \'Pass (w/notes)\') or stores pass/fail as boolean.", "Date filtering assumes swap_actual_date is a timestamp/date and end_date is treated as exclusive (< end_date); change to <= if your reporting convention is inclusive.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedTable) relation \\"public.pm_tracker\\" does not exist\\nLINE 1: ...S site_code,   swap_actual_date,   call_test FROM public.pm_...\\n                                                             ^\\n\\n[SQL: SELECT   COALESCE(site_id, site_code) AS site_code,   swap_actual_date,   call", "Re-validation warning: Runtime error: (psycopg2.errors.UndefinedTable) relation \\"public.pm_tracker\\" does not exist\\nLINE 1: ...S site_code,   swap_actual_date,   call_test FROM public.pm_...\\n                                                             ^\\n\\n[SQL: SELECT   COALESCE(site_id, site_code) AS site_code,   swap_actual_date,   call"], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "remove this kpi"}, {"role": "assistant", "content": "I can remove it. To confirm: do you want it fully deleted/retired (no KPI definition at all), or should it be kept but marked inactive/deprecated?\\n\\nIf you want it fully removed, here are the updates to clear the definition:\\n\\n<updates>\\n{\\n  \\"python_function\\": \\"\\",\\n  \\"relationship_type\\": \\"\\",\\n  \\"related_core_node_ids\\": [],\\n  \\"formula_description\\": \\"\\"\\n}\\n</updates>"}, {"role": "user", "content": "yes please remove"}, {"role": "assistant", "content": "<updates>\\n{\\n  \\"python_function\\": \\"\\",\\n  \\"relationship_type\\": \\"\\",\\n  \\"related_core_node_ids\\": [],\\n  \\"formula_description\\": \\"\\"\\n}\\n</updates>"}], "approved_by": "user", "approved_at": "2026-03-07T13:42:02.199195+00:00", "contract": {"function_name": "get_swap_ftr", "node_type": "kpi", "node_id": "0a6abf62-5092-40a1-89b0-4f74894cfde3", "node_label": "Swap FTR %", "description": "Measures First-Time-Right success rate of swap execution at the site level.\\n\\nCalculation:\\n- Identify swap attempts from pm_tracker as rows where swap_actual_date IS NOT NULL.\\n- Denominator (Total Swaps Attempted): count of distinct sites (site_id/site_code) that have >= 1 swap attempt (>= 1 pm_tracker row with non-null swap_actual_date) within the selected reporting period.\\n- Numerator (First-Time-Right Sites): count of distinct sites that have exactly 1 swap attempt (exactly 1 pm_tracker row with non-null swap_actual_date) AND that single attempt has call_test = \'passed\' (normalized for case/variants).\\n- FTR % = (Numerator / Denominator) * 100.\\n\\nJoin/dimensions:\\n- Join pm_tracker to tmo_retro_mbt_tracker on site identifier (site_id/site_code) to attribute each site to market, area, and region; aggregate FTR % by these dimensions.\\n\\nExclusions/notes:\\n- Sites with 2+ swap attempts (2+ non-null swap_actual_date records) are considered not FTR regardless of whether the latest attempt passed.\\n- tmo_hse_supervision is not part of the core KPI; it can be optionally joined (via site_id and/or ndpd_project_id as available) for drill-down classification of non-FTR sites (e.g., HSE-related rework vs technical).", "parameters": [], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', name: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', label: 'CPO to Cx Start', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "For each Project, compute cycle_time_days = (ms_1550_construction_start_actual::date - cpo_date::date), where cpo_date is parsed from the VARCHAR column \\"confirm_receipt_of_base_pos_and_spos_generated\\" only when it matches ^\\\\d{4}-\\\\d{2}-\\\\d{2}. Keep only rows with both dates present and cycle_time_days >= 0. Aggregate across projects within each (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives) group to report project_count, average, median (P50 via PERCENTILE_CONT), and P90 (via PERCENTILE_CONT)."}', nl_description: 'For each Project, compute cycle_time_days = (ms_1550_construction_start_actual::date - cpo_date::date), where cpo_date is parsed from the VARCHAR column "confirm_receipt_of_base_pos_and_spos_generated" only when it matches ^\\d{4}-\\d{2}-\\d{2}. Keep only rows with both dates present and cycle_time_days >= 0. Aggregate across projects within each (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives) group to report project_count, average, median (P50 via PERCENTILE_CONT), and P90 (via PERCENTILE_CONT).', nl_business_rule: '', kpi_json: '{"kpi_id": "56171ab1-3ce1-44b6-b22e-400f5ffd9552", "name": "CPO to Cx Start", "description": "Measures cycle time in days from CPO receipt confirmation to Construction Start Actual for each project/site, using milestone dates stored on the Project record in `stg_ndpd_mbt_tmobile_macro_combined`. Calculation per project: `ms_1550_construction_start_actual` minus `confirm_receipt_of_base_pos_and_spos_generated`, expressed in days (end_date - start_date). Include only rows where both dates are non-null and the resulting difference is >= 0. Aggregate and report as average, median (P50), and P90 cycle time, grouped by `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`, and `por_regional_dev_initiatives` (optionally filterable by these dimensions). Uses Project identifiers such as `pj_project_id` for joining/uniqueness; rollups should be computed across projects within each grouping.", "related_core_node_ids": ["project"], "relationship_type": "AGGREGATES_FROM", "python_function": "def get_cpo_to_cx_start(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"CPO to Cx Start cycle time (days): ms_1550_construction_start_actual - confirm_receipt_of_base_pos_and_spos_generated.\\n\\n    Returns grouped rollups with average, median (P50), and P90 across projects.\\n    Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives.\\n\\n    Optional filters supported (exact-match):\\n      - rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives\\n      - pj_project_id, s_site_id\\n      - start_date, end_date (applies to ms_1550_construction_start_actual)\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def _to_date_str(v):\\n        if v is None:\\n            return None\\n        s = str(v).strip()\\n        if not s:\\n            return None\\n        return s[:10]\\n\\n    where_parts = []\\n\\n    # Dimension filters\\n    for k in [\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"por_regional_dev_initiatives\\",\\n        \\"pj_project_id\\",\\n        \\"s_site_id\\",\\n    ]:\\n        if filters.get(k) is not None and str(filters.get(k)).strip() != \\"\\":\\n            escaped = str(filters[k]).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\\"{k} = \'{escaped}\'\\")\\n\\n    # Date range filter: apply to end milestone (construction start actual)\\n    start_date = _to_date_str(filters.get(\\"start_date\\"))\\n    end_date = _to_date_str(filters.get(\\"end_date\\"))\\n    if start_date:\\n        where_parts.append(f\\"ms_1550_construction_start_actual::date >= \'{start_date}\'::date\\")\\n    if end_date:\\n        where_parts.append(f\\"ms_1550_construction_start_actual::date <= \'{end_date}\'::date\\")\\n\\n    # Base filters to avoid scanning + ensure we can compute cycle time\\n    # CPO column is VARCHAR with mixed content; only parse when it begins with YYYY-MM-DD.\\n    where_parts.append(\\"ms_1550_construction_start_actual IS NOT NULL\\")\\n    where_parts.append(\'\\"confirm_receipt_of_base_pos_and_spos_generated\\" IS NOT NULL\')\\n    where_parts.append(\'\\"confirm_receipt_of_base_pos_and_spos_generated\\" ~ \\\\\'^\\\\\\\\\\\\\\\\d{4}-\\\\\\\\\\\\\\\\d{2}-\\\\\\\\\\\\\\\\d{2}\\\\\'\')\\n\\n    where_sql = \\"WHERE \\" + \\" AND \\".join(where_parts)\\n\\n    sql = f\\"\\"\\"\\n        WITH base AS (\\n            SELECT\\n                pj_project_id,\\n                rgn_region,\\n                m_area,\\n                m_market,\\n                pj_general_contractor,\\n                por_regional_dev_initiatives,\\n                (\\"confirm_receipt_of_base_pos_and_spos_generated\\"::date) AS cpo_date,\\n                (ms_1550_construction_start_actual::date) AS cx_start_date\\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n            {where_sql}\\n        ), valid AS (\\n            SELECT\\n                pj_project_id,\\n                rgn_region,\\n                m_area,\\n                m_market,\\n                pj_general_contractor,\\n                por_regional_dev_initiatives,\\n                (cx_start_date - cpo_date) AS cycle_time_days\\n            FROM base\\n            WHERE cpo_date IS NOT NULL\\n              AND cx_start_date IS NOT NULL\\n              AND (cx_start_date - cpo_date) >= 0\\n        )\\n        SELECT\\n            rgn_region,\\n            m_area,\\n            m_market,\\n            pj_general_contractor,\\n            por_regional_dev_initiatives,\\n            COUNT(DISTINCT pj_project_id) AS project_count,\\n            AVG(cycle_time_days::numeric) AS avg_cycle_time_days,\\n            PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY cycle_time_days) AS median_p50_cycle_time_days,\\n            PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY cycle_time_days) AS p90_cycle_time_days\\n        FROM valid\\n        GROUP BY 1,2,3,4,5\\n        ORDER BY 1,2,3,4,5\\n    \\"\\"\\"\\n\\n    return execute_query(sql)\\n  ", "formula_description": "For each Project, compute cycle_time_days = (ms_1550_construction_start_actual::date - cpo_date::date), where cpo_date is parsed from the VARCHAR column \\"confirm_receipt_of_base_pos_and_spos_generated\\" only when it matches ^\\\\d{4}-\\\\d{2}-\\\\d{2}. Keep only rows with both dates present and cycle_time_days >= 0. Aggregate across projects within each (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives) group to report project_count, average, median (P50 via PERCENTILE_CONT), and P90 (via PERCENTILE_CONT).", "caveats": ["Milestone columns (confirm_receipt_of_base_pos_and_spos_generated, ms_1550_construction_start_actual, por_regional_dev_initiatives, rgn_region) are not exposed by the Tier-1 Project accessor in the provided mapping, so raw SQL is used to read them from the wide table.", "Dates are truncated to date (not timestamp) before subtraction; if sub-day precision is required, adjust to compute using timestamps and divide seconds by 86400.", "General contractor and some dimensions are free-text and may contain casing/punctuation variants that will split groupings unless normalized upstream."], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "**1. Missing base WHERE filters \\u2014 pulls entire table.** Unlike the CX Cycle Time KPI which filters in SQL (`ms_1550 IS NOT NULL AND ms_1555 IS NOT NULL`), this one pulls ALL rows and relies on Python-side null checking. It should add `ms_1550_construction_start_actual IS NOT NULL AND confirm_receipt_of_base_pos_and_spos_generated IS NOT NULL` to the SQL WHERE clause to avoid scanning hundreds of thousands of rows unnecessarily.\\n\\n**2. Python-side aggregation instead of SQL.** The CX Cycle Time and Civil Cycle Time KPIs both use `PERCENTILE_CONT` in SQL. This one pulls raw rows to Python and computes percentiles in-memory. It works, but it\'s inconsistent with the other cycle-time KPIs and much less efficient on large datasets. Should be refactored to match the SQL-side pattern.\\n\\n**3. The CPO date column is CHARACTER VARYING, not TIMESTAMP.** `confirm_receipt_of_base_pos_and_spos_generated` stores mixed content \\u2014 sometimes a timestamp string like `2025-12-09 10:21:06`, sometimes possibly a confirmation flag or text. The Python parsing handles this gracefully (returns None for unparseable values), but it could silently drop a significant number of rows. The system should first check the hit rate:\\n\\n```sql\\nSELECT \\n  COUNT(*) AS total,\\n  COUNT(*) FILTER (WHERE confirm_receipt_of_base_pos_and_spos_generated IS NOT NULL) AS non_null,\\n  COUNT(*) FILTER (WHERE confirm_receipt_of_base_pos_and_spos_generated ~ \'^\\\\d{4}-\\\\d{2}-\\\\d{2}\') AS parseable_dates\\nFROM stg_ndpd_mbt_tmobile_macro_combined\\nWHERE ms_1550_construction_start_actual IS NOT NULL\\n```\\n\\nIf the parseable date rate is low, fall back to `pj_a_4200_pull_construction_po_number_finish` as the CPO date \\u2014 that\'s a cleaner milestone column.\\n\\n**4. Long column name truncation risk.** `confirm_receipt_of_base_pos_and_spos_generated` is 52 characters, which is under Postgres\'s 63-char limit, so it should be fine. But worth double-quoting it to be safe given the issues we\'ve seen with other long names.\\n\\n**Recommendation:** Tell the system to refactor this to match the SQL-side pattern used in CX Cycle Time, add base WHERE filters, and double-quote the CPO column. Want me to draft the corrected version?"}, {"role": "assistant", "content": "Yes\\u2014your recommendations are the right direction. We should refactor to (a) push null filtering into SQL, (b) do the aggregation + percentiles in SQL (consistent with the other cycle-time KPIs), and (c) safely handle the \\u201cCPO date\\u201d being a `varchar` by explicitly extracting a date only when it\\u2019s parseable. Also fine to double-quote the long column name.\\n\\nOne nuance: because the CPO field is mixed-content text, we should *not* rely on a simple `::date` cast (it can error). Instead, use a guarded parse: only cast when it matches `^\\\\d{4}-\\\\d{2}-\\\\d{2}`.\\n\\nBelow is a corrected version that:\\n- Adds base WHERE filters (end milestone not null, and CPO text present + parseable)\\n- Aggregates in SQL with `AVG`, `PERCENTILE_CONT(0.5)`, `PERCENTILE_CONT(0.9)`\\n- Computes `cycle_time_days` in SQL\\n- Double-quotes `\\"confirm_receipt_of_base_pos_and_spos_generated\\"`\\n- Keeps existing dimension filters + end-date range filters\\n\\nIf later we decide to implement your fallback to `pj_a_4200_pull_construction_po_number_finish`, we can add a switch (or an automatic fallback based on a \\u201cparseable rate\\u201d prequery), but I\\u2019m not adding that behavior yet since it changes the KPI definition logic.\\n\\n<updates>\\n{\\n  \\"python_function\\": \\"def get_cpo_to_cx_start(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"CPO to Cx Start cycle time (days): ms_1550_construction_start_actual - confirm_receipt_of_base_pos_and_spos_generated.\\\\n\\\\n    Returns grouped rollups with average, median (P50), and P90 across projects.\\\\n    Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives.\\\\n\\\\n    Optional filters supported (exact-match):\\\\n      - rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives\\\\n      - pj_project_id, s_site_id\\\\n      - start_date, end_date (applies to ms_1550_construction_start_actual)\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    filters = filters or {}\\\\n\\\\n    def _to_date_str(v):\\\\n        if v is None:\\\\n            return None\\\\n        s = str(v).strip()\\\\n        if not s:\\\\n            return None\\\\n        return s[:10]\\\\n\\\\n    where_parts = []\\\\n\\\\n    # Dimension filters\\\\n    for k in [\\\\n        \\\\\\"rgn_region\\\\\\",\\\\n        \\\\\\"m_area\\\\\\",\\\\n        \\\\\\"m_market\\\\\\",\\\\n        \\\\\\"pj_general_contractor\\\\\\",\\\\n        \\\\\\"por_regional_dev_initiatives\\\\\\",\\\\n        \\\\\\"pj_project_id\\\\\\",\\\\n        \\\\\\"s_site_id\\\\\\",\\\\n    ]:\\\\n        if filters.get(k) is not None and str(filters.get(k)).strip() != \\\\\\"\\\\\\":\\\\n            escaped = str(filters[k]).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n            where_parts.append(f\\\\\\"{k} = \'{escaped}\'\\\\\\")\\\\n\\\\n    # Date range filter: apply to end milestone (construction start actual)\\\\n    start_date = _to_date_str(filters.get(\\\\\\"start_date\\\\\\"))\\\\n    end_date = _to_date_str(filters.get(\\\\\\"end_date\\\\\\"))\\\\n    if start_date:\\\\n        where_parts.append(f\\\\\\"ms_1550_construction_start_actual::date >= \'{start_date}\'::date\\\\\\")\\\\n    if end_date:\\\\n        where_parts.append(f\\\\\\"ms_1550_construction_start_actual::date <= \'{end_date}\'::date\\\\\\")\\\\n\\\\n    # Base filters to avoid scanning + ensure we can compute cycle time\\\\n    # CPO column is VARCHAR with mixed content; only parse when it begins with YYYY-MM-DD.\\\\n    where_parts.append(\\\\\\"ms_1550_construction_start_actual IS NOT NULL\\\\\\")\\\\n    where_parts.append(\'\\\\\\"confirm_receipt_of_base_pos_and_spos_generated\\\\\\" IS NOT NULL\')\\\\n    where_parts.append(\'\\\\\\"confirm_receipt_of_base_pos_and_spos_generated\\\\\\" ~ \\\\\\\\\'^\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\d{4}-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\d{2}-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\d{2}\\\\\\\\\'\')\\\\n\\\\n    where_sql = \\\\\\"WHERE \\\\\\" + \\\\\\" AND \\\\\\".join(where_parts)\\\\n\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n        WITH base AS (\\\\n            SELECT\\\\n                pj_project_id,\\\\n                rgn_region,\\\\n                m_area,\\\\n                m_market,\\\\n                pj_general_contractor,\\\\n                por_regional_dev_initiatives,\\\\n                (\\\\\\"confirm_receipt_of_base_pos_and_spos_generated\\\\\\"::date) AS cpo_date,\\\\n                (ms_1550_construction_start_actual::date) AS cx_start_date\\\\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\\\\n            {where_sql}\\\\n        ), valid AS (\\\\n            SELECT\\\\n                pj_project_id,\\\\n                rgn_region,\\\\n                m_area,\\\\n                m_market,\\\\n                pj_general_contractor,\\\\n                por_regional_dev_initiatives,\\\\n                (cx_start_date - cpo_date) AS cycle_time_days\\\\n            FROM base\\\\n            WHERE cpo_date IS NOT NULL\\\\n              AND cx_start_date IS NOT NULL\\\\n              AND (cx_start_date - cpo_date) >= 0\\\\n        )\\\\n        SELECT\\\\n            rgn_region,\\\\n            m_area,\\\\n            m_market,\\\\n            pj_general_contractor,\\\\n            por_regional_dev_initiatives,\\\\n            COUNT(DISTINCT pj_project_id) AS project_count,\\\\n            AVG(cycle_time_days::numeric) AS avg_cycle_time_days,\\\\n            PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY cycle_time_days) AS median_p50_cycle_time_days,\\\\n            PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY cycle_time_days) AS p90_cycle_time_days\\\\n        FROM valid\\\\n        GROUP BY 1,2,3,4,5\\\\n        ORDER BY 1,2,3,4,5\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    return execute_query(sql)\\\\n  \\",\\n  \\"formula_description\\": \\"For each Project, compute cycle_time_days = (ms_1550_construction_start_actual::date - cpo_date::date), where cpo_date is parsed from the VARCHAR column \\\\\\"confirm_receipt_of_base_pos_and_spos_generated\\\\\\" only when it matches ^\\\\\\\\d{4}-\\\\\\\\d{2}-\\\\\\\\d{2}. Keep only rows with both dates present and cycle_time_days >= 0. Aggregate across projects within each (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives) group to report project_count, average, median (P50 via PERCENTILE_CONT), and P90 (via PERCENTILE_CONT).\\"\\n}\\n</updates>\\n\\nIf you want, I can also add an optional flag like `filters={\\"cpo_source\\":\\"fallback_4200\\"}` (or an automatic fallback based on a quick parseable-rate precheck) to switch from `\\"confirm_receipt_of_base_pos_and_spos_generated\\"` to `pj_a_4200_pull_construction_po_number_finish` when parseability is poor."}], "approved_by": "user", "approved_at": "2026-03-07T13:46:44.682743+00:00", "contract": {"function_name": "get_cpo_to_cx_start", "node_type": "kpi", "node_id": "56171ab1-3ce1-44b6-b22e-400f5ffd9552", "node_label": "CPO to Cx Start", "description": "Measures cycle time in days from CPO receipt confirmation to Construction Start Actual for each project/site, using milestone dates stored on the Project record in `stg_ndpd_mbt_tmobile_macro_combined`. Calculation per project: `ms_1550_construction_start_actual` minus `confirm_receipt_of_base_pos_and_spos_generated`, expressed in days (end_date - start_date). Include only rows where both dates are non-null and the resulting difference is >= 0. Aggregate and report as average, median (P50), and P90 cycle time, grouped by `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`, and `por_regional_dev_initiatives` (optionally filterable by these dimensions). Uses Project identifiers such as `pj_project_id` for joining/uniqueness; rollups should be computed across projects within each grouping.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '86351076-dcbb-42b7-83bf-58eae5481ae8', name: '86351076-dcbb-42b7-83bf-58eae5481ae8', label: 'Pending MW Acceptance', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields."}', nl_description: 'Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.', nl_business_rule: '', kpi_json: '{"kpi_id": "86351076-dcbb-42b7-83bf-58eae5481ae8", "name": "Pending MW Acceptance", "description": "Counts the number of distinct projects/sites pending microwave link final acceptance. Calculation: COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_a_4425_mw_installation_complete_finish IS NOT NULL (MW installation completed) AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL (MW link not formally accepted/operational). Reportable/groupable by rgn_region, m_area, m_market, and optionally pj_general_contractor and por_regional_dev_initiatives (build plan year/program segmentation). No joins required; all fields are in the same table.", "related_core_node_ids": ["project"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_pending_mw_acceptance(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Counts distinct projects pending MW link final acceptance.\\n\\n    Definition:\\n      MW installation complete date is NOT NULL\\n      AND MW link final accepted/operational date is NULL\\n      KPI = COUNT(DISTINCT pj_project_id)\\n\\n    Groupable by: rgn_region, m_area, m_market; optionally pj_general_contractor, por_regional_dev_initiatives.\\n\\n    Notes:\\n      The Tier-1 get_project accessor does not expose the two MW milestone columns, so we use raw SQL.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Dimensions to group by\\n    group_by = filters.get(\\"group_by\\")\\n    if not group_by:\\n        group_by_cols = [\\"rgn_region\\", \\"m_area\\", \\"m_market\\"]\\n    else:\\n        if isinstance(group_by, str):\\n            group_by_cols = [c.strip() for c in group_by.split(\\",\\") if c.strip()]\\n        else:\\n            group_by_cols = [str(c).strip() for c in group_by if str(c).strip()]\\n\\n    # Allowlist group-by columns for safety\\n    allowed_group_bys = {\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"por_regional_dev_initiatives\\",\\n        \\"pj_program_name\\"\\n    }\\n    group_by_cols = [c for c in group_by_cols if c in allowed_group_bys]\\n    if not group_by_cols:\\n        group_by_cols = [\\"rgn_region\\", \\"m_area\\", \\"m_market\\"]\\n\\n    select_dims = \\", \\".join(group_by_cols)\\n    group_by_sql = \\", \\".join(group_by_cols)\\n\\n    where_parts = [\\n        \\"pj_a_4425_mw_installation_complete_finish IS NOT NULL\\",\\n        \\"pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL\\"\\n    ]\\n\\n    # Optional filters\\n    # (No explicit date filtering since KPI definition is based on milestone null-ness;\\n    #  but allow slicing by region/area/market/gc/program/project/site if provided.)\\n    allowed_filters = {\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"por_regional_dev_initiatives\\",\\n        \\"pj_program_name\\",\\n        \\"pj_project_id\\",\\n        \\"s_site_id\\"\\n    }\\n    for k, v in (filters or {}).items():\\n        if k in (\\"group_by\\", \\"start_date\\", \\"end_date\\"):\\n            continue\\n        if k not in allowed_filters:\\n            continue\\n        if v is None or v == \\"\\":\\n            continue\\n        escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"{k} = \'{escaped}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    sql = (\\n        \\"SELECT \\"\\n        f\\"{select_dims}, \\"\\n        \\"COUNT(DISTINCT pj_project_id) AS pending_mw_acceptance_count \\"\\n        \\"FROM public.stg_ndpd_mbt_tmobile_macro_combined \\"\\n        f\\"WHERE {where_sql} \\"\\n        f\\"GROUP BY {group_by_sql} \\"\\n        f\\"ORDER BY {group_by_sql}\\"\\n    )\\n\\n    rows = execute_query(sql)\\n    return rows\\n", "formula_description": "Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.", "caveats": ["Uses raw SQL because the Tier-1 Project accessor does not currently return the MW milestone columns pj_a_4425_mw_installation_complete_finish and pj_a_5300_mw_link_final_accepted_and_operational_finish.", "General contractor and program segmentation fields are free-text and may have formatting variations that affect grouping (e.g., casing/punctuation).", "No date-range filter is applied by default because the KPI is defined by milestone null/non-null status; if you need \'as-of\' logic by date, clarify the intended behavior."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pending_mw_acceptance_count": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pending_mw_acceptance_count": 5}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pending_mw_acceptance_count": 7}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "COLUMBUS", "pending_mw_acceptance_count": 6}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pending_mw_acceptance_count": 6}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pending_mw_acceptance_count": 5}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "LOUISVILLE", "pending_mw_acceptance_count": 4}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "MILWAUKEE", "pending_mw_acceptance_count": 7}, {"rgn_region": "CENTRAL", "m_area": "GREAT PLAINS", "m_market": "KANSAS CITY", "pending_mw_acceptance_count": 4}, {"rgn_region": "CENTRAL", "m_area": "GREAT PLAINS", "m_market": "MINNEAPOLIS", "pending_mw_acceptance_count": 4}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T09:20:54.578530+00:00", "contract": {"function_name": "get_pending_mw_acceptance", "node_type": "kpi", "node_id": "86351076-dcbb-42b7-83bf-58eae5481ae8", "node_label": "Pending MW Acceptance", "description": "Counts the number of distinct projects/sites pending microwave link final acceptance. Calculation: COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_a_4425_mw_installation_complete_finish IS NOT NULL (MW installation completed) AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL (MW link not formally accepted/operational). Reportable/groupable by rgn_region, m_area, m_market, and optionally pj_general_contractor and por_regional_dev_initiatives (build plan year/program segmentation). No joins required; all fields are in the same table.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pending_mw_acceptance_count", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pending_mw_acceptance_count": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pending_mw_acceptance_count": 5}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pending_mw_acceptance_count": 7}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '7b7c5043-acce-4353-be87-bf1c2049565f', name: '7b7c5043-acce-4353-be87-bf1c2049565f', label: 'Prereq Readiness Rate', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Prereq Readiness Rate (%) = 100 * (count of distinct active projects with no construction start date that have NTP cleared AND material pickup date present AND power-ready date present AND (fiber-ready OR MW-install-complete present)) / (count of distinct active projects with no construction start date), grouped by region/area/market/GC/(optional) por_category."}', nl_description: 'Prereq Readiness Rate (%) = 100 * (count of distinct active projects with no construction start date that have NTP cleared AND material pickup date present AND power-ready date present AND (fiber-ready OR MW-install-complete present)) / (count of distinct active projects with no construction start date), grouped by region/area/market/GC/(optional) por_category.', nl_business_rule: '', kpi_json: '{"kpi_id": "7b7c5043-acce-4353-be87-bf1c2049565f", "name": "Prereq Readiness Rate", "description": "Measures the % of active, not-yet-started construction pipeline projects that meet all prerequisite readiness gates (baseline readiness).\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only (no joins).\\n\\nDenominator (pipeline WIP): COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator (ready-to-start): COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all readiness gates below:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready (default): pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL). If both are NULL, treat as not ready.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nImplementation notes / optional refinements (not applied unless explicitly enabled):\\n- Denominator tightening if the rate is artificially low due to early pipeline sites: add ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to the denominator filter.\\n- Power readiness fill-rate issue: if pj_a_4525_power_ready_finish is sparsely populated, consider a softer power gate using pj_a_4450_permanent_power_ordered_finish IS NOT NULL (either as a fallback or as a separate variant KPI).", "related_core_node_ids": ["project"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_prereq_readiness_rate(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Prereq Readiness Rate (%): among active pipeline (not yet started construction) projects,\\n    percent that meet baseline readiness gates (NTP, material pickup, power ready, backhaul ready).\\n\\n    Returns rows grouped by: rgn_region, m_area, m_market, pj_general_contractor, por_category (if present).\\n\\n    Supported filters (optional):\\n      - rgn_region, m_area, m_market, pj_general_contractor, por_category\\n      - pj_project_id, s_site_id\\n      - enable_scoping_validated_denominator (bool): if truthy, adds ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to denominator\\n      - enable_soft_power_gate (bool): if truthy, power gate is (pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL)\\n\\n    Note: Data source is public.stg_ndpd_mbt_tmobile_macro_combined only (no joins).\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Non-SQL-control filters (do not push down as simple equality filters)\\n    enable_scoping_validated_denominator = bool(filters.pop(\\"enable_scoping_validated_denominator\\", False))\\n    enable_soft_power_gate = bool(filters.pop(\\"enable_soft_power_gate\\", False))\\n\\n    where_parts = []\\n\\n    # Base denominator conditions\\n    where_parts.append(\\"t.\\\\\\"pj_project_status\\\\\\" = \'Active\'\\")\\n    where_parts.append(\\"t.\\\\\\"ms_1550_construction_start_actual\\\\\\" IS NULL\\")\\n\\n    # Optional denominator refinement\\n    if enable_scoping_validated_denominator:\\n        where_parts.append(\\"t.\\\\\\"ms_1327_scoping_and_quoting_package_validated_actual\\\\\\" IS NOT NULL\\")\\n\\n    # Push down any simple equality filters that match table columns\\n    for k, v in list(filters.items()):\\n        if v is None:\\n            continue\\n        escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n        if k in {\\n            \\"rgn_region\\",\\n            \\"m_area\\",\\n            \\"m_market\\",\\n            \\"pj_general_contractor\\",\\n            \\"por_category\\",\\n            \\"pj_project_id\\",\\n            \\"s_site_id\\",\\n        }:\\n            where_parts.append(f\\"t.\\\\\\"{k}\\\\\\" = \'{escaped}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    # Readiness gates (quote exact column names explicitly)\\n    ntp_gate = \\"(t.\\\\\\"ms_1507_tower_ntp_approved_actual\\\\\\" IS NOT NULL OR t.\\\\\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\\\\\" IS NOT NULL)\\"\\n    material_gate = \\"(t.\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\" IS NOT NULL)\\"\\n\\n    if enable_soft_power_gate:\\n        power_gate = \\"(t.\\\\\\"pj_a_4525_power_ready_finish\\\\\\" IS NOT NULL OR t.\\\\\\"pj_a_4450_permanent_power_ordered_finish\\\\\\" IS NOT NULL)\\"\\n    else:\\n        power_gate = \\"(t.\\\\\\"pj_a_4525_power_ready_finish\\\\\\" IS NOT NULL)\\"\\n\\n    backhaul_gate = \\"(t.\\\\\\"pj_a_4925_aav_fiber_ready_finish\\\\\\" IS NOT NULL OR t.\\\\\\"pj_a_4425_mw_installation_complete_finish\\\\\\" IS NOT NULL)\\"\\n\\n    readiness_all_gates = f\\"({ntp_gate} AND {material_gate} AND {power_gate} AND {backhaul_gate})\\"\\n\\n    group_cols = [\\n        \\"t.\\\\\\"rgn_region\\\\\\"\\",\\n        \\"t.\\\\\\"m_area\\\\\\"\\",\\n        \\"t.\\\\\\"m_market\\\\\\"\\",\\n        \\"t.\\\\\\"pj_general_contractor\\\\\\"\\",\\n        \\"t.\\\\\\"por_category\\\\\\"\\",\\n    ]\\n\\n    select_group_cols = \\", \\".join(group_cols)\\n    group_by_sql = \\", \\".join(group_cols)\\n\\n    sql = f\\"\\"\\"\\n        SELECT\\n            {select_group_cols},\\n            COUNT(DISTINCT t.\\\\\\"pj_project_id\\\\\\") AS denominator_pipeline_wip,\\n            COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\\\\\"pj_project_id\\\\\\" ELSE NULL END) AS numerator_ready_to_start,\\n            (100.0 * COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\\\\\"pj_project_id\\\\\\" ELSE NULL END)\\n                  / NULLIF(COUNT(DISTINCT t.\\\\\\"pj_project_id\\\\\\"), 0)) AS prereq_readiness_rate\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined AS t\\n        WHERE {where_sql}\\n        GROUP BY {group_by_sql}\\n    \\"\\"\\".strip()\\n\\n    return execute_query(sql, db=None, max_rows=None)\\n", "formula_description": "Prereq Readiness Rate (%) = 100 * (count of distinct active projects with no construction start date that have NTP cleared AND material pickup date present AND power-ready date present AND (fiber-ready OR MW-install-complete present)) / (count of distinct active projects with no construction start date), grouped by region/area/market/GC/(optional) por_category.", "caveats": ["Assumes readiness gate milestone columns (ms_1507_tower_ntp_approved_actual, pj_a_4100_construction_ntp_accepted_by_gc_finish, pj_a_3925_msi_pickup_date_finish, pj_a_4525_power_ready_finish, pj_a_4925_aav_fiber_ready_finish, pj_a_4425_mw_installation_complete_finish) exist on public.stg_ndpd_mbt_tmobile_macro_combined; if any are absent/renamed, the SQL must be updated.", "pj_general_contractor and por_category are free-text and may contain casing/punctuation variants, which will fragment groupings unless normalized upstream.", "Backhaul gate follows the rule: if both AAV fiber ready and MW install complete are NULL, project is not ready (implemented as OR with both nullable fields).", "Optional refinements are implemented only when filters enable_scoping_validated_denominator and/or enable_soft_power_gate are truthy; otherwise the KPI uses the strict baseline definition.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedColumn) column \\"pj_a_3925_msi_pickup_date_finish\\" does not exist\\nLINE 4: ...ction_ntp_accepted_by_gc_finish IS NOT NULL) AND (pj_a_3925_...\\n                                                             ^\\nHINT:  Perhaps you meant to reference the column \\"stg_ndpd_mbt_tmobile_"], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "Don\'t confirm yet \\u2014 there\'s a column naming error. Let me check the actual name.The column `pj_a_3925_msi_pickup_date_finish` **does exist** in the schema \\u2014 all 6 gate columns are confirmed present with exact names. The error is likely a quoting or schema qualification issue, not a missing column.\\n\\nTell the system: the column name is correct as `pj_a_3925_msi_pickup_date_finish`. The issue is probably that the SQL is referencing it without proper quoting or the table alias is wrong. All gate columns exist on `public.stg_ndpd_mbt_tmobile_macro_combined`:\\n\\n- `pj_a_3925_msi_pickup_date_finish` \\u2713\\n- `pj_a_4525_power_ready_finish` \\u2713\\n- `pj_a_4925_aav_fiber_ready_finish` \\u2713\\n- `pj_a_4425_mw_installation_complete_finish` \\u2713\\n- `ms_1507_tower_ntp_approved_actual` \\u2713\\n- `pj_a_4100_construction_ntp_accepted_by_gc_finish` \\u2713\\n\\nThe HINT in the error (\\"Perhaps you meant to reference the column...\\") usually means Postgres found a close match \\u2014 the system should check if there\'s a typo in the generated SQL (extra space, wrong case, or truncated name). These are `CHARACTER VARYING` columns storing timestamp strings, so the IS NOT NULL check should work directly without casting.\\n\\nRetry with the exact column names above, and confirm once it executes successfully."}, {"role": "assistant", "content": "Understood: `pj_a_3925_msi_pickup_date_finish` is the correct column name, and all six gate columns exist on `public.stg_ndpd_mbt_tmobile_macro_combined` exactly as listed. That strongly suggests the failure is coming from *how* the SQL is being generated/referenced (quoting/alias/schema), not from a missing column.\\n\\nTo make the SQL maximally robust against:\\n\\n- accidental aliasing issues,\\n- reserved-word/identifier parsing quirks,\\n- or any subtle generation/whitespace issues,\\n\\nI\\u2019m going to update the KPI SQL to **fully qualify the table with an alias** and **double-quote all six gate columns** (and IDs) wherever referenced. This is consistent with the \\u201cperhaps you meant\\u2026\\u201d Postgres hint, which often appears when the parser isn\\u2019t actually seeing the identifier you think it is (e.g., due to aliasing, quoting, or a slightly different token).\\n\\nHere\\u2019s the concrete update.\\n\\n<updates>\\n{\\n  \\"python_function\\": \\"def get_prereq_readiness_rate(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"Prereq Readiness Rate (%): among active pipeline (not yet started construction) projects,\\\\n    percent that meet baseline readiness gates (NTP, material pickup, power ready, backhaul ready).\\\\n\\\\n    Returns rows grouped by: rgn_region, m_area, m_market, pj_general_contractor, por_category (if present).\\\\n\\\\n    Supported filters (optional):\\\\n      - rgn_region, m_area, m_market, pj_general_contractor, por_category\\\\n      - pj_project_id, s_site_id\\\\n      - enable_scoping_validated_denominator (bool): if truthy, adds ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to denominator\\\\n      - enable_soft_power_gate (bool): if truthy, power gate is (pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL)\\\\n\\\\n    Note: Data source is public.stg_ndpd_mbt_tmobile_macro_combined only (no joins).\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    filters = filters or {}\\\\n\\\\n    # Non-SQL-control filters (do not push down as simple equality filters)\\\\n    enable_scoping_validated_denominator = bool(filters.pop(\\\\\\"enable_scoping_validated_denominator\\\\\\", False))\\\\n    enable_soft_power_gate = bool(filters.pop(\\\\\\"enable_soft_power_gate\\\\\\", False))\\\\n\\\\n    where_parts = []\\\\n\\\\n    # Base denominator conditions\\\\n    where_parts.append(\\\\\\"t.\\\\\\\\\\\\\\"pj_project_status\\\\\\\\\\\\\\" = \'Active\'\\\\\\")\\\\n    where_parts.append(\\\\\\"t.\\\\\\\\\\\\\\"ms_1550_construction_start_actual\\\\\\\\\\\\\\" IS NULL\\\\\\")\\\\n\\\\n    # Optional denominator refinement\\\\n    if enable_scoping_validated_denominator:\\\\n        where_parts.append(\\\\\\"t.\\\\\\\\\\\\\\"ms_1327_scoping_and_quoting_package_validated_actual\\\\\\\\\\\\\\" IS NOT NULL\\\\\\")\\\\n\\\\n    # Push down any simple equality filters that match table columns\\\\n    for k, v in list(filters.items()):\\\\n        if v is None:\\\\n            continue\\\\n        escaped = str(v).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n        if k in {\\\\n            \\\\\\"rgn_region\\\\\\",\\\\n            \\\\\\"m_area\\\\\\",\\\\n            \\\\\\"m_market\\\\\\",\\\\n            \\\\\\"pj_general_contractor\\\\\\",\\\\n            \\\\\\"por_category\\\\\\",\\\\n            \\\\\\"pj_project_id\\\\\\",\\\\n            \\\\\\"s_site_id\\\\\\",\\\\n        }:\\\\n            where_parts.append(f\\\\\\"t.\\\\\\\\\\\\\\"{k}\\\\\\\\\\\\\\" = \'{escaped}\'\\\\\\")\\\\n\\\\n    where_sql = \\\\\\" AND \\\\\\".join(where_parts)\\\\n\\\\n    # Readiness gates (quote exact column names explicitly)\\\\n    ntp_gate = \\\\\\"(t.\\\\\\\\\\\\\\"ms_1507_tower_ntp_approved_actual\\\\\\\\\\\\\\" IS NOT NULL OR t.\\\\\\\\\\\\\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n    material_gate = \\\\\\"(t.\\\\\\\\\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n\\\\n    if enable_soft_power_gate:\\\\n        power_gate = \\\\\\"(t.\\\\\\\\\\\\\\"pj_a_4525_power_ready_finish\\\\\\\\\\\\\\" IS NOT NULL OR t.\\\\\\\\\\\\\\"pj_a_4450_permanent_power_ordered_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n    else:\\\\n        power_gate = \\\\\\"(t.\\\\\\\\\\\\\\"pj_a_4525_power_ready_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n\\\\n    backhaul_gate = \\\\\\"(t.\\\\\\\\\\\\\\"pj_a_4925_aav_fiber_ready_finish\\\\\\\\\\\\\\" IS NOT NULL OR t.\\\\\\\\\\\\\\"pj_a_4425_mw_installation_complete_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n\\\\n    readiness_all_gates = f\\\\\\"({ntp_gate} AND {material_gate} AND {power_gate} AND {backhaul_gate})\\\\\\"\\\\n\\\\n    group_cols = [\\\\n        \\\\\\"t.\\\\\\\\\\\\\\"rgn_region\\\\\\\\\\\\\\"\\\\\\",\\\\n        \\\\\\"t.\\\\\\\\\\\\\\"m_area\\\\\\\\\\\\\\"\\\\\\",\\\\n        \\\\\\"t.\\\\\\\\\\\\\\"m_market\\\\\\\\\\\\\\"\\\\\\",\\\\n        \\\\\\"t.\\\\\\\\\\\\\\"pj_general_contractor\\\\\\\\\\\\\\"\\\\\\",\\\\n        \\\\\\"t.\\\\\\\\\\\\\\"por_category\\\\\\\\\\\\\\"\\\\\\",\\\\n    ]\\\\n\\\\n    select_group_cols = \\\\\\", \\\\\\".join(group_cols)\\\\n    group_by_sql = \\\\\\", \\\\\\".join(group_cols)\\\\n\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n        SELECT\\\\n            {select_group_cols},\\\\n            COUNT(DISTINCT t.\\\\\\\\\\\\\\"pj_project_id\\\\\\\\\\\\\\") AS denominator_pipeline_wip,\\\\n            COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\\\\\\\\\\\\\"pj_project_id\\\\\\\\\\\\\\" ELSE NULL END) AS numerator_ready_to_start,\\\\n            (100.0 * COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\\\\\\\\\\\\\"pj_project_id\\\\\\\\\\\\\\" ELSE NULL END)\\\\n                  / NULLIF(COUNT(DISTINCT t.\\\\\\\\\\\\\\"pj_project_id\\\\\\\\\\\\\\"), 0)) AS prereq_readiness_rate\\\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined AS t\\\\n        WHERE {where_sql}\\\\n        GROUP BY {group_by_sql}\\\\n    \\\\\\"\\\\\\"\\\\\\".strip()\\\\n\\\\n    return execute_query(sql, db=None, max_rows=None)\\\\n\\"\\n}\\n</updates>\\n\\nIf it still errors after this change, the next most likely causes (based on Postgres\\u2019 \\u201cperhaps you meant\\u2026\\u201d) are:\\n\\n1) the query is actually running against a different relation (view/table) than expected in that environment, or  \\n2) the connection\\u2019s `search_path` / current schema differs and something else named `stg_ndpd_mbt_tmobile_macro_combined` is being resolved (fixed by the explicit `public.` qualification we now have), or  \\n3) a non-printing character made it into the generated SQL identifier (fixed by the explicit quoting + static strings above).\\n\\nRun it with this update; once it executes cleanly, we can confirm and lock the definition."}], "approved_by": "user", "approved_at": "2026-03-07T09:49:43.466059+00:00", "contract": {"function_name": "get_prereq_readiness_rate", "node_type": "kpi", "node_id": "7b7c5043-acce-4353-be87-bf1c2049565f", "node_label": "Prereq Readiness Rate", "description": "Measures the % of active, not-yet-started construction pipeline projects that meet all prerequisite readiness gates (baseline readiness).\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only (no joins).\\n\\nDenominator (pipeline WIP): COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator (ready-to-start): COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all readiness gates below:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready (default): pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL). If both are NULL, treat as not ready.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nImplementation notes / optional refinements (not applied unless explicitly enabled):\\n- Denominator tightening if the rate is artificially low due to early pipeline sites: add ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to the denominator filter.\\n- Power readiness fill-rate issue: if pj_a_4525_power_ready_finish is sparsely populated, consider a softer power gate using pj_a_4450_permanent_power_ordered_finish IS NOT NULL (either as a fallback or as a separate variant KPI).", "parameters": [], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', name: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', label: 'Prereq Readiness Strict', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins)."}', nl_description: 'Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', nl_business_rule: '', kpi_json: '{"kpi_id": "dcf98a0e-2891-47a3-a258-ebea62201ba4", "name": "Prereq Readiness Strict", "description": "Strict version of prerequisite readiness rate: same as Prereq Readiness Rate, but additionally requires a proxy for demonstrated site access.\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only.\\n\\nDenominator: COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator: COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all baseline readiness gates (NTP cleared, material pickup, power ready, backhaul ready) AND:\\n5) Site access proxy: pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nNotes: Split scope flag confirm_split_spo is intentionally omitted as a readiness gate (NULL implies tower-only; NOT NULL implies civil+tower confirmed; neither blocks readiness). Optional refinements for denominator tightening and power gate softening are the same as the baseline KPI.", "related_core_node_ids": ["project"], "relationship_type": "DERIVED_FROM", "python_function": "def get_prereq_readiness_strict(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Prereq Readiness Strict (%) grouped by region/area/market/GC.\\n\\n    Source: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).\\n\\n    Denominator (Active, construction not started):\\n      - pj_project_status = \'Active\'\\n      - ms_1550_construction_start_actual IS NULL\\n\\n    Numerator: Denominator + all prerequisite gates met:\\n      - NTP cleared:\\n          ms_1507_tower_ntp_approved_actual IS NOT NULL\\n          OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL\\n      - Material pickup: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n      - Power ready: pj_a_4525_power_ready_finish IS NOT NULL\\n      - Backhaul ready:\\n          pj_a_4925_aav_fiber_ready_finish IS NOT NULL\\n          OR pj_a_4425_mw_installation_complete_finish IS NOT NULL\\n      - Site access (strict): pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL\\n\\n    KPI = 100 * numerator / denominator\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Fixed, verified physical column predicates (no placeholders)\\n    denom_pred = \\"(pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL)\\"\\n\\n    ntp_pred = \\"(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\"\\n    material_pred = \\"(pj_a_3925_msi_pickup_date_finish IS NOT NULL)\\"\\n    power_pred = \\"(pj_a_4525_power_ready_finish IS NOT NULL)\\"\\n    backhaul_pred = \\"(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\"\\n    site_access_pred = \\"(pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL)\\"\\n\\n    num_pred = \\" AND \\".join([\\n        denom_pred,\\n        ntp_pred,\\n        material_pred,\\n        power_pred,\\n        backhaul_pred,\\n        site_access_pred,\\n    ])\\n\\n    # Grouping (fixed as requested)\\n    group_dims = [\\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\"]\\n\\n    # Optional dimension filters (exact-match)\\n    where_parts = []\\n    if filters.get(\\"rgn_region\\") is not None:\\n        v = str(filters.get(\\"rgn_region\\")).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"rgn_region = \'{v}\'\\")\\n    if filters.get(\\"m_area\\") is not None:\\n        v = str(filters.get(\\"m_area\\")).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"m_area = \'{v}\'\\")\\n    if filters.get(\\"m_market\\") is not None:\\n        v = str(filters.get(\\"m_market\\")).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"m_market = \'{v}\'\\")\\n    if filters.get(\\"pj_general_contractor\\") is not None:\\n        v = str(filters.get(\\"pj_general_contractor\\")).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"pj_general_contractor = \'{v}\'\\")\\n\\n    where_clause = \\"\\"\\n    if where_parts:\\n        where_clause = \\"WHERE \\" + \\" AND \\".join(where_parts)\\n\\n    group_by = \\", \\".join(group_dims)\\n    select_dims = \\", \\".join(group_dims)\\n\\n    sql = f\\"\\"\\"\\n        SELECT\\n            {select_dims},\\n            COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END) AS denominator,\\n            COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END) AS numerator,\\n            100.0 * COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END)\\n                / NULLIF(COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END), 0) AS kpi_value\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n        {where_clause}\\n        GROUP BY {group_by}\\n        ORDER BY {group_by}\\n    \\"\\"\\".strip()\\n\\n    rows = execute_query(sql)\\n\\n    out = []\\n    for r in rows:\\n        rec = {k: r.get(k) for k in group_dims}\\n        rec[\\"denominator\\"] = r.get(\\"denominator\\")\\n        rec[\\"numerator\\"] = r.get(\\"numerator\\")\\n        rec[\\"kpi_value\\"] = r.get(\\"kpi_value\\")\\n        out.append(rec)\\n    return out\\n", "formula_description": "Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).", "caveats": ["The Tier-1 Project accessor does not expose the required milestone columns (ms_1550_construction_start_actual and the readiness gate timestamps), so this KPI uses raw SQL against public.stg_ndpd_mbt_tmobile_macro_combined.", "Baseline readiness gate column names for NTP/material/power/backhaul are not provided in the mapping; defaults in the function are placeholders and should be overridden via filters (ntp_cleared_column, material_pickup_column, power_ready_column, backhaul_ready_column) to match the actual schema.", "pj_a_3825_pre_construction_walk_complete_finish is treated as a strict site access proxy as specified; if this field is sparsely populated or delayed, the KPI may understate operational readiness.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedColumn) column \\"ms_ntp_cleared_actual\\" does not exist\\nLINE 4: ...ND ms_1550_construction_start_actual IS NULL) AND ms_ntp_cle...\\n                                                             ^\\n\\n[SQL: SELECT\\n            rgn_region, m_area, m_market, pj_general_contractor,\\n   "], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "Don\'t confirm \\u2014 the system fell back to placeholder column names instead of using the actual ones. It\'s using `ms_ntp_cleared_actual` which doesn\'t exist. Feed back the exact SQL column mapping:\\n\\n**Tell the system to replace its placeholders with these exact column names:**\\n\\n- NTP cleared: `ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL`\\n- Material pickup: `pj_a_3925_msi_pickup_date_finish IS NOT NULL`\\n- Power ready: `pj_a_4525_power_ready_finish IS NOT NULL`\\n- Backhaul ready: `pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL`\\n- Site access (strict gate): `pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL`\\n- Construction not started: `ms_1550_construction_start_actual IS NULL`\\n- Active filter: `pj_project_status = \'Active\'`\\n- Grouping: `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`\\n\\nAll columns live on `public.stg_ndpd_mbt_tmobile_macro_combined`. No joins needed, no placeholders \\u2014 these are the verified physical column names. Have it retry with these hardcoded into the SQL."}, {"role": "assistant", "content": "<updates>\\n{\\n  \\"python_function\\": \\"def get_prereq_readiness_strict(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"Prereq Readiness Strict (%) grouped by region/area/market/GC.\\\\n\\\\n    Source: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).\\\\n\\\\n    Denominator (Active, construction not started):\\\\n      - pj_project_status = \'Active\'\\\\n      - ms_1550_construction_start_actual IS NULL\\\\n\\\\n    Numerator: Denominator + all prerequisite gates met:\\\\n      - NTP cleared:\\\\n          ms_1507_tower_ntp_approved_actual IS NOT NULL\\\\n          OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL\\\\n      - Material pickup: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\\\n      - Power ready: pj_a_4525_power_ready_finish IS NOT NULL\\\\n      - Backhaul ready:\\\\n          pj_a_4925_aav_fiber_ready_finish IS NOT NULL\\\\n          OR pj_a_4425_mw_installation_complete_finish IS NOT NULL\\\\n      - Site access (strict): pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL\\\\n\\\\n    KPI = 100 * numerator / denominator\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    filters = filters or {}\\\\n\\\\n    # Fixed, verified physical column predicates (no placeholders)\\\\n    denom_pred = \\\\\\"(pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL)\\\\\\"\\\\n\\\\n    ntp_pred = \\\\\\"(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\\\\\"\\\\n    material_pred = \\\\\\"(pj_a_3925_msi_pickup_date_finish IS NOT NULL)\\\\\\"\\\\n    power_pred = \\\\\\"(pj_a_4525_power_ready_finish IS NOT NULL)\\\\\\"\\\\n    backhaul_pred = \\\\\\"(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\\\\\"\\\\n    site_access_pred = \\\\\\"(pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL)\\\\\\"\\\\n\\\\n    num_pred = \\\\\\" AND \\\\\\".join([\\\\n        denom_pred,\\\\n        ntp_pred,\\\\n        material_pred,\\\\n        power_pred,\\\\n        backhaul_pred,\\\\n        site_access_pred,\\\\n    ])\\\\n\\\\n    # Grouping (fixed as requested)\\\\n    group_dims = [\\\\\\"rgn_region\\\\\\", \\\\\\"m_area\\\\\\", \\\\\\"m_market\\\\\\", \\\\\\"pj_general_contractor\\\\\\"]\\\\n\\\\n    # Optional dimension filters (exact-match)\\\\n    where_parts = []\\\\n    if filters.get(\\\\\\"rgn_region\\\\\\") is not None:\\\\n        v = str(filters.get(\\\\\\"rgn_region\\\\\\")).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n        where_parts.append(f\\\\\\"rgn_region = \'{v}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_area\\\\\\") is not None:\\\\n        v = str(filters.get(\\\\\\"m_area\\\\\\")).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n        where_parts.append(f\\\\\\"m_area = \'{v}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_market\\\\\\") is not None:\\\\n        v = str(filters.get(\\\\\\"m_market\\\\\\")).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n        where_parts.append(f\\\\\\"m_market = \'{v}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_general_contractor\\\\\\") is not None:\\\\n        v = str(filters.get(\\\\\\"pj_general_contractor\\\\\\")).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n        where_parts.append(f\\\\\\"pj_general_contractor = \'{v}\'\\\\\\")\\\\n\\\\n    where_clause = \\\\\\"\\\\\\"\\\\n    if where_parts:\\\\n        where_clause = \\\\\\"WHERE \\\\\\" + \\\\\\" AND \\\\\\".join(where_parts)\\\\n\\\\n    group_by = \\\\\\", \\\\\\".join(group_dims)\\\\n    select_dims = \\\\\\", \\\\\\".join(group_dims)\\\\n\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n        SELECT\\\\n            {select_dims},\\\\n            COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END) AS denominator,\\\\n            COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END) AS numerator,\\\\n            100.0 * COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END)\\\\n                / NULLIF(COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END), 0) AS kpi_value\\\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\\\n        {where_clause}\\\\n        GROUP BY {group_by}\\\\n        ORDER BY {group_by}\\\\n    \\\\\\"\\\\\\"\\\\\\".strip()\\\\n\\\\n    rows = execute_query(sql)\\\\n\\\\n    out = []\\\\n    for r in rows:\\\\n        rec = {k: r.get(k) for k in group_dims}\\\\n        rec[\\\\\\"denominator\\\\\\"] = r.get(\\\\\\"denominator\\\\\\")\\\\n        rec[\\\\\\"numerator\\\\\\"] = r.get(\\\\\\"numerator\\\\\\")\\\\n        rec[\\\\\\"kpi_value\\\\\\"] = r.get(\\\\\\"kpi_value\\\\\\")\\\\n        out.append(rec)\\\\n    return out\\\\n\\",\\n  \\"formula_description\\": \\"Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).\\"\\n}\\n</updates>"}], "approved_by": "user", "approved_at": "2026-03-07T09:53:18.934949+00:00", "contract": {"function_name": "get_prereq_readiness_strict", "node_type": "kpi", "node_id": "dcf98a0e-2891-47a3-a258-ebea62201ba4", "node_label": "Prereq Readiness Strict", "description": "Strict version of prerequisite readiness rate: same as Prereq Readiness Rate, but additionally requires a proxy for demonstrated site access.\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only.\\n\\nDenominator: COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator: COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all baseline readiness gates (NTP cleared, material pickup, power ready, backhaul ready) AND:\\n5) Site access proxy: pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nNotes: Split scope flag confirm_split_spo is intentionally omitted as a readiness gate (NULL implies tower-only; NOT NULL implies civil+tower confirmed; neither blocks readiness). Optional refinements for denominator tightening and power gate softening are the same as the baseline KPI.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '3c1fd435-6d07-4984-9546-45233e3bac72', name: '3c1fd435-6d07-4984-9546-45233e3bac72', label: 'CX Cycle Time', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "CX Cycle Time is computed per project as (construction_complete_actual::date \\u2212 construction_start_actual::date) for projects with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally sliced by POR category and site class) to produce AVG, P50, P90, and MAX cycle days."}', nl_description: 'CX Cycle Time is computed per project as (construction_complete_actual::date − construction_start_actual::date) for projects with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally sliced by POR category and site class) to produce AVG, P50, P90, and MAX cycle days.', nl_business_rule: '', kpi_json: '{"kpi_id": "3c1fd435-6d07-4984-9546-45233e3bac72", "name": "CX Cycle Time", "description": "Measures calendar days from construction start to construction complete per project/site, used as the primary construction benchmark for planning and capacity modeling. Source table: stg_ndpd_mbt_tmobile_macro_combined. Grain: one record per distinct pj_project_id with valid dates. Numerator/measure per project: (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) as cx_cycle_days. Inclusion criteria: ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL AND (ms_1555::date - ms_1550::date) >= 0. No pj_project_status filter (completed construction dates define the population). Aggregations to publish per grouping: AVG(cx_cycle_days), PERCENTILE_CONT(0.50) as median/P50, PERCENTILE_CONT(0.90) as P90, and MAX(cx_cycle_days). Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor; optional slices: por_category and s_site_class.", "related_core_node_ids": ["project", "site"], "relationship_type": "AGGREGATES", "python_function": "def get_cx_cycle_time(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"CX Cycle Time\\n    Computes per-project construction cycle days and publishes grouped aggregates:\\n      avg, p50 (median), p90, max.\\n\\n    Inclusion criteria (per project row):\\n      - ms_1550_construction_start_actual IS NOT NULL\\n      - ms_1555_construction_complete_actual IS NOT NULL\\n      - (complete::date - start::date) >= 0\\n\\n    Group-by dimensions:\\n      rgn_region, m_area, m_market, pj_general_contractor\\n    Optional slices (if present in data):\\n      por_category, s_site_class\\n\\n    Filters (optional):\\n      - start_date/end_date: applied to construction_complete_actual::date (common reporting anchor)\\n      - rgn_region, m_area, m_market, pj_general_contractor, por_category, s_site_class, pj_project_id, s_site_id\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Need milestone date columns not exposed via Tier-1 accessors, plus optional slice columns.\\n    where_parts = [\\n        \\"ms_1550_construction_start_actual IS NOT NULL\\",\\n        \\"ms_1555_construction_complete_actual IS NOT NULL\\",\\n        \\"(ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) >= 0\\"\\n    ]\\n\\n    def esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Date range applied to completion date (projects considered complete)\\n    if filters.get(\\"start_date\\"):\\n        where_parts.append(f\\"ms_1555_construction_complete_actual::date >= \'{esc(filters[\'start_date\'])}\'\\")\\n    if filters.get(\\"end_date\\"):\\n        where_parts.append(f\\"ms_1555_construction_complete_actual::date <= \'{esc(filters[\'end_date\'])}\'\\")\\n\\n    # Optional dimensional filters\\n    for col in [\\n        \\"pj_project_id\\",\\n        \\"s_site_id\\",\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"por_category\\",\\n        \\"s_site_class\\"\\n    ]:\\n        if filters.get(col) is not None:\\n            where_parts.append(f\\"{col} = \'{esc(filters[col])}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    sql = f\\"\\"\\"\\n    WITH base AS (\\n      SELECT\\n        pj_project_id,\\n        rgn_region,\\n        m_area,\\n        m_market,\\n        pj_general_contractor,\\n        por_category,\\n        s_site_class,\\n        (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) AS cx_cycle_days\\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n      WHERE {where_sql}\\n    ),\\n    grouped AS (\\n      SELECT\\n        rgn_region,\\n        m_area,\\n        m_market,\\n        pj_general_contractor,\\n        por_category,\\n        s_site_class,\\n        COUNT(*)::int AS project_count,\\n        AVG(cx_cycle_days)::float AS avg_cx_cycle_days,\\n        PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY cx_cycle_days) AS p50_cx_cycle_days,\\n        PERCENTILE_CONT(0.90) WITHIN GROUP (ORDER BY cx_cycle_days) AS p90_cx_cycle_days,\\n        MAX(cx_cycle_days)::int AS max_cx_cycle_days\\n      FROM base\\n      GROUP BY 1,2,3,4,5,6\\n    )\\n    SELECT\\n      rgn_region,\\n      m_area,\\n      m_market,\\n      pj_general_contractor,\\n      por_category,\\n      s_site_class,\\n      project_count,\\n      avg_cx_cycle_days,\\n      p50_cx_cycle_days,\\n      p90_cx_cycle_days,\\n      max_cx_cycle_days\\n    FROM grouped\\n    ORDER BY rgn_region, m_area, m_market, pj_general_contractor, por_category, s_site_class\\n    \\"\\"\\"\\n\\n    rows = execute_query(sql)\\n\\n    # If por_category and/or s_site_class are not desired for a particular publication,\\n    # caller can ignore them; to support \\"optional slices\\" behavior, we keep them nullable.\\n    return rows\\n", "formula_description": "CX Cycle Time is computed per project as (construction_complete_actual::date \\u2212 construction_start_actual::date) for projects with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally sliced by POR category and site class) to produce AVG, P50, P90, and MAX cycle days.", "caveats": ["Tier-1 accessors for Project/Site do not expose ms_1550_construction_start_actual or ms_1555_construction_complete_actual, so raw SQL is required to compute the KPI.", "Date range filtering is applied to construction complete date; if the business prefers filtering by start date or by overlap of [start,complete] with the window, adjust the WHERE clause accordingly.", "GC and market fields are free-text and may contain casing/punctuation variants that can split groups unless normalized upstream.", "Function execution warning: Runtime error: Only SELECT queries are allowed."], "evidence": {"sample_data": []}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:03:54.257719+00:00", "contract": {"function_name": "get_cx_cycle_time", "node_type": "kpi", "node_id": "3c1fd435-6d07-4984-9546-45233e3bac72", "node_label": "CX Cycle Time", "description": "Measures calendar days from construction start to construction complete per project/site, used as the primary construction benchmark for planning and capacity modeling. Source table: stg_ndpd_mbt_tmobile_macro_combined. Grain: one record per distinct pj_project_id with valid dates. Numerator/measure per project: (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) as cx_cycle_days. Inclusion criteria: ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL AND (ms_1555::date - ms_1550::date) >= 0. No pj_project_status filter (completed construction dates define the population). Aggregations to publish per grouping: AVG(cx_cycle_days), PERCENTILE_CONT(0.50) as median/P50, PERCENTILE_CONT(0.90) as P90, and MAX(cx_cycle_days). Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor; optional slices: por_category and s_site_class.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'b91a6e98-8c3f-4fae-a943-003665793220', name: 'b91a6e98-8c3f-4fae-a943-003665793220', label: 'Civil Cycle Time', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Civil Cycle Time is computed per project as (civil construction complete actual date \\u2212 civil construction start actual date) in calendar days for split-scope/civil-confirmed records with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally POR category and site class) using avg, median (P50), P90, max, and count."}', nl_description: 'Civil Cycle Time is computed per project as (civil construction complete actual date − civil construction start actual date) in calendar days for split-scope/civil-confirmed records with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally POR category and site class) using avg, median (P50), P90, max, and count.', nl_business_rule: '', kpi_json: '{"kpi_id": "b91a6e98-8c3f-4fae-a943-003665793220", "name": "Civil Cycle Time", "description": "Measures civil construction cycle time in calendar days for split-scope/civil sites and aggregates by market and general contractor. Data source: single table `stg_ndpd_mbt_tmobile_macro_combined`.\\n\\nApplicability filter:\\n- `confirm_split_spo IS NOT NULL` (civil + tower scope confirmed)\\n\\nPer-project calculation (only when both civil dates exist):\\n- `civil_cycle_days = (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date)`\\n- Include records where `ms_1549_civil_construction_start_actual IS NOT NULL` AND `ms_1551_civil_construction_complete_actual_date IS NOT NULL` AND `civil_cycle_days >= 0`.\\n\\nAggregations within each grouping:\\n- Average, Median (P50), P90, Max (and optional count).\\n\\nGroup-by dimensions: `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`; optional: `por_category`, `s_site_class`.\\n\\nNotes: This KPI supports monitoring against the civil SLA target (<= 21 days) and can be paired with a separate SLA-breach rate KPI if desired.", "related_core_node_ids": ["project", "market", "general_contractor"], "relationship_type": "AGGREGATES", "python_function": "def get_civil_cycle_time(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Civil Cycle Time (calendar days) for split-scope/civil-confirmed sites.\\n\\n    Returns one row per grouping with avg/median/p90/max/count of civil cycle days.\\n\\n    Expected optional filters keys (all optional):\\n      - start_date, end_date: applied to ms_1549_civil_construction_start_actual (date)\\n      - rgn_region, m_area, m_market, pj_general_contractor\\n      - por_category, s_site_class\\n\\n    Notes:\\n      - Uses raw SQL because the needed civil milestone columns are not exposed by Tier-1 accessors.\\n      - Postgres date math: (complete_date::date - start_date::date) yields integer days.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def _esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    where_parts = [\\n        \\"confirm_split_spo IS NOT NULL\\",\\n        \\"ms_1549_civil_construction_start_actual IS NOT NULL\\",\\n        \\"ms_1551_civil_construction_complete_actual_date IS NOT NULL\\",\\n        \\"(ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date) >= 0\\"\\n    ]\\n\\n    # Date range filter on START date (common operational interpretation)\\n    if filters.get(\\"start_date\\"):\\n        where_parts.append(f\\"ms_1549_civil_construction_start_actual::date >= \'{_esc(filters[\'start_date\'])}\'\\")\\n    if filters.get(\\"end_date\\"):\\n        where_parts.append(f\\"ms_1549_civil_construction_start_actual::date <= \'{_esc(filters[\'end_date\'])}\'\\")\\n\\n    # Dimension filters\\n    dim_filter_keys = [\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"por_category\\",\\n        \\"s_site_class\\"\\n    ]\\n    for k in dim_filter_keys:\\n        if filters.get(k) is not None and filters.get(k) != \\"\\":\\n            where_parts.append(f\\"{k} = \'{_esc(filters[k])}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    # Group-by dimensions (mandatory set + optional)\\n    group_dims = [\\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\"]\\n    optional_dims = []\\n    if filters.get(\\"group_by_por_category\\"):\\n        optional_dims.append(\\"por_category\\")\\n    if filters.get(\\"group_by_site_class\\"):\\n        optional_dims.append(\\"s_site_class\\")\\n\\n    group_dims_all = group_dims + optional_dims\\n\\n    select_dims_sql = \\", \\".join(group_dims_all) if group_dims_all else \\"\\"\\n    group_by_sql = f\\"GROUP BY {\', \'.join(group_dims_all)}\\" if group_dims_all else \\"\\"\\n    order_by_sql = f\\"ORDER BY {\', \'.join(group_dims_all)}\\" if group_dims_all else \\"\\"\\n\\n    if select_dims_sql:\\n        select_prefix = select_dims_sql + \\",\\\\n       \\"\\n    else:\\n        select_prefix = \\"\\"\\n\\n    sql = f\\"\\"\\"\\nWITH base AS (\\n  SELECT\\n    rgn_region,\\n    m_area,\\n    m_market,\\n    pj_general_contractor,\\n    por_category,\\n    s_site_class,\\n    (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date) AS civil_cycle_days\\n  FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n  WHERE {where_sql}\\n)\\nSELECT\\n       {select_prefix}COUNT(*) AS project_count,\\n       AVG(civil_cycle_days)::numeric(18,2) AS avg_civil_cycle_days,\\n       percentile_cont(0.5) WITHIN GROUP (ORDER BY civil_cycle_days) AS median_p50_civil_cycle_days,\\n       percentile_cont(0.9) WITHIN GROUP (ORDER BY civil_cycle_days) AS p90_civil_cycle_days,\\n       MAX(civil_cycle_days) AS max_civil_cycle_days\\nFROM base\\n{group_by_sql}\\n{order_by_sql}\\n\\"\\"\\".strip()\\n\\n    return execute_query(sql)\\n", "formula_description": "Civil Cycle Time is computed per project as (civil construction complete actual date \\u2212 civil construction start actual date) in calendar days for split-scope/civil-confirmed records with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally POR category and site class) using avg, median (P50), P90, max, and count.", "caveats": ["Tier-1 accessors do not expose ms_1549_civil_construction_start_actual, ms_1551_civil_construction_complete_actual_date, or confirm_split_spo, so raw SQL is required.", "Date range filtering is applied to the civil start date; if reporting should be based on completion date instead, adjust the WHERE clause accordingly.", "pj_general_contractor and GC-related fields are free-text and may contain casing/suffix variations; consider normalizing for cleaner contractor rollups.", "Function execution warning: Runtime error: Only SELECT queries are allowed."], "evidence": {"sample_data": []}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:05:06.890132+00:00", "contract": {"function_name": "get_civil_cycle_time", "node_type": "kpi", "node_id": "b91a6e98-8c3f-4fae-a943-003665793220", "node_label": "Civil Cycle Time", "description": "Measures civil construction cycle time in calendar days for split-scope/civil sites and aggregates by market and general contractor. Data source: single table `stg_ndpd_mbt_tmobile_macro_combined`.\\n\\nApplicability filter:\\n- `confirm_split_spo IS NOT NULL` (civil + tower scope confirmed)\\n\\nPer-project calculation (only when both civil dates exist):\\n- `civil_cycle_days = (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date)`\\n- Include records where `ms_1549_civil_construction_start_actual IS NOT NULL` AND `ms_1551_civil_construction_complete_actual_date IS NOT NULL` AND `civil_cycle_days >= 0`.\\n\\nAggregations within each grouping:\\n- Average, Median (P50), P90, Max (and optional count).\\n\\nGroup-by dimensions: `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`; optional: `por_category`, `s_site_class`.\\n\\nNotes: This KPI supports monitoring against the civil SLA target (<= 21 days) and can be paired with a separate SLA-breach rate KPI if desired.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "group_by_por_category", "type": "string", "description": "Filter by group by por category", "required": false, "sample_values": []}, {"name": "group_by_site_class", "type": "string", "description": "Filter by group by site class", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303', name: '4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303', label: 'Weekly GC Run Rate', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Weekly GC Run Rate (per region/area/market/GC) = count of distinct pj_project_id with non-null ms_1555_construction_complete_actual in the trailing 84 days ending CURRENT_DATE, divided by 12."}', nl_description: 'Weekly GC Run Rate (per region/area/market/GC) = count of distinct pj_project_id with non-null ms_1555_construction_complete_actual in the trailing 84 days ending CURRENT_DATE, divided by 12.', nl_business_rule: '', kpi_json: '{"kpi_id": "4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303", "name": "Weekly GC Run Rate", "description": "Measures observed construction throughput as a trailing-12-week average completions per week for each (Market, General Contractor) pair, anchored to CURRENT_DATE (snapshot). Per (m_market, pj_general_contractor): compute the number of distinct projects with construction complete in the last 12 weeks (inclusive window ending CURRENT_DATE), bucket completions by week using date_trunc(\'week\', ms_1555_construction_complete_actual::date), then compute run rate as: COUNT(DISTINCT pj_project_id) / 12. Include only rows where ms_1555_construction_complete_actual IS NOT NULL and ms_1555_construction_complete_actual::date >= (CURRENT_DATE - INTERVAL \'84 days\') (i.e., trailing 12 weeks). If a (market, GC) has zero completions in the trailing window, its run rate is 0 (no fallback to averages). Groupable by rgn_region, m_area, m_market, pj_general_contractor.", "related_core_node_ids": ["project", "market", "general_contractor"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_weekly_gc_run_rate(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Trailing-12-week observed construction completion throughput per (region, area, market, GC).\\n\\n    Definition (per spec):\\n      - Include only projects where ms_1555_construction_complete_actual is not null\\n      - And ms_1555_construction_complete_actual::date >= CURRENT_DATE - INTERVAL \'84 days\'\\n      - Run rate = COUNT(DISTINCT pj_project_id) / 12\\n      - Anchored to CURRENT_DATE (snapshot)\\n\\n    Optional filters supported (if provided): rgn_region, m_area, m_market, pj_general_contractor, start_date, end_date.\\n      - start_date/end_date override the trailing window if both provided; otherwise trailing window is used.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Prefer raw SQL here because Tier-1 accessors do not expose ms_1555_construction_complete_actual,\\n    # and pushing date filtering/distinct counting to the DB avoids full-table pulls.\\n\\n    where_parts = [\\n        \\"ms_1555_construction_complete_actual IS NOT NULL\\"\\n    ]\\n\\n    # Window handling\\n    start_date = filters.get(\\"start_date\\")\\n    end_date = filters.get(\\"end_date\\")\\n    if start_date and end_date:\\n        sd = str(start_date).replace(\\"\'\\", \\"\'\'\\")\\n        ed = str(end_date).replace(\\"\'\\", \\"\'\'\\")\\n        where_parts.append(f\\"ms_1555_construction_complete_actual::date >= \'{sd}\'::date\\")\\n        where_parts.append(f\\"ms_1555_construction_complete_actual::date <= \'{ed}\'::date\\")\\n    else:\\n        where_parts.append(\\"ms_1555_construction_complete_actual::date >= (CURRENT_DATE - INTERVAL \'84 days\')\\")\\n        where_parts.append(\\"ms_1555_construction_complete_actual::date <= CURRENT_DATE\\")\\n\\n    # Dimensional filters\\n    for col in (\\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\"):\\n        if filters.get(col) is not None and filters.get(col) != \\"\\":\\n            val = str(filters[col]).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\\"{col} = \'{val}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    sql = f\\"\\"\\"\\n        WITH base AS (\\n            SELECT\\n                rgn_region,\\n                m_area,\\n                m_market,\\n                pj_general_contractor,\\n                pj_project_id,\\n                date_trunc(\'week\', ms_1555_construction_complete_actual::date)::date AS completion_week\\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n            WHERE {where_sql}\\n        ),\\n        agg AS (\\n            SELECT\\n                rgn_region,\\n                m_area,\\n                m_market,\\n                pj_general_contractor,\\n                COUNT(DISTINCT pj_project_id) AS completed_projects_12w\\n            FROM base\\n            GROUP BY 1,2,3,4\\n        )\\n        SELECT\\n            rgn_region,\\n            m_area,\\n            m_market,\\n            pj_general_contractor,\\n            completed_projects_12w,\\n            (completed_projects_12w::numeric / 12.0) AS weekly_gc_run_rate\\n        FROM agg\\n        ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\n    \\"\\"\\"\\n\\n    rows = execute_query(sql)\\n\\n    # Ensure numeric stability in Python (and provide explicit 0s if any nulls slip through)\\n    out = []\\n    for r in rows:\\n        completed = r.get(\\"completed_projects_12w\\") or 0\\n        run_rate = r.get(\\"weekly_gc_run_rate\\")\\n        if run_rate is None:\\n            run_rate = float(completed) / 12.0\\n        out.append({\\n            \\"rgn_region\\": r.get(\\"rgn_region\\"),\\n            \\"m_area\\": r.get(\\"m_area\\"),\\n            \\"m_market\\": r.get(\\"m_market\\"),\\n            \\"pj_general_contractor\\": r.get(\\"pj_general_contractor\\"),\\n            \\"completed_projects_12w\\": int(completed),\\n            \\"weekly_gc_run_rate\\": float(run_rate)\\n        })\\n\\n    return out\\n", "formula_description": "Weekly GC Run Rate (per region/area/market/GC) = count of distinct pj_project_id with non-null ms_1555_construction_complete_actual in the trailing 84 days ending CURRENT_DATE, divided by 12.", "caveats": ["ms_1555_construction_complete_actual is referenced by the KPI spec but is not exposed by the Tier-1 Project accessor columns list, so this implementation uses raw SQL against the underlying wide project table.", "General contractor is free-text (pj_general_contractor); casing/suffix variations can split the same vendor into multiple groups unless a normalization layer is applied.", "This returns only (market, GC) pairs observed in the trailing window; pairs with zero completions are implicitly absent unless you provide a complete market\\u00d7GC spine table to left-join against.", "Function execution warning: Runtime error: Only SELECT queries are allowed."], "evidence": {"sample_data": []}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:11:59.003264+00:00", "contract": {"function_name": "get_weekly_gc_run_rate", "node_type": "kpi", "node_id": "4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303", "node_label": "Weekly GC Run Rate", "description": "Measures observed construction throughput as a trailing-12-week average completions per week for each (Market, General Contractor) pair, anchored to CURRENT_DATE (snapshot). Per (m_market, pj_general_contractor): compute the number of distinct projects with construction complete in the last 12 weeks (inclusive window ending CURRENT_DATE), bucket completions by week using date_trunc(\'week\', ms_1555_construction_complete_actual::date), then compute run rate as: COUNT(DISTINCT pj_project_id) / 12. Include only rows where ms_1555_construction_complete_actual IS NOT NULL and ms_1555_construction_complete_actual::date >= (CURRENT_DATE - INTERVAL \'84 days\') (i.e., trailing 12 weeks). If a (market, GC) has zero completions in the trailing window, its run rate is 0 (no fallback to averages). Groupable by rgn_region, m_area, m_market, pj_general_contractor.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '72e61595-33fb-4639-b09b-b20643936de0', name: '72e61595-33fb-4639-b09b-b20643936de0', label: 'Weekly GC Run Rate', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Weekly GC Run Rate = (count of distinct pj_project_id with ms_1555_construction_complete_actual in the trailing 84 days ending on evaluation_date) \\u00f7 12, grouped by rgn_region, m_area, m_market, and pj_general_contractor."}', nl_description: 'Weekly GC Run Rate = (count of distinct pj_project_id with ms_1555_construction_complete_actual in the trailing 84 days ending on evaluation_date) ÷ 12, grouped by rgn_region, m_area, m_market, and pj_general_contractor.', nl_business_rule: '', kpi_json: '{"kpi_id": "72e61595-33fb-4639-b09b-b20643936de0", "name": "Weekly GC Run Rate", "description": "Observed weekly throughput proxy per (m_market, pj_general_contractor) used as capacity input to the capacity-vs-demand gap.\\n\\nCalculation: COUNT(DISTINCT pj_project_id with ms_1555_construction_complete_actual in trailing 12 weeks)/12, where trailing 12 weeks is defined as ms_1555_construction_complete_actual::date >= (evaluation_date - INTERVAL \'84 days\') AND ms_1555_construction_complete_actual::date < evaluation_date + INTERVAL \'1 day\' (or <= evaluation_date).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nNotes: This is a historical run-rate (sites/week) and acts as a capacity proxy in absence of explicit crew counts.", "related_core_node_ids": ["project", "market", "general_contractor"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_weekly_gc_run_rate(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Weekly GC Run Rate (sites/week) per (rgn_region, m_area, m_market, pj_general_contractor).\\n\\n    Definition:\\n      COUNT(DISTINCT pj_project_id completed in trailing 12 weeks) / 12\\n    Trailing 12 weeks window (relative to evaluation_date):\\n      ms_1555_construction_complete_actual::date >= (evaluation_date - INTERVAL \'84 days\')\\n      AND ms_1555_construction_complete_actual::date < (evaluation_date + INTERVAL \'1 day\')\\n\\n    Expected filters (optional):\\n      - evaluation_date (YYYY-MM-DD). If not provided, uses CURRENT_DATE.\\n      - rgn_region, m_area, m_market, pj_general_contractor, pj_project_id\\n      - start_date/end_date are ignored for this KPI (window is defined via evaluation_date)\\n\\n    Returns list[dict] grouped by region/area/market/gc.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    eval_date = filters.get(\\"evaluation_date\\") or filters.get(\\"as_of_date\\") or filters.get(\\"date\\")\\n    if eval_date is None:\\n        eval_date_sql = \\"CURRENT_DATE\\"\\n    else:\\n        eval_date_escaped = str(eval_date).replace(\\"\'\\", \\"\'\'\\")\\n        eval_date_sql = f\\"DATE \'{eval_date_escaped}\'\\"\\n\\n    # Build additional WHERE clauses for dimension filtering (do NOT include evaluation_date)\\n    where_parts = [\\n        \\"ms_1555_construction_complete_actual IS NOT NULL\\",\\n        f\\"(ms_1555_construction_complete_actual::date >= ({eval_date_sql} - INTERVAL \'84 days\'))\\",\\n        f\\"(ms_1555_construction_complete_actual::date < ({eval_date_sql} + INTERVAL \'1 day\'))\\",\\n    ]\\n\\n    allowed_dim_filters = {\\n        \\"rgn_region\\": \\"rgn_region\\",\\n        \\"m_area\\": \\"m_area\\",\\n        \\"m_market\\": \\"m_market\\",\\n        \\"pj_general_contractor\\": \\"pj_general_contractor\\",\\n        \\"pj_project_id\\": \\"pj_project_id\\",\\n    }\\n\\n    for fk, col in allowed_dim_filters.items():\\n        if fk in filters and filters[fk] is not None and str(filters[fk]) != \\"\\":\\n            v = str(filters[fk]).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\\"{col} = \'{v}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    # Raw SQL is used because the Tier-1 accessors do not expose ms_1555_construction_complete_actual\\n    # and we need COUNT(DISTINCT ...) grouped with a date window.\\n    sql = f\\"\\"\\"\\n        SELECT\\n            rgn_region,\\n            m_area,\\n            m_market,\\n            pj_general_contractor,\\n            (COUNT(DISTINCT pj_project_id)::numeric / 12.0) AS weekly_gc_run_rate,\\n            COUNT(DISTINCT pj_project_id) AS completed_projects_trailing_12w\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n        WHERE {where_sql}\\n        GROUP BY rgn_region, m_area, m_market, pj_general_contractor\\n    \\"\\"\\".strip()\\n\\n    rows = execute_query(sql)\\n\\n    # Normalize output types\\n    out = []\\n    for r in rows or []:\\n        out.append({\\n            \\"rgn_region\\": r.get(\\"rgn_region\\"),\\n            \\"m_area\\": r.get(\\"m_area\\"),\\n            \\"m_market\\": r.get(\\"m_market\\"),\\n            \\"pj_general_contractor\\": r.get(\\"pj_general_contractor\\"),\\n            \\"weekly_gc_run_rate\\": float(r.get(\\"weekly_gc_run_rate\\")) if r.get(\\"weekly_gc_run_rate\\") is not None else None,\\n            \\"completed_projects_trailing_12w\\": int(r.get(\\"completed_projects_trailing_12w\\")) if r.get(\\"completed_projects_trailing_12w\\") is not None else 0,\\n            \\"evaluation_date\\": str(eval_date) if eval_date is not None else None,\\n        })\\n\\n    return out\\n", "formula_description": "Weekly GC Run Rate = (count of distinct pj_project_id with ms_1555_construction_complete_actual in the trailing 84 days ending on evaluation_date) \\u00f7 12, grouped by rgn_region, m_area, m_market, and pj_general_contractor.", "caveats": ["Tier-1 accessors for Project/Market/General Contractor do not expose ms_1555_construction_complete_actual, so raw SQL against stg_ndpd_mbt_tmobile_macro_combined is required.", "pj_general_contractor is free-text and may contain duplicates/variants (casing/suffix punctuation), which will split throughput across multiple GC names unless normalized upstream.", "If multiple rows per pj_project_id exist in the wide table, COUNT(DISTINCT pj_project_id) mitigates double-counting but assumes pj_project_id uniquely identifies a completion event."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "ews group", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "impirium", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pj_general_contractor": "ews group", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "kcctech", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "LOUISVILLE", "pj_general_contractor": "sba communications", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT PLAINS", "m_market": "KANSAS CITY", "pj_general_contractor": "kcctech", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT PLAINS", "m_market": "MINNEAPOLIS", "pj_general_contractor": "towerco", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "MID-ATLANTIC", "m_market": "PITTSBURGH", "pj_general_contractor": "impirium", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "MID-SOUTH", "m_market": "NASHVILLE", "pj_general_contractor": "nwtp solutions", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:13:07.489353+00:00", "contract": {"function_name": "get_weekly_gc_run_rate", "node_type": "kpi", "node_id": "72e61595-33fb-4639-b09b-b20643936de0", "node_label": "Weekly GC Run Rate", "description": "Observed weekly throughput proxy per (m_market, pj_general_contractor) used as capacity input to the capacity-vs-demand gap.\\n\\nCalculation: COUNT(DISTINCT pj_project_id with ms_1555_construction_complete_actual in trailing 12 weeks)/12, where trailing 12 weeks is defined as ms_1555_construction_complete_actual::date >= (evaluation_date - INTERVAL \'84 days\') AND ms_1555_construction_complete_actual::date < evaluation_date + INTERVAL \'1 day\' (or <= evaluation_date).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nNotes: This is a historical run-rate (sites/week) and acts as a capacity proxy in absence of explicit crew counts.", "parameters": [{"name": "evaluation_date", "type": "date", "description": "Filter by evaluation date", "required": false, "sample_values": []}, {"name": "as_of_date", "type": "date", "description": "Filter by as of date", "required": false, "sample_values": []}, {"name": "date", "type": "date", "description": "Filter by date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "weekly_gc_run_rate", "type": "number", "nullable": false}, {"name": "completed_projects_trailing_12w", "type": "number", "nullable": false}, {"name": "evaluation_date", "type": "null", "nullable": true}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "ews group", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "impirium", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '656de982-3668-41a9-bbcf-2a1fb4a75979', name: '656de982-3668-41a9-bbcf-2a1fb4a75979', label: 'Ready Site Backlog', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Ready Site Backlog = COUNT(DISTINCT pj_project_id) from Project records where construction start actual is NULL and all readiness-gate milestone dates are satisfied, grouped by rgn_region, m_area, m_market, and pj_general_contractor."}', nl_description: 'Ready Site Backlog = COUNT(DISTINCT pj_project_id) from Project records where construction start actual is NULL and all readiness-gate milestone dates are satisfied, grouped by rgn_region, m_area, m_market, and pj_general_contractor.', nl_business_rule: '', kpi_json: '{"kpi_id": "656de982-3668-41a9-bbcf-2a1fb4a75979", "name": "Ready Site Backlog", "description": "Counts projects that are ready for construction start but have not started yet, grouped by market and GC.\\n\\nFilter: ms_1550_construction_start_actual IS NULL AND readiness gates satisfied:\\n- (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n- pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n- pj_a_4525_power_ready_finish IS NOT NULL\\n- (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\n\\nAggregation: COUNT(DISTINCT pj_project_id).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nInterpretation: demand signal representing ready-to-start work waiting for crews.", "related_core_node_ids": ["project", "market", "general_contractor", "milestone"], "relationship_type": "AGGREGATES", "python_function": "def get_ready_site_backlog(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Counts projects ready to start construction but not started yet, grouped by region/area/market and GC.\\"\\"\\"\\n\\n    def _sql_escape(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Base WHERE clauses from KPI definition\\n    where_parts = [\\n        \\"ms_1550_construction_start_actual IS NULL\\",\\n        \\"(ms_1507_tower_ntp_approved_actual IS NOT NULL OR \\\\\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\\\\\" IS NOT NULL)\\",\\n        \\"\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\" IS NOT NULL\\",\\n        \\"\\\\\\"pj_a_4525_power_ready_finish\\\\\\" IS NOT NULL\\",\\n        \\"(\\\\\\"pj_a_4925_aav_fiber_ready_finish\\\\\\" IS NOT NULL OR \\\\\\"pj_a_4425_mw_installation_complete_finish\\\\\\" IS NOT NULL)\\"\\n    ]\\n\\n    # Optional user filters (kept flexible)\\n    filters = filters or {}\\n\\n    # Common dimension filters\\n    if filters.get(\\"rgn_region\\") is not None:\\n        where_parts.append(f\\"rgn_region = \'{_sql_escape(filters[\'rgn_region\'])}\'\\")\\n    if filters.get(\\"m_area\\") is not None:\\n        where_parts.append(f\\"m_area = \'{_sql_escape(filters[\'m_area\'])}\'\\")\\n    if filters.get(\\"m_market\\") is not None:\\n        where_parts.append(f\\"m_market = \'{_sql_escape(filters[\'m_market\'])}\'\\")\\n    if filters.get(\\"pj_general_contractor\\") is not None:\\n        where_parts.append(f\\"pj_general_contractor = \'{_sql_escape(filters[\'pj_general_contractor\'])}\'\\")\\n    if filters.get(\\"pj_project_id\\") is not None:\\n        where_parts.append(f\\"pj_project_id = \'{_sql_escape(filters[\'pj_project_id\'])}\'\\")\\n    if filters.get(\\"s_site_id\\") is not None:\\n        where_parts.append(f\\"s_site_id = \'{_sql_escape(filters[\'s_site_id\'])}\'\\")\\n\\n    # Optional date window: apply against construction-start actual (even though NULL),\\n    # so instead apply to a readiness anchor if provided.\\n    # Use MSI pickup finish as the anchor (earliest hard readiness gate in this KPI).\\n    if filters.get(\\"start_date\\") is not None:\\n        where_parts.append(f\\"\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\" >= \'{_sql_escape(filters[\'start_date\'])}\'\\")\\n    if filters.get(\\"end_date\\") is not None:\\n        where_parts.append(f\\"\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\" < \'{_sql_escape(filters[\'end_date\'])}\'\\")\\n\\n    where_sql = \\" AND \\".join(where_parts)\\n\\n    sql = (\\n        \\"SELECT \\"\\n        \\"  rgn_region, \\"\\n        \\"  m_area, \\"\\n        \\"  m_market, \\"\\n        \\"  pj_general_contractor, \\"\\n        \\"  COUNT(DISTINCT pj_project_id) AS ready_site_backlog \\"\\n        \\"FROM public.stg_ndpd_mbt_tmobile_macro_combined \\"\\n        f\\"WHERE {where_sql} \\"\\n        \\"GROUP BY rgn_region, m_area, m_market, pj_general_contractor \\"\\n        \\"ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\"\\n    )\\n\\n    rows = execute_query(sql, db=None, max_rows=None) or []\\n\\n    # Normalize output keys\\n    out = []\\n    for r in rows:\\n        out.append({\\n            \\"rgn_region\\": r.get(\\"rgn_region\\"),\\n            \\"m_area\\": r.get(\\"m_area\\"),\\n            \\"m_market\\": r.get(\\"m_market\\"),\\n            \\"pj_general_contractor\\": r.get(\\"pj_general_contractor\\"),\\n            \\"ready_site_backlog\\": r.get(\\"ready_site_backlog\\")\\n        })\\n    return out\\n", "formula_description": "Ready Site Backlog = COUNT(DISTINCT pj_project_id) from Project records where construction start actual is NULL and all readiness-gate milestone dates are satisfied, grouped by rgn_region, m_area, m_market, and pj_general_contractor.", "caveats": ["Milestone fields used in the readiness-gate logic are not exposed via the Tier-1 accessors for Project/Milestone, so this KPI uses raw SQL against the wide source table.", "pj_general_contractor is free-text and may contain duplicates due to casing/suffix/punctuation differences, which can split counts across multiple GC labels.", "Date filtering (start_date/end_date) is applied to pj_a_3925_msi_pickup_date_finish as an anchor readiness date; adjust if the business prefers a different readiness anchor.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedColumn) column \\"pj_a_3925_msi_pickup_date_finish\\" does not exist\\nLINE 1: ...uction_ntp_accepted_by_gc_finish IS NOT NULL) AND pj_a_3925_...\\n                                                             ^\\nHINT:  Perhaps you meant to reference the column \\"stg_ndpd_mbt_tmobile_"], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "Same column error as earlier with `pj_a_3925_msi_pickup_date_finish`. The column exists in the schema \\u2014 we verified it. This is likely a Postgres quoting issue. Tell the system to wrap the column name in double quotes in the SQL:\\n\\nReplace all references to:\\n- `pj_a_3925_msi_pickup_date_finish` \\u2192 `\\"pj_a_3925_msi_pickup_date_finish\\"`\\n\\nAnd while at it, do the same for the other long milestone column names to be safe:\\n- `\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\"`\\n- `\\"pj_a_4525_power_ready_finish\\"`\\n- `\\"pj_a_4925_aav_fiber_ready_finish\\"`\\n- `\\"pj_a_4425_mw_installation_complete_finish\\"`\\n\\nThe HINT saying \\"Perhaps you meant to reference the column...\\" means Postgres found a near-match, which typically happens when the column name is being truncated at the 63-character identifier limit or there\'s an invisible character. Double-quoting forces exact matching and bypasses any truncation.\\n\\nThe logic itself is correct \\u2014 don\'t change the KPI definition, just fix the quoting and retry."}, {"role": "assistant", "content": "<updates>\\n{\\n  \\"python_function\\": \\"def get_ready_site_backlog(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"Counts projects ready to start construction but not started yet, grouped by region/area/market and GC.\\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    def _sql_escape(v):\\\\n        return str(v).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n\\\\n    # Base WHERE clauses from KPI definition\\\\n    where_parts = [\\\\n        \\\\\\"ms_1550_construction_start_actual IS NULL\\\\\\",\\\\n        \\\\\\"(ms_1507_tower_ntp_approved_actual IS NOT NULL OR \\\\\\\\\\\\\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\",\\\\n        \\\\\\"\\\\\\\\\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\\\\\\\\\" IS NOT NULL\\\\\\",\\\\n        \\\\\\"\\\\\\\\\\\\\\"pj_a_4525_power_ready_finish\\\\\\\\\\\\\\" IS NOT NULL\\\\\\",\\\\n        \\\\\\"(\\\\\\\\\\\\\\"pj_a_4925_aav_fiber_ready_finish\\\\\\\\\\\\\\" IS NOT NULL OR \\\\\\\\\\\\\\"pj_a_4425_mw_installation_complete_finish\\\\\\\\\\\\\\" IS NOT NULL)\\\\\\"\\\\n    ]\\\\n\\\\n    # Optional user filters (kept flexible)\\\\n    filters = filters or {}\\\\n\\\\n    # Common dimension filters\\\\n    if filters.get(\\\\\\"rgn_region\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"rgn_region = \'{_sql_escape(filters[\'rgn_region\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_area\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"m_area = \'{_sql_escape(filters[\'m_area\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_market\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"m_market = \'{_sql_escape(filters[\'m_market\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_general_contractor\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"pj_general_contractor = \'{_sql_escape(filters[\'pj_general_contractor\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_project_id\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"pj_project_id = \'{_sql_escape(filters[\'pj_project_id\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"s_site_id\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"s_site_id = \'{_sql_escape(filters[\'s_site_id\'])}\'\\\\\\")\\\\n\\\\n    # Optional date window: apply against construction-start actual (even though NULL),\\\\n    # so instead apply to a readiness anchor if provided.\\\\n    # Use MSI pickup finish as the anchor (earliest hard readiness gate in this KPI).\\\\n    if filters.get(\\\\\\"start_date\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"\\\\\\\\\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\\\\\\\\\" >= \'{_sql_escape(filters[\'start_date\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"end_date\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"\\\\\\\\\\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\\\\\\\\\" < \'{_sql_escape(filters[\'end_date\'])}\'\\\\\\")\\\\n\\\\n    where_sql = \\\\\\" AND \\\\\\".join(where_parts)\\\\n\\\\n    sql = (\\\\n        \\\\\\"SELECT \\\\\\"\\\\n        \\\\\\"  rgn_region, \\\\\\"\\\\n        \\\\\\"  m_area, \\\\\\"\\\\n        \\\\\\"  m_market, \\\\\\"\\\\n        \\\\\\"  pj_general_contractor, \\\\\\"\\\\n        \\\\\\"  COUNT(DISTINCT pj_project_id) AS ready_site_backlog \\\\\\"\\\\n        \\\\\\"FROM public.stg_ndpd_mbt_tmobile_macro_combined \\\\\\"\\\\n        f\\\\\\"WHERE {where_sql} \\\\\\"\\\\n        \\\\\\"GROUP BY rgn_region, m_area, m_market, pj_general_contractor \\\\\\"\\\\n        \\\\\\"ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\\\\\"\\\\n    )\\\\n\\\\n    rows = execute_query(sql, db=None, max_rows=None) or []\\\\n\\\\n    # Normalize output keys\\\\n    out = []\\\\n    for r in rows:\\\\n        out.append({\\\\n            \\\\\\"rgn_region\\\\\\": r.get(\\\\\\"rgn_region\\\\\\"),\\\\n            \\\\\\"m_area\\\\\\": r.get(\\\\\\"m_area\\\\\\"),\\\\n            \\\\\\"m_market\\\\\\": r.get(\\\\\\"m_market\\\\\\"),\\\\n            \\\\\\"pj_general_contractor\\\\\\": r.get(\\\\\\"pj_general_contractor\\\\\\"),\\\\n            \\\\\\"ready_site_backlog\\\\\\": r.get(\\\\\\"ready_site_backlog\\\\\\")\\\\n        })\\\\n    return out\\\\n\\"\\n}\\n</updates>\\n\\nThis keeps the KPI logic unchanged and only forces exact identifier matching for the long milestone columns (including the MSI pickup date anchor used in the optional date filters)."}], "approved_by": "user", "approved_at": "2026-03-07T10:14:42.800558+00:00", "contract": {"function_name": "get_ready_site_backlog", "node_type": "kpi", "node_id": "656de982-3668-41a9-bbcf-2a1fb4a75979", "node_label": "Ready Site Backlog", "description": "Counts projects that are ready for construction start but have not started yet, grouped by market and GC.\\n\\nFilter: ms_1550_construction_start_actual IS NULL AND readiness gates satisfied:\\n- (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n- pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n- pj_a_4525_power_ready_finish IS NOT NULL\\n- (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\n\\nAggregation: COUNT(DISTINCT pj_project_id).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nInterpretation: demand signal representing ready-to-start work waiting for crews.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '5976040b-71f0-4f2b-a57e-8db52d8c853d', name: '5976040b-71f0-4f2b-a57e-8db52d8c853d', label: 'Ready Site Backlog', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "Ready Site Backlog = count of distinct Project IDs where construction start actual is NULL and the NTP/material/power/backhaul readiness gates are all satisfied, grouped by (region, area, market, general contractor)."}', nl_description: 'Ready Site Backlog = count of distinct Project IDs where construction start actual is NULL and the NTP/material/power/backhaul readiness gates are all satisfied, grouped by (region, area, market, general contractor).', nl_business_rule: '', kpi_json: '{"kpi_id": "5976040b-71f0-4f2b-a57e-8db52d8c853d", "name": "Ready Site Backlog", "description": "Counts ready-but-not-started projects per (Market, General Contractor) as-of CURRENT_DATE. Demand definition: COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NULL AND all readiness gates are met:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready: pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\nThis is a CURRENT_DATE snapshot (no time series). Groupable by rgn_region, m_area, m_market, pj_general_contractor. Entities involved: Project (pj_project_id) joined to Market (m_market/m_area/rgn_region) and General Contractor (pj_general_contractor) via the shared combined table.", "related_core_node_ids": ["project", "market", "general_contractor"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_ready_site_backlog(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Counts ready-but-not-started projects per (rgn_region, m_area, m_market, pj_general_contractor) as-of CURRENT_DATE.\\n\\n    Demand definition:\\n      COUNT(DISTINCT pj_project_id)\\n      WHERE ms_1550_construction_start_actual IS NULL\\n        AND NTP cleared\\n        AND material picked up\\n        AND power ready\\n        AND backhaul ready\\n\\n    Notes:\\n      - Uses raw SQL because readiness gates require milestone/date columns that are not exposed by Tier-1 accessors.\\n      - Filters are applied as additional WHERE predicates when provided.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def _esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Only allow filters that can be applied to this KPI query.\\n    allowed_filter_cols = {\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"pj_project_id\\",\\n        \\"s_site_id\\",\\n        \\"pj_program_name\\",\\n        \\"pj_project_status\\",\\n        \\"pj_project_type\\",\\n    }\\n\\n    where_parts = []\\n\\n    # Optional entity filters\\n    for k, v in filters.items():\\n        if v is None:\\n            continue\\n        if k in (\\"start_date\\", \\"end_date\\"):\\n            # This KPI is defined as a CURRENT_DATE snapshot; ignore date-range filters.\\n            continue\\n        if k not in allowed_filter_cols:\\n            continue\\n        where_parts.append(f\\"{k} = \'{_esc(v)}\'\\")\\n\\n    # Base readiness logic\\n    where_parts.append(\\"ms_1550_construction_start_actual IS NULL\\")\\n\\n    # 1) NTP cleared\\n    where_parts.append(\\"(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\")\\n\\n    # 2) Material picked up\\n    where_parts.append(\\"pj_a_3925_msi_pickup_date_finish IS NOT NULL\\")\\n\\n    # 3) Power ready\\n    where_parts.append(\\"pj_a_4525_power_ready_finish IS NOT NULL\\")\\n\\n    # 4) Backhaul ready\\n    where_parts.append(\\"(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\")\\n\\n    where_sql = \\" AND \\".join(where_parts) if where_parts else \\"TRUE\\"\\n\\n    sql = f\\"\\"\\"\\n        SELECT\\n            rgn_region,\\n            m_area,\\n            m_market,\\n            pj_general_contractor,\\n            COUNT(DISTINCT pj_project_id) AS ready_site_backlog\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n        WHERE {where_sql}\\n        GROUP BY rgn_region, m_area, m_market, pj_general_contractor\\n        ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\n    \\"\\"\\".strip()\\n\\n    return execute_query(sql)", "formula_description": "Ready Site Backlog = count of distinct Project IDs where construction start actual is NULL and the NTP/material/power/backhaul readiness gates are all satisfied, grouped by (region, area, market, general contractor).", "caveats": ["Tier-1 accessors do not expose the milestone/date columns needed for readiness gates, so raw SQL against the combined wide table is used.", "pj_general_contractor and related GC fields are free-text and may contain duplicates/variants (casing/suffixes), which can split counts across names unless normalized.", "This is a CURRENT_DATE snapshot by definition; start_date/end_date filters are intentionally ignored.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedColumn) column \\"pj_a_3925_msi_pickup_date_finish\\" does not exist\\nLINE 8: ...uction_ntp_accepted_by_gc_finish IS NOT NULL) AND pj_a_3925_...\\n                                                             ^\\nHINT:  Perhaps you meant to reference the column \\"stg_ndpd_mbt_tmobile_"], "evidence": {"sample_data": []}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:15:07.083305+00:00", "contract": {"function_name": "get_ready_site_backlog", "node_type": "kpi", "node_id": "5976040b-71f0-4f2b-a57e-8db52d8c853d", "node_label": "Ready Site Backlog", "description": "Counts ready-but-not-started projects per (Market, General Contractor) as-of CURRENT_DATE. Demand definition: COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NULL AND all readiness gates are met:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready: pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\nThis is a CURRENT_DATE snapshot (no time series). Groupable by rgn_region, m_area, m_market, pj_general_contractor. Entities involved: Project (pj_project_id) joined to Market (m_market/m_area/rgn_region) and General Contractor (pj_general_contractor) via the shared combined table.", "parameters": [], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'ea9583cb-1701-45ef-a2db-5cc07b01948c', name: 'ea9583cb-1701-45ef-a2db-5cc07b01948c', label: 'Capacity vs Demand Gap', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "For each (rgn_region, m_area, m_market, pj_general_contractor), compute run_rate = distinct projects completed in the last 12 weeks \\u00f7 12, backlog = distinct projects that are readiness-gated and not started as of CURRENT_DATE, and gap = run_rate \\u2212 backlog."}', nl_description: 'For each (rgn_region, m_area, m_market, pj_general_contractor), compute run_rate = distinct projects completed in the last 12 weeks ÷ 12, backlog = distinct projects that are readiness-gated and not started as of CURRENT_DATE, and gap = run_rate − backlog.', nl_business_rule: '', kpi_json: '{"kpi_id": "ea9583cb-1701-45ef-a2db-5cc07b01948c", "name": "Capacity vs Demand Gap", "description": "Computes the current execution gap per (Market, General Contractor) as: (Weekly GC Run Rate) \\u2212 (Ready Site Backlog), anchored to CURRENT_DATE. Interpreting sign: positive => implied spare capacity/underutilization; negative => backlog pressure (more ready sites than observed weekly delivery capacity). Implementation: for each (m_market, pj_general_contractor) produce two measures: (a) run_rate = COUNT(DISTINCT pj_project_id completed in trailing 12 weeks) / 12 with 0 when none; (b) backlog = COUNT(DISTINCT pj_project_id) meeting readiness gates and not started. gap = run_rate - backlog. Groupable by rgn_region, m_area, m_market, pj_general_contractor.", "related_core_node_ids": ["project", "market", "general_contractor"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_capacity_vs_demand_gap(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Capacity vs Demand Gap per (rgn_region, m_area, m_market, pj_general_contractor).\\n\\n    run_rate = COUNT(DISTINCT completed projects in trailing 12 weeks) / 12\\n    backlog  = COUNT(DISTINCT projects not started as-of CURRENT_DATE that meet readiness gates)\\n    gap      = run_rate - backlog\\n\\n    Notes:\\n      - Uses raw SQL against public.stg_ndpd_mbt_tmobile_macro_combined for milestone fields.\\n      - Readiness gates are aligned to the Ready Site Backlog KPI\'s 4-gate definition.\\n      - Long column names are double-quoted to avoid truncation/case issues.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    where_parts = []\\n    if filters.get(\\"rgn_region\\") is not None:\\n        where_parts.append(f\\"rgn_region = \'{esc(filters[\'rgn_region\'])}\'\\")\\n    if filters.get(\\"m_area\\") is not None:\\n        where_parts.append(f\\"m_area = \'{esc(filters[\'m_area\'])}\'\\")\\n    if filters.get(\\"m_market\\") is not None:\\n        where_parts.append(f\\"m_market = \'{esc(filters[\'m_market\'])}\'\\")\\n    if filters.get(\\"pj_general_contractor\\") is not None:\\n        where_parts.append(f\\"pj_general_contractor = \'{esc(filters[\'pj_general_contractor\'])}\'\\")\\n    if filters.get(\\"pj_program_name\\") is not None:\\n        where_parts.append(f\\"pj_program_name = \'{esc(filters[\'pj_program_name\'])}\'\\")\\n    if filters.get(\\"pj_project_type\\") is not None:\\n        where_parts.append(f\\"pj_project_type = \'{esc(filters[\'pj_project_type\'])}\'\\")\\n\\n    where_sql = (\\"WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    completed_col = \'\\"ms_1555_construction_complete_actual\\"\'\\n    started_col = \'\\"ms_1550_construction_start_actual\\"\'\\n\\n    readiness_expr = \\"\\"\\"\\n    (\\n      (\\"ms_1507_tower_ntp_approved_actual\\" IS NOT NULL\\n         OR \\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\" IS NOT NULL)\\n      AND \\"pj_a_3925_msi_pickup_date_finish\\" IS NOT NULL\\n      AND \\"pj_a_4525_power_ready_finish\\" IS NOT NULL\\n      AND (\\"pj_a_4925_aav_fiber_ready_finish\\" IS NOT NULL\\n         OR \\"pj_a_4425_mw_installation_complete_finish\\" IS NOT NULL)\\n    )\\n    \\"\\"\\"\\n\\n    sql = f\\"\\"\\"\\n    WITH base AS (\\n      SELECT\\n        rgn_region,\\n        m_area,\\n        m_market,\\n        pj_general_contractor,\\n        pj_project_id,\\n        {completed_col}::timestamp AS completed_at,\\n        {started_col}::timestamp AS started_at,\\n        {readiness_expr} AS is_ready\\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n      {where_sql}\\n    ),\\n    run_rate_by_grp AS (\\n      SELECT\\n        rgn_region,\\n        m_area,\\n        m_market,\\n        pj_general_contractor,\\n        COUNT(DISTINCT pj_project_id) AS completed_12w\\n      FROM base\\n      WHERE completed_at IS NOT NULL\\n        AND completed_at >= (CURRENT_DATE - INTERVAL \'84 days\')\\n        AND completed_at < (CURRENT_DATE + INTERVAL \'1 day\')\\n      GROUP BY 1,2,3,4\\n    ),\\n    backlog_by_grp AS (\\n      SELECT\\n        rgn_region,\\n        m_area,\\n        m_market,\\n        pj_general_contractor,\\n        COUNT(DISTINCT pj_project_id) AS ready_not_started\\n      FROM base\\n      WHERE started_at IS NULL\\n        AND is_ready\\n      GROUP BY 1,2,3,4\\n    ),\\n    all_grps AS (\\n      SELECT DISTINCT rgn_region, m_area, m_market, pj_general_contractor\\n      FROM base\\n      WHERE pj_general_contractor IS NOT NULL\\n        AND m_market IS NOT NULL\\n    )\\n    SELECT\\n      g.rgn_region,\\n      g.m_area,\\n      g.m_market,\\n      g.pj_general_contractor,\\n      COALESCE(r.completed_12w, 0)::numeric / 12.0 AS run_rate,\\n      COALESCE(b.ready_not_started, 0) AS backlog,\\n      (COALESCE(r.completed_12w, 0)::numeric / 12.0) - COALESCE(b.ready_not_started, 0) AS gap\\n    FROM all_grps g\\n    LEFT JOIN run_rate_by_grp r\\n      ON r.rgn_region = g.rgn_region\\n     AND r.m_area = g.m_area\\n     AND r.m_market = g.m_market\\n     AND r.pj_general_contractor = g.pj_general_contractor\\n    LEFT JOIN backlog_by_grp b\\n      ON b.rgn_region = g.rgn_region\\n     AND b.m_area = g.m_area\\n     AND b.m_market = g.m_market\\n     AND b.pj_general_contractor = g.pj_general_contractor\\n    ORDER BY g.rgn_region, g.m_area, g.m_market, g.pj_general_contractor\\n    ;\\n    \\"\\"\\"\\n\\n    return execute_query(sql)\\n", "formula_description": "For each (rgn_region, m_area, m_market, pj_general_contractor), compute run_rate = distinct projects completed in the last 12 weeks \\u00f7 12, backlog = distinct projects that are readiness-gated and not started as of CURRENT_DATE, and gap = run_rate \\u2212 backlog.", "caveats": ["Tier-1 Project accessor does not expose the milestone/date fields needed to identify completed, started, and readiness-gated projects; this implementation uses raw SQL and assumes the underlying wide table contains ms_1554_tw_works_start_actual (start) and ms_1555_tw_works_complete_actual (complete) plus either ready_site_backlog_flag or ready_site_date for readiness.", "General contractor is free-text (casing/suffix differences), so grouping by pj_general_contractor may split the same vendor into multiple names unless normalized upstream.", "Backlog definition (\'readiness gates\') must be confirmed\\u2014replace ready_site_backlog_flag/ready_site_date with the agreed milestone-based readiness rule once finalized.", "Function execution warning: Runtime error: Only SELECT queries are allowed."], "evidence": {"sample_data": []}, "conversation_history": [{"role": "user", "content": "Don\'t confirm \\u2014 three column name errors and the readiness logic is wrong. Tell the system:\\n\\n**Wrong column names \\u2014 fix these:**\\n\\n| System used | Correct column |\\n|---|---|\\n| `ms_1555_tw_works_complete_actual` | `ms_1555_construction_complete_actual` |\\n| `ms_1554_tw_works_start_actual` | `ms_1550_construction_start_actual` |\\n| `ready_site_backlog_flag` | Does not exist |\\n| `ready_site_date` | Does not exist |\\n\\n**Readiness gate logic** \\u2014 replace the `ready_bool_expr` placeholder with the actual 4-gate check that\'s already defined and working in the Ready Site Backlog KPI:\\n\\n```sql\\n(ms_1507_tower_ntp_approved_actual IS NOT NULL \\n   OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\nAND \\"pj_a_3925_msi_pickup_date_finish\\" IS NOT NULL\\nAND \\"pj_a_4525_power_ready_finish\\" IS NOT NULL\\nAND (\\"pj_a_4925_aav_fiber_ready_finish\\" IS NOT NULL \\n   OR \\"pj_a_4425_mw_installation_complete_finish\\" IS NOT NULL)\\n```\\n\\nThe backlog CTE should then be:\\n```sql\\nWHERE ms_1550_construction_start_actual IS NULL\\n  AND [above 4 gates]\\n```\\n\\nThe overall architecture is good \\u2014 the LEFT JOIN from `all_grps` spine to `run_rate_by_grp` and `backlog_by_grp` correctly handles GCs with zero completions or zero backlog. Just fix the column names, remove the placeholder boolean, and use double-quoted long column names to avoid the truncation issue. Retry."}, {"role": "assistant", "content": "<updates>\\n{\\n  \\"python_function\\": \\"def get_capacity_vs_demand_gap(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"Capacity vs Demand Gap per (rgn_region, m_area, m_market, pj_general_contractor).\\\\n\\\\n    run_rate = COUNT(DISTINCT completed projects in trailing 12 weeks) / 12\\\\n    backlog  = COUNT(DISTINCT projects not started as-of CURRENT_DATE that meet readiness gates)\\\\n    gap      = run_rate - backlog\\\\n\\\\n    Notes:\\\\n      - Uses raw SQL against public.stg_ndpd_mbt_tmobile_macro_combined for milestone fields.\\\\n      - Readiness gates are aligned to the Ready Site Backlog KPI\'s 4-gate definition.\\\\n      - Long column names are double-quoted to avoid truncation/case issues.\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    filters = filters or {}\\\\n\\\\n    def esc(v):\\\\n        return str(v).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n\\\\n    where_parts = []\\\\n    if filters.get(\\\\\\"rgn_region\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"rgn_region = \'{esc(filters[\'rgn_region\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_area\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"m_area = \'{esc(filters[\'m_area\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"m_market\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"m_market = \'{esc(filters[\'m_market\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_general_contractor\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"pj_general_contractor = \'{esc(filters[\'pj_general_contractor\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_program_name\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"pj_program_name = \'{esc(filters[\'pj_program_name\'])}\'\\\\\\")\\\\n    if filters.get(\\\\\\"pj_project_type\\\\\\") is not None:\\\\n        where_parts.append(f\\\\\\"pj_project_type = \'{esc(filters[\'pj_project_type\'])}\'\\\\\\")\\\\n\\\\n    where_sql = (\\\\\\"WHERE \\\\\\" + \\\\\\" AND \\\\\\".join(where_parts)) if where_parts else \\\\\\"\\\\\\"\\\\n\\\\n    completed_col = \'\\\\\\"ms_1555_construction_complete_actual\\\\\\"\'\\\\n    started_col = \'\\\\\\"ms_1550_construction_start_actual\\\\\\"\'\\\\n\\\\n    readiness_expr = \\\\\\"\\\\\\"\\\\\\"\\\\n    (\\\\n      (\\\\\\"ms_1507_tower_ntp_approved_actual\\\\\\" IS NOT NULL\\\\n         OR \\\\\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\\\\\" IS NOT NULL)\\\\n      AND \\\\\\"pj_a_3925_msi_pickup_date_finish\\\\\\" IS NOT NULL\\\\n      AND \\\\\\"pj_a_4525_power_ready_finish\\\\\\" IS NOT NULL\\\\n      AND (\\\\\\"pj_a_4925_aav_fiber_ready_finish\\\\\\" IS NOT NULL\\\\n         OR \\\\\\"pj_a_4425_mw_installation_complete_finish\\\\\\" IS NOT NULL)\\\\n    )\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n    WITH base AS (\\\\n      SELECT\\\\n        rgn_region,\\\\n        m_area,\\\\n        m_market,\\\\n        pj_general_contractor,\\\\n        pj_project_id,\\\\n        {completed_col}::timestamp AS completed_at,\\\\n        {started_col}::timestamp AS started_at,\\\\n        {readiness_expr} AS is_ready\\\\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\\\\n      {where_sql}\\\\n    ),\\\\n    run_rate_by_grp AS (\\\\n      SELECT\\\\n        rgn_region,\\\\n        m_area,\\\\n        m_market,\\\\n        pj_general_contractor,\\\\n        COUNT(DISTINCT pj_project_id) AS completed_12w\\\\n      FROM base\\\\n      WHERE completed_at IS NOT NULL\\\\n        AND completed_at >= (CURRENT_DATE - INTERVAL \'84 days\')\\\\n        AND completed_at < (CURRENT_DATE + INTERVAL \'1 day\')\\\\n      GROUP BY 1,2,3,4\\\\n    ),\\\\n    backlog_by_grp AS (\\\\n      SELECT\\\\n        rgn_region,\\\\n        m_area,\\\\n        m_market,\\\\n        pj_general_contractor,\\\\n        COUNT(DISTINCT pj_project_id) AS ready_not_started\\\\n      FROM base\\\\n      WHERE started_at IS NULL\\\\n        AND is_ready\\\\n      GROUP BY 1,2,3,4\\\\n    ),\\\\n    all_grps AS (\\\\n      SELECT DISTINCT rgn_region, m_area, m_market, pj_general_contractor\\\\n      FROM base\\\\n      WHERE pj_general_contractor IS NOT NULL\\\\n        AND m_market IS NOT NULL\\\\n    )\\\\n    SELECT\\\\n      g.rgn_region,\\\\n      g.m_area,\\\\n      g.m_market,\\\\n      g.pj_general_contractor,\\\\n      COALESCE(r.completed_12w, 0)::numeric / 12.0 AS run_rate,\\\\n      COALESCE(b.ready_not_started, 0) AS backlog,\\\\n      (COALESCE(r.completed_12w, 0)::numeric / 12.0) - COALESCE(b.ready_not_started, 0) AS gap\\\\n    FROM all_grps g\\\\n    LEFT JOIN run_rate_by_grp r\\\\n      ON r.rgn_region = g.rgn_region\\\\n     AND r.m_area = g.m_area\\\\n     AND r.m_market = g.m_market\\\\n     AND r.pj_general_contractor = g.pj_general_contractor\\\\n    LEFT JOIN backlog_by_grp b\\\\n      ON b.rgn_region = g.rgn_region\\\\n     AND b.m_area = g.m_area\\\\n     AND b.m_market = g.m_market\\\\n     AND b.pj_general_contractor = g.pj_general_contractor\\\\n    ORDER BY g.rgn_region, g.m_area, g.m_market, g.pj_general_contractor\\\\n    ;\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    return execute_query(sql)\\\\n\\"\\n}\\n</updates>"}], "approved_by": "user", "approved_at": "2026-03-07T10:20:02.033997+00:00", "contract": {"function_name": "get_capacity_vs_demand_gap", "node_type": "kpi", "node_id": "ea9583cb-1701-45ef-a2db-5cc07b01948c", "node_label": "Capacity vs Demand Gap", "description": "Computes the current execution gap per (Market, General Contractor) as: (Weekly GC Run Rate) \\u2212 (Ready Site Backlog), anchored to CURRENT_DATE. Interpreting sign: positive => implied spare capacity/underutilization; negative => backlog pressure (more ready sites than observed weekly delivery capacity). Implementation: for each (m_market, pj_general_contractor) produce two measures: (a) run_rate = COUNT(DISTINCT pj_project_id completed in trailing 12 weeks) / 12 with 0 when none; (b) backlog = COUNT(DISTINCT pj_project_id) meeting readiness gates and not started. gap = run_rate - backlog. Groupable by rgn_region, m_area, m_market, pj_general_contractor.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "pj_program_name", "type": "string", "description": "Filter by pj program name", "required": false, "sample_values": []}, {"name": "pj_project_type", "type": "string", "description": "Filter by pj project type", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91', name: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91', label: 'CX to On-Air Lead Time', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "CX to On-Air Lead Time = (pj_completion_objective_actual_date::date \\u2212 ms_1555_construction_complete_actual::date) in calendar days for records with both dates present and non-negative, aggregated by (rgn_region, m_area, m_market, pj_general_contractor) and summarized via average, median (P50), P90, and max."}', nl_description: 'CX to On-Air Lead Time = (pj_completion_objective_actual_date::date − ms_1555_construction_complete_actual::date) in calendar days for records with both dates present and non-negative, aggregated by (rgn_region, m_area, m_market, pj_general_contractor) and summarized via average, median (P50), P90, and max.', nl_business_rule: '', kpi_json: '{"kpi_id": "6b91dd88-d284-4ba1-b95a-b66c1ee08d91", "name": "CX to On-Air Lead Time", "description": "Measures post-construction lead time for projects that have reached On-Air. Calculate calendar days as (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) for rows where both dates are NOT NULL and the difference is >= 0. Aggregate by (rgn_region, m_area, m_market, pj_general_contractor) and return distribution statistics: average days, P50/median, P90, and maximum. Source table: stg_ndpd_mbt_tmobile_macro_combined. Key entity: Project (pj_project_id) joined implicitly to Market/GC attributes via same table. Exclude negative durations and null dates to avoid bad data artifacts.", "related_core_node_ids": ["project"], "relationship_type": "AGGREGATES", "python_function": "def get_cx_to_on_air_lead_time(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"CX to On-Air Lead Time distribution by (rgn_region, m_area, m_market, pj_general_contractor).\\n\\n    Lead time (calendar days) = (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date)\\n    where both dates are not null and diff >= 0.\\n\\n    Returns list of dicts with avg_days, p50_days, p90_days, max_days, n.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def _escape(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Build WHERE clause from provided filters.\\n    # Note: start/end_date are applied to pj_completion_objective_actual_date (On-Air) by default.\\n    where_parts = [\\n        \\"pj_completion_objective_actual_date IS NOT NULL\\",\\n        \\"ms_1555_construction_complete_actual IS NOT NULL\\",\\n        \\"(pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) >= 0\\"\\n    ]\\n\\n    # Common dimensional filters\\n    passthrough_keys = [\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"pj_project_id\\",\\n        \\"s_site_id\\",\\n        \\"pj_project_status\\",\\n        \\"pj_project_type\\",\\n        \\"pj_program_name\\"\\n    ]\\n    for k in passthrough_keys:\\n        if k in filters and filters.get(k) is not None and filters.get(k) != \\"\\":\\n            where_parts.append(f\\"{k} = \'{_escape(filters.get(k))}\'\\")\\n\\n    start_date = filters.get(\\"start_date\\")\\n    end_date = filters.get(\\"end_date\\")\\n    if start_date:\\n        where_parts.append(f\\"pj_completion_objective_actual_date::date >= \'{_escape(start_date)}\'::date\\")\\n    if end_date:\\n        where_parts.append(f\\"pj_completion_objective_actual_date::date <= \'{_escape(end_date)}\'::date\\")\\n\\n    where_sql = \\" WHERE \\" + \\" AND \\".join(where_parts)\\n\\n    # Use raw SQL (preferred here) because required columns are not exposed by Tier-1 accessors,\\n    # and we need percentiles efficiently.\\n    sql = (\\n        \\"SELECT \\"\\n        \\"  rgn_region, \\"\\n        \\"  m_area, \\"\\n        \\"  m_market, \\"\\n        \\"  pj_general_contractor, \\"\\n        \\"  COUNT(*) AS n, \\"\\n        \\"  AVG((pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS avg_days, \\"\\n        \\"  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS p50_days, \\"\\n        \\"  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS p90_days, \\"\\n        \\"  MAX((pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS max_days \\"\\n        \\"FROM public.stg_ndpd_mbt_tmobile_macro_combined\\"\\n        + where_sql +\\n        \\" GROUP BY rgn_region, m_area, m_market, pj_general_contractor \\"\\n        \\" ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\"\\n    )\\n\\n    return execute_query(sql)\\n", "formula_description": "CX to On-Air Lead Time = (pj_completion_objective_actual_date::date \\u2212 ms_1555_construction_complete_actual::date) in calendar days for records with both dates present and non-negative, aggregated by (rgn_region, m_area, m_market, pj_general_contractor) and summarized via average, median (P50), P90, and max.", "caveats": ["Tier-1 accessors for Project do not expose pj_completion_objective_actual_date or ms_1555_construction_complete_actual, so raw SQL is used against the wide source table.", "start_date/end_date filtering is applied to pj_completion_objective_actual_date (On-Air) by default; if you need filtering on construction complete date instead, the WHERE clause should be adjusted.", "pj_general_contractor is free-text and may contain duplicates/variants (casing/suffixes), which can split groups unless normalized."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "telcom construction", "n": 1, "avg_days": 420.0, "p50_days": 420.0, "p90_days": 420.0, "max_days": 420.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "uci", "n": 1, "avg_days": 358.0, "p50_days": 358.0, "p90_days": 358.0, "max_days": 358.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "vericore", "n": 1, "avg_days": 128.0, "p50_days": 128.0, "p90_days": 128.0, "max_days": 128.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "allied tower services", "n": 1, "avg_days": 362.0, "p50_days": 362.0, "p90_days": 362.0, "max_days": 362.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "kcctech", "n": 1, "avg_days": 104.0, "p50_days": 104.0, "p90_days": 104.0, "max_days": 104.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pj_general_contractor": "adcom communication wireless", "n": 1, "avg_days": 259.0, "p50_days": 259.0, "p90_days": 259.0, "max_days": 259.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pj_general_contractor": "hampton enterprises", "n": 1, "avg_days": 419.0, "p50_days": 419.0, "p90_days": 419.0, "max_days": 419.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "allied tower services", "n": 1, "avg_days": 170.0, "p50_days": 170.0, "p90_days": 170.0, "max_days": 170.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "pm communications", "n": 1, "avg_days": 195.0, "p50_days": 195.0, "p90_days": 195.0, "max_days": 195.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "telcom construction", "n": 1, "avg_days": 61.0, "p50_days": 61.0, "p90_days": 61.0, "max_days": 61.0}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:23:30.885194+00:00", "contract": {"function_name": "get_cx_to_on_air_lead_time", "node_type": "kpi", "node_id": "6b91dd88-d284-4ba1-b95a-b66c1ee08d91", "node_label": "CX to On-Air Lead Time", "description": "Measures post-construction lead time for projects that have reached On-Air. Calculate calendar days as (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) for rows where both dates are NOT NULL and the difference is >= 0. Aggregate by (rgn_region, m_area, m_market, pj_general_contractor) and return distribution statistics: average days, P50/median, P90, and maximum. Source table: stg_ndpd_mbt_tmobile_macro_combined. Key entity: Project (pj_project_id) joined implicitly to Market/GC attributes via same table. Exclude negative durations and null dates to avoid bad data artifacts.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "n", "type": "number", "nullable": false}, {"name": "avg_days", "type": "number", "nullable": false}, {"name": "p50_days", "type": "number", "nullable": false}, {"name": "p90_days", "type": "number", "nullable": false}, {"name": "max_days", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "telcom construction", "n": 1, "avg_days": 420.0, "p50_days": 420.0, "p90_days": 420.0, "max_days": 420.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "uci", "n": 1, "avg_days": 358.0, "p50_days": 358.0, "p90_days": 358.0, "max_days": 358.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "vericore", "n": 1, "avg_days": 128.0, "p50_days": 128.0, "p90_days": 128.0, "max_days": 128.0}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'a3f0a09c-5a86-4bcd-8d8a-7842e73c5e3e', name: 'a3f0a09c-5a86-4bcd-8d8a-7842e73c5e3e', label: 'CX to On-Air Backlog', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "CX to On-Air Backlog = COUNT(DISTINCT pj_project_id) for projects where construction is complete (ms_1555_construction_complete_actual not null) and On-Air actual date is null (pj_completion_objective_actual_date null), grouped by rgn_region/m_area/m_market/pj_general_contractor, with each backlog project assigned to exactly one blocker stage based on integration start, integration completion, and COP approval milestone null-ness."}', nl_description: 'CX to On-Air Backlog = COUNT(DISTINCT pj_project_id) for projects where construction is complete (ms_1555_construction_complete_actual not null) and On-Air actual date is null (pj_completion_objective_actual_date null), grouped by rgn_region/m_area/m_market/pj_general_contractor, with each backlog project assigned to exactly one blocker stage based on integration start, integration completion, and COP approval milestone null-ness.', nl_business_rule: '', kpi_json: '{"kpi_id": "a3f0a09c-5a86-4bcd-8d8a-7842e73c5e3e", "name": "CX to On-Air Backlog", "description": "Counts projects that have completed construction but have not yet gone On-Air (current snapshot), and breaks the backlog down by the most actionable blocking stage.\\n\\nEntities / joins: Project (stg_ndpd_mbt_tmobile_macro_combined) grouped by rgn_region, m_area, m_market, pj_general_contractor; keyed by pj_project_id.\\n\\nInput columns:\\n- pj_project_id\\n- ms_1555_construction_complete_actual\\n- pj_completion_objective_actual_date\\n- pj_a_5270_integration_start_finish\\n- ms_1970_integration_complete_actual\\n- ms_1559_cop_approved_by_t_mobile_actual\\n- rgn_region, m_area, m_market, pj_general_contractor\\n\\nBacklog population definition:\\n- Backlog projects are those where:\\n  - ms_1555_construction_complete_actual IS NOT NULL\\n  - AND pj_completion_objective_actual_date IS NULL\\n\\nCore outputs (per grouping):\\n- backlog_count = COUNT(DISTINCT pj_project_id) over the backlog population\\n\\nBlocker-stage breakdown outputs (per grouping). Compute as counts over the backlog population using mutually exclusive stage logic, evaluated in this order:\\n1) backlog_integration_not_started_count:\\n   - pj_a_5270_integration_start_finish IS NULL\\n2) backlog_integration_in_progress_count:\\n   - pj_a_5270_integration_start_finish IS NOT NULL\\n   - AND ms_1970_integration_complete_actual IS NULL\\n3) backlog_post_integration_cop_pending_count:\\n   - ms_1970_integration_complete_actual IS NOT NULL\\n   - AND ms_1559_cop_approved_by_t_mobile_actual IS NULL\\n4) backlog_other_post_cop_count (optional catch-all to avoid silent leakage):\\n   - ms_1970_integration_complete_actual IS NOT NULL\\n   - AND ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL\\n   - AND pj_completion_objective_actual_date IS NULL\\n\\nImplementation notes:\\n- Use COUNT(DISTINCT pj_project_id) for all counts.\\n- Ensure the breakdown stage counts sum to backlog_count when the optional catch-all is included.\\n- This is a CURRENT_DATE snapshot metric (no time bucketing).", "related_core_node_ids": ["project"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_cx_to_on_air_backlog(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Counts projects that are construction complete but not yet On-Air, grouped by region/area/market/GC,\\n    with mutually-exclusive blocker-stage breakdown.\\n\\n    Backlog definition:\\n      - ms_1555_construction_complete_actual IS NOT NULL\\n      - AND pj_completion_objective_actual_date IS NULL\\n\\n    Stage assignment (in order):\\n      1) integration_not_started: pj_a_5270_integration_start_finish IS NULL\\n      2) integration_in_progress: pj_a_5270_integration_start_finish IS NOT NULL AND ms_1970_integration_complete_actual IS NULL\\n      3) post_integration_cop_pending: ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NULL\\n      4) other_post_cop (catch-all): ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # Accessor for Project does not expose the required milestone columns, so use raw SQL (single-table).\\n    where_parts = []\\n\\n    # Optional dimension filters (only add if present). These column names are expected on the project table.\\n    for k in [\\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_project_id\\", \\"pj_project_status\\", \\"pj_project_type\\", \\"pj_program_name\\"]:\\n        if k in filters and filters.get(k) is not None and str(filters.get(k)) != \\"\\":\\n            v = str(filters.get(k)).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\\"{k} = \'{v}\'\\")\\n\\n    # Explicit snapshot metric: do not time-bucket. If caller passes start/end dates, ignore them (by design).\\n\\n    # Backlog population constraints\\n    where_parts.append(\\"ms_1555_construction_complete_actual IS NOT NULL\\")\\n    where_parts.append(\\"pj_completion_objective_actual_date IS NULL\\")\\n\\n    where_sql = (\\"WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    sql = f\\"\\"\\"\\n        SELECT\\n            rgn_region,\\n            m_area,\\n            m_market,\\n            pj_general_contractor,\\n            pj_project_id,\\n            pj_a_5270_integration_start_finish,\\n            ms_1970_integration_complete_actual,\\n            ms_1559_cop_approved_by_t_mobile_actual,\\n            pj_completion_objective_actual_date\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n        {where_sql}\\n    \\"\\"\\".strip()\\n\\n    rows = execute_query(sql)\\n\\n    def norm_dim(val):\\n        if val is None:\\n            return \\"(null)\\"\\n        s = str(val).strip()\\n        return s if s != \\"\\" else \\"(blank)\\"\\n\\n    def is_nullish(v):\\n        return v is None or str(v).strip() == \\"\\"\\n\\n    # Aggregate distinct pj_project_id per grouping and stage\\n    agg = {}\\n    for r in rows:\\n        project_id = r.get(\\"pj_project_id\\")\\n        if is_nullish(project_id):\\n            # Cannot COUNT(DISTINCT) without an identifier\\n            continue\\n\\n        gk = (\\n            norm_dim(r.get(\\"rgn_region\\")),\\n            norm_dim(r.get(\\"m_area\\")),\\n            norm_dim(r.get(\\"m_market\\")),\\n            norm_dim(r.get(\\"pj_general_contractor\\"))\\n        )\\n        if gk not in agg:\\n            agg[gk] = {\\n                \\"backlog_projects\\": set(),\\n                \\"integration_not_started\\": set(),\\n                \\"integration_in_progress\\": set(),\\n                \\"post_integration_cop_pending\\": set(),\\n                \\"other_post_cop\\": set()\\n            }\\n\\n        s = agg[gk]\\n        s[\\"backlog_projects\\"].add(project_id)\\n\\n        integ_start_finish = r.get(\\"pj_a_5270_integration_start_finish\\")\\n        integ_complete = r.get(\\"ms_1970_integration_complete_actual\\")\\n        cop_approved = r.get(\\"ms_1559_cop_approved_by_t_mobile_actual\\")\\n        onair_date = r.get(\\"pj_completion_objective_actual_date\\")\\n\\n        # Mutually exclusive stage selection in the specified order\\n        if is_nullish(integ_start_finish):\\n            s[\\"integration_not_started\\"].add(project_id)\\n        elif (not is_nullish(integ_start_finish)) and is_nullish(integ_complete):\\n            s[\\"integration_in_progress\\"].add(project_id)\\n        elif (not is_nullish(integ_complete)) and is_nullish(cop_approved):\\n            s[\\"post_integration_cop_pending\\"].add(project_id)\\n        elif (not is_nullish(integ_complete)) and (not is_nullish(cop_approved)) and is_nullish(onair_date):\\n            s[\\"other_post_cop\\"].add(project_id)\\n        else:\\n            # If this happens, it indicates leakage vs the stated stage rules.\\n            # We do not create an extra bucket; caller can detect via sums not matching backlog_count.\\n            pass\\n\\n    out = []\\n    for (rgn_region, m_area, m_market, pj_general_contractor), s in sorted(agg.items()):\\n        backlog_count = len(s[\\"backlog_projects\\"])\\n        not_started = len(s[\\"integration_not_started\\"])\\n        in_progress = len(s[\\"integration_in_progress\\"])\\n        cop_pending = len(s[\\"post_integration_cop_pending\\"])\\n        other_post_cop = len(s[\\"other_post_cop\\"])\\n\\n        out.append({\\n            \\"rgn_region\\": rgn_region,\\n            \\"m_area\\": m_area,\\n            \\"m_market\\": m_market,\\n            \\"pj_general_contractor\\": pj_general_contractor,\\n            \\"backlog_count\\": backlog_count,\\n            \\"backlog_integration_not_started_count\\": not_started,\\n            \\"backlog_integration_in_progress_count\\": in_progress,\\n            \\"backlog_post_integration_cop_pending_count\\": cop_pending,\\n            \\"backlog_other_post_cop_count\\": other_post_cop,\\n            \\"breakdown_sums_to_backlog\\": (not_started + in_progress + cop_pending + other_post_cop) == backlog_count\\n        })\\n\\n    return out\\n", "formula_description": "CX to On-Air Backlog = COUNT(DISTINCT pj_project_id) for projects where construction is complete (ms_1555_construction_complete_actual not null) and On-Air actual date is null (pj_completion_objective_actual_date null), grouped by rgn_region/m_area/m_market/pj_general_contractor, with each backlog project assigned to exactly one blocker stage based on integration start, integration completion, and COP approval milestone null-ness.", "caveats": ["Tier-1 get_project() accessor does not expose the required milestone columns, so this implementation uses raw SQL against public.stg_ndpd_mbt_tmobile_macro_combined (single-table, no joins).", "General contractor is free-text; casing/suffix variations may fragment grouping unless a normalized GC dimension is introduced.", "If milestone fields contain empty-strings instead of NULLs, the function treats empty/whitespace as NULL to reduce misclassification."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "kcctech", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "adcom communication wireless", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "armony construction", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "nwtp solutions", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "sba communications", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "COLUMBUS", "pj_general_contractor": "kcctech", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pj_general_contractor": "meridian networks", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "on air solutions", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:24:22.332387+00:00", "contract": {"function_name": "get_cx_to_on_air_backlog", "node_type": "kpi", "node_id": "a3f0a09c-5a86-4bcd-8d8a-7842e73c5e3e", "node_label": "CX to On-Air Backlog", "description": "Counts projects that have completed construction but have not yet gone On-Air (current snapshot), and breaks the backlog down by the most actionable blocking stage.\\n\\nEntities / joins: Project (stg_ndpd_mbt_tmobile_macro_combined) grouped by rgn_region, m_area, m_market, pj_general_contractor; keyed by pj_project_id.\\n\\nInput columns:\\n- pj_project_id\\n- ms_1555_construction_complete_actual\\n- pj_completion_objective_actual_date\\n- pj_a_5270_integration_start_finish\\n- ms_1970_integration_complete_actual\\n- ms_1559_cop_approved_by_t_mobile_actual\\n- rgn_region, m_area, m_market, pj_general_contractor\\n\\nBacklog population definition:\\n- Backlog projects are those where:\\n  - ms_1555_construction_complete_actual IS NOT NULL\\n  - AND pj_completion_objective_actual_date IS NULL\\n\\nCore outputs (per grouping):\\n- backlog_count = COUNT(DISTINCT pj_project_id) over the backlog population\\n\\nBlocker-stage breakdown outputs (per grouping). Compute as counts over the backlog population using mutually exclusive stage logic, evaluated in this order:\\n1) backlog_integration_not_started_count:\\n   - pj_a_5270_integration_start_finish IS NULL\\n2) backlog_integration_in_progress_count:\\n   - pj_a_5270_integration_start_finish IS NOT NULL\\n   - AND ms_1970_integration_complete_actual IS NULL\\n3) backlog_post_integration_cop_pending_count:\\n   - ms_1970_integration_complete_actual IS NOT NULL\\n   - AND ms_1559_cop_approved_by_t_mobile_actual IS NULL\\n4) backlog_other_post_cop_count (optional catch-all to avoid silent leakage):\\n   - ms_1970_integration_complete_actual IS NOT NULL\\n   - AND ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL\\n   - AND pj_completion_objective_actual_date IS NULL\\n\\nImplementation notes:\\n- Use COUNT(DISTINCT pj_project_id) for all counts.\\n- Ensure the breakdown stage counts sum to backlog_count when the optional catch-all is included.\\n- This is a CURRENT_DATE snapshot metric (no time bucketing).", "parameters": [], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "backlog_count", "type": "number", "nullable": false}, {"name": "backlog_integration_not_started_count", "type": "number", "nullable": false}, {"name": "backlog_integration_in_progress_count", "type": "number", "nullable": false}, {"name": "backlog_post_integration_cop_pending_count", "type": "number", "nullable": false}, {"name": "backlog_other_post_cop_count", "type": "number", "nullable": false}, {"name": "breakdown_sums_to_backlog", "type": "boolean", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "kcctech", "backlog_count": 1, "backlog_integration_not_started_count": 1, "backlog_integration_in_progress_count": 0, "backlog_post_integration_cop_pending_count": 0, "backlog_other_post_cop_count": 0, "breakdown_sums_to_backlog": true}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'a9310885-be13-4778-bc99-7ead870d99ee', name: 'a9310885-be13-4778-bc99-7ead870d99ee', label: 'CX to On-Air Backlog', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "KPI = per (rgn_region, m_area, m_market, pj_general_contractor) counts of DISTINCT pj_project_id where construction is complete (ms_1555_construction_complete_actual not null) and On-Air is not complete (pj_completion_objective_actual_date null), with additional columns splitting that backlog into mutually exclusive blocker-stage buckets based on integration start, integration complete, and COP approval milestone null/not-null status."}', nl_description: 'KPI = per (rgn_region, m_area, m_market, pj_general_contractor) counts of DISTINCT pj_project_id where construction is complete (ms_1555_construction_complete_actual not null) and On-Air is not complete (pj_completion_objective_actual_date null), with additional columns splitting that backlog into mutually exclusive blocker-stage buckets based on integration start, integration complete, and COP approval milestone null/not-null status.', nl_business_rule: '', kpi_json: '{"kpi_id": "a9310885-be13-4778-bc99-7ead870d99ee", "name": "CX to On-Air Backlog", "description": "Counts projects where construction is complete but the site is not yet On-Air, as a CURRENT_DATE snapshot, and breaks the backlog into blocker-stage columns (wide output). Base backlog population per group (rgn_region, m_area, m_market, pj_general_contractor): DISTINCT pj_project_id where ms_1555_construction_complete_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Output columns per group must include: (1) total_cx_complete_not_on_air = count distinct projects in base population; (2) pending_integration_start = count distinct projects in base population where pj_a_5270_integration_start_finish IS NULL; (3) pending_integration_complete = count distinct projects where pj_a_5270_integration_start_finish IS NOT NULL AND ms_1970_integration_complete_actual IS NULL; (4) pending_cop_approval = count distinct projects where ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NULL; (5) pending_other = count distinct projects where ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Ensure these are additional columns on the same group row (no pivot required). Source table: stg_ndpd_mbt_tmobile_macro_combined; main entity: Project (pj_project_id) with group-by attributes from same table.", "related_core_node_ids": ["project"], "relationship_type": "AGGREGATES", "python_function": "def get_cx_to_on_air_backlog(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"CX to On-Air Backlog (CURRENT_DATE snapshot).\\n\\n    Base population per group:\\n      DISTINCT pj_project_id\\n      where ms_1555_construction_complete_actual IS NOT NULL\\n        AND pj_completion_objective_actual_date IS NULL\\n\\n    Output columns per group:\\n      - total_cx_complete_not_on_air\\n      - pending_integration_start\\n      - pending_integration_complete\\n      - pending_cop_approval\\n      - pending_other\\n\\n    Note: Uses raw SQL because required milestone columns are not exposed by Tier-1 accessors.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    def _sql_str(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Build optional WHERE predicates.\\n    # We filter on the same table; allow common grouping filters and project identifiers.\\n    allowed_filters = {\\n        \\"rgn_region\\": \\"rgn_region\\",\\n        \\"m_area\\": \\"m_area\\",\\n        \\"m_market\\": \\"m_market\\",\\n        \\"pj_general_contractor\\": \\"pj_general_contractor\\",\\n        \\"pj_project_id\\": \\"pj_project_id\\",\\n        \\"s_site_id\\": \\"s_site_id\\"\\n    }\\n\\n    where_parts = []\\n\\n    # Optional snapshot-as-of filter: treat the milestone dates as occurring on/before end_date.\\n    # If end_date not supplied, we leave as a CURRENT state check (NULL vs NOT NULL).\\n    end_date = filters.get(\\"end_date\\")\\n    if end_date:\\n        ed = _sql_str(end_date)\\n        where_parts.append(f\\"ms_1555_construction_complete_actual::date <= \'{ed}\'::date\\")\\n        # If a project has On-Air date after snapshot, it should still be in backlog at snapshot.\\n        where_parts.append(f\\"(pj_completion_objective_actual_date IS NULL OR pj_completion_objective_actual_date::date > \'{ed}\'::date)\\")\\n\\n    # Add simple equality filters\\n    for k, col in allowed_filters.items():\\n        if k in filters and filters[k] is not None and filters[k] != \\"\\":\\n            where_parts.append(f\\"{col} = \'{_sql_str(filters[k])}\'\\")\\n\\n    where_sql = (\\"WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    sql = f\\"\\"\\"\\n    SELECT\\n      rgn_region,\\n      m_area,\\n      m_market,\\n      pj_general_contractor,\\n\\n      COUNT(DISTINCT CASE\\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\\n         AND pj_completion_objective_actual_date IS NULL\\n        THEN pj_project_id END\\n      ) AS total_cx_complete_not_on_air,\\n\\n      COUNT(DISTINCT CASE\\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\\n         AND pj_completion_objective_actual_date IS NULL\\n         AND pj_a_5270_integration_start_finish IS NULL\\n        THEN pj_project_id END\\n      ) AS pending_integration_start,\\n\\n      COUNT(DISTINCT CASE\\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\\n         AND pj_completion_objective_actual_date IS NULL\\n         AND pj_a_5270_integration_start_finish IS NOT NULL\\n         AND ms_1970_integration_complete_actual IS NULL\\n        THEN pj_project_id END\\n      ) AS pending_integration_complete,\\n\\n      COUNT(DISTINCT CASE\\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\\n         AND pj_completion_objective_actual_date IS NULL\\n         AND ms_1970_integration_complete_actual IS NOT NULL\\n         AND ms_1559_cop_approved_by_t_mobile_actual IS NULL\\n        THEN pj_project_id END\\n      ) AS pending_cop_approval,\\n\\n      COUNT(DISTINCT CASE\\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\\n         AND pj_completion_objective_actual_date IS NULL\\n         AND ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL\\n        THEN pj_project_id END\\n      ) AS pending_other\\n\\n    FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n    {where_sql}\\n    GROUP BY rgn_region, m_area, m_market, pj_general_contractor\\n    ORDER BY rgn_region, m_area, m_market, pj_general_contractor\\n    \\"\\"\\"\\n\\n    return execute_query(sql)\\n", "formula_description": "KPI = per (rgn_region, m_area, m_market, pj_general_contractor) counts of DISTINCT pj_project_id where construction is complete (ms_1555_construction_complete_actual not null) and On-Air is not complete (pj_completion_objective_actual_date null), with additional columns splitting that backlog into mutually exclusive blocker-stage buckets based on integration start, integration complete, and COP approval milestone null/not-null status.", "caveats": ["Tier-1 accessors for Project do not expose the milestone/date columns needed (ms_1555_construction_complete_actual, pj_completion_objective_actual_date, pj_a_5270_integration_start_finish, ms_1970_integration_complete_actual, ms_1559_cop_approved_by_t_mobile_actual), so raw SQL is used.", "If there are multiple rows per pj_project_id in stg_ndpd_mbt_tmobile_macro_combined (despite the implied 1:1), DISTINCT counting mitigates double-counting but grouping attributes could vary across duplicates and affect attribution.", "Snapshot-as-of behavior is only applied when filters[\'end_date\'] is provided; otherwise the KPI is computed as a current-state NULL/not-NULL snapshot."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "allied tower services", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "apex tower solutions", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "armony construction", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "clearpath telecom", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "ews group", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "hampton enterprises", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "total_cx_complete_not_on_air": 1, "pending_integration_start": 1, "pending_integration_complete": 0, "pending_cop_approval": 1, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "kcctech", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "total_cx_complete_not_on_air": 1, "pending_integration_start": 1, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "nextgen infrastructure", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}]}, "conversation_history": [], "approved_by": "user", "approved_at": "2026-03-07T10:25:52.980246+00:00", "contract": {"function_name": "get_cx_to_on_air_backlog", "node_type": "kpi", "node_id": "a9310885-be13-4778-bc99-7ead870d99ee", "node_label": "CX to On-Air Backlog", "description": "Counts projects where construction is complete but the site is not yet On-Air, as a CURRENT_DATE snapshot, and breaks the backlog into blocker-stage columns (wide output). Base backlog population per group (rgn_region, m_area, m_market, pj_general_contractor): DISTINCT pj_project_id where ms_1555_construction_complete_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Output columns per group must include: (1) total_cx_complete_not_on_air = count distinct projects in base population; (2) pending_integration_start = count distinct projects in base population where pj_a_5270_integration_start_finish IS NULL; (3) pending_integration_complete = count distinct projects where pj_a_5270_integration_start_finish IS NOT NULL AND ms_1970_integration_complete_actual IS NULL; (4) pending_cop_approval = count distinct projects where ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NULL; (5) pending_other = count distinct projects where ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Ensure these are additional columns on the same group row (no pivot required). Source table: stg_ndpd_mbt_tmobile_macro_combined; main entity: Project (pj_project_id) with group-by attributes from same table.", "parameters": [{"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "total_cx_complete_not_on_air", "type": "number", "nullable": false}, {"name": "pending_integration_start", "type": "number", "nullable": false}, {"name": "pending_integration_complete", "type": "number", "nullable": false}, {"name": "pending_cop_approval", "type": "number", "nullable": false}, {"name": "pending_other", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "allied tower services", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "apex tower solutions", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "armony construction", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: '313756f8-da42-470a-998f-dc558b1940f3', name: '313756f8-da42-470a-998f-dc558b1940f3', label: 'HSE Daily Compliance Rate', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant."}', nl_description: 'HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.', nl_business_rule: '', kpi_json: '{"kpi_id": "313756f8-da42-470a-998f-dc558b1940f3", "name": "HSE Daily Compliance Rate", "description": "Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. Grain: one row per (region, market, gc_name, gsd_hse_review_check_date). Source table: stg_ndpd_hse_site_checklist. \\n\\nDenominator (attempted reviews): COUNT(DISTINCT site_id) where gsd_hse_review_check_date IS NOT NULL AND check_in_status IS NOT NULL (i.e., an HSE review attempt exists for that site-day).\\n\\nNumerator (fully compliant): COUNT(DISTINCT site_id) where check_in_status IN (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\\n\\nRate: 100.0 * numerator / NULLIF(denominator, 0).\\n\\nInclude additional output columns (wide-format) for actionable diagnosis on the same row: \\n- attempted_reviews (denominator)\\n- compliant_reviews (numerator)\\n- compliance_rate_pct\\n- fail_check_in_count: COUNT(DISTINCT site_id) among attempted reviews where check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL\\n- fail_ppe_count: COUNT(DISTINCT site_id) among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'\\n- fail_jsa_count: COUNT(DISTINCT site_id) among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'\\n- fail_ptid_i2w_count: COUNT(DISTINCT site_id) among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'\\n- any_non_compliant_count: COUNT(DISTINCT site_id) among attempted reviews where NOT(all 4 gates pass)\\n\\nNotes/handling: Use DISTINCT site_id to avoid multiple checklist rows per site-day double counting. Use the table\\u2019s region/market/gc_name columns for grouping; optionally also surface hse_status and/or non_compliance_status as reference fields (not part of the rate unless you request it). If you later switch to stg_tmo_hse_daily_tracker_v0_1, preserve the same logic but map date to review_date and use compliance_status/escalation columns for additional breakdown KPIs.", "related_core_node_ids": ["customer"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_hse_daily_compliance_rate(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"Grain: one row per (region, market, gc_name, gsd_hse_review_check_date::date).\\n\\n    Computes attempted vs compliant distinct sites and failure-gate distinct-site counts.\\n    \\"\\"\\"\\n\\n    def _esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Build WHERE clause (PostgreSQL)\\n    where_parts = []\\n\\n    # Date filtering: apply to gsd_hse_review_check_date\\n    if filters:\\n        start_date = filters.get(\\"start_date\\")\\n        end_date = filters.get(\\"end_date\\")\\n        if start_date:\\n            where_parts.append(f\\"gsd_hse_review_check_date >= \'{_esc(start_date)}\'\\")\\n        if end_date:\\n            where_parts.append(\\n                f\\"gsd_hse_review_check_date < (\'{_esc(end_date)}\'::date + interval \'1 day\')\\"\\n            )\\n\\n        # Optional dimension filters (only if provided)\\n        for k in [\\n            \\"region\\",\\n            \\"market\\",\\n            \\"gc_name\\",\\n            \\"site_id\\",\\n            \\"customer_name\\",\\n            \\"hse_status\\",\\n            \\"non_compliance_status\\",\\n            \\"hse_engineer_name\\",\\n            \\"smp_id\\",\\n            \\"smp_name\\",\\n        ]:\\n            if k in filters and filters.get(k) is not None and filters.get(k) != \\"\\":\\n                where_parts.append(f\\"{k} = \'{_esc(filters.get(k))}\'\\")\\n\\n    where_parts.append(\\"gsd_hse_review_check_date IS NOT NULL\\")\\n\\n    where_sql = \\"\\"\\n    if where_parts:\\n        where_sql = \\"WHERE \\" + \\" AND \\".join(where_parts)\\n\\n    # NOTE: \\"each_crew_ptid_I2w_status\\" is a physically-cased column name; must be double-quoted in Postgres.\\n    sql = f\\"\\"\\"\\n        SELECT\\n            region,\\n            market,\\n            gc_name,\\n            (gsd_hse_review_check_date::date) AS gsd_hse_review_check_date,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                THEN site_id\\n            END) AS attempted_reviews,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND check_in_status IN (\'Done\',\'Checked In\')\\n                 AND ppe_validation = \'Pass\'\\n                 AND jsa_completion_status = \'Completed\'\\n                 AND \\"each_crew_ptid_I2w_status\\" = \'Available\'\\n                THEN site_id\\n            END) AS compliant_reviews,\\n\\n            (100.0 *\\n                COUNT(DISTINCT CASE\\n                    WHEN gsd_hse_review_check_date IS NOT NULL\\n                     AND check_in_status IS NOT NULL\\n                     AND check_in_status IN (\'Done\',\'Checked In\')\\n                     AND ppe_validation = \'Pass\'\\n                     AND jsa_completion_status = \'Completed\'\\n                     AND \\"each_crew_ptid_I2w_status\\" = \'Available\'\\n                    THEN site_id\\n                END)\\n             / NULLIF(\\n                COUNT(DISTINCT CASE\\n                    WHEN gsd_hse_review_check_date IS NOT NULL\\n                     AND check_in_status IS NOT NULL\\n                    THEN site_id\\n                END)\\n             , 0)\\n            ) AS compliance_rate_pct,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND (check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL)\\n                THEN site_id\\n            END) AS fail_check_in_count,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND (ppe_validation IS DISTINCT FROM \'Pass\')\\n                THEN site_id\\n            END) AS fail_ppe_count,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND (jsa_completion_status IS DISTINCT FROM \'Completed\')\\n                THEN site_id\\n            END) AS fail_jsa_count,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND (\\"each_crew_ptid_I2w_status\\" IS DISTINCT FROM \'Available\')\\n                THEN site_id\\n            END) AS fail_ptid_i2w_count,\\n\\n            COUNT(DISTINCT CASE\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\n                 AND check_in_status IS NOT NULL\\n                 AND NOT (\\n                    check_in_status IN (\'Done\',\'Checked In\')\\n                    AND ppe_validation = \'Pass\'\\n                    AND jsa_completion_status = \'Completed\'\\n                    AND \\"each_crew_ptid_I2w_status\\" = \'Available\'\\n                 )\\n                THEN site_id\\n            END) AS any_non_compliant_count\\n\\n        FROM public.stg_ndpd_hse_site_checklist\\n        {where_sql}\\n        GROUP BY\\n            region,\\n            market,\\n            gc_name,\\n            (gsd_hse_review_check_date::date)\\n        ORDER BY\\n            region,\\n            market,\\n            gc_name,\\n            (gsd_hse_review_check_date::date)\\n    \\"\\"\\"\\n\\n    return execute_query(sql, db=\\"public\\")\\n", "formula_description": "HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.", "caveats": ["Uses raw SQL (PostgreSQL) to correctly apply COUNT(DISTINCT ...) aggregations and IS DISTINCT FROM semantics for NULL-safe gate failures.", "Grain uses gsd_hse_review_check_date::date; if business expects timestamp-level grain, remove the ::date cast.", "Denominator excludes rows with check_in_status NULL per requirement; fail_check_in_count therefore counts only attempted reviews (check_in_status NOT NULL) and will typically be 0 unless non-standard values exist.", "Function execution warning: Runtime error: (psycopg2.errors.UndefinedColumn) column \\"each_crew_ptid_i2w_status\\" does not exist\\nLINE 20:                  AND each_crew_ptid_I2w_status = \'Available\'\\n                              ^\\nHINT:  Perhaps you meant to reference the column \\"stg_ndpd_hse_site_checklist.each_crew_ptid_I2w_status\\".\\n\\n[SQL: \\n"], "evidence": {"sample_data": [{"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2024-10-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2025-03-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "EWS Group", "gsd_hse_review_check_date": "2024-10-27", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "EWS Group", "gsd_hse_review_check_date": "2024-12-27", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "NWTP Solutions", "gsd_hse_review_check_date": "2024-11-22", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 1, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "PM Communications", "gsd_hse_review_check_date": "2025-05-29", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "UCI", "gsd_hse_review_check_date": "2025-06-14", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 1, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Cincinnati", "gc_name": "Allied Tower Services", "gsd_hse_review_check_date": "2025-03-24", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Cincinnati", "gc_name": "ClearPath Telecom", "gsd_hse_review_check_date": "2025-08-17", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Cincinnati", "gc_name": "On Air Solutions", "gsd_hse_review_check_date": "2025-06-21", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 1, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}]}, "conversation_history": [{"role": "user", "content": "Don\'t confirm yet \\u2014 column name case sensitivity issue. The error says:\\n\\n> column \\"each_crew_ptid_i2w_status\\" does not exist ... HINT: Perhaps you meant to reference the column \\"stg_ndpd_hse_site_checklist.each_crew_ptid_I2w_status\\"\\n\\nThe column has a capital `I` in `I2w`. Postgres lowercases unquoted identifiers, so `each_crew_ptid_I2w_status` in the SQL becomes `each_crew_ptid_i2w_status` which doesn\'t match the physical column `each_crew_ptid_I2w_status`.\\n\\nTell the system to double-quote this column everywhere it appears:\\n\\n`\\"each_crew_ptid_I2w_status\\"`\\n\\nSo every reference like:\\n```sql\\nAND each_crew_ptid_I2w_status = \'Available\'\\n```\\nbecomes:\\n```sql\\nAND \\"each_crew_ptid_I2w_status\\" = \'Available\'\\n```\\n\\nSame fix needed in all 3 places it appears in the SQL (compliant_reviews, fail_ptid_i2w_count, and any_non_compliant_count CASE expressions). The logic itself is correct \\u2014 just a quoting fix. Retry."}, {"role": "assistant", "content": "<updates>\\n{\\n  \\"python_function\\": \\"def get_hse_daily_compliance_rate(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"Grain: one row per (region, market, gc_name, gsd_hse_review_check_date::date).\\\\n\\\\n    Computes attempted vs compliant distinct sites and failure-gate distinct-site counts.\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    def _esc(v):\\\\n        return str(v).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n\\\\n    # Build WHERE clause (PostgreSQL)\\\\n    where_parts = []\\\\n\\\\n    # Date filtering: apply to gsd_hse_review_check_date\\\\n    if filters:\\\\n        start_date = filters.get(\\\\\\"start_date\\\\\\")\\\\n        end_date = filters.get(\\\\\\"end_date\\\\\\")\\\\n        if start_date:\\\\n            where_parts.append(f\\\\\\"gsd_hse_review_check_date >= \'{_esc(start_date)}\'\\\\\\")\\\\n        if end_date:\\\\n            where_parts.append(\\\\n                f\\\\\\"gsd_hse_review_check_date < (\'{_esc(end_date)}\'::date + interval \'1 day\')\\\\\\"\\\\n            )\\\\n\\\\n        # Optional dimension filters (only if provided)\\\\n        for k in [\\\\n            \\\\\\"region\\\\\\",\\\\n            \\\\\\"market\\\\\\",\\\\n            \\\\\\"gc_name\\\\\\",\\\\n            \\\\\\"site_id\\\\\\",\\\\n            \\\\\\"customer_name\\\\\\",\\\\n            \\\\\\"hse_status\\\\\\",\\\\n            \\\\\\"non_compliance_status\\\\\\",\\\\n            \\\\\\"hse_engineer_name\\\\\\",\\\\n            \\\\\\"smp_id\\\\\\",\\\\n            \\\\\\"smp_name\\\\\\",\\\\n        ]:\\\\n            if k in filters and filters.get(k) is not None and filters.get(k) != \\\\\\"\\\\\\":\\\\n                where_parts.append(f\\\\\\"{k} = \'{_esc(filters.get(k))}\'\\\\\\")\\\\n\\\\n    where_parts.append(\\\\\\"gsd_hse_review_check_date IS NOT NULL\\\\\\")\\\\n\\\\n    where_sql = \\\\\\"\\\\\\"\\\\n    if where_parts:\\\\n        where_sql = \\\\\\"WHERE \\\\\\" + \\\\\\" AND \\\\\\".join(where_parts)\\\\n\\\\n    # NOTE: \\\\\\"each_crew_ptid_I2w_status\\\\\\" is a physically-cased column name; must be double-quoted in Postgres.\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n        SELECT\\\\n            region,\\\\n            market,\\\\n            gc_name,\\\\n            (gsd_hse_review_check_date::date) AS gsd_hse_review_check_date,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                THEN site_id\\\\n            END) AS attempted_reviews,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND check_in_status IN (\'Done\',\'Checked In\')\\\\n                 AND ppe_validation = \'Pass\'\\\\n                 AND jsa_completion_status = \'Completed\'\\\\n                 AND \\\\\\"each_crew_ptid_I2w_status\\\\\\" = \'Available\'\\\\n                THEN site_id\\\\n            END) AS compliant_reviews,\\\\n\\\\n            (100.0 *\\\\n                COUNT(DISTINCT CASE\\\\n                    WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                     AND check_in_status IS NOT NULL\\\\n                     AND check_in_status IN (\'Done\',\'Checked In\')\\\\n                     AND ppe_validation = \'Pass\'\\\\n                     AND jsa_completion_status = \'Completed\'\\\\n                     AND \\\\\\"each_crew_ptid_I2w_status\\\\\\" = \'Available\'\\\\n                    THEN site_id\\\\n                END)\\\\n             / NULLIF(\\\\n                COUNT(DISTINCT CASE\\\\n                    WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                     AND check_in_status IS NOT NULL\\\\n                    THEN site_id\\\\n                END)\\\\n             , 0)\\\\n            ) AS compliance_rate_pct,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND (check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL)\\\\n                THEN site_id\\\\n            END) AS fail_check_in_count,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND (ppe_validation IS DISTINCT FROM \'Pass\')\\\\n                THEN site_id\\\\n            END) AS fail_ppe_count,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND (jsa_completion_status IS DISTINCT FROM \'Completed\')\\\\n                THEN site_id\\\\n            END) AS fail_jsa_count,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND (\\\\\\"each_crew_ptid_I2w_status\\\\\\" IS DISTINCT FROM \'Available\')\\\\n                THEN site_id\\\\n            END) AS fail_ptid_i2w_count,\\\\n\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN gsd_hse_review_check_date IS NOT NULL\\\\n                 AND check_in_status IS NOT NULL\\\\n                 AND NOT (\\\\n                    check_in_status IN (\'Done\',\'Checked In\')\\\\n                    AND ppe_validation = \'Pass\'\\\\n                    AND jsa_completion_status = \'Completed\'\\\\n                    AND \\\\\\"each_crew_ptid_I2w_status\\\\\\" = \'Available\'\\\\n                 )\\\\n                THEN site_id\\\\n            END) AS any_non_compliant_count\\\\n\\\\n        FROM public.stg_ndpd_hse_site_checklist\\\\n        {where_sql}\\\\n        GROUP BY\\\\n            region,\\\\n            market,\\\\n            gc_name,\\\\n            (gsd_hse_review_check_date::date)\\\\n        ORDER BY\\\\n            region,\\\\n            market,\\\\n            gc_name,\\\\n            (gsd_hse_review_check_date::date)\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    return execute_query(sql, db=\\\\\\"public\\\\\\")\\\\n\\"\\n}\\n</updates>"}], "approved_by": "user", "approved_at": "2026-03-07T10:30:21.999514+00:00", "contract": {"function_name": "get_hse_daily_compliance_rate", "node_type": "kpi", "node_id": "313756f8-da42-470a-998f-dc558b1940f3", "node_label": "HSE Daily Compliance Rate", "description": "Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. Grain: one row per (region, market, gc_name, gsd_hse_review_check_date). Source table: stg_ndpd_hse_site_checklist. \\n\\nDenominator (attempted reviews): COUNT(DISTINCT site_id) where gsd_hse_review_check_date IS NOT NULL AND check_in_status IS NOT NULL (i.e., an HSE review attempt exists for that site-day).\\n\\nNumerator (fully compliant): COUNT(DISTINCT site_id) where check_in_status IN (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\\n\\nRate: 100.0 * numerator / NULLIF(denominator, 0).\\n\\nInclude additional output columns (wide-format) for actionable diagnosis on the same row: \\n- attempted_reviews (denominator)\\n- compliant_reviews (numerator)\\n- compliance_rate_pct\\n- fail_check_in_count: COUNT(DISTINCT site_id) among attempted reviews where check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL\\n- fail_ppe_count: COUNT(DISTINCT site_id) among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'\\n- fail_jsa_count: COUNT(DISTINCT site_id) among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'\\n- fail_ptid_i2w_count: COUNT(DISTINCT site_id) among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'\\n- any_non_compliant_count: COUNT(DISTINCT site_id) among attempted reviews where NOT(all 4 gates pass)\\n\\nNotes/handling: Use DISTINCT site_id to avoid multiple checklist rows per site-day double counting. Use the table\\u2019s region/market/gc_name columns for grouping; optionally also surface hse_status and/or non_compliance_status as reference fields (not part of the rate unless you request it). If you later switch to stg_tmo_hse_daily_tracker_v0_1, preserve the same logic but map date to review_date and use compliance_status/escalation columns for additional breakdown KPIs.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "region", "type": "string", "nullable": false}, {"name": "market", "type": "string", "nullable": false}, {"name": "gc_name", "type": "string", "nullable": false}, {"name": "gsd_hse_review_check_date", "type": "date", "nullable": false}, {"name": "attempted_reviews", "type": "number", "nullable": false}, {"name": "compliant_reviews", "type": "number", "nullable": false}, {"name": "compliance_rate_pct", "type": "string", "nullable": false}, {"name": "fail_check_in_count", "type": "number", "nullable": false}, {"name": "fail_ppe_count", "type": "number", "nullable": false}, {"name": "fail_jsa_count", "type": "number", "nullable": false}, {"name": "fail_ptid_i2w_count", "type": "number", "nullable": false}, {"name": "any_non_compliant_count", "type": "number", "nullable": false}], "sample_output": [{"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2024-10-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2025-03-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "EWS Group", "gsd_hse_review_check_date": "2024-10-27", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}], "row_count": 10}}'});
CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'f44a788a-0aab-4a97-b60e-38a9d43063af', name: 'f44a788a-0aab-4a97-b60e-38a9d43063af', label: 'NDPc Quality FTR Rate', node_type: 'CORE', entity_type: 'kpi', status: 'mentioned', details_json: '{"definition": "FTR Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null and NULLIF(TRIM(first_time_right),\'\')=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null),0), grouped by region/area/market/GC (optionally por_category and s_site_class)."}', nl_description: 'FTR Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null and NULLIF(TRIM(first_time_right),\'\')=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null),0), grouped by region/area/market/GC (optionally por_category and s_site_class).', nl_business_rule: '', kpi_json: '{"kpi_id": "f44a788a-0aab-4a97-b60e-38a9d43063af", "name": "NDPc Quality FTR Rate", "description": "Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. Data source: stg_ndpd_mbt_tmobile_macro_combined. Denominator = COUNT(DISTINCT pj_project_id) for rows where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL (quality audit completed, reached the gate), regardless of first_time_right value. Numerator = COUNT(DISTINCT pj_project_id) where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL AND first_time_right is explicitly \'Yes\' (apply TRIM and treat blank as NULL via NULLIF(TRIM(first_time_right),\'\'); do not attempt to enumerate non-Yes values; all non-Yes/NULL are excluded from numerator but remain in denominator if MS1556 is present). FTR Rate (%) = 100.0 * numerator / NULLIF(denominator,0). Output should include: ftr_rate_pct, ftr_yes_count (numerator), audited_count (denominator), and optionally not_ftr_or_unknown_count = audited_count - ftr_yes_count. Group by rgn_region, m_area, m_market, pj_general_contractor; optionally extend grouping with por_category and s_site_class for segmentation.", "related_core_node_ids": ["project"], "relationship_type": "COMPUTES_FROM", "python_function": "def get_ndpc_quality_ftr_rate(execute_query, filters=None) -> list[dict]:\\n    \\"\\"\\"NDPc Quality FTR Rate (%): audited projects that are First Time Right / audited projects.\\n\\n    Denominator: DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL.\\n    Numerator: DISTINCT pj_project_id where ms_1556... IS NOT NULL AND NULLIF(TRIM(first_time_right),\'\') = \'Yes\'.\\n\\n    Output grouped by (default): rgn_region, m_area, m_market, pj_general_contractor.\\n    Optional extra segmentation: por_category, s_site_class when filters[\'group_by\'] includes them.\\n    \\"\\"\\"\\n\\n    filters = filters or {}\\n\\n    # ---- grouping ----\\n    default_group = [\\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\"]\\n    allowed_optional = {\\"por_category\\", \\"s_site_class\\"}\\n\\n    group_by = filters.get(\\"group_by\\")\\n    if group_by is None:\\n        group_cols = list(default_group)\\n    else:\\n        if isinstance(group_by, str):\\n            group_by = [g.strip() for g in group_by.split(\\",\\") if g.strip()]\\n        group_cols = []\\n        for g in group_by:\\n            if g in default_group or g in allowed_optional:\\n                if g not in group_cols:\\n                    group_cols.append(g)\\n        if not group_cols:\\n            group_cols = list(default_group)\\n\\n    # ---- WHERE clause from filters ----\\n    # Only apply filters that are known/used for slicing this KPI.\\n    where_parts = []\\n\\n    def esc(v):\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    # Base filter: only audited rows (avoids zero-audit noise groups)\\n    where_parts.append(\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\")\\n\\n    # Date range applies to the Nokia audit completion timestamp\\n    start_date = filters.get(\\"start_date\\")\\n    end_date = filters.get(\\"end_date\\")\\n    if start_date:\\n        where_parts.append(\\n            f\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual >= \'{esc(start_date)}\'\\"\\n        )\\n    if end_date:\\n        where_parts.append(\\n            f\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual <= \'{esc(end_date)}\'\\"\\n        )\\n\\n    # Common dimensional filters\\n    for k in [\\n        \\"rgn_region\\",\\n        \\"m_area\\",\\n        \\"m_market\\",\\n        \\"pj_general_contractor\\",\\n        \\"pj_project_id\\",\\n        \\"por_category\\",\\n        \\"s_site_class\\",\\n    ]:\\n        if filters.get(k) is not None and filters.get(k) != \\"\\":\\n            where_parts.append(f\\"{k} = \'{esc(filters.get(k))}\'\\")\\n\\n    where_sql = (\\"WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    # ---- raw SQL (needed because we must reference ms_1556... and first_time_right columns not exposed by Tier-1 accessors) ----\\n    group_sql = \\", \\".join(group_cols)\\n    select_group_sql = (group_sql + \\", \\") if group_cols else \\"\\"\\n\\n    sql = f\\"\\"\\"\\n        SELECT\\n            {select_group_sql}\\n            COUNT(DISTINCT CASE\\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\n                THEN pj_project_id\\n                ELSE NULL\\n            END) AS audited_count,\\n            COUNT(DISTINCT CASE\\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\n                 AND NULLIF(TRIM(first_time_right), \'\') = \'Yes\'\\n                THEN pj_project_id\\n                ELSE NULL\\n            END) AS ftr_yes_count\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\n        {where_sql}\\n        GROUP BY {group_sql}\\n        ORDER BY {group_sql}\\n    \\"\\"\\"\\n\\n    rows = execute_query(sql, db=None, max_rows=None) or []\\n\\n    out = []\\n    for r in rows:\\n        audited = r.get(\\"audited_count\\") or 0\\n        ftr_yes = r.get(\\"ftr_yes_count\\") or 0\\n        not_ftr_or_unknown = audited - ftr_yes\\n        ftr_rate_pct = (100.0 * ftr_yes / audited) if audited else None\\n\\n        rec = {c: r.get(c) for c in group_cols}\\n        rec.update(\\n            {\\n                \\"audited_count\\": audited,\\n                \\"ftr_yes_count\\": ftr_yes,\\n                \\"not_ftr_or_unknown_count\\": not_ftr_or_unknown,\\n                \\"ftr_rate_pct\\": ftr_rate_pct,\\n            }\\n        )\\n        out.append(rec)\\n\\n    return out\\n", "formula_description": "FTR Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null and NULLIF(TRIM(first_time_right),\'\')=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null),0), grouped by region/area/market/GC (optionally por_category and s_site_class).", "caveats": ["This KPI requires columns (ms_1556_punch_checklist_audit_completed_by_nokia_actual, first_time_right, rgn_region, por_category, s_site_class) that are not exposed by the Tier-1 accessors shown, so raw SQL against the base table is used.", "pj_general_contractor is free-text and may not be normalized; casing/suffix differences can split counts across multiple GC labels.", "If first_time_right contains values like \' YES \' they will be counted due to TRIM, but case variants like \'yes\' will NOT be counted unless the source uses exact \'Yes\' as specified."], "evidence": {"sample_data": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "clearpath telecom", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "omni-tech", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "on air solutions", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "sba communications", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "telcom construction", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "towerco", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "uci", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "adcom communication wireless", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}]}, "conversation_history": [{"role": "user", "content": "Implementation logic is correct. Confirm it, but suggest one refinement: add ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL to the base WHERE clause (not just inside the CASE). Right now the query scans all rows and groups GCs that have zero audits, producing noise rows with audited_count = 0 and null FTR rate. Adding the base filter will eliminate those empty rows and make the output cleaner. Not a blocker \\u2014 the math is right either way.\\nThe sample showing 0% FTR for the GCs that do have audits is worth noting to the business \\u2014 either the first_time_right column is sparsely populated (mostly NULL/blank), or quality really is that low in those markets. A quick SELECT first_time_right, COUNT(*) FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1556... IS NOT NULL GROUP BY 1 would tell you which."}, {"role": "assistant", "content": "You\\u2019re right: the current math is correct either way because the denominator/numerator both gate on `ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL` inside the `COUNT(DISTINCT CASE ...)`.  \\n\\nRefinement suggestion is also correct: adding `ms_1556... IS NOT NULL` to the base `WHERE` will (a) avoid scanning/grouping non-audited rows, and (b) prevent \\u201cnoise\\u201d groups that only exist due to non-audited records and end up with `audited_count = 0` and `ftr_rate_pct = NULL`.\\n\\nBelow is the minimal code change: inject that predicate into `where_parts` unconditionally so it always applies, while keeping the optional date range filters (which now become additional constraints on already-audited rows).\\n\\n<updates>\\n{\\n  \\"python_function\\": \\"def get_ndpc_quality_ftr_rate(execute_query, filters=None) -> list[dict]:\\\\n    \\\\\\"\\\\\\"\\\\\\"NDPc Quality FTR Rate (%): audited projects that are First Time Right / audited projects.\\\\n\\\\n    Denominator: DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL.\\\\n    Numerator: DISTINCT pj_project_id where ms_1556... IS NOT NULL AND NULLIF(TRIM(first_time_right),\'\') = \'Yes\'.\\\\n\\\\n    Output grouped by (default): rgn_region, m_area, m_market, pj_general_contractor.\\\\n    Optional extra segmentation: por_category, s_site_class when filters[\'group_by\'] includes them.\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    filters = filters or {}\\\\n\\\\n    # ---- grouping ----\\\\n    default_group = [\\\\\\"rgn_region\\\\\\", \\\\\\"m_area\\\\\\", \\\\\\"m_market\\\\\\", \\\\\\"pj_general_contractor\\\\\\"]\\\\n    allowed_optional = {\\\\\\"por_category\\\\\\", \\\\\\"s_site_class\\\\\\"}\\\\n\\\\n    group_by = filters.get(\\\\\\"group_by\\\\\\")\\\\n    if group_by is None:\\\\n        group_cols = list(default_group)\\\\n    else:\\\\n        if isinstance(group_by, str):\\\\n            group_by = [g.strip() for g in group_by.split(\\\\\\",\\\\\\") if g.strip()]\\\\n        group_cols = []\\\\n        for g in group_by:\\\\n            if g in default_group or g in allowed_optional:\\\\n                if g not in group_cols:\\\\n                    group_cols.append(g)\\\\n        if not group_cols:\\\\n            group_cols = list(default_group)\\\\n\\\\n    # ---- WHERE clause from filters ----\\\\n    # Only apply filters that are known/used for slicing this KPI.\\\\n    where_parts = []\\\\n\\\\n    def esc(v):\\\\n        return str(v).replace(\\\\\\"\'\\\\\\", \\\\\\"\'\'\\\\\\")\\\\n\\\\n    # Base filter: only audited rows (avoids zero-audit noise groups)\\\\n    where_parts.append(\\\\\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\\\\\")\\\\n\\\\n    # Date range applies to the Nokia audit completion timestamp\\\\n    start_date = filters.get(\\\\\\"start_date\\\\\\")\\\\n    end_date = filters.get(\\\\\\"end_date\\\\\\")\\\\n    if start_date:\\\\n        where_parts.append(\\\\n            f\\\\\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual >= \'{esc(start_date)}\'\\\\\\"\\\\n        )\\\\n    if end_date:\\\\n        where_parts.append(\\\\n            f\\\\\\"ms_1556_punch_checklist_audit_completed_by_nokia_actual <= \'{esc(end_date)}\'\\\\\\"\\\\n        )\\\\n\\\\n    # Common dimensional filters\\\\n    for k in [\\\\n        \\\\\\"rgn_region\\\\\\",\\\\n        \\\\\\"m_area\\\\\\",\\\\n        \\\\\\"m_market\\\\\\",\\\\n        \\\\\\"pj_general_contractor\\\\\\",\\\\n        \\\\\\"pj_project_id\\\\\\",\\\\n        \\\\\\"por_category\\\\\\",\\\\n        \\\\\\"s_site_class\\\\\\",\\\\n    ]:\\\\n        if filters.get(k) is not None and filters.get(k) != \\\\\\"\\\\\\":\\\\n            where_parts.append(f\\\\\\"{k} = \'{esc(filters.get(k))}\'\\\\\\")\\\\n\\\\n    where_sql = (\\\\\\"WHERE \\\\\\" + \\\\\\" AND \\\\\\".join(where_parts)) if where_parts else \\\\\\"\\\\\\"\\\\n\\\\n    # ---- raw SQL (needed because we must reference ms_1556... and first_time_right columns not exposed by Tier-1 accessors) ----\\\\n    group_sql = \\\\\\", \\\\\\".join(group_cols)\\\\n    select_group_sql = (group_sql + \\\\\\", \\\\\\") if group_cols else \\\\\\"\\\\\\"\\\\n\\\\n    sql = f\\\\\\"\\\\\\"\\\\\\"\\\\n        SELECT\\\\n            {select_group_sql}\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\\\n                THEN pj_project_id\\\\n                ELSE NULL\\\\n            END) AS audited_count,\\\\n            COUNT(DISTINCT CASE\\\\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\\\n                 AND NULLIF(TRIM(first_time_right), \'\') = \'Yes\'\\\\n                THEN pj_project_id\\\\n                ELSE NULL\\\\n            END) AS ftr_yes_count\\\\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\\\\n        {where_sql}\\\\n        GROUP BY {group_sql}\\\\n        ORDER BY {group_sql}\\\\n    \\\\\\"\\\\\\"\\\\\\"\\\\n\\\\n    rows = execute_query(sql, db=None, max_rows=None) or []\\\\n\\\\n    out = []\\\\n    for r in rows:\\\\n        audited = r.get(\\\\\\"audited_count\\\\\\") or 0\\\\n        ftr_yes = r.get(\\\\\\"ftr_yes_count\\\\\\") or 0\\\\n        not_ftr_or_unknown = audited - ftr_yes\\\\n        ftr_rate_pct = (100.0 * ftr_yes / audited) if audited else None\\\\n\\\\n        rec = {c: r.get(c) for c in group_cols}\\\\n        rec.update(\\\\n            {\\\\n                \\\\\\"audited_count\\\\\\": audited,\\\\n                \\\\\\"ftr_yes_count\\\\\\": ftr_yes,\\\\n                \\\\\\"not_ftr_or_unknown_count\\\\\\": not_ftr_or_unknown,\\\\n                \\\\\\"ftr_rate_pct\\\\\\": ftr_rate_pct,\\\\n            }\\\\n        )\\\\n        out.append(rec)\\\\n\\\\n    return out\\\\n\\"\\n}\\n</updates>\\n\\nOn the business observation: agreed it\\u2019s worth flagging. If audited GCs are showing 0% FTR, it\\u2019s commonly either (1) `first_time_right` is mostly NULL/blank (so numerator ~0), or (2) truly low FTR. Your suggested quick distribution check is the right next step:\\n\\n```sql\\nSELECT first_time_right, COUNT(*)\\nFROM public.stg_ndpd_mbt_tmobile_macro_combined\\nWHERE ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\\nGROUP BY 1\\nORDER BY 2 DESC;\\n```\\n\\nIf you want it even more diagnostic, we can normalize values (trim/casefold) and bucket blanks vs NULLs explicitly."}], "approved_by": "user", "approved_at": "2026-03-07T10:34:57.529586+00:00", "contract": {"function_name": "get_ndpc_quality_ftr_rate", "node_type": "kpi", "node_id": "f44a788a-0aab-4a97-b60e-38a9d43063af", "node_label": "NDPc Quality FTR Rate", "description": "Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. Data source: stg_ndpd_mbt_tmobile_macro_combined. Denominator = COUNT(DISTINCT pj_project_id) for rows where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL (quality audit completed, reached the gate), regardless of first_time_right value. Numerator = COUNT(DISTINCT pj_project_id) where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL AND first_time_right is explicitly \'Yes\' (apply TRIM and treat blank as NULL via NULLIF(TRIM(first_time_right),\'\'); do not attempt to enumerate non-Yes values; all non-Yes/NULL are excluded from numerator but remain in denominator if MS1556 is present). FTR Rate (%) = 100.0 * numerator / NULLIF(denominator,0). Output should include: ftr_rate_pct, ftr_yes_count (numerator), audited_count (denominator), and optionally not_ftr_or_unknown_count = audited_count - ftr_yes_count. Group by rgn_region, m_area, m_market, pj_general_contractor; optionally extend grouping with por_category and s_site_class for segmentation.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "audited_count", "type": "number", "nullable": false}, {"name": "ftr_yes_count", "type": "number", "nullable": false}, {"name": "not_ftr_or_unknown_count", "type": "number", "nullable": false}, {"name": "ftr_rate_pct", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "clearpath telecom", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}], "row_count": 10}}'});

