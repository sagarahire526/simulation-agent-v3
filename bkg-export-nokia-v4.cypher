CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'project', name: 'project', label: 'Project', node_type: 'CORE', entity_type: 'core', status: 'active', details_json: '{"definition": "Unit of work managed for a Site (1:1). Identified by Site Code (T-Mobile), SMP ID (internal Nokia), and Project ID. Contains hundreds of milestone fields (~792 columns) representing lifecycle gating and dates. Includes priority (P1/P2/P3), construction scope type (tower-only vs civil+tower), and an attribute for whether NTP is required (case-by-case; triggers NTP approval flow when true). Also includes a key lifecycle anchor milestone for On-Air (OA) date."}', nl_description: 'Unit of work managed for a Site (1:1). Identified by Site Code (T-Mobile), SMP ID (internal Nokia), and Project ID. Contains hundreds of milestone fields (~792 columns) representing lifecycle gating and dates. Includes priority (P1/P2/P3), construction scope type (tower-only vs civil+tower), and an attribute for whether NTP is required (case-by-case; triggers NTP approval flow when true). Also includes a key lifecycle anchor milestone for On-Air (OA) date.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_mbt_tmobile_macro_combined", "key_column": "pj_project_id", "label_column": "pj_project_name", "database_name": "public", "sql_template": "SELECT \\"id\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_por_count\\", \\"pj_program_name\\", \\"pj_project_id\\", \\"pj_project_name\\", \\"pj_project_status\\", \\"pj_project_type\\" FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"", "python_function": "def get_project(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Project records.\\n    Node: Project | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\\n    \\"\\"\\"\\n    def _escape(v) -> str:\\n        return str(v).replace(\\"\'\\", \\"\'\'\\")\\n\\n    def _quote_ident(ident: str) -> str:\\n        ident = str(ident)\\n        return \'\\"\' + ident.replace(\'\\"\', \'\\"\\"\') + \'\\"\'\\n\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            col = _quote_ident(k)\\n\\n            if v is None:\\n                where_parts.append(f\\"{col} IS NULL\\")\\n                continue\\n\\n            # Allow filtering by a list/tuple/set via IN (...)\\n            if isinstance(v, (list, tuple, set)):\\n                values = list(v)\\n                if not values:\\n                    # Empty IN list should match nothing; use a false predicate.\\n                    where_parts.append(\\"1 = 0\\")\\n                    continue\\n                in_vals = \\", \\".join(f\\"\'{_escape(item)}\'\\" for item in values)\\n                where_parts.append(f\\"{col} IN ({in_vals})\\")\\n                continue\\n\\n            where_parts.append(f\\"{col} = \'{_escape(v)}\'\\")\\n\\n    where = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n\\n    # NOTE: Do NOT add LIMIT here. The provided template had LIMIT 5 only for validation.\\n    sql = f\'SELECT * FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"{where}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-02T13:49:50.881751+00:00", "method": "confirmed"}, "caveats": ["Site and Project are denormalized into the same wide table; 1:1 is implied via pj_project_id including the site code and the presence of s_site_id."], "evidence": {"sample_values": [{"id": 30000, "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "pj_por_count": "1", "pj_program_name": "LTW_Like-for-Like Tower Work", "pj_project_id": "CH10000A-0002000000", "pj_project_name": "CH10000A - Equipment Upgrade (2458591)", "pj_project_status": "Dead", "pj_project_type": "M-Modification General", "por_category": "NTM", "por_por_id": "POR1000000