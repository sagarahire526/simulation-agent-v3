CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'radio_unit', name: 'radio_unit', label: 'Radio Unit', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "An individual radio hardware asset (e.g., RRU/BBU components) tracked at serial/asset level in FAST Tracker. Starts as an expected BOM line item and becomes an installed asset at a Site; validated against the BOM and integrated during the project lifecycle. Common issues include hardware failures, BOM mismatches, and missing components."}', nl_description: 'An individual radio hardware asset (e.g., RRU/BBU components) tracked at serial/asset level in FAST Tracker. Starts as an expected BOM line item and becomes an installed asset at a Site; validated against the BOM and integrated during the project lifecycle. Common issues include hardware failures, BOM mismatches, and missing components.', nl_business_rule: '', mapping_json: '{"table_name": "stg_tmo_rejections_master_file", "key_column": "id", "label_column": null, "database_name": "public", "sql_template": "SELECT \\"id\\", \\"trmf_region\\", \\"trmf_combined_market\\", \\"trmf_market\\", \\"trmf_site_code\\", \\"trmf_wb_id\\", \\"trmf_packagename\\", \\"trmf_ms_1553_cw_quality_media_cl_reviewed_company\\", \\"trmf_ms_1554_tw_works_start_actual\\", \\"trmf_ms_1555_tw_works_complete_actual\\" FROM \\"public\\".\\"stg_tmo_rejections_master_file\\"", "python_function": "def get_radio_unit(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Radio Unit records.\\n    Node: Radio Unit | Table: stg_tmo_rejections_master_file | Key: id | DB: public\\n    \\"\\"\\"\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\'\\"{k}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\'SELECT * FROM \\"stg_tmo_rejections_master_file\\"{where}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-05T12:15:43.969406+00:00", "method": "confirmed"}, "caveats": ["Does not track individual radio units as assets (no serial/asset-level entity rows); only flags/issues at site/package level.", "Not suitable for inventory/BOM vs installed asset reconciliation."], "evidence": {"sample_values": [{"id": 144100, "trmf_region": null, "trmf_combined_market": null, "trmf_market": null, "trmf_site_code": "head", "trmf_wb_id": "remain", "trmf_packagename": null, "trmf_ms_1553_cw_quality_media_cl_reviewed_company": "stay", "trmf_ms_1554_tw_works_start_actual": null, "trmf_ms_1555_tw_works_complete_actual": null, "trmf_tw_media_checklist_notification_sent_to_tmo": null, "trmf_tw_media_checklist_rejected_by_tmo": "2024-11-17 22:37:51", "trmf_responsible": null, "trmf_no_of_tmo_punch_points": "job", "trmf_tmo_punch_point_details": "before", "trmf_beyond_nokia_checklist_punch_points_count": "0", "trmf_missing_5_percent_rejection_count": null, "trmf_tmo_rejection_matching_with_nokia_count": null, "trmf_missed_in_nokia_review_count": "choose", "trmf_beyond_nokia_checklist_punch_points": "can", "trmf_missing_5_percent_rejection": "role", "trmf_tmo_rejection_matching_with_nokia": "region", "trmf_missed_in_nokia_review": null, "trmf_jha_jsa": null, "trmf_rigging_lifting": null, "trmf_fiber_sweep_test_results": "remember", "trmf_build_permit_coo_coc_form": null, "trmf_cd_as_built_redlined": "center", "trmf_rfds_as_built": "their", "trmf_materials_pick_slip": null, "trmf_mla": "may", "trmf_rma_form": "perform", "trmf_port_matrix_document": "treatment", "trmf_decomm_form": "ahead", "trmf_tape_drop_form": "industry", "trmf_release_of_lien": null, "trmf_rets_screenshots": null, "trmf_aat_tool_results": null, "trmf_mcb_breaker": null, "trmf_ethernet_cable": "worker", "trmf_combination_locks_to_cabinet