CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'closeout_package', name: 'closeout_package', label: 'Closeout Package', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "A project deliverable document set assembled for a site/project closeout (including as-built documentation) and submitted for customer review; triggers COP approval and downstream acceptance/payment steps."}', nl_description: 'A project deliverable document set assembled for a site/project closeout (including as-built documentation) and submitted for customer review; triggers COP approval and downstream acceptance/payment steps.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_mbt_tmobile_macro_combined", "key_column": "pj_project_id", "label_column": "pj_project_name", "database_name": "public", "sql_template": "SELECT \\"id\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_por_count\\", \\"pj_program_name\\", \\"pj_project_id\\", \\"pj_project_name\\", \\"pj_project_status\\", \\"pj_project_type\\" FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"", "python_function": "def get_closeout_package(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Closeout Package records.\\n    Node: Closeout Package | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\\n    \\"\\"\\"\\n    where_parts = []\\n\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n                continue\\n\\n            if isinstance(v, (list, tuple, set)):\\n                vals = list(v)\\n                if not vals:\\n                    where_parts.append(\\"1 = 0\\")\\n                    continue\\n\\n                in_parts = []\\n                for item in vals:\\n                    if item is None:\\n  