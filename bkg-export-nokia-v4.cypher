CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'site_survey', name: 'site_survey', label: 'Site Survey', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "A survey activity for a site used to determine/validate scope and derive the Bill of Materials (BOM). Survey paths include Manual Survey, Drone Survey (via external vendor), or No Survey for urgent sites. Tracked via project milestones for assignment and completion."}', nl_description: 'A survey activity for a site used to determine/validate scope and derive the Bill of Materials (BOM). Survey paths include Manual Survey, Drone Survey (via external vendor), or No Survey for urgent sites. Tracked via project milestones for assignment and completion.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_mbt_tmobile_macro_combined", "key_column": "id", "label_column": null, "database_name": "public", "sql_template": "SELECT \\"id\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_por_count\\", \\"pj_program_name\\", \\"pj_project_id\\", \\"pj_project_name\\", \\"pj_project_status\\", \\"pj_project_type\\" FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"", "python_function": "def get_site_survey(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Site Survey records.\\n    Node: Site Survey | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: id | DB: public\\n    \\"\\"\\"\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n                continue\\n\\n            if isinstance(v, (list, tuple, set)):\\n                values = list(v)\\n                if not values:\\n                    return []\\n                in_parts = []\\n                for item in values:\\n                    if item is None:\\n                        in_parts.append(\\"NULL\\")\\n                    else:\\n                        escaped = str(item).replace(\\"\'\\", \\"\'\'\\")\\n                        in_parts.append(f\\"\'{escaped}\'\\")\\n                where_parts.append(f\'\\"{col}\\" IN ({\\", \\".join(in_parts)})\')\\n                continue\\n\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\'\\"{col}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where_clause = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\'SELECT * FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"{where_clause}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-05T12:18:01.254360+00:00", "method": "confirmed"}, "caveats": ["Survey is not a separate transactional table; represented as milestone timestamps/flags on the project/site record."], "evidence": {"sample_values": [{"id": 30000, "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "pj_por_count": "1", "pj_program_name": "LTW_Like-for-Like Tower Work", "pj_project_id": "CH10000A-0002000000", "pj_project_name": "CH10000A - Equipment Upgrade (2458591)", "pj_project_status": "Dead", "pj_project_type": "M-Modification General", "por_category": "NTM", "por_por_id": "POR1000000", "por_regional_dev_initiatives": "2027 Build Plan", "rgn_region": "CENTRAL", "s_city": "North Judithbury", "s_site_id": "CH10000A", "s_site_name": "Taylor Inc/Brittany Bypass", "s_site_type": "Structure Non Building", "pj_a_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_p_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_aav_telco_ready_status": "pending", "pj_approve_close_out_binder_status": null, "pj_backhaul_task_selection": null, "pj_bid_walk_complete_optional_status": "N/A", "pj_bom_in_bat_3850_doc": "CH10000A_stay.xlsx", "pj_bt