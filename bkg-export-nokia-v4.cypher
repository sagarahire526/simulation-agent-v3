CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'general_contractor', name: 'general_contractor', label: 'General Contractor', node_type: 'CORE', entity_type: 'core', status: 'active', details_json: '{"definition": "A vendor company performing the physical construction work on sites. Assigned early based on market forecast; can accept/reject assignment; reassignment possible but uncommon once work begins. Tracked with identity attributes and market presence; crew count/capacity tracked per market; performance (e.g., productivity, on-time, SLA breach, rework) tracked operationally."}', nl_description: 'A vendor company performing the physical construction work on sites. Assigned early based on market forecast; can accept/reject assignment; reassignment possible but uncommon once work begins. Tracked with identity attributes and market presence; crew count/capacity tracked per market; performance (e.g., productivity, on-time, SLA breach, rework) tracked operationally.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_mbt_tmobile_macro_combined", "key_column": "construction_gc", "label_column": "construction_gc", "database_name": "public", "sql_template": "SELECT \\"id\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_por_count\\", \\"pj_program_name\\", \\"pj_project_id\\", \\"pj_project_name\\", \\"pj_project_status\\", \\"pj_project_type\\" FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"", "python_function": "def get_general_contractor(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all General Contractor records.\\n    Node: General Contractor | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: construction_gc | DB: public\\n    \\"\\"\\"\\n    table = \'\\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"\'\\n\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n                continue\\n\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\'\\"{col}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\\"SELECT * FROM {table}{where}\\"\\n\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-02T13:52:33.976485+00:00", "method": "confirmed"}, "caveats": ["GC is stored as free-text; duplicates will occur due to suffixes/casing/punctuation (e.g., \'IMPIRIUM LLC.\' vs \'impirium\'). Consider adding a normalized GC name in a curated layer for entity resolution.", "\\u26a0 Key column [construction_gc] has 97.5% duplicate values (25 distinct / 1,000 total)"], "evidence": {"sample_values": [{"id": 30000, "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "pj_por_count": "1", "pj_program_name": "LTW_Like-for-Like Tower Work", "pj_project_id": "CH10000A-0002000000", "pj_project_name": "CH10000A - Equipment Upgrade (2458591)", "pj_project_status": "Dead", "pj_project_type": "M-Modification General", "por_category": "NTM", "por_por_id": "POR1000000", "por_regional_dev_initiatives": "2027 Build Plan", "rgn_region": "CENTRAL", "s_city": "North Judithbury", "s_site_id": "CH10000A", "s_site_name": "Taylor Inc/Brittany Bypass", "s_site_type": "Structure Non Building", "pj_a_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_p_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_aav_telco_ready_status": "pending", "pj_approve_close_out_binder_status": null, "pj_backhaul_task_selection": null, "pj_bid_walk_complete_optional_status": "N/A", "pj_bom_in_bat_3850_doc": "CH10000A_stay.xlsx", "pj_bts_general_comments": "Compare rock fill start.", "pj_building_permit_approved_status": "N/A", "pj_building