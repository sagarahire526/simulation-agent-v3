CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'approval', name: 'approval', label: 'Approval', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "A lightweight approval touchpoint/event between Nokia and T-Mobile for a specific Project (e.g., NTP, Scoping Package Approval, Punch Checklist review, Closeout Package/COP, Customer Acceptance). Has type and status (pending/approved/rejected) and is evidenced/controlled via project milestone fields. Created only when the approval gate applies (e.g., NTP approval created when NTP_required=true)."}', nl_description: 'A lightweight approval touchpoint/event between Nokia and T-Mobile for a specific Project (e.g., NTP, Scoping Package Approval, Punch Checklist review, Closeout Package/COP, Customer Acceptance). Has type and status (pending/approved/rejected) and is evidenced/controlled via project milestone fields. Created only when the approval gate applies (e.g., NTP approval created when NTP_required=true).', nl_business_rule: '', mapping_json: '{"table_name": "stg_nas_log_data", "key_column": "id", "label_column": "nas_event_type", "database_name": "public", "sql_template": "SELECT \\"id\\", \\"nas_region\\", \\"nas_market\\", \\"nas_site_id\\", \\"nas_session_id\\", \\"nas_activity_type\\", \\"nas_nest_type\\", \\"nas_project_category\\", \\"nas_event_type\\", \\"nas_sla_nest\\" FROM \\"public\\".\\"stg_nas_log_data\\"", "python_function": "def get_approval(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Approval records.\\n    Node: Approval | Table: stg_nas_log_data | Key: id | DB: public\\n    \\"\\"\\"\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\'\\"{k}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where_clause = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\'SELECT * FROM \\"stg_nas_log_data\\"{where_clause}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-05T12:52:33.607585+00:00", "method": "confirmed"}, "caveats": ["Primarily NAS/NEST approvals; customer (T-Mobile) approvals like scoping/COP are stored as milestone fields in the master project table rather than as discrete approval event rows."], "evidence": {"sample_values": [{"id": 7625982, "nas_region": "Central", "nas_market": "Chicago", "nas_site_id": "CH10000A", "nas_session_id": "300000", "nas_activity_type": "[E911 Testing]", "nas_nest_type": "NSI", "nas_project_category": "Equipment Upgrade", "nas_event_type": "Nest Approved", "nas_sla_nest": "5", "nas_event_time": "2025-11-12 16:41:35", "nas_user_id": "dre.longoria.ext@nokia.com", "create_uid": 1573, "create_date": "2026-02-17 10:14:15", "write_uid": 1573, "write_date": "2026-02-17 10:14:15"}, {"id": 7625983, "nas_region": "Central", "nas_market": "Detroit", "nas_site_id": "DE10001A", "nas_session_id": "300001", "nas_activity_type": "[iNTP Validation]", "nas_nest_type": "SI", "nas_project_category": "ABIO Swap plus 5G Midband", "nas_event_type": "Conditional Approval-Approved", "nas_sla_nest": "2", "nas_event_time": "2026-02-08 01:50:07", "nas_user_id": "pradeep.r.ext@nokia.com", "create_uid": 1911, "create_date": "2026-02-17 07:12:26", "write_uid": 1911, "write_date": "2026-02-17 07:12:26"}, {"id": 7625984, "nas_region": "Central", "nas_market": "Indianapolis", "nas_site_id": "IN10002A", "nas_session_id": "300002", "nas_activity_type": "[Punch Items]", "nas_nest_type": "NSI", "nas_project_category": "Anchor Phase 3", "nas_event_type": "Nest Approved", "nas_sla_nest": "6", "nas_event_time": "2025-11-12 18:41:44", "nas_user_id": "cuthbert.cuffy.ext@nokia.com", "create_uid": 1845, "create_date": "2026-02-17 10:58:38", "write_uid": 1845, "write_date": "2026-02-17 10:58:38"}], "validation_queries": [{"purpose": "Check st