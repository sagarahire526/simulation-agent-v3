CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'customer', name: 'customer', label: 'Customer', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "The customer organization for whom the deployment program is executed (T-Mobile for this program). Used as a contextual anchor for projects, sites, approvals, and payments."}', nl_description: 'The customer organization for whom the deployment program is executed (T-Mobile for this program). Used as a contextual anchor for projects, sites, approvals, and payments.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_hse_site_checklist", "key_column": "id", "label_column": "customer_name", "database_name": "public", "sql_template": "SELECT \\"id\\", \\"sl_no_moved0\\", \\"gsd_hse_review_check_date\\", \\"hse_status\\", \\"hse_engineer_name\\", \\"customer_name\\", \\"smp_name\\", \\"smp_id\\", \\"region\\", \\"market\\" FROM \\"public\\".\\"stg_ndpd_hse_site_checklist\\"", "python_function": "def get_customer(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Customer records.\\n    Node: Customer | Table: stg_ndpd_hse_site_checklist | Key: id | DB: public\\n    \\"\\"\\"\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n                continue\\n\\n            # Support simple IN filters if caller supplies a list/tuple/set\\n            if isinstance(v, (list, tuple, set)):\\n                values = []\\n                for item in v:\\n                    if item is None:\\n                        values.append(\\"NULL\\")\\n                    else:\\n                        escaped_item = str(item).replace(\\"\'\\", \\"\'\'\\")\\n                        values.append(f\\"\'{escaped_item}\'\\")\\n                if values:\\n                    where_parts.append(f\\"\\\\\\"{col}\\\\\\" IN ({\', \'.join(values)})\\")\\n                continue\\n\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\\"\\\\\\"{col}\\\\\\" = \'{escaped}\'\\")\\n\\n    where = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\'SELECT * FROM \\"public\\".\\"stg_ndpd_hse_site_checklist\\"{where}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-05T12:15:38.803654+00:00", "method": "confirmed"}, "caveats": ["Customer is not normalized (no customer_id); represented as text and repeated across multiple operational tables."], "evidence": {"sample_values": [{"id": 15894882, "sl_no_moved0": "writer", "gsd_hse_review_check_date": "2025-05-29 15:22:16", "hse_status": "WIP", "hse_engineer_name": "those", "customer_name": "US_NAM TMO CT T-Mobile", "smp_name": "Anchor", "smp_id": "SMP-WO-800000", "region": "Central", "market": "Chicago", "market_cm_name": null, "site_id": "CH10000A", "site_name": "Taylor Inc/Brittany Bypass", "gc_name": "PM Communications", "ms13_actual": null, "ms15_forecast": null, "ms15_actual": "2025-07-24 23:41:03", "ms16_actual": "gas", "crew_lead_name": "Karen Norris", "no_of_persons_working_at_site_moved0": null, "check_in_status": "Not Checked In", "check_in_date": null, "ppe_photo_available": "N/A", "ppe_validation": "N/A", "ndpd_ai_ml_status": null, "ndpc_session_creation_status": "Pending", "ndpc_session_creation_date": null, "jsa_completion_status": "Completed", "each_crew_ptid_I2w_status": null, "non_compliance_status": "Completed", "non_compliance_category": "relate", "escalation_l1_to_gc": "card", "level_1_status": "Pending", "escalation_l2_to_cm": "organization", "level_2_status": "In Progress", "escalation_l3_to_pm": "white", "level_3_status": "In Progress", "escalation_l4_pd_all": null, "level_4_status": "In Progress", "remarks":