CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'material_equipment', name: 'material_equipment', label: 'Material/Equipment', node_type: 'CORE', entity_type: 'core', status: 'enriched', details_json: '{"definition": "Customer-owned materials/equipment required per site (Bill of Materials). BOM status/availability is milestone-gated (BOM exists/approved \\u2192 material available at T-Mobile warehouse \\u2192 GC pickup confirmed \\u2192 pickup validated). BOM can be survey-validated or design-based (urgent/no-survey path); discrepancies may be reconciled during construction/integration."}', nl_description: 'Customer-owned materials/equipment required per site (Bill of Materials). BOM status/availability is milestone-gated (BOM exists/approved → material available at T-Mobile warehouse → GC pickup confirmed → pickup validated). BOM can be survey-validated or design-based (urgent/no-survey path); discrepancies may be reconciled during construction/integration.', nl_business_rule: '', mapping_json: '{"table_name": "stg_ndpd_mbt_tmobile_macro_combined", "key_column": "pj_project_id", "label_column": null, "database_name": "public", "sql_template": "SELECT \\"id\\", \\"m_area\\", \\"m_market\\", \\"pj_general_contractor\\", \\"pj_por_count\\", \\"pj_program_name\\", \\"pj_project_id\\", \\"pj_project_name\\", \\"pj_project_status\\", \\"pj_project_type\\" FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"", "python_function": "def get_material_equipment(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Material/Equipment records.\\n    Node: Material/Equipment | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\\n    \\"\\"\\"\\n    where_parts: list[str] = []\\n\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n            elif isinstance(v, bool):\\n                where_parts.append(f\'\\"{col}\\" IS {\\"TRUE\\" if v else \\"FALSE\\"}\')\\n            elif isinstance(v, (int, float)) and not isinstance(v, bool):\\n                where_parts.append(f\'\\"{col}\\" = {v}\')\\n            else:\\n                escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n                where_parts.append(f\'\\"{col}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where_clause = f\\" WHERE {\' AND \'.join(where_parts)}\\" if where_parts else \\"\\"\\n\\n    sql = f\'SELECT * FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"{where_clause}\'\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-02T13:53:01.299696+00:00", "method": "confirmed"}, "caveats": ["This does not provide BOM line-item granularity; it is project/site-level BOM status and document references, not a true Bill of Materials table."], "evidence": {"sample_values": [{"id": 30000, "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "pj_por_count": "1", "pj_program_name": "LTW_Like-for-Like Tower Work", "pj_project_id": "CH10000A-0002000000", "pj_project_name": "CH10000A - Equipment Upgrade (2458591)", "pj_project_status": "Dead", "pj_project_type": "M-Modification General", "por_category": "NTM", "por_por_id": "POR1000000", "por_regional_dev_initiatives": "2027 Build Plan", "rgn_region": "CENTRAL", "s_city": "North Judithbury", "s_site_id": "CH10000A", "s_site_name": "Taylor Inc/Brittany Bypass", "s_site_type": "Structure Non Building", "pj_a_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_p_5000_aav_circuit_ready_to_integrate_salesforce_finish_move": null, "pj_aav_telco_ready_status": "pending", "pj_approve_close_out_binder_status": null, "pj_backhaul_task_selection": null, "pj_bid_walk_complete_optional_status": "N/A", "pj_bom_in_bat_3850_doc": "CH10000A_stay.xlsx", "pj_bts_general_comments": "Com