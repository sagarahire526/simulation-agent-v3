CREATE (:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'integration_activity', name: 'integration_activity', label: 'Integration Activity', node_type: 'CORE', entity_type: 'core', status: 'mentioned', details_json: '{"definition": "A set of integration work performed by NAS integration engineers to bring installed radio equipment on-air, validate readiness artifacts, integrate technologies, and complete post-integration monitoring. Can begin once a site reaches an integration-ready/matured phase and is not strictly sequential with construction."}', nl_description: 'A set of integration work performed by NAS integration engineers to bring installed radio equipment on-air, validate readiness artifacts, integrate technologies, and complete post-integration monitoring. Can begin once a site reaches an integration-ready/matured phase and is not strictly sequential with construction.', nl_business_rule: '', mapping_json: '{"table_name": "stg_nas_session_level_combined_data", "key_column": "id", "label_column": null, "database_name": "public", "sql_template": "SELECT \\"id\\", \\"nas_market\\", \\"nas_project_category\\", \\"nas_date_period\\", \\"nas_site_id\\", \\"nas_session_id\\", \\"nas_contact_person_only\\", \\"nas_activity_type\\", \\"nas_vendor_name\\", \\"nas_company_name\\" FROM \\"public\\".\\"stg_nas_session_level_combined_data\\"", "python_function": "def get_integration_activity(execute_query: callable, filters: dict = None) -> list[dict]:\\n    \\"\\"\\"Fetch all Integration Activity records.\\n    Node: Integration Activity | Table: stg_nas_session_level_combined_data | Key: id | DB: public\\n    \\"\\"\\"\\n    table = \'\\"public\\".\\"stg_nas_session_level_combined_data\\"\'\\n\\n    where_parts = []\\n    if filters:\\n        for k, v in filters.items():\\n            col = str(k).replace(\'\\"\', \'\\"\\"\')\\n\\n            if v is None:\\n                where_parts.append(f\'\\"{col}\\" IS NULL\')\\n                continue\\n\\n            escaped = str(v).replace(\\"\'\\", \\"\'\'\\")\\n            where_parts.append(f\'\\"{col}\\" = \\\\\'{escaped}\\\\\'\')\\n\\n    where = (\\" WHERE \\" + \\" AND \\".join(where_parts)) if where_parts else \\"\\"\\n    sql = f\\"SELECT * FROM {table}{where}\\"\\n\\n    rows = execute_query(sql)\\n    return rows if rows else []", "approval_log": {"approved_by": "user", "approved_at": "2026-03-05T12:18:22.046942+00:00", "method": "confirmed"}, "caveats": ["Represents session-level integration events rather than a normalized \'integration activity\' entity with explicit start/end per defined activity type taxonomy."], "evidence": {"sample_values": [{"id": 5344885, "nas_market": "Chicago", "nas_project_category": "AHLOA-B SWAP", "nas_date_period": "Macro", "nas_site_id": "CH10000A", "nas_session_id": "300000", "nas_contact_person_only": "Bryan Cowan", "nas_activity_type": "ACS DAS Venue", "nas_vendor_name": null, "nas_company_name": "Summit Wireless", "nas_primary_gc": "SUM", "nas_contact_person": "Bryan Cowan", "nas_maxdowntime_daily_existinglayers_hrs": null, "nas_maxdowntime_hourly_existinglayers_hrs": null, "nas_outage_cells": null, "nas_user_id": "dre.longoria.ext@nokia.com", "nas_workorder_id": null, "nas_nest_type": "NSI", "nas_session_create_time": null, "nas_status_description": null, "nas_status_nest_active": null, "nas_last_event": null, "nas_status_e911_test": null, "nas_status_cbn_validation": null, "nas_status_gc_checkout": null, "nas_nest_start_time_requested": null, "nas_nest_time_requested": null, "nas_nest_time_requested_hrs": null, "nas_nest_start_time": "2025-11-15 19:37:29", "nas_precheck_time": null, "nas_checkout_time": "2025-11-15 20:01:29", "nas_total_activity_duration": null, "nas_phone_number": null, "nas_cbn_request_time": null, "nas_cbn_approve_time": null, "nas_msisdn": null, "nas_status_conditional_approval": null, "nas_checkout_gc_notes": null, "nas_checkout_warroom_notes": null, "nas_checkout_approve_time": "2025-11-16 08:27:29",