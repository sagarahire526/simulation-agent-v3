CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_session_level_combined_data'], nl_business_rule: '', kpi_formula_description: 'Per (nas_market, nas_activity_type, nas_company_name, date_bucket) over completed sessions (nas_checkout_approve_time IS NOT NULL): completed_sessions = COUNT(DISTINCT nas_session_id); checkout_sla_rate_pct = 100 * COUNT(DISTINCT completed sessions with extension proxy = no extension) / NULLIF(COUNT(DISTINCT completed sessions),0); extension_rate_pct = 100 * COUNT(DISTINCT completed sessions with extension proxy = extension) / NULLIF(COUNT(DISTINCT completed sessions),0); avg_extensions_per_session = AVG(nas_total_ext_count_approved) over completed sessions where COALESCE(nas_total_ext_count_approved,0)>0; avg_activity_duration = AVG(nas_total_activity_duration).', kpi_output_schema: '[{"column": "nas_market", "type": "string", "description": "NAS market grouping dimension."}, {"column": "nas_activity_type", "type": "string", "description": "NAS activity type grouping dimension."}, {"column": "nas_company_name", "type": "string", "description": "NAS company name grouping dimension."}, {"column": "date_bucket", "type": "string", "description": "Time bucket derived from nas_checkout_approve_time at the selected grain (day or week)."}, {"column": "completed_sessions", "type": "int", "description": "Distinct count of completed sessions."}, {"column": "checkout_sla_rate_pct", "type": "float", "description": "Percent of completed sessions completed without needing an extension (SLA proxy)."}, {"column": "extension_rate_pct", "type": "float", "description": "Percent of completed sessions that required an extension (proxy)."}, {"column": "avg_extensions_per_session", "type": "float", "description": "Average approved extensions among completed sessions with at least one approved extension."}, {"column": "avg_activity_duration", "type": "float", "description": "Average total activity duration over completed sessions (may be NULL if duration is stored as non-numeric text)."}]', kpi_business_logic: '1) Start from stg_nas_session_level_combined_data (session-level).\n2) Keep only completed sessions where nas_checkout_approve_time IS NOT NULL.\n3) Derive date_bucket from nas_checkout_approve_time (day: cast to date; week: date_trunc(\'week\')::date).\n4) Group by nas_market, nas_activity_type, nas_company_name, date_bucket.\n5) Compute completed_sessions as COUNT(DISTINCT nas_session_id).\n6) Compute checkout_sla_rate_pct as percent of completed sessions with no approved extensions (either COALESCE(nas_total_ext_count_approved,0)=0 or, in the provided SQL option, nas_status_nest_ext IS NULL).\n7) Compute extension_rate_pct as percent of completed sessions with extensions (either COALESCE(nas_total_ext_count_approved,0)>0 or, in the provided SQL option, nas_status_nest_ext IS NOT NULL).\n8) Compute avg_extensions_per_session as AVG(nas_total_ext_count_approved) over completed sessions with COALESCE(nas_total_ext_count_approved,0)>0.\n9) Compute avg_activity_duration as AVG(nas_total_activity_duration) over completed sessions (SQL casts to numeric; may be NULL if non-numeric text).', kpi_filters: '[{"name": "completed_sessions_only", "type": "string", "description": "Includes only sessions where nas_checkout_approve_time IS NOT NULL."}, {"name": "start_date", "type": "date", "description": "Filters nas_checkout_approve_time to be >= start_date."}, {"name": "end_date", "type": "date", "description": "Filters nas_checkout_approve_time to be < end_date."}, {"name": "nas_market", "type": "string", "description": "Limits results to a specific nas_market."}, {"name": "nas_activity_type", "type": "string", "description": "Limits results to a specific nas_activity_type."}, {"name": "nas_company_name", "type": "string", "description": "Limits results to a specific nas_company_name."}, {"name": "nas_vendor_name", "type": "string", "description": "Optional filter for nas_vendor_name."}, {"name": "nas_primary_gc", "type": "string", "description": "Optional filter for nas_primary_gc."}, {"name": "nas_session_id", "type": "string", "description": "Optional filter for a specific nas_session_id."}, {"name": "nas_site_id", "type": "string", "description": "Optional filter for a specific nas_site_id."}, {"name": "nas_project_category", "type": "string", "description": "Optional filter for a specific nas_project_category."}, {"name": "nas_date_period", "type": "string", "description": "Optional filter for a specific nas_date_period."}, {"name": "time_grain", "type": "string", "description": "Controls date_bucket derivation: daily (nas_checkout_approve_time::date) or weekly (date_trunc(\'week\', nas_checkout_approve_time)::date)."}]', kpi_contract: '{"function_name": "get_nas_integration_sla", "node_type": "kpi", "node_id": "dc2892a1-5c59-4892-b008-e30afd4df123", "node_label": "NAS Integration SLA", "description": "Combined NAS integration capacity KPI returning multiple measures per (nas_market, nas_activity_type, nas_company_name, date_bucket) from `stg_nas_session_level_combined_data`. A session is considered completed when `nas_checkout_approve_time IS NOT NULL` and is counted as `COUNT(DISTINCT nas_session_id)`.\\n\\nOutput columns per row:\\n1) completed_sessions: COUNT(DISTINCT nas_session_id) over completed sessions.\\n2) checkout_sla_rate_pct: 100 * (COUNT(DISTINCT nas_session_id) where completed AND COALESCE(nas_total_ext_count_approved,0)=0) / NULLIF(COUNT(DISTINCT nas_session_id) where completed, 0). (SLA proxy = completed without any approved extensions.)\\n3) extension_rate_pct: 100 * (COUNT(DISTINCT nas_session_id) where completed AND COALESCE(nas_total_ext_count_approved,0)>0) / NULLIF(COUNT(DISTINCT nas_session_id) where completed, 0).\\n4) avg_extensions_per_session: AVG(nas_total_ext_count_approved) over completed sessions with COALESCE(nas_total_ext_count_approved,0)>0.\\n5) avg_activity_duration: AVG(nas_total_activity_duration) over completed sessions.\\n\\nTime grouping: date_bucket derived from `nas_checkout_approve_time` (daily: `nas_checkout_approve_time::date`; weekly: `date_trunc(\'week\', nas_checkout_approve_time)::date`). Grouping dimensions: nas_market, nas_activity_type, nas_company_name, date_bucket. Optional additional dimensions if needed: nas_vendor_name, nas_primary_gc.\\n\\nPrimary entities involved: Integration Activity (session-level records) joined conceptually to Market and vendor/company; computed directly from NAS session fact table without requiring additional joins.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "time_grain", "type": "date", "description": "Filter by time grain", "required": false, "sample_values": []}, {"name": "date_bucket_grain", "type": "date", "description": "Filter by date bucket grain", "required": false, "sample_values": []}], "output_columns": [{"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_activity_type", "type": "string", "nullable": false}, {"name": "nas_company_name", "type": "string", "nullable": false}, {"name": "date_bucket", "type": "date", "nullable": false}, {"name": "completed_sessions", "type": "number", "nullable": false}, {"name": "checkout_sla_rate_pct", "type": "string", "nullable": false}, {"name": "extension_rate_pct", "type": "string", "nullable": false}, {"name": "avg_activity_duration", "type": "null", "nullable": true}], "sample_output": [{"nas_market": "Cincinnati", "nas_activity_type": "Radio Upgrade NR", "nas_company_name": "PM Communications", "date_bucket": "2025-10-01", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}, {"nas_market": "Los Angeles", "nas_activity_type": "Punch Items", "nas_company_name": "ClearPath Telecom", "date_bucket": "2025-10-01", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}, {"nas_market": "Kansas City", "nas_activity_type": "Tower Inspection", "nas_company_name": "On Air Solutions", "date_bucket": "2025-10-02", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}], "row_count": 10}', nl_description: 'KPI = aggregates over completed Integration Activity sessions grouped by (nas_market, nas_activity_type, nas_company_name, date_bucket) where completed sessions are those with nas_checkout_approve_time not null. Uses single-table extension proxy: sessions with nas_status_nest_ext IS NULL are treated as completed within original window (checkout_sla_rate_pct), while nas_status_nest_ext IS NOT NULL indicates an extension was needed (extension_rate_pct). Note: avg_activity_duration is included as a throughput/capacity signal, but may be NULL if nas_total_activity_duration is stored as non-numeric text (e.g., \'1h 19m\'); parsing to minutes would be a future enhancement.', node_type: 'CORE', definition: 'KPI = aggregates over completed Integration Activity sessions grouped by (nas_market, nas_activity_type, nas_company_name, date_bucket) where completed sessions are those with nas_checkout_approve_time not null. Uses single-table extension proxy: sessions with nas_status_nest_ext IS NULL are treated as completed within original window (checkout_sla_rate_pct), while nas_status_nest_ext IS NOT NULL indicates an extension was needed (extension_rate_pct). Note: avg_activity_duration is included as a throughput/capacity signal, but may be NULL if nas_total_activity_duration is stored as non-numeric text (e.g., \'1h 19m\'); parsing to minutes would be a future enhancement.', kpi_python_function: 'def get_nas_integration_sla(execute_query, filters=None) -> list[dict]:\n    filters = filters or {}\n\n    # Integration Activity accessor doesn\'t expose required measure fields,\n    # so we aggregate via raw SQL from the session-level combined table.\n\n    # Base predicate: only completed sessions (approve time present)\n    where = ["nas_checkout_approve_time IS NOT NULL"]\n\n    # Date range filtering applies to approve time (the KPI\'s time anchor)\n    if filters.get(\'start_date\') is not None:\n        sd = str(filters.get(\'start_date\')).replace("\'", "\'\'")\n        where.append(f"nas_checkout_approve_time >= \'{sd}\'")\n    if filters.get(\'end_date\') is not None:\n        ed = str(filters.get(\'end_date\')).replace("\'", "\'\'")\n        where.append(f"nas_checkout_approve_time < \'{ed}\'")\n\n    # Optional dimension filters\n    dim_filter_map = {\n        \'nas_market\': \'nas_market\',\n        \'nas_activity_type\': \'nas_activity_type\',\n        \'nas_company_name\': \'nas_company_name\',\n        \'nas_vendor_name\': \'nas_vendor_name\',\n        \'nas_primary_gc\': \'nas_primary_gc\',\n        \'nas_session_id\': \'nas_session_id\',\n        \'nas_site_id\': \'nas_site_id\',\n        \'nas_project_category\': \'nas_project_category\',\n        \'nas_date_period\': \'nas_date_period\'\n    }\n    for fk, col in dim_filter_map.items():\n        if filters.get(fk) is not None:\n            val = str(filters.get(fk)).replace("\'", "\'\'")\n            where.append(f"{col} = \'{val}\'")\n\n    # Time grouping\n    time_grain = (filters.get(\'time_grain\') or filters.get(\'date_bucket_grain\') or \'day\').lower()\n    if time_grain in (\'week\', \'weekly\'):\n        date_bucket_expr = "date_trunc(\'week\', nas_checkout_approve_time)::date"\n    else:\n        date_bucket_expr = "nas_checkout_approve_time::date"\n\n    where_sql = "\\n  AND ".join(where)\n\n    # Option A (single-table): use nas_status_nest_ext as extension proxy.\n    sql = f"""\nSELECT\n  nas_market,\n  nas_activity_type,\n  nas_company_name,\n  {date_bucket_expr} AS date_bucket,\n\n  COUNT(DISTINCT nas_session_id) AS completed_sessions,\n\n  100.0 * COUNT(DISTINCT CASE WHEN nas_status_nest_ext IS NULL THEN nas_session_id END)\n    / NULLIF(COUNT(DISTINCT nas_session_id), 0) AS checkout_sla_rate_pct,\n\n  100.0 * COUNT(DISTINCT CASE WHEN nas_status_nest_ext IS NOT NULL THEN nas_session_id END)\n    / NULLIF(COUNT(DISTINCT nas_session_id), 0) AS extension_rate_pct,\n\n  AVG(nas_total_activity_duration::numeric) AS avg_activity_duration\n\nFROM public.stg_nas_session_level_combined_data\nWHERE {where_sql}\nGROUP BY\n  nas_market,\n  nas_activity_type,\n  nas_company_name,\n  {date_bucket_expr}\nORDER BY\n  date_bucket,\n  nas_market,\n  nas_activity_type,\n  nas_company_name\n"""\n\n    return execute_query(sql)\n', kpi_source_columns: ['nas_market', 'nas_activity_type', 'nas_company_name', 'nas_checkout_approve_time', 'nas_session_id', 'nas_total_ext_count_approved', 'nas_total_activity_duration', 'nas_status_nest_ext', 'nas_vendor_name', 'nas_primary_gc', 'nas_site_id', 'nas_project_category', 'nas_date_period'], session_id: '69a3d22f26e208edc083a06e', label: 'NAS Integration SLA', kpi_related_core_node_ids: ['integration_activity'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'dc2892a1-5c59-4892-b008-e30afd4df123', entity_type: 'kpi', kpi_name: 'NAS Integration SLA', name: 'dc2892a1-5c59-4892-b008-e30afd4df123', kpi_dimensions: ['nas_market', 'nas_activity_type', 'nas_company_name', 'date_bucket', 'nas_vendor_name', 'nas_primary_gc'], kpi_description: 'Measures NAS integration capacity and a proxy for checkout SLA by summarizing completed integration activity sessions. It reports how many sessions were completed and the share completed without needing an extension, segmented by market, activity type, company, and time period.', status: 'mentioned', node_id: 'dc2892a1-5c59-4892-b008-e30afd4df123'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping value."}, {"column": "m_area", "type": "string", "description": "Area grouping value."}, {"column": "m_market", "type": "string", "description": "Market grouping value."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping value."}, {"column": "por_regional_dev_initiatives", "type": "string", "description": "Regional development initiatives grouping value."}, {"column": "project_count", "type": "int", "description": "Number of distinct projects (COUNT DISTINCT pj_project_id) in the group."}, {"column": "avg_cycle_time_days", "type": "float", "description": "Average cycle time in days across projects in the group."}, {"column": "median_p50_cycle_time_days", "type": "float", "description": "Median (P50) cycle time in days across projects in the group."}, {"column": "p90_cycle_time_days", "type": "float", "description": "90th percentile (P90) cycle time in days across projects in the group."}]', kpi_business_logic: '1) From stg_ndpd_mbt_tmobile_macro_combined, read ms_1550_construction_start_actual and confirm_receipt_of_base_pos_and_spos_generated.\n2) Parse cpo_date from confirm_receipt_of_base_pos_and_spos_generated only if it matches the pattern YYYY-MM-DD; cast ms_1550_construction_start_actual to cx_start_date (date).\n3) Keep rows where cpo_date and cx_start_date are not null and (cx_start_date - cpo_date) >= 0.\n4) Compute cycle_time_days = cx_start_date - cpo_date per pj_project_id.\n5) Group by rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives.\n6) For each group, compute COUNT(DISTINCT pj_project_id) as project_count, AVG(cycle_time_days) as avg_cycle_time_days, PERCENTILE_CONT(0.5) as median_p50_cycle_time_days, and PERCENTILE_CONT(0.9) as p90_cycle_time_days.\n7) Optional exact-match filters may be applied on rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives, pj_project_id, s_site_id; optional date range filters apply to ms_1550_construction_start_actual (cx_start_date).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on market."}, {"name": "pj_general_contractor", "type": "string", "description": "Exact-match filter on general contractor."}, {"name": "por_regional_dev_initiatives", "type": "string", "description": "Exact-match filter on regional development initiatives."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter to a specific site."}, {"name": "start_date", "type": "date", "description": "Lower bound date filter applied to ms_1550_construction_start_actual (construction start actual)."}, {"name": "end_date", "type": "date", "description": "Upper bound date filter applied to ms_1550_construction_start_actual (construction start actual)."}, {"name": "valid_cpo_date_format", "type": "string", "description": "Include only records where confirm_receipt_of_base_pos_and_spos_generated matches ^\\\\d{4}-\\\\d{2}-\\\\d{2} for parsing to a date."}, {"name": "non_null_milestones_and_non_negative_cycle", "type": "string", "description": "Include only records where both milestone dates are non-null and (ms_1550_construction_start_actual - cpo_date) >= 0."}]', kpi_contract: '{"function_name": "get_cpo_to_cx_start", "node_type": "kpi", "node_id": "56171ab1-3ce1-44b6-b22e-400f5ffd9552", "node_label": "CPO to Cx Start", "description": "Measures the cycle time (in days) from CPO receipt confirmation to Construction Start Actual for each project/site. This helps track how long it takes to move from CPO receipt to the start of construction and enables performance comparisons across regions/markets/contractors and initiative groupings.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives).', node_type: 'CORE', definition: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives).', kpi_python_function: 'def get_cpo_to_cx_start(execute_query, filters=None) -> list[dict]:\n    """CPO to Cx Start cycle time (days).\n\n    Preferred CPO source (production intent): confirm_receipt_of_base_pos_and_spos_generated.\n    Active implementation (until preferred column is populated): pj_a_4200_pull_construction_po_number_finish (MS 4200).\n\n    Cycle time (days) = ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date.\n\n    Returns grouped rollups with average, median (P50), and P90 across projects.\n    Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives.\n\n    Optional filters supported (exact-match):\n      - rgn_region, m_area, m_market, pj_general_contractor, por_regional_dev_initiatives\n      - pj_project_id, s_site_id\n      - start_date, end_date (applies to ms_1550_construction_start_actual)\n    """\n\n    filters = filters or {}\n\n    def _to_date_str(v):\n        if v is None:\n            return None\n        s = str(v).strip()\n        if not s:\n            return None\n        return s[:10]\n\n    where_parts = []\n\n    # Dimension filters ONLY\n    for k in [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_regional_dev_initiatives",\n        "pj_project_id",\n        "s_site_id",\n    ]:\n        if filters.get(k) is not None and str(filters.get(k)).strip() != "":\n            escaped = str(filters[k]).replace("\'", "\'\'")\n            where_parts.append(f"{k} = \'{escaped}\'")\n\n    # Date range filter: apply to end milestone (construction start actual)\n    start_date = _to_date_str(filters.get("start_date"))\n    end_date = _to_date_str(filters.get("end_date"))\n    if start_date:\n        where_parts.append(f"ms_1550_construction_start_actual::date >= \'{start_date}\'::date")\n    if end_date:\n        where_parts.append(f"ms_1550_construction_start_actual::date <= \'{end_date}\'::date")\n\n    additional_where = ""\n    if where_parts:\n        additional_where = " AND " + " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            pj_general_contractor,\n            por_regional_dev_initiatives,\n            COUNT(DISTINCT pj_project_id) AS project_count,\n            AVG(cycle_time_days::numeric) AS avg_cycle_time_days,\n            PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY cycle_time_days) AS median_p50_cycle_time_days,\n            PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY cycle_time_days) AS p90_cycle_time_days\n        FROM (\n            SELECT\n                pj_project_id,\n                rgn_region,\n                m_area,\n                m_market,\n                pj_general_contractor,\n                por_regional_dev_initiatives,\n                (ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date) AS cycle_time_days\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\n            WHERE ms_1550_construction_start_actual IS NOT NULL\n              AND pj_a_4200_pull_construction_po_number_finish IS NOT NULL\n              AND (ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date) >= 0\n              {additional_where}\n        ) sub\n        GROUP BY 1,2,3,4,5\n        ORDER BY 1,2,3,4,5\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['ms_1550_construction_start_actual', 'confirm_receipt_of_base_pos_and_spos_generated', 'pj_project_id', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_regional_dev_initiatives', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'CPO to Cx Start', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES_FROM', kpi_kpi_id: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', entity_type: 'kpi', kpi_name: 'CPO to Cx Start', name: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_regional_dev_initiatives'], kpi_description: 'Measures the cycle time (in days) from CPO receipt confirmation to Construction Start Actual for each project/site. This helps track how long it takes to move from CPO receipt to the start of construction and enables performance comparisons across regions/markets/contractors and initiative groupings.', status: 'mentioned', node_id: '56171ab1-3ce1-44b6-b22e-400f5ffd9552'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'COUNT(DISTINCT pj_project_id) where pj_a_4425_mw_installation_complete_finish IS NOT NULL AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping field (optional)."}, {"column": "por_regional_dev_initiatives", "type": "string", "description": "Regional development initiative / build plan year or program segmentation grouping field (optional)."}, {"column": "pj_program_name", "type": "string", "description": "Program name grouping field (optional)."}, {"column": "pending_mw_acceptance_count", "type": "int", "description": "Count of distinct projects pending MW link final acceptance."}]', kpi_business_logic: '1) Start with records from public.stg_ndpd_mbt_tmobile_macro_combined.\n2) Keep only rows where MW installation complete finish date is present (pj_a_4425_mw_installation_complete_finish IS NOT NULL).\n3) Also require MW link final accepted/operational finish date is missing (pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL).\n4) Count distinct pj_project_id.\n5) Optionally group results by rgn_region, m_area, m_market, and/or pj_general_contractor, por_regional_dev_initiatives, pj_program_name.', kpi_filters: '[{"name": "pj_a_4425_mw_installation_complete_finish", "type": "date", "description": "Include only records where MW installation complete finish date is not null."}, {"name": "pj_a_5300_mw_link_final_accepted_and_operational_finish", "type": "date", "description": "Include only records where MW link final accepted/operational finish date is null."}, {"name": "rgn_region", "type": "string", "description": "Optional slice/filter by region."}, {"name": "m_area", "type": "string", "description": "Optional slice/filter by area."}, {"name": "m_market", "type": "string", "description": "Optional slice/filter by market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional slice/filter by general contractor."}, {"name": "por_regional_dev_initiatives", "type": "string", "description": "Optional slice/filter by regional development initiative / build plan year or program segmentation."}, {"name": "pj_program_name", "type": "string", "description": "Optional slice/filter by program name."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to a specific project id."}, {"name": "s_site_id", "type": "string", "description": "Optional filter to a specific site id."}]', kpi_contract: '{"function_name": "get_pending_mw_acceptance", "node_type": "kpi", "node_id": "86351076-dcbb-42b7-83bf-58eae5481ae8", "node_label": "Pending MW Acceptance", "description": "Counts the number of distinct projects/sites pending microwave link final acceptance. Calculation: COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_a_4425_mw_installation_complete_finish IS NOT NULL (MW installation completed) AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL (MW link not formally accepted/operational). Reportable/groupable by rgn_region, m_area, m_market, and optionally pj_general_contractor and por_regional_dev_initiatives (build plan year/program segmentation). No joins required; all fields are in the same table.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pending_mw_acceptance_count", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pending_mw_acceptance_count": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pending_mw_acceptance_count": 5}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pending_mw_acceptance_count": 7}], "row_count": 10}', nl_description: 'Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.', node_type: 'CORE', definition: 'Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.', kpi_python_function: 'def get_pending_mw_acceptance(execute_query, filters=None) -> list[dict]:\n    """Counts distinct projects pending MW link final acceptance.\n\n    Definition:\n      MW installation complete date is NOT NULL\n      AND MW link final accepted/operational date is NULL\n      KPI = COUNT(DISTINCT pj_project_id)\n\n    Groupable by: rgn_region, m_area, m_market; optionally pj_general_contractor, por_regional_dev_initiatives.\n\n    Notes:\n      The Tier-1 get_project accessor does not expose the two MW milestone columns, so we use raw SQL.\n    """\n\n    filters = filters or {}\n\n    # Dimensions to group by\n    group_by = filters.get("group_by")\n    if not group_by:\n        group_by_cols = ["rgn_region", "m_area", "m_market"]\n    else:\n        if isinstance(group_by, str):\n            group_by_cols = [c.strip() for c in group_by.split(",") if c.strip()]\n        else:\n            group_by_cols = [str(c).strip() for c in group_by if str(c).strip()]\n\n    # Allowlist group-by columns for safety\n    allowed_group_bys = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_regional_dev_initiatives",\n        "pj_program_name"\n    }\n    group_by_cols = [c for c in group_by_cols if c in allowed_group_bys]\n    if not group_by_cols:\n        group_by_cols = ["rgn_region", "m_area", "m_market"]\n\n    select_dims = ", ".join(group_by_cols)\n    group_by_sql = ", ".join(group_by_cols)\n\n    where_parts = [\n        "pj_a_4425_mw_installation_complete_finish IS NOT NULL",\n        "pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL"\n    ]\n\n    # Optional filters\n    # (No explicit date filtering since KPI definition is based on milestone null-ness;\n    #  but allow slicing by region/area/market/gc/program/project/site if provided.)\n    allowed_filters = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_regional_dev_initiatives",\n        "pj_program_name",\n        "pj_project_id",\n        "s_site_id"\n    }\n    for k, v in (filters or {}).items():\n        if k in ("group_by", "start_date", "end_date"):\n            continue\n        if k not in allowed_filters:\n            continue\n        if v is None or v == "":\n            continue\n        escaped = str(v).replace("\'", "\'\'")\n        where_parts.append(f"{k} = \'{escaped}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        f"{select_dims}, "\n        "COUNT(DISTINCT pj_project_id) AS pending_mw_acceptance_count "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"WHERE {where_sql} "\n        f"GROUP BY {group_by_sql} "\n        f"ORDER BY {group_by_sql}"\n    )\n\n    rows = execute_query(sql)\n    return rows\n', kpi_source_columns: ['pj_project_id', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_5300_mw_link_final_accepted_and_operational_finish', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_regional_dev_initiatives', 'pj_program_name', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'Pending MW Acceptance', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '86351076-dcbb-42b7-83bf-58eae5481ae8', entity_type: 'kpi', kpi_name: 'Pending MW Acceptance', name: '86351076-dcbb-42b7-83bf-58eae5481ae8', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_regional_dev_initiatives', 'pj_program_name'], kpi_description: 'Counts the number of distinct projects/sites that are pending microwave link final acceptance. This indicates work where MW installation is complete but the link has not yet been formally accepted/operational.', status: 'mentioned', node_id: '86351076-dcbb-42b7-83bf-58eae5481ae8'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Prereq Readiness Rate (%) = 100.0 * Numerator / NULLIF(Denominator, 0), where Denominator = distinct active projects with no construction start date, and Numerator = those denominator projects meeting all readiness gates (NTP cleared, material picked up, power ready, and backhaul ready).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping field."}, {"column": "por_category", "type": "string", "description": "POR category grouping field (optional drilldown if present)."}, {"column": "denominator_pipeline_wip", "type": "int", "description": "Count of distinct active projects with no construction start actual date."}, {"column": "numerator_ready_to_start", "type": "int", "description": "Count of distinct denominator projects meeting all prerequisite readiness gates."}, {"column": "prereq_readiness_rate", "type": "float", "description": "Percentage of denominator projects that meet all readiness gates."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined at the Project/Site grain (distinct pj_project_id).\n2) Denominator: count distinct pj_project_id where pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\n3) Numerator: within the denominator population, count distinct pj_project_id that satisfy all gates:\n   a) NTP cleared: ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL\n   b) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\n   c) Power ready (default): pj_a_4525_power_ready_finish IS NOT NULL\n   d) Backhaul ready: pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL (if both NULL, not ready)\n4) KPI = 100.0 * Numerator / NULLIF(Denominator, 0).\n5) Group results by rgn_region, m_area, m_market, pj_general_contractor, and por_category (optional).', kpi_filters: '[{"name": "pj_project_status", "type": "string", "description": "Include only projects with status \'Active\'."}, {"name": "ms_1550_construction_start_actual", "type": "date", "description": "Include only projects where construction start actual is NULL (not yet started)."}, {"name": "ms_1327_scoping_and_quoting_package_validated_actual", "type": "date", "description": "Optional denominator refinement (enabled via enable_scoping_validated_denominator): require scoping and quoting package validated actual to be NOT NULL."}, {"name": "enable_scoping_validated_denominator", "type": "string", "description": "Optional boolean flag to tighten the denominator by requiring ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL."}, {"name": "enable_soft_power_gate", "type": "string", "description": "Optional boolean flag to soften the power readiness gate: power gate becomes pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL."}, {"name": "rgn_region", "type": "string", "description": "Optional filter to restrict results to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional filter to restrict results to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional filter to restrict results to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional filter to restrict results to a specific general contractor."}, {"name": "por_category", "type": "string", "description": "Optional filter to restrict results to a specific por_category."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to restrict results to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Optional filter to restrict results to a specific site."}]', kpi_contract: '{"function_name": "get_prereq_readiness_rate", "node_type": "kpi", "node_id": "7b7c5043-acce-4353-be87-bf1c2049565f", "node_label": "Prereq Readiness Rate", "description": "Measures the % of active, not-yet-started construction pipeline projects that meet all prerequisite readiness gates (baseline readiness).\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only (no joins).\\n\\nDenominator (pipeline WIP): COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator (ready-to-start): COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all readiness gates below:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready (default): pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL). If both are NULL, treat as not ready.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nImplementation notes / optional refinements (not applied unless explicitly enabled):\\n- Denominator tightening if the rate is artificially low due to early pipeline sites: add ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to the denominator filter.\\n- Power readiness fill-rate issue: if pj_a_4525_power_ready_finish is sparsely populated, consider a softer power gate using pj_a_4450_permanent_power_ordered_finish IS NOT NULL (either as a fallback or as a separate variant KPI).", "parameters": [], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "denominator_pipeline_wip", "type": "number", "nullable": false}, {"name": "numerator_ready_to_start", "type": "number", "nullable": false}, {"name": "prereq_readiness_rate", "type": "string", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "ews group", "por_category": "Anchor", "denominator_pipeline_wip": 1, "numerator_ready_to_start": 0, "prereq_readiness_rate": "0E-20"}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "por_category": "New Build", "denominator_pipeline_wip": 1, "numerator_ready_to_start": 0, "prereq_readiness_rate": "0E-20"}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "sba communications", "por_category": "New Build", "denominator_pipeline_wip": 1, "numerator_ready_to_start": 0, "prereq_readiness_rate": "0E-20"}], "row_count": 10}', nl_description: 'Prereq Readiness Rate (%) = 100 * (count of distinct active projects with no construction start date that have NTP cleared AND material pickup date present AND power-ready date present AND (fiber-ready OR MW-install-complete present)) / (count of distinct active projects with no construction start date), grouped by region/area/market/GC/(optional) por_category.', node_type: 'CORE', definition: 'Prereq Readiness Rate (%) = 100 * (count of distinct active projects with no construction start date that have NTP cleared AND material pickup date present AND power-ready date present AND (fiber-ready OR MW-install-complete present)) / (count of distinct active projects with no construction start date), grouped by region/area/market/GC/(optional) por_category.', kpi_python_function: 'def get_prereq_readiness_rate(execute_query, filters=None) -> list[dict]:\n    """Prereq Readiness Rate (%): among active pipeline (not yet started construction) projects,\n    percent that meet baseline readiness gates (NTP, material pickup, power ready, backhaul ready).\n\n    Returns rows grouped by: rgn_region, m_area, m_market, pj_general_contractor, por_category (if present).\n\n    Supported filters (optional):\n      - rgn_region, m_area, m_market, pj_general_contractor, por_category\n      - pj_project_id, s_site_id\n      - enable_scoping_validated_denominator (bool): if truthy, adds ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL to denominator\n      - enable_soft_power_gate (bool): if truthy, power gate is (pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL)\n\n    Note: Data source is public.stg_ndpd_mbt_tmobile_macro_combined only (no joins).\n    """\n\n    filters = filters or {}\n\n    enable_scoping_validated_denominator = bool(filters.pop("enable_scoping_validated_denominator", False))\n    enable_soft_power_gate = bool(filters.pop("enable_soft_power_gate", False))\n\n    where_parts = []\n    where_parts.append("t.\\"pj_project_status\\" = \'Active\'")\n    where_parts.append("t.\\"ms_1550_construction_start_actual\\" IS NULL")\n\n    if enable_scoping_validated_denominator:\n        where_parts.append("t.\\"ms_1327_scoping_and_quoting_package_validated_actual\\" IS NOT NULL")\n\n    for k, v in list(filters.items()):\n        if v is None:\n            continue\n        escaped = str(v).replace("\'", "\'\'")\n        if k in {\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "pj_general_contractor",\n            "por_category",\n            "pj_project_id",\n            "s_site_id",\n        }:\n            where_parts.append(f"t.\\"{k}\\" = \'{escaped}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    ntp_gate = "(t.\\"ms_1507_tower_ntp_approved_actual\\" IS NOT NULL OR t.\\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\" IS NOT NULL)"\n\n    # Physical column name is mixed-case in Postgres; must be double-quoted exactly.\n    material_gate = \'(t."pj_a_3925_msI_pickup_date_finish" IS NOT NULL)\'\n\n    if enable_soft_power_gate:\n        power_gate = "(t.\\"pj_a_4525_power_ready_finish\\" IS NOT NULL OR t.\\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL)"\n    else:\n        power_gate = "(t.\\"pj_a_4525_power_ready_finish\\" IS NOT NULL)"\n\n    backhaul_gate = "(t.\\"pj_a_4925_aav_fiber_ready_finish\\" IS NOT NULL OR t.\\"pj_a_4425_mw_installation_complete_finish\\" IS NOT NULL)"\n\n    readiness_all_gates = f"({ntp_gate} AND {material_gate} AND {power_gate} AND {backhaul_gate})"\n\n    group_cols = [\n        "t.\\"rgn_region\\"",\n        "t.\\"m_area\\"",\n        "t.\\"m_market\\"",\n        "t.\\"pj_general_contractor\\"",\n        "t.\\"por_category\\"",\n    ]\n\n    select_group_cols = ", ".join(group_cols)\n    group_by_sql = ", ".join(group_cols)\n\n    sql = f"""\n        SELECT\n            {select_group_cols},\n            COUNT(DISTINCT t.\\"pj_project_id\\") AS denominator_pipeline_wip,\n            COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\"pj_project_id\\" ELSE NULL END) AS numerator_ready_to_start,\n            (100.0 * COUNT(DISTINCT CASE WHEN {readiness_all_gates} THEN t.\\"pj_project_id\\" ELSE NULL END)\n                  / NULLIF(COUNT(DISTINCT t.\\"pj_project_id\\"), 0)) AS prereq_readiness_rate\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined AS t\n        WHERE {where_sql}\n        GROUP BY {group_by_sql}\n    """.strip()\n\n    return execute_query(sql, db=None, max_rows=None)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msi_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 'ms_1327_scoping_and_quoting_package_validated_actual', 'pj_a_4450_permanent_power_ordered_finish', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'Prereq Readiness Rate', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '7b7c5043-acce-4353-be87-bf1c2049565f', entity_type: 'kpi', kpi_name: 'Prereq Readiness Rate', name: '7b7c5043-acce-4353-be87-bf1c2049565f', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category'], kpi_description: 'Measures the percentage of active construction pipeline projects that have not yet started construction and already meet all prerequisite readiness gates. This indicates baseline readiness to begin construction.', status: 'mentioned', node_id: '7b7c5043-acce-4353-be87-bf1c2049565f'});
