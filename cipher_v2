nish IS NOT NULL."}, {"name": "readiness_gate_power_ready", "type": "date", "description": "Requires pj_a_4525_power_ready_finish IS NOT NULL."}, {"name": "readiness_gate_fiber_or_mw_complete", "type": "date", "description": "Requires pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL."}]', kpi_contract: '{"function_name": "get_ready_site_backlog", "node_type": "kpi", "node_id": "656de982-3668-41a9-bbcf-2a1fb4a75979", "node_label": "Ready Site Backlog", "description": "Counts projects that are ready for construction start but have not started yet, grouped by market and GC.\\n\\nFilter: ms_1550_construction_start_actual IS NULL AND readiness gates satisfied:\\n- (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n- pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n- pj_a_4525_power_ready_finish IS NOT NULL\\n- (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\n\\nAggregation: COUNT(DISTINCT pj_project_id).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nInterpretation: demand signal representing ready-to-start work waiting for crews.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site 