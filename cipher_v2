ction_walk_complete_finish IS NOT NULL\n4) KPI value = 100.0 * Numerator / NULLIF(Denominator, 0).\n5) Group results by rgn_region, m_area, m_market, pj_general_contractor (optional por_category mentioned).', kpi_filters: '[{"name": "pj_project_status", "type": "string", "description": "Restricts denominator (and therefore numerator) to active projects/sites (pj_project_status = \'Active\')."}, {"name": "ms_1550_construction_start_actual", "type": "date", "description": "Restricts denominator (and therefore numerator) to projects/sites where construction has not started (ms_1550_construction_start_actual IS NULL)."}, {"name": "NTP_cleared", "type": "date", "description": "Numerator readiness gate: NTP is cleared when ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL."}, {"name": "material_pickup", "type": "date", "description": "Numerator readiness gate: material pickup completed when pj_a_3925_msi_pickup_date_finish IS NOT NULL."}, {"name": "power_ready", "type": "date", "description": "Numerator readiness gate: power ready when pj_a_4525_power_ready_finish IS NOT NULL."}, {"name": "backhaul_ready", "type": "date", "description": "Numerator readiness gate: backhaul ready when pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL."}, {"name": "site_access_strict", "type": "date", "description": "Numerator strict site access proxy: pre-construction walk complete when pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL."}, {"name": "rgn_region", "type": "string", "description": "Optional exact-match dimension filter for region."}, {"name": "m_area", "type": "string", "description": "Optional exact-match dimension filter for area."}, {"name": "m_market", "type": "string", "description": "Optional exact-match dimension filter for market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional exact-match dimension filter for general contractor."}]', kpi_contract: '{"function_name": "get_prereq_readiness_strict", "node_type": "kpi", "node_id": "dcf98a0e-2891-47a3-a258-ebea62201ba4", "node_label": "Prereq Readiness Strict", "description": "Strict version of prerequisite readiness rate: same as Prereq Readiness Rate, but additionally requires a proxy for demonstrated site access.\\n\\nEntity grain: Project/Site (distinct pj_project_id). Data source: stg_ndpd_mbt_tmobile_macro_combined only.\\n\\nDenominator: COUNT(DISTINCT pj_project_id) WHERE pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\\n\\nNumerator: COUNT(DISTINCT pj_project_id) satisfying the Denominator filter AND all baseline readiness gates (NTP cleared, material pickup, power ready, backhaul ready) AND:\\n5) Site access proxy: pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL.\\n\\nKPI value: 100.0 * Numerator / NULLIF(Denominator, 0).\\n\\nGrouping/drilldowns: rgn_region, m_area, m_market, pj_general_contractor, optional por_category.\\n\\nNotes: Split scope flag confirm_split_spo is intentionally omitted as a readiness gate (NULL implies tower-only; NOT NULL implies civil+tower confirmed; neither blocks readiness). Optional refinements for denominator tightening and power gate softening are the same as the baseline KPI.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "pj_general_contractor", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', node_type: 'CORE', definition: 'Prereq Readiness Strict (%) = 100 * (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL AND NTP cleared [ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL] AND material pickup [pj_a_3925_msi_pickup_date_finish IS NOT NULL] AND power ready [pj_a_4525_power_ready_finish IS NOT NULL] AND backhaul ready [pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL] AND site access strict [pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL]) / (distinct pj_project_id where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL), grouped by rgn_region, m_area, m_market, pj_general_contractor. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', kpi_python_function: 'def get_prereq_readiness_strict(execute_query, filters=None) -> list[dict]:\n    """Prereq Readiness Strict (%) grouped by region/area/market/GC.\n\n    Source: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).\n\n    Denominator (Active, construction not started):\n      - pj_project_status = \'Active\'\n      - ms_1550_construction_start_actual IS NULL\n\n    Numerator: Denominator + all prerequisite gates met:\n      - NTP cleared:\n          ms_1507_tower_ntp_approved_actual IS NOT NULL\n          OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL\n      - Material pickup: pj_a_3925_msi_pickup_date_finish IS NOT NULL\n      - Power ready: pj_a_4525_power_ready_finish IS NOT NULL\n      - Backhaul ready:\n          pj_a_4925_aav_fiber_ready_finish IS NOT NULL\n          OR pj_a_4425_mw_installation_complete_finish IS NOT NULL\n      - Site access (strict): pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL\n\n    KPI = 100 * numerator / denominator\n    """\n\n    filters = filters or {}\n\n    # Fixed, verified physical column predicates (no placeholders)\n    denom_pred = "(pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL)"\n\n    ntp_pred = "(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)"\n    material_pred = "(pj_a_3925_msi_pickup_date_finish IS NOT NULL)"\n    power_pred = "(pj_a_4525_power_ready_finish IS NOT NULL)"\n    backhaul_pred = "(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)"\n    site_access_pred = "(pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL)"\n\n    num_pred = " AND ".join([\n        denom_pred,\n        ntp_pred,\n        material_pred,\n        power_pred,\n        backhaul_pred,\n        site_access_pred,\n    ])\n\n    # Grouping (fixed as requested)\n    group_dims = ["rgn_region", "m_area", "m_market", "pj_general_contractor"]\n\n    # Optional dimension filters (exact-match)\n    where_parts = []\n    if filters.get("rgn_region") is not None:\n        v = str(filters.get("rgn_region")).replace("\'", "\'\'")\n        where_parts.append(f"rgn_region = \'{v}\'")\n    if filters.get("m_area") is not None:\n        v = str(filters.get("m_area")).replace("\'", "\'\'")\n        where_parts.append(f"m_area = \'{v}\'")\n    if filters.get("m_market") is not None:\n        v = str(filters.get("m_market")).replace("\'", "\'\'")\n        where_parts.append(f"m_market = \'{v}\'")\n    if filters.get("pj_general_contractor") is not None:\n        v = str(filters.get("pj_general_contractor")).replace("\'", "\'\'")\n        where_parts.append(f"pj_general_contractor = \'{v}\'")\n\n    where_clause = ""\n    if where_parts:\n        where_clause = "WHERE " + " AND ".join(where_parts)\n\n    group_by = ", ".join(group_dims)\n    select_dims = ", ".join(group_dims)\n\n    sql = f"""\n        SELECT\n            {select_dims},\n            COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END) AS denominator,\n            COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END) AS numerator,\n            100.0 * COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END)\n                / NULLIF(COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END), 0) AS kpi_value\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_clause}\n        GROUP BY {group_by}\n        ORDER BY {group_by}\n    """.strip()\n\n    rows = execute_query(sql)\n\n    out = []\n    for r in rows:\n        rec = {k: r.get(k) for k in group_dims}\n        rec["denominator"] = r.get("denominator")\n        rec["numerator"] = r.get("numerator")\n        rec["kpi_value"] = r.get("kpi_value")\n        out.append(rec)\n    return out\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msi_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_3825_pre_construction_walk_complete_finish', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 'confirm_split_spo'], session_id: '69a3d22f26e208edc083a06e', label: 'Prereq Readiness Strict', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', entity_type: 'kpi', kpi_name: 'Prereq Readiness Strict', name: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category'], kpi_description: 'Strict version of prerequisite readiness rate that measures the share of active projects/sites that are ready to start construction and also have demonstrated site access. It is used to track readiness progress with an added requirement for a site-access proxy.', status: 'mentioned', node_id: 'dcf98a0e-2891-47a3-a258-ebea62201ba4'});
CREATE (:BKGNode {kpi_source_tables: ['stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Per project: cx_cycle_days = construction_complete_actual::date - construction_start_actual::date (only where both dates exist and duration >= 0); publish grouped AVG, P50, P90, and MAX of cx_cycle_days.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping dimension."}, {"column": "por_category", "type": "string", "description": "Optional slice dimension for POR category."}, {"column": "s_site_class", "type": "string", "description": "Optional slice dimension for site class."}, {"column": "project_count", "type": "int", "description": "Number of projects in the group."}, {"column": "avg_cx_cycle_days", "type": "float", "description": "Average construction cycle time in days for the group."}, {"column": "p50_cx_cycle_days", "type": "float", "description": "Median (P50) construction cycle time in days for the group."}, {"column": "p90_cx_cycle_days", "type": "float", "description": "90th percentile construction cycle time in days for the group."}, {"column": "max_cx_cycle_days", "type": "int", "description": "Maximum construction cycle time in days for the group."}]', kpi_business_logic: '1) From stg_ndpd_mbt_tmobile_macro_combined, keep rows where ms_1550_construction_start_actual IS NOT NULL and ms_1555_construction_complete_actual IS NOT NULL.\n2) Compute cx_cycle_days = (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date).\n3) Exclude rows where cx_cycle_days < 0.\n4) Group results by rgn_region, m_area, m_market, pj_general_contractor, por_category, s_site_class.\n5) For each group, compute project_count, AVG(cx_cycle_days), PERCENTILE_CONT(0.50) (P50/median), PERCENTILE_CONT(0.90) (P90), and MAX(cx_cycle_days).\n6) Optional: apply a date range filter to ms_1555_construction_complete_actual::date and optional equality filters on listed dimension/id columns.', kpi_filters: '[{"name": "ms_1550_construction_start_actual IS NOT NULL", "type": "string", "description": "Include only projects with a construction start actual date."}, {"name": "ms_1555_construction_complete_actual IS NOT NULL", "type": "string", "description": "Include only projects with a construction complete actual date."}, {"name": "cx_cycle_days >= 0", "type": "number", "description": "Exclude projects where completion date is earlier than start date."}, {"name": "start_date", "type": "date", "description": "If provided, include only projects with ms_1555_construction_complete_actual::date on/after this date."}, {"name": "end_date", "type": "date", "description": "If provided, include only projects with ms_1555_construction_complete_actual::date on/before this date."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Optional filter to a specific site."}, {"name": "rgn_region", "type": "string", "description": "Optional filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional filter to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional filter to a specific general contractor."}, {"name": "por_category", "type": "string", "description": "Optional filter to a specific POR category."}, {"name": "s_site_class", "type": "string", "description": "Optional filter to a specific site class."}]', kpi_contract: '{"function_name": "get_cx_cycle_time", "node_type": "kpi", "node_id": "3c1fd435-6d07-4984-9546-45233e3bac72", "node_label": "CX Cycle Time", "description": "Measures calendar days from construction start to construction complete per project/site, used as the primary construction benchmark for planning and capacity modeling. Source table: stg_ndpd_mbt_tmobile_macro_combined. Grain: one record per distinct pj_project_id with valid dates. Numerator/measure per project: (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) as cx_cycle_days. Inclusion criteria: ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL AND (ms_1555::date - ms_1550::date) >= 0. No pj_project_status filter (completed construction dates define the population). Aggregations to publish per grouping: AVG(cx_cycle_days), PERCENTILE_CONT(0.50) as median/P50, PERCENTILE_CONT(0.90) as P90, and MAX(cx_cycle_days). Group-by dimensions: rgn_region, m_area, m_market, pj_general_contractor; optional slices: por_category and s_site_class.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'CX Cycle Time is computed per project as (construction_complete_actual::date − construction_start_actual::date) for projects with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally sliced by POR category and site class) to produce AVG, P50, P90, and MAX cycle days.', node_type: 'CORE', definition: 'CX Cycle Time is computed per project as (construction_complete_actual::date − construction_start_actual::date) for projects with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally sliced by POR category and site class) to produce AVG, P50, P90, and MAX cycle days.', kpi_python_function: 'def get_cx_cycle_time(execute_query, filters=None) -> list[dict]:\n    """CX Cycle Time\n    Computes per-project construction cycle days and publishes grouped aggregates:\n      avg, p50 (median), p90, max.\n\n    Inclusion criteria (per project row):\n      - ms_1550_construction_start_actual IS NOT NULL\n      - ms_1555_construction_complete_actual IS NOT NULL\n      - (complete::date - start::date) >= 0\n\n    Group-by dimensions:\n      rgn_region, m_area, m_market, pj_general_contractor\n    Optional slices (if present in data):\n      por_category, s_site_class\n\n    Filters (optional):\n      - start_date/end_date: applied to construction_complete_actual::date (common reporting anchor)\n      - rgn_region, m_area, m_market, pj_general_contractor, por_category, s_site_class, pj_project_id, s_site_id\n    """\n\n    filters = filters or {}\n\n    # Need milestone date columns not exposed via Tier-1 accessors, plus optional slice columns.\n    where_parts = [\n        "ms_1550_construction_start_actual IS NOT NULL",\n        "ms_1555_construction_complete_actual IS NOT NULL",\n        "(ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) >= 0"\n    ]\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Date range applied to completion date (projects considered complete)\n    if filters.get("start_date"):\n        where_parts.append(f"ms_1555_construction_complete_actual::date >= \'{esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"ms_1555_construction_complete_actual::date <= \'{esc(filters[\'end_date\'])}\'")\n\n    # Optional dimensional filters\n    for col in [\n        "pj_project_id",\n        "s_site_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_category",\n        "s_site_class"\n    ]:\n        if filters.get(col) is not None:\n            where_parts.append(f"{col} = \'{esc(filters[col])}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n    WITH base AS (\n      SELECT\n        pj_project_id,\n        rgn_region,\n        m_area,\n        m_market,\n        pj_general_contractor,\n        por_category,\n        s_site_class,\n        (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) AS cx_cycle_days\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      WHERE {where_sql}\n    ),\n    grouped AS (\n      SELECT\n        rgn_region,\n        m_area,\n        m_market,\n        pj_general_contractor,\n        por_category,\n        s_site_class,\n        COUNT(*)::int AS project_count,\n        AVG(cx_cycle_days)::float AS avg_cx_cycle_days,\n        PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY cx_cycle_days) AS p50_cx_cycle_days,\n        PERCENTILE_CONT(0.90) WITHIN GROUP (ORDER BY cx_cycle_days) AS p90_cx_cycle_days,\n        MAX(cx_cycle_days)::int AS max_cx_cycle_days\n      FROM base\n      GROUP BY 1,2,3,4,5,6\n    )\n    SELECT\n      rgn_region,\n      m_area,\n      m_market,\n      pj_general_contractor,\n      por_category,\n      s_site_class,\n      project_count,\n      avg_cx_cycle_days,\n      p50_cx_cycle_days,\n      p90_cx_cycle_days,\n      max_cx_cycle_days\n    FROM grouped\n    ORDER BY rgn_region, m_area, m_market, pj_general_contractor, por_category, s_site_class\n    """\n\n    rows = execute_query(sql)\n\n    # If por_category and/or s_site_class are not desired for a particular publication,\n    # caller can ignore them; to support "optional slices" behavior, we keep them nullable.\n    return rows\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'CX Cycle Time', kpi_related_core_node_ids: ['project', 'site'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '3c1fd435-6d07-4984-9546-45233e3bac72', entity_type: 'kpi', kpi_name: 'CX Cycle Time', name: '3c1fd435-6d07-4984-9546-45233e3bac72', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class'], kpi_description: 'Measures the number of calendar days it takes to complete construction for a project/site, from construction start to construction complete. It is used as the primary construction benchmark for planning and capacity modeling.', status: 'mentioned', node_id: '3c1fd435-6d07-4984-9546-45233e3bac72'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'civil_cycle_days = (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date); aggregate by dimensions using AVG, P50 (median), P90, MAX, COUNT.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping field."}, {"column": "por_category", "type": "string", "description": "Optional grouping field when enabled."}, {"column": "s_site_class", "type": "string", "description": "Optional grouping field when enabled."}, {"column": "project_count", "type": "int", "description": "Number of projects (rows) included in the group after filters."}, {"column": "avg_civil_cycle_days", "type": "float", "description": "Average civil cycle time in days for the group."}, {"column": "median_p50_civil_cycle_days", "type": "float", "description": "Median (P50) civil cycle time in days for the group."}, {"column": "p90_civil_cycle_days", "type": "float", "description": "90th percentile civil cycle time in days for the group."}, {"column": "max_civil_cycle_days", "type": "int", "description": "Maximum civil cycle time in days for the group."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined. 2) Keep only records where confirm_split_spo IS NOT NULL. 3) Require ms_1549_civil_construction_start_actual IS NOT NULL and ms_1551_civil_construction_complete_actual_date IS NOT NULL. 4) Compute civil_cycle_days = complete_date::date - start_date::date. 5) Exclude rows where civil_cycle_days < 0. 6) Group by rgn_region, m_area, m_market, pj_general_contractor (optionally por_category, s_site_class). 7) For each group, compute project_count, avg_civil_cycle_days, median_p50_civil_cycle_days, p90_civil_cycle_days, max_civil_cycle_days.', kpi_filters: '[{"name": "confirm_split_spo_is_not_null", "type": "string", "description": "Includes only split-scope/civil-confirmed records (confirm_split_spo IS NOT NULL)."}, {"name": "civil_start_date_present", "type": "date", "description": "Requires civil construction start actual date to be present (ms_1549_civil_construction_start_actual IS NOT NULL)."}, {"name": "civil_complete_date_present", "type": "date", "description": "Requires civil construction complete actual date to be present (ms_1551_civil_construction_complete_actual_date IS NOT NULL)."}, {"name": "non_negative_cycle_time", "type": "number", "description": "Keeps only records where (complete_date::date - start_date::date) >= 0."}, {"name": "start_date", "type": "date", "description": "Optional filter applied to ms_1549_civil_construction_start_actual::date >= start_date."}, {"name": "end_date", "type": "date", "description": "Optional filter applied to ms_1549_civil_construction_start_actual::date <= end_date."}, {"name": "rgn_region", "type": "string", "description": "Optional equality filter on rgn_region."}, {"name": "m_area", "type": "string", "description": "Optional equality filter on m_area."}, {"name": "m_market", "type": "string", "description": "Optional equality filter on m_market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional equality filter on pj_general_contractor."}, {"name": "por_category", "type": "string", "description": "Optional equality filter on por_category."}, {"name": "s_site_class", "type": "string", "description": "Optional equality filter on s_site_class."}]', kpi_contract: '{"function_name": "get_civil_cycle_time", "node_type": "kpi", "node_id": "b91a6e98-8c3f-4fae-a943-003665793220", "node_label": "Civil Cycle Time", "description": "Measures civil construction cycle time in calendar days for split-scope/civil sites and aggregates by market and general contractor. Data source: single table `stg_ndpd_mbt_tmobile_macro_combined`.\\n\\nApplicability filter:\\n- `confirm_split_spo IS NOT NULL` (civil + tower scope confirmed)\\n\\nPer-project calculation (only when both civil dates exist):\\n- `civil_cycle_days = (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date)`\\n- Include records where `ms_1549_civil_construction_start_actual IS NOT NULL` AND `ms_1551_civil_construction_complete_actual_date IS NOT NULL` AND `civil_cycle_days >= 0`.\\n\\nAggregations within each grouping:\\n- Average, Median (P50), P90, Max (and optional count).\\n\\nGroup-by dimensions: `rgn_region`, `m_area`, `m_market`, `pj_general_contractor`; optional: `por_category`, `s_site_class`.\\n\\nNotes: This KPI supports monitoring against the civil SLA target (<= 21 days) and can be paired with a separate SLA-breach rate KPI if desired.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "group_by_por_category", "type": "string", "description": "Filter by group by por category", "required": false, "sample_values": []}, {"name": "group_by_site_class", "type": "string", "description": "Filter by group by site class", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Civil Cycle Time is computed per project as (civil construction complete actual date − civil construction start actual date) in calendar days for split-scope/civil-confirmed records with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally POR category and site class) using avg, median (P50), P90, max, and count.', node_type: 'CORE', definition: 'Civil Cycle Time is computed per project as (civil construction complete actual date − civil construction start actual date) in calendar days for split-scope/civil-confirmed records with both dates present and non-negative duration, then aggregated by region/area/market/general contractor (optionally POR category and site class) using avg, median (P50), P90, max, and count.', kpi_python_function: 'def get_civil_cycle_time(execute_query, filters=None) -> list[dict]:\n    """Civil Cycle Time (calendar days) for split-scope/civil-confirmed sites.\n\n    Returns one row per grouping with avg/median/p90/max/count of civil cycle days.\n\n    Expected optional filters keys (all optional):\n      - start_date, end_date: applied to ms_1549_civil_construction_start_actual (date)\n      - rgn_region, m_area, m_market, pj_general_contractor\n      - por_category, s_site_class\n\n    Notes:\n      - Uses raw SQL because the needed civil milestone columns are not exposed by Tier-1 accessors.\n      - Postgres date math: (complete_date::date - start_date::date) yields integer days.\n    """\n\n    filters = filters or {}\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = [\n        "confirm_split_spo IS NOT NULL",\n        "ms_1549_civil_construction_start_actual IS NOT NULL",\n        "ms_1551_civil_construction_complete_actual_date IS NOT NULL",\n        "(ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date) >= 0"\n    ]\n\n    # Date range filter on START date (common operational interpretation)\n    if filters.get("start_date"):\n        where_parts.append(f"ms_1549_civil_construction_start_actual::date >= \'{_esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"ms_1549_civil_construction_start_actual::date <= \'{_esc(filters[\'end_date\'])}\'")\n\n    # Dimension filters\n    dim_filter_keys = [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_category",\n        "s_site_class"\n    ]\n    for k in dim_filter_keys:\n        if filters.get(k) is not None and filters.get(k) != "":\n            where_parts.append(f"{k} = \'{_esc(filters[k])}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    # Group-by dimensions (mandatory set + optional)\n    group_dims = ["rgn_region", "m_area", "m_market", "pj_general_contractor"]\n    optional_dims = []\n    if filters.get("group_by_por_category"):\n        optional_dims.append("por_category")\n    if filters.get("group_by_site_class"):\n        optional_dims.append("s_site_class")\n\n    group_dims_all = group_dims + optional_dims\n\n    select_dims_sql = ", ".join(group_dims_all) if group_dims_all else ""\n    group_by_sql = f"GROUP BY {\', \'.join(group_dims_all)}" if group_dims_all else ""\n    order_by_sql = f"ORDER BY {\', \'.join(group_dims_all)}" if group_dims_all else ""\n\n    if select_dims_sql:\n        select_prefix = select_dims_sql + ",\\n       "\n    else:\n        select_prefix = ""\n\n    sql = f"""\nWITH base AS (\n  SELECT\n    rgn_region,\n    m_area,\n    m_market,\n    pj_general_contractor,\n    por_category,\n    s_site_class,\n    (ms_1551_civil_construction_complete_actual_date::date - ms_1549_civil_construction_start_actual::date) AS civil_cycle_days\n  FROM public.stg_ndpd_mbt_tmobile_macro_combined\n  WHERE {where_sql}\n)\nSELECT\n       {select_prefix}COUNT(*) AS project_count,\n       AVG(civil_cycle_days)::numeric(18,2) AS avg_civil_cycle_days,\n       percentile_cont(0.5) WITHIN GROUP (ORDER BY civil_cycle_days) AS median_p50_civil_cycle_days,\n       percentile_cont(0.9) WITHIN GROUP (ORDER BY civil_cycle_days) AS p90_civil_cycle_days,\n       MAX(civil_cycle_days) AS max_civil_cycle_days\nFROM base\n{group_by_sql}\n{order_by_sql}\n""".strip()\n\n    return execute_query(sql)\n', kpi_source_columns: ['confirm_split_spo', 'ms_1549_civil_construction_start_actual', 'ms_1551_civil_construction_complete_actual_date', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class'], session_id: '69a3d22f26e208edc083a06e', label: 'Civil Cycle Time', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'b91a6e98-8c3f-4fae-a943-003665793220', entity_type: 'kpi', kpi_name: 'Civil Cycle Time', name: 'b91a6e98-8c3f-4fae-a943-003665793220', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class'], kpi_description: 'Measures the civil construction cycle time in calendar days for split-scope/civil-confirmed sites, used to monitor performance against the civil SLA target (<= 21 days). Results are summarized by market and general contractor (and related regional rollups).', status: 'mentioned', node_id: 'b91a6e98-8c3f-4fae-a943-003665793220'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Weekly GC Run Rate = COUNT(DISTINCT pj_project_id with non-null ms_1555_construction_complete_actual in trailing 84 days ending CURRENT_DATE) / 12', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension for grouping."}, {"column": "m_area", "type": "string", "description": "Area dimension for grouping."}, {"column": "m_market", "type": "string", "description": "Market dimension for grouping."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor dimension for grouping."}, {"column": "completed_projects_12w", "type": "int", "description": "Distinct count of completed projects in the selected (default trailing 12-week) window."}, {"column": "weekly_gc_run_rate", "type": "float", "description": "Average completed projects per week over 12 weeks (completed_projects_12w / 12)."}]', kpi_business_logic: '1) Start from project records.\n2) Keep only rows where ms_1555_construction_complete_actual is not null.\n3) Limit to completions in the trailing 12-week window: ms_1555_construction_complete_actual::date between (CURRENT_DATE - INTERVAL \'84 days\') and CURRENT_DATE (inclusive).\n4) Group by rgn_region, m_area, m_market, pj_general_contractor.\n5) For each group, compute completed_projects_12w = COUNT(DISTINCT pj_project_id).\n6) Compute weekly_gc_run_rate = completed_projects_12w / 12.\n7) If a (market, GC) has zero completions in the window, weekly_gc_run_rate is 0.', kpi_filters: '[{"name": "ms_1555_construction_complete_actual_is_not_null", "type": "date", "description": "Includes only projects with a non-null construction complete actual date."}, {"name": "trailing_12_weeks_window", "type": "date", "description": "Restricts ms_1555_construction_complete_actual::date to be between CURRENT_DATE - 84 days and CURRENT_DATE (inclusive)."}, {"name": "rgn_region", "type": "string", "description": "Optional filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional filter to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional filter to a specific general contractor."}, {"name": "start_date", "type": "date", "description": "If provided with end_date, overrides trailing window start for ms_1555_construction_complete_actual::date (>= start_date)."}, {"name": "end_date", "type": "date", "description": "If provided with start_date, overrides trailing window end for ms_1555_construction_complete_actual::date (<= end_date)."}]', kpi_contract: '{"function_name": "get_weekly_gc_run_rate", "node_type": "kpi", "node_id": "4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303", "node_label": "Weekly GC Run Rate", "description": "Measures observed construction throughput as a trailing-12-week average completions per week for each (Market, General Contractor) pair, anchored to CURRENT_DATE (snapshot). Per (m_market, pj_general_contractor): compute the number of distinct projects with construction complete in the last 12 weeks (inclusive window ending CURRENT_DATE), bucket completions by week using date_trunc(\'week\', ms_1555_construction_complete_actual::date), then compute run rate as: COUNT(DISTINCT pj_project_id) / 12. Include only rows where ms_1555_construction_complete_actual IS NOT NULL and ms_1555_construction_complete_actual::date >= (CURRENT_DATE - INTERVAL \'84 days\') (i.e., trailing 12 weeks). If a (market, GC) has zero completions in the trailing window, its run rate is 0 (no fallback to averages). Groupable by rgn_region, m_area, m_market, pj_general_contractor.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Weekly GC Run Rate (per region/area/market/GC) = count of distinct pj_project_id with non-null ms_1555_construction_complete_actual in the trailing 84 days ending CURRENT_DATE, divided by 12.', node_type: 'CORE', definition: 'Weekly GC Run Rate (per region/area/market/GC) = count of distinct pj_project_id with non-null ms_1555_construction_complete_actual in the trailing 84 days ending CURRENT_DATE, divided by 12.', kpi_python_function: 'def get_weekly_gc_run_rate(execute_query, filters=None) -> list[dict]:\n    """Trailing-12-week observed construction completion throughput per (region, area, market, GC).\n\n    Definition (per spec):\n      - Include only projects where ms_1555_construction_complete_actual is not null\n      - And ms_1555_construction_complete_actual::date >= CURRENT_DATE - INTERVAL \'84 days\'\n      - Run rate = COUNT(DISTINCT pj_project_id) / 12\n      - Anchored to CURRENT_DATE (snapshot)\n\n    Optional filters supported (if provided): rgn_region, m_area, m_market, pj_general_contractor, start_date, end_date.\n      - start_date/end_date override the trailing window if both provided; otherwise trailing window is used.\n    """\n\n    filters = filters or {}\n\n    # Prefer raw SQL here because Tier-1 accessors do not expose ms_1555_construction_complete_actual,\n    # and pushing date filtering/distinct counting to the DB avoids full-table pulls.\n\n    where_parts = [\n        "ms_1555_construction_complete_actual IS NOT NULL"\n    ]\n\n    # Window handling\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n    if start_date and end_date:\n        sd = str(start_date).replace("\'", "\'\'")\n        ed = str(end_date).replace("\'", "\'\'")\n        where_parts.append(f"ms_1555_construction_complete_actual::date >= \'{sd}\'::date")\n        where_parts.append(f"ms_1555_construction_complete_actual::date <= \'{ed}\'::date")\n    else:\n        where_parts.append("ms_1555_construction_complete_actual::date >= (CURRENT_DATE - INTERVAL \'84 days\')")\n        where_parts.append("ms_1555_construction_complete_actual::date <= CURRENT_DATE")\n\n    # Dimensional filters\n    for col in ("rgn_region", "m_area", "m_market", "pj_general_contractor"):\n        if filters.get(col) is not None and filters.get(col) != "":\n            val = str(filters[col]).replace("\'", "\'\'")\n            where_parts.append(f"{col} = \'{val}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n        WITH base AS (\n            SELECT\n                rgn_region,\n                m_area,\n                m_market,\n                pj_general_contractor,\n                pj_project_id,\n                date_trunc(\'week\', ms_1555_construction_complete_actual::date)::date AS completion_week\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\n            WHERE {where_sql}\n        ),\n        agg AS (\n            SELECT\n                rgn_region,\n                m_area,\n                m_market,\n                pj_general_contractor,\n                COUNT(DISTINCT pj_project_id) AS completed_projects_12w\n            FROM base\n            GROUP BY 1,2,3,4\n        )\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            pj_general_contractor,\n            completed_projects_12w,\n            (completed_projects_12w::numeric / 12.0) AS weekly_gc_run_rate\n        FROM agg\n        ORDER BY rgn_region, m_area, m_market, pj_general_contractor\n    """\n\n    rows = execute_query(sql)\n\n    # Ensure numeric stability in Python (and provide explicit 0s if any nulls slip through)\n    out = []\n    for r in rows:\n        completed = r.get("completed_projects_12w") or 0\n        run_rate = r.get("weekly_gc_run_rate")\n        if run_rate is None:\n            run_rate = float(completed) / 12.0\n        out.append({\n            "rgn_region": r.get("rgn_region"),\n            "m_area": r.get("m_area"),\n            "m_market": r.get("m_market"),\n            "pj_general_contractor": r.get("pj_general_contractor"),\n            "completed_projects_12w": int(completed),\n            "weekly_gc_run_rate": float(run_rate)\n        })\n\n    return out\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'pj_project_id', 'ms_1555_construction_complete_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Weekly GC Run Rate', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303', entity_type: 'kpi', kpi_name: 'Weekly GC Run Rate', name: '4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Measures observed construction throughput as a trailing 12-week average number of construction completions per week for each Market and General Contractor pair, anchored to the current date snapshot. This indicates recent delivery pace by contractor within a market.', status: 'mentioned', node_id: '4f4168bb-fda0-4a4b-8bf3-1c1fbafe6303'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Weekly GC Run Rate = COUNT(DISTINCT pj_project_id completed in trailing 12 weeks ending on evaluation_date) / 12.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping dimension."}, {"column": "weekly_gc_run_rate", "type": "float", "description": "Average completed sites per week over the trailing 12-week window (distinct completed projects / 12)."}, {"column": "completed_projects_trailing_12w", "type": "int", "description": "Count of distinct projects completed within the trailing 12-week window."}, {"column": "evaluation_date", "type": "string", "description": "Evaluation date used to define the trailing window (null when default CURRENT_DATE is used)."}]', kpi_business_logic: '1) Set evaluation_date (default CURRENT_DATE if not provided). 2) Filter records to those with ms_1555_construction_complete_actual not null and with ms_1555_construction_complete_actual::date >= (evaluation_date - 84 days) and < (evaluation_date + 1 day). 3) Group by rgn_region, m_area, m_market, pj_general_contractor. 4) Compute completed_projects_trailing_12w = COUNT(DISTINCT pj_project_id). 5) Compute weekly_gc_run_rate = completed_projects_trailing_12w / 12.', kpi_filters: '[{"name": "evaluation_date", "type": "date", "description": "Sets the end of the trailing 12-week window used to include completed projects (defaults to CURRENT_DATE if not provided)."}, {"name": "ms_1555_construction_complete_actual", "type": "date", "description": "Must be not null and fall within the trailing 84 days ending on evaluation_date (inclusive via < evaluation_date + 1 day)."}, {"name": "rgn_region", "type": "string", "description": "Optional dimension filter to restrict results to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional dimension filter to restrict results to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional dimension filter to restrict results to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional dimension filter to restrict results to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to restrict results to a specific project id."}]', kpi_contract: '{"function_name": "get_weekly_gc_run_rate", "node_type": "kpi", "node_id": "72e61595-33fb-4639-b09b-b20643936de0", "node_label": "Weekly GC Run Rate", "description": "Observed weekly throughput proxy per (m_market, pj_general_contractor) used as capacity input to the capacity-vs-demand gap.\\n\\nCalculation: COUNT(DISTINCT pj_project_id with ms_1555_construction_complete_actual in trailing 12 weeks)/12, where trailing 12 weeks is defined as ms_1555_construction_complete_actual::date >= (evaluation_date - INTERVAL \'84 days\') AND ms_1555_construction_complete_actual::date < evaluation_date + INTERVAL \'1 day\' (or <= evaluation_date).\\n\\nGroup by: rgn_region, m_area, m_market, pj_general_contractor.\\n\\nSource: stg_ndpd_mbt_tmobile_macro_combined.\\n\\nNotes: This is a historical run-rate (sites/week) and acts as a capacity proxy in absence of explicit crew counts.", "parameters": [{"name": "evaluation_date", "type": "date", "description": "Filter by evaluation date", "required": false, "sample_values": []}, {"name": "as_of_date", "type": "date", "description": "Filter by as of date", "required": false, "sample_values": []}, {"name": "date", "type": "date", "description": "Filter by date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "weekly_gc_run_rate", "type": "number", "nullable": false}, {"name": "completed_projects_trailing_12w", "type": "number", "nullable": false}, {"name": "evaluation_date", "type": "null", "nullable": true}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pj_general_contractor": "ews group", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pj_general_contractor": "impirium", "weekly_gc_run_rate": 0.08333333333333333, "completed_projects_trailing_12w": 1, "evaluation_date": null}], "row_count": 10}', nl_description: 'Weekly GC Run Rate = (count of distinct pj_project_id with ms_1555_construction_complete_actual in the trailing 84 days ending on evaluation_date) ÷ 12, grouped by rgn_region, m_area, m_market, and pj_general_contractor.', node_type: 'CORE', definition: 'Weekly GC Run Rate = (count of distinct pj_project_id with ms_1555_construction_complete_actual in the trailing 84 days ending on evaluation_date) ÷ 12, grouped by rgn_region, m_area, m_market, and pj_general_contractor.', kpi_python_function: 'def get_weekly_gc_run_rate(execute_query, filters=None) -> list[dict]:\n    """Weekly GC Run Rate (sites/week) per (rgn_region, m_area, m_market, pj_general_contractor).\n\n    Definition:\n      COUNT(DISTINCT pj_project_id completed in trailing 12 weeks) / 12\n    Trailing 12 weeks window (relative to evaluation_date):\n      ms_1555_construction_complete_actual::date >= (evaluation_date - INTERVAL \'84 days\')\n      AND ms_1555_construction_complete_actual::date < (evaluation_date + INTERVAL \'1 day\')\n\n    Expected filters (optional):\n      - evaluation_date (YYYY-MM-DD). If not provided, uses CURRENT_DATE.\n      - rgn_region, m_area, m_market, pj_general_contractor, pj_project_id\n      - start_date/end_date are ignored for this KPI (window is defined via evaluation_date)\n\n    Returns list[dict] grouped by region/area/market/gc.\n    """\n\n    filters = filters or {}\n\n    eval_date = filters.get("evaluation_date") or filters.get("as_of_date") or filters.get("date")\n    if eval_date is None:\n        eval_date_sql = "CURRENT_DATE"\n    else:\n        eval_date_escaped = str(eval_date).replace("\'", "\'\'")\n        eval_date_sql = f"DATE \'{eval_date_escaped}\'"\n\n    # Build additional WHERE clauses for dimension filtering (do NOT include evaluation_date)\n    where_parts = [\n        "ms_1555_construction_complete_actual IS NOT NULL",\n        f"(ms_1555_construction_complete_actual::date >= ({eval_date_sql} - INTERVAL \'84 days\'))",\n        f"(ms_1555_construction_complete_actual::date < ({eval_date_sql} + INTERVAL \'1 day\'))",\n    ]\n\n    allowed_dim_filters = {\n        "rgn_region": "rgn_region",\n        "m_area": "m_area",\n        "m_market": "m_market",\n        "pj_general_contractor": "pj_general_contractor",\n        "pj_project_id": "pj_project_id",\n    }\n\n    for fk, col in allowed_dim_filters.items():\n        if fk in filters and filters[fk] is not None and str(filters[fk]) != "":\n            v = str(filters[fk]).replace("\'", "\'\'")\n            where_parts.append(f"{col} = \'{v}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    # Raw SQL is used because the Tier-1 accessors do not expose ms_1555_construction_complete_actual\n    # and we need COUNT(DISTINCT ...) grouped with a date window.\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            pj_general_contractor,\n            (COUNT(DISTINCT pj_project_id)::numeric / 12.0) AS weekly_gc_run_rate,\n            COUNT(DISTINCT pj_project_id) AS completed_projects_trailing_12w\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        WHERE {where_sql}\n        GROUP BY rgn_region, m_area, m_market, pj_general_contractor\n    """.strip()\n\n    rows = execute_query(sql)\n\n    # Normalize output types\n    out = []\n    for r in rows or []:\n        out.append({\n            "rgn_region": r.get("rgn_region"),\n            "m_area": r.get("m_area"),\n            "m_market": r.get("m_market"),\n            "pj_general_contractor": r.get("pj_general_contractor"),\n            "weekly_gc_run_rate": float(r.get("weekly_gc_run_rate")) if r.get("weekly_gc_run_rate") is not None else None,\n            "completed_projects_trailing_12w": int(r.get("completed_projects_trailing_12w")) if r.get("completed_projects_trailing_12w") is not None else 0,\n            "evaluation_date": str(eval_date) if eval_date is not None else None,\n        })\n\n    return out\n', kpi_source_columns: ['pj_project_id', 'ms_1555_construction_complete_actual', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], session_id: '69a3d22f26e208edc083a06e', label: 'Weekly GC Run Rate', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '72e61595-33fb-4639-b09b-b20643936de0', entity_type: 'kpi', kpi_name: 'Weekly GC Run Rate', name: '72e61595-33fb-4639-b09b-b20643936de0', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Observed weekly throughput (sites/week) per market and general contractor, used as a capacity proxy input to a capacity-vs-demand gap analysis when explicit crew counts are not available.', status: 'mentioned', node_id: '72e61595-33fb-4639-b09b-b20643936de0'});
