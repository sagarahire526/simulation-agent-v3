_area, m_market, pj_general_contractor.\n2) Plan Achievement %: denom = COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NOT NULL; num = COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL; plan_achievement_pct = 100*num/denom; if denom=0 return NULL.\n3) Avg CX Cycle Days: for projects with ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL, compute (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) and average.\n4) FTR Rate %: denom = COUNT(DISTINCT pj_project_id) where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL; num = COUNT(DISTINCT pj_project_id) where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL AND first_time_right=\'Yes\'; ftr_rate_pct = 100*num/denom; if denom=0 return NULL.\n5) Active Backlog (WIP): COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NULL.\n6) On-Air Pending: COUNT(DISTINCT pj_project_id) where ms_1555_construction_complete_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL.\n7) Output one row per group with these measures as columns.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Filter to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Filter to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Filter to a specific site."}, {"name": "pj_project_status", "type": "string", "description": "Filter to a specific project status."}, {"name": "pj_project_type