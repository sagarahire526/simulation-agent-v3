      "(ms_1507_tower_ntp_approved_actual IS NOT NULL OR \\"pj_a_4100_construction_ntp_accepted_by_gc_finish\\" IS NOT NULL)",\n        "\\"pj_a_3925_msI_pickup_date_finish\\" IS NOT NULL",\n        "\\"pj_a_4525_power_ready_finish\\" IS NOT NULL",\n        "(\\"pj_a_4925_aav_fiber_ready_finish\\" IS NOT NULL OR \\"pj_a_4425_mw_installation_complete_finish\\" IS NOT NULL)"\n    ]\n\n    # Optional user filters (kept flexible)\n    filters = filters or {}\n\n    # Common dimension filters\n    if filters.get("rgn_region") is not None:\n        where_parts.append(f"rgn_region = \'{_sql_escape(filters[\'rgn_region\'])}\'")\n    if filters.get("m_area") is not None:\n        where_parts.append(f"m_area = \'{_sql_escape(filters[\'m_area\'])}\'")\n    if filters.get("m_market") is not None:\n        where_parts.append(f"m_market = \'{_sql_escape(filters[\'m_market\'])}\'")\n    if filters.get("pj_general_contractor") is not None:\n        where_parts.append(f"pj_general_contractor = \'{_sql_escape(filters[\'pj_general_contractor\'])}\'")\n    if filters.get("pj_project_id") is not None:\n        where_parts.append(f"pj_project_id = \'{_sql_escape(filters[\'pj_project_id\'])}\'")\n    if filters.get("s_site_id") is not None:\n        where_parts.append(f"s_site_id = \'{_sql_escape(filters[\'s_site_id\'])}\'")\n\n    # Optional date window: apply against construction-start actual (even though NULL),\n    # so instead apply to a readiness anchor if provided.\n    # Use MSI pickup finish as the anchor (earliest hard readiness gate in this KPI).\n    if filters.get("start_date") is not None:\n        where_parts.append(f"\\"pj_a_3925_msi_pickup_date_finish\\" >= \'{_sql_escape(filters[\'start_date\'])}\'")\n    if filters.get("end_date") is not None:\n        where_parts.append(f"\\"pj_a_3925_msi_pickup_date_finish\\" < \'{_sql_escape(filters[\'end_date\'])}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  rgn_region, "\n        "  m_area, "\n        "  m_market, "\n        "  pj_general_contractor, "\n        "  COUNT(DISTINCT pj_project_id) AS ready_site_backlog "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"WHERE {where_sql} "\n        "GROUP BY rgn_region, m_area, m_market, pj_general_contractor "\n        "ORDER BY rgn_region, m_area, m_market, pj_general_contractor"\n    )\n\n    rows = execute_query(sql, db=None, max_rows=None) or []\n\n    # Normalize output keys\n    out = []\n    for r in rows:\n        out.append({\n            "rgn_region": r.get("rgn_region"),\n            "m_area": r.get("m_area"),\n            "m_market": r.get("m_market"),\n            "pj_general_contractor": r.get("pj_general_contractor"),\n            "ready_site_backlog": r.get("ready_site_backlog")\n        })\n    return out\n', kpi_source_columns: ['pj_project_id', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msi_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], session_id: '69a3d22f26e208edc083a06e', label: 'Ready Site Backlog', kpi_related_core_node_ids: ['project', 'market', 'general_contractor', 'milestone'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '656de982-3668-41a9-bbcf-2a1fb4a75979', entity_type: 'kpi', kpi_name: 'Ready Site Backlog', name: '656de982-3668-41a9-bbcf-2a1fb4a75979', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Counts projects that are ready for construction start but have not started yet. Interpreted as a demand signal representing ready-to-start work waiting for crews.', status: 'mentioned', node_id: '656de982-3668-41a9-bbcf-2a1fb4a75979'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NULL and all readiness gates (NTP, material, power, backhaul) are satisfied; grouped by rgn_region, m_area, m_market, pj_general_contractor.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor dimension."}, {"column": "ready_site_backlog", "type": "int", "description": "Count of distinct ready-but-not-started projects in the group."}]', kpi_business_logic: '1) Start from the combined project dataset as of CURRENT_DATE (snapshot).\n2) Keep rows where ms_1550_construction_start_actual IS NULL.\n3) Require NTP cleared: ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL.\n4) Require material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL.\n5) Require power ready: pj_a_4525_power_ready_finish IS NOT NULL.\n6) Require backhaul ready: pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL.\n7) Apply optional equality filters when provided for: rgn_region, m_area, m_market, pj_general_contractor, pj_project_id, s_site_id, pj_program_name, pj_project_status, pj_project_type. Ignore start_date/end_date filters.\n8) Group by rgn_region, m_area, m_market, pj_general_contractor.\n9) Output COUNT(DISTINCT pj_project_id) as ready_site_backlog.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Filter results to a specific region."}, {"name": "m_area", "type": "string", "description": "Filter results to a specific area."}, {"name": "m_market", "type": "string", "description": "Filter results to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Filter results to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Filter results to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Filter results to a specific site."}, {"name": "pj_program_name", "type": "string", "description": "Filter results to a specific program."}, {"name": "pj_project_status", "type": "string", "description": "Filter results to a specific project status."}, {"name": "pj_project_type", "type": "string", "description": "Filter results to a specific project type."}]', kpi_contract: '{"function_name": "get_ready_site_backlog", "node_type": "kpi", "node_id": "5976040b-71f0-4f2b-a57e-8db52d8c853d", "node_label": "Ready Site Backlog", "description": "Counts ready-but-not-started projects per (Market, General Contractor) as-of CURRENT_DATE. Demand definition: COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual IS NULL AND all readiness gates are met:\\n1) NTP cleared: (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)\\n2) Material picked up: pj_a_3925_msi_pickup_date_finish IS NOT NULL\\n3) Power ready: pj_a_4525_power_ready_finish IS NOT NULL\\n4) Backhaul ready: (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)\\nThis is a CURRENT_DATE snapshot (no time series). Groupable by rgn_region, m_area, m_market, pj_general_contractor. Entities involved: Project (pj_project_id) joined to Market (m_market/m_area/rgn_region) and General Contractor (pj_general_contractor) via the shared combined table.", "parameters": [], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "ready_site_backlog", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "uci", "ready_site_backlog": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "DETROIT", "pj_general_contractor": "nwtp solutions", "ready_site_backlog": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "INDIANAPOLIS", "pj_general_contractor": "impirium", "ready_site_backlog": 1}], "row_count": 10}', nl_description: 'Ready Site Backlog = count of distinct Project IDs where construction start actual is NULL and the NTP/material/power/backhaul readiness gates are all satisfied, grouped by (region, area, market, general contractor).', node_type: 'CORE', definition: 'Ready Site Backlog = count of distinct Project IDs where construction start actual is NULL and the NTP/material/power/backhaul readiness gates are all satisfied, grouped by (region, area, market, general contractor).', kpi_python_function: 'def get_ready_site_backlog(execute_query, filters=None) -> list[dict]:\n    """Counts ready-but-not-started projects per (rgn_region, m_area, m_market, pj_general_contractor) as-of CURRENT_DATE.\n\n    Demand definition:\n      COUNT(DISTINCT pj_project_id)\n      WHERE ms_1550_construction_start_actual IS NULL\n        AND NTP cleared\n        AND material picked up\n        AND power ready\n        AND backhaul ready\n\n    Notes:\n      - Uses raw SQL because readiness gates require milestone/date columns that are not exposed by Tier-1 accessors.\n      - Filters are applied as additional WHERE predicates when provided.\n    """\n\n    filters = filters or {}\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Only allow filters that can be applied to this KPI query.\n    allowed_filter_cols = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "pj_project_id",\n        "s_site_id",\n        "pj_program_name",\n        "pj_project_status",\n        "pj_project_type",\n    }\n\n    where_parts = []\n\n    # Optional entity filters\n    for k, v in filters.items():\n        if v is None:\n            continue\n        if k in ("start_date", "end_date"):\n            # This KPI is defined as a CURRENT_DATE snapshot; ignore date-range filters.\n            continue\n        if k not in allowed_filter_cols:\n            continue\n        where_parts.append(f"{k} = \'{_esc(v)}\'")\n\n    # Base readiness logic\n    where_parts.append("ms_1550_construction_start_actual IS NULL")\n\n    # 1) NTP cleared\n    where_parts.append("(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)")\n\n    # 2) Material picked up\n    where_parts.append(\'"pj_a_3925_msI_pickup_date_finish" IS NOT NULL\')\n\n    # 3) Power ready\n    where_parts.append("pj_a_4525_power_ready_finish IS NOT NULL")\n\n    # 4) Backhaul ready\n    where_parts.append("(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)")\n\n    where_sql = " AND ".join(where_parts) if where_parts else "TRUE"\n\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            pj_general_contractor,\n            COUNT(DISTINCT pj_project_id) AS ready_site_backlog\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        WHERE {where_sql}\n        GROUP BY rgn_region, m_area, m_market, pj_general_contractor\n        ORDER BY rgn_region, m_area, m_market, pj_general_contractor\n    """.strip()\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msi_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 's_site_id', 'pj_program_name', 'pj_project_status', 'pj_project_type'], session_id: '69a3d22f26e208edc083a06e', label: 'Ready Site Backlog', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '5976040b-71f0-4f2b-a57e-8db52d8c853d', entity_type: 'kpi', kpi_name: 'Ready Site Backlog', name: '5976040b-71f0-4f2b-a57e-8db52d8c853d', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Counts projects that are ready to start construction but have not yet started, shown by market and general contractor as of the current date. This helps quantify construction-ready demand/backlog by geography and GC.', status: 'mentioned', node_id: '5976040b-71f0-4f2b-a57e-8db52d8c853d'});
