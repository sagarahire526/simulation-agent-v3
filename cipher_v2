ady_days": null, "p50_pre_ntp_to_scoping_ready_days": null, "avg_scoping_ready_to_validated_days": 11.4, "p50_scoping_ready_to_validated_days": 11.0, "avg_full_scoping_cycle_days": null, "p50_full_scoping_cycle_days": null, "pending_scoping_count": 0, "scoping_ftr_pct": null, "scoping_ftr_numerator_completed_ftr": 0, "scoping_ftr_denominator_completed": 0, "project_count_in_cohort": 19}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "avg_pre_ntp_to_scoping_ready_days": 15.0, "p50_pre_ntp_to_scoping_ready_days": 15.0, "avg_scoping_ready_to_validated_days": 5.0, "p50_scoping_ready_to_validated_days": 5.0, "avg_full_scoping_cycle_days": 1.0, "p50_full_scoping_cycle_days": 1.0, "pending_scoping_count": 1, "scoping_ftr_pct": null, "scoping_ftr_numerator_completed_ftr": 0, "scoping_ftr_denominator_completed": 0, "project_count_in_cohort": 19}], "row_count": 10}', nl_description: 'KPI = per (rgn_region, m_area, m_market) (optionally pj_general_contractor) scorecard where cycle-time measures are AVG/P50 of non-negative day differences between milestone dates (ms_1323-ms_1310, ms_1327-ms_1323, ms_1327-ms_1310), backlog is count of Active projects with ms_1310 present and ms_1327 null, and quality is scoping FTR% = 100×(completed with rcm_ftr=\'option1\')/(completed), joined to markets via rcm_site_id→s_site_id when possible.', node_type: 'CORE', definition: 'KPI = per (rgn_region, m_area, m_market) (optionally pj_general_contractor) scorecard where cycle-time measures are AVG/P50 of non-negative day differences between milestone dates (ms_1323-ms_1310, ms_1327-ms_1323, ms_1327-ms_1310), backlog is count of Active projects with ms_1310 present and ms_1327 null, and quality is scoping FTR% = 100×(completed with rcm_ftr=\'option1\')/(completed), joined to markets via rcm_site_id→s_site_id when possible.', kpi_python_function: 'def get_scoping_cycle_time_quality(execute_query, filters=None) -> list[dict]:\n    """Per-market (region/area/market) scorecard KPI for scoping cycle time, backlog, and FTR quality.\n\n    Filters supported (optional):\n      - rgn_region, m_area, m_market\n      - pj_general_contractor\n      - start_date, end_date: applied to ms_1310 (package received) for cycle/backlog measures\n      - rcm_assignee: drilldown for FTR\n      - ftr_join_mode: \'site\' (default) to inherit macro market via rcm_site_id->s_site_id; \'rcm\' to group by (rcm_region, rcm_market)\n\n    Returns: list of dict rows at grain (rgn_region, m_area, m_market, pj_general_contractor?) with multiple measures.\n    """\n\n    filters = filters or {}\n\n    # -----------------------------\n    # Helpers\n    # -----------------------------\n    from datetime import datetime, date\n\n    def _parse_date(x):\n        if x is None:\n            return None\n        if isinstance(x, date) and not isinstance(x, datetime):\n            return x\n        if isinstance(x, datetime):\n            return x.date()\n        s = str(x).strip()\n        if not s:\n            return None\n        # Handle common formats: \'YYYY-MM-DD\', \'YYYY-MM-DD HH:MM:SS\', ISO\n        try:\n            return datetime.fromisoformat(s.replace(\'Z\', \'\')).date()\n        except Exception:\n            # fallback: take first 10 chars if looks like date\n            try:\n                return datetime.strptime(s[:10], \'%Y-%m-%d\').date()\n            except Exception:\n                return None\n\n    def _days_diff(d2, d1):\n        # d2 - d1 in days\n        if d1 is None or d2 is None:\n            return None\n        return (d2 - d1).days\n\n    def _percentile_cont(sorted_vals, p):\n        # Continuous percentile like Postgres percentile_cont\n        n = len(sorted_vals)\n        if n == 0:\n            return None\n        if n == 1:\n            return float(sorted_vals[0])\n        if p <= 0:\n            return float(sorted_vals[0])\n        if p >= 1:\n            return float(sorted_vals[-1])\n        pos = (n - 1) * p\n        lo = int(pos)\n        hi = lo + 1\n        if hi >= n:\n            return float(sorted_vals[lo])\n        frac = pos - lo\n        return float(sorted_vals[lo] + (sorted_vals[hi] - sorted_vals[lo]) * frac)\n\n    def _in_date_range(d, start_d, end_d):\n        if d is None:\n            return False\n        if start_d and d < start_d:\n            return False\n        if end_d and d > end_d:\n            return False\n        return True\n\n    # -----------------------------\n    # Load macro project rows (Tier 2: raw SQL needed because milestone date columns are not exposed by Tier-1 accessors)\n    # -----------------------------\n    start_d = _parse_date(filters.get(\'start_date\'))\n    end_d = _parse_date(filters.get(\'end_date\'))\n\n    where = []\n    if filters.get(\'rgn_region\'):\n        v = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n        where.append(f"rgn_region = \'{v}\'")\n    if filters.get(\'m_area\'):\n        v = str(filters[\'m_area\']).replace("\'", "\'\'")\n        where.append(f"m_area = \'{v}\'")\n    if filters.get(\'m_market\'):\n        v = str(filters[\'m_market\']).replace("\'", "\'\'")\n        where.append(f"m_market = \'{v}\'")\n    if filters.get(\'pj_general_contractor\'):\n        v = str(filters[\'pj_general_contractor\']).replace("\'", "\'\'")\n        where.append(f"pj_general_contractor = \'{v}\'")\n    # Note: start/end date are applied after fetch (to ms_1310), to avoid casting issues and keep logic explicit.\n\n    where_sql = ("WHERE " + " AND ".join(where)) if where else ""\n\n    macro_sql = (\n        "SELECT "\n        "  pj_project_id, pj_project_status, pj_general_contractor, "\n        "  rgn_region, m_area, m_market, "\n        "  s_site_id, "\n        "  ms_1310_pre_construction_package_received_actual, "\n        "  ms_1323_ready_for_scoping_actual, "\n        "  ms_1327_scoping_and_quoting_package_validated_actual "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"{where_sql}"\n    )\n\n    macro_rows = execute_query(macro_sql)\n\n    # Build site->(region,area,market,gc) mapping for FTR join option A\n    site_dim = {}\n    for r in macro_rows:\n        site_id = r.get(\'s_site_id\')\n        if site_id and site_id not in site_dim:\n            site_dim[site_id] = {\n                \'rgn_region\': r.get(\'rgn_region\'),\n                \'m_area\': r.get(\'m_area\'),\n                \'m_market\': r.get(\'m_market\'),\n                \'pj_general_contractor\': r.get(\'pj_general_contractor\')\n            }\n\n    # -----------------------------\n    # Compute cycle-time and backlog measures per group\n    # Grouping = (rgn_region, m_area, m_market) + optionally pj_general_contractor if provided as drilldown\n    # -----------------------------\n    drill_gc = bool(filters.get(\'pj_general_contractor\'))\n\n    groups = {}  # key -> accumulator\n    for r in macro_rows:\n        pj_project_id = r.get(\'pj_project_id\')\n        if not pj_project_id:\n            continue\n\n        region = r.get(\'rgn_region\')\n        area = r.get(\'m_area\')\n        market = r.get(\'m_market\')\n        gc = r.get(\'pj_general_contractor\')\n\n        key = (region, area, market, gc) if drill_gc else (region, area, market)\n        if key not in groups:\n            groups[key] = {\n                \'projects_seen\': set(),\n                \'pre_to_ready_diffs\': [],\n                \'ready_to_val_diffs\': [],\n                \'full_cycle_diffs\': [],\n                \'pending_projects\': set()\n            }\n\n        acc = groups[key]\n        acc[\'projects_seen\'].add(pj_project_id)\n\n        d1310 = _parse_date(r.get(\'ms_1310_pre_construction_package_received_actual\'))\n        d1323 = _parse_date(r.get(\'ms_1323_ready_for_scoping_actual\'))\n        d1327 = _parse_date(r.get(\'ms_1327_scoping_and_quoting_package_validated_actual\'))\n\n        # Optional date filtering applied on package received date (ms_1310)\n        if (start_d or end_d):\n            # only include rows where ms_1310 exists and falls in range\n            if not _in_date_range(d1310, start_d, end_d):\n                # still allow pending backlog? spec says backlog component primary source; keep consistent with same cohort\n                continue\n\n        # Pre-NTP to Scoping Ready\n        diff = _days_diff(d1323, d1310)\n        if diff is not None and diff >= 0:\n            acc[\'pre_to_ready_diffs\'].append(diff)\n\n        # Scoping Ready to Validated\n        diff = _days_diff(d1327, d1323)\n        if diff is not None and diff >= 0:\n            acc[\'ready_to_val_diffs\'].append(diff)\n\n        # Full Scoping Cycle\n        diff = _days_diff(d1327, d1310)\n        if diff is not None and diff >= 0:\n            acc[\'full_cycle_diffs\'].append(diff)\n\n        # Pending Scoping Count\n        if (r.get(\'pj_project_status\') == \'Active\') and (d1310 is not None) and (d1327 is None):\n            acc[\'pending_projects\'].add(pj_project_id)\n\n    # -----------------------------\n    # Load RCM rows and compute FTR\n    # -----------------------------\n    ftr_join_mode = (filters.get(\'ftr_join_mode\') or \'site\').lower().strip()  # \'site\' or \'rcm\'\n\n    rcm_filters = {}\n    # Pass-through entity filters when possible\n    if filters.get(\'rcm_assignee\'):\n        rcm_filters[\'rcm_assignee\'] = filters.get(\'rcm_assignee\')\n    if filters.get(\'m_market\') and ftr_join_mode == \'rcm\':\n        # only applies if ftr_join_mode=\'rcm\' and rcm_market exists\n        rcm_filters[\'rcm_market\'] = filters.get(\'m_market\')\n    if filters.get(\'rgn_region\') and ftr_join_mode == \'rcm\':\n        rcm_filters[\'rcm_region\'] = filters.get(\'rgn_region\')\n\n    rcm_rows = get_scoping_package(execute_query, rcm_filters)\n\n    ftr_groups = {}  # key -> {\'num\': int, \'den\': int}\n    for r in rcm_rows:\n        state = r.get(\'rcm_state\')\n        if state != \'completed\':\n            continue\n\n        # denominator always counts completed\n        if ftr_join_mode == \'site\':\n            site_id = r.get(\'rcm_site_id\')\n            dim = site_dim.get(site_id) if site_id else None\n            if not dim:\n                # if we cannot map to macro market, skip rather than mis-attribute\n                continue\n            region = dim.get(\'rgn_region\')\n            area = dim.get(\'m_area\')\n            market = dim.get(\'m_market\')\n            gc = dim.get(\'pj_general_contractor\')\n            key = (region, area, market, gc) if drill_gc else (region, area, market)\n        else:\n            # \'rcm\' mode: grouped by (rcm_region, rcm_market); m_area is unknown -> None\n            region = r.get(\'rcm_region\')\n            market = r.get(\'rcm_market\')\n            area = None\n            gc = None\n            key = (region, area, market, gc) if drill_gc else (region, area, market)\n\n        if key not in ftr_groups:\n            ftr_groups[key] = {\'num\': 0, \'den\': 0}\n\n        ftr_groups[key][\'den\'] += 1\n        if r.get(\'rcm_ftr\') == \'option1\':\n            ftr_groups[key][\'num\'] += 1\n\n    # -----------------------------\n    # Assemble output\n    # -----------------------------\n    out = []\n    for key, acc in groups.items():\n        if drill_gc:\n            region, area, market, gc = key\n        else:\n            region, area, market = key\n            gc = None\n\n        def _avg(vals):\n            return (sum(vals) / len(vals)) if vals else None\n\n        pre_sorted = sorted(acc[\'pre_to_ready_diffs\'])\n        rtv_sorted = sorted(acc[\'ready_to_val_diffs\'])\n        full_sorted = sorted(acc[\'full_cycle_diffs\'])\n\n        ftr = ftr_groups.get(key, {\'num\': 0, \'den\': 0})\n        ftr_pct = (100.0 * ftr[\'num\'] / ftr[\'den\']) if ftr[\'den\'] else None\n\n        row = {\n            \'rgn_region\': region,\n            \'m_area\': area,\n            \'m_market\': market,\n            \'avg_pre_ntp_to_scoping_ready_days\': _avg(pre_sorted),\n            \'p50_pre_ntp_to_scoping_ready_days\': _percentile_cont(pre_sorted, 0.5),\n            \'avg_scoping_ready_to_validated_days\': _avg(rtv_sorted),\n            \'p50_scoping_ready_to_validated_days\': _percentile_cont(rtv_sorted, 0.5),\n            \'avg_full_scoping_cycle_days\': _avg(full_sorted),\n            \'p50_full_scoping_cycle_days\': _percentile_cont(full_sorted, 0.5),\n            \'pending_scoping_count\': len(acc[\'pending_projects\']),\n            \'scoping_ftr_pct\': ftr_pct,\n            \'scoping_ftr_numerator_completed_ftr\': ftr[\'num\'],\n            \'scoping_ftr_denominator_completed\': ftr[\'den\'],\n            \'project_count_in_cohort\': len(acc[\'projects_seen\'])\n        }\n        if drill_gc:\n            row[\'pj_general_contractor\'] = gc\n        out.append(row)\n\n    # Include any FTR-only groups that didn\'t exist in macro cohort (optional, but useful in \'rcm\' mode)\n    # Only add when ftr_join_mode != \'site\' (otherwise groups should generally align to macro table).\n    if ftr_join_mode != \'site\':\n        existing_keys = set(groups.keys())\n        for key, ftr in ftr_groups.items():\n            if key in existing_keys:\n                continue\n            if drill_gc:\n                region, area, market, gc = key\n            else:\n                region, area, market = key\n                gc = None\n            ftr_pct = (100.0 * ftr[\'num\'] / ftr[\'den\']) if ftr[\'den\'] else None\n            row = {\n                \'rgn_region\': region,\n                \'m_area\': area,\n                \'m_market\': market,\n                \'avg_pre_ntp_to_scoping_ready_days\': None,\n                \'p50_pre_ntp_to_scoping_ready_days\': None,\n                \'avg_scoping_ready_to_validated_days\': None,\n                \'p50_scoping_ready_to_validated_days\': None,\n                \'avg_full_scoping_cycle_days\': None,\n                \'p50_full_scoping_cycle_days\': None,\n                \'pending_scoping_count\': 0,\n                \'scoping_ftr_pct\': ftr_pct,\n                \'scoping_ftr_numerator_completed_ftr\': ftr[\'num\'],\n                \'scoping_ftr_denominator_completed\': ftr[\'den\'],\n                \'project_count_in_cohort\': 0\n            }\n            if drill_gc:\n                row[\'pj_general_contractor\'] = gc\n            out.append(row)\n\n    # Stable sort\n    def _s(x):\n        return (x.get(\'rgn_region\') or \'\', x.get(\'m_area\') or \'\', x.get(\'m_market\') or \'\', x.get(\'pj_general_contractor\') or \'\')\n\n    out.sort(key=_s)\n    return out\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'pj_project_id', 'pj_project_status', 's_site_id', 'ms_1310_pre_construction_package_received_actual', 'ms_1323_ready_for_scoping_actual', 'ms_1327_scoping_and_quoting_package_validated_actual', 'rcm_state', 'rcm_ftr', 'rcm_site_id', 'rcm_region', 'rcm_market', 'rcm_assignee'], session_id: '69a3d22f26e208edc083a06e', label: 'Scoping Cycle Time & Quality', kpi_related_core_node_ids: ['project', 'site', 'scoping_package', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '9308cdae-49ee-4686-a0f8-c338053aedb5', entity_type: 'kpi', kpi_name: 'Scoping Cycle Time & Quality', name: '9308cdae-49ee-4686-a0f8-c338053aedb5', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Grouped scorecard KPI measuring scoping lifecycle speed, backlog, and first-time-right (FTR) quality. It is used to assess how quickly scoping progresses, how much scoping work is pending, and the quality of completed scoping outcomes.', status: 'mentioned', node_id: '9308cdae-49ee-4686-a0f8-c338053aedb5'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_rejection_data_last_30_days', 'public.stg_nas_session_level_combined_data'], nl_business_rule: '', kpi_formula_description: 'checkout_rejection_rate_pct = (COUNT(DISTINCT rejected checkout sessions) / COUNT(DISTINCT sessions that reached checkout gate)) * 100; also produces distinct-session counts by check-in and check-out rejection reason.', kpi_output_schema: '[{"column": "result_set", "type": "string", "description": "Discriminator for which result set the row belongs to: \'A\' (rate scorecard) or \'B\' (reason breakdown)."}, {"column": "nas_rej_region", "type": "string", "description": "Rejection region."}, {"column": "nas_rej_market", "type": "string", "description": "Rejection market (also used to align/join to session market)."}, {"column": "checkout_rejection_count", "type": "int", "description": "Distinct rejected sessions with a non-null checkout rejection reason (Result set A only)."}, {"column": "checkin_rejection_count", "type": "int", "description": "Distinct rejected sessions with a non-null check-in rejection reason (Result set A only)."}, {"column": "total_rejection_sessions", "type": "int", "description": "Distinct rejected sessions in the filtered rejection dataset (Result set A only)."}, {"column": "total_completed_sessions", "type": "int", "description": "Distinct sessions that reached checkout gate in the filtered session dataset (Result set A only)."}, {"column": "checkout_rejection_rate_pct", "type": "float", "description": "Checkout rejection percentage = checkout_rejection_count / total_completed_sessions * 100; NULL when total_completed_sessions = 0 (Result set A only)."}, {"column": "reason_type", "type": "string", "description": "Reason category: \'checkin\' or \'checkout\' (Result set B only)."}, {"column": "reason_value", "type": "string", "description": "Rejection reason value from the corresponding reason column (Result set B only)."}, {"column": "reason_count", "type": "int", "description": "Distinct rejected sessions for the given reason (Result set B only)."}]', kpi_business_logic: '1) (Optional) Apply date range filters.\n2) From stg_nas_rejection_data_last_30_days, filter by nas_rej_rejection_time within the date range; group by nas_rej_region, nas_rej_market.\n3) Compute: checkout_rejection_count = COUNT(DISTINCT nas_rej_sessionid) where nas_rej_checkout_reject_reason IS NOT NULL; checkin_rejection_count = COUNT(DISTINCT nas_rej_sessionid) where nas_rej_checkin_reject_reason IS NOT NULL; total_rejection_sessions = COUNT(DISTINCT nas_rej_sessionid).\n4) Build denominator from stg_nas_session_level_combined_data: keep sessions that reached checkout gate (nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL) and whose COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) is within the same date range; group by nas_market (treated as nas_rej_market) and compute total_completed_sessions = COUNT(DISTINCT nas_session_id).\n5) Left join numerator to denominator on nas_rej_market.\n6) Compute checkout_rejection_rate_pct = (checkout_rejection_count / total_completed_sessions) * 100; if total_completed_sessions = 0 return NULL.\n7) Reason breakdown: using the same rejection-table date filter, emit rows grouped by nas_rej_region, nas_rej_market, reason_type, reason_value where reason_type is \'checkin\' with reason_value = nas_rej_checkin_reject_reason (non-null) and \'checkout\' with reason_value = nas_rej_checkout_reject_reason (non-null); reason_count = COUNT(DISTINCT nas_rej_sessionid).', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Lower bound (inclusive) for filtering nas_rej_rejection_time in the rejection table and COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) in the session table."}, {"name": "end_date", "type": "date", "description": "Upper bound (exclusive) for filtering nas_rej_rejection_time in the rejection table and COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) in the session table."}, {"name": "nas_rej_*", "type": "string", "description": "Optional drill-down equality filters applied to the rejection table (any filter key starting with \'nas_rej_\')."}, {"name": "session_table_*", "type": "string", "description": "Optional drill-down equality filters applied to the session table for non-\'nas_rej_\' keys (e.g., nas_session_id, nas_market)."}]', kpi_contract: '{"function_name": "get_nas_checkout_rejection", "node_type": "kpi", "node_id": "41414556-b0ca-4b2c-8acd-4214a700b491", "node_label": "NAS Checkout Rejection", "description": "Measures NAS session rejection and rework signals by market/region, including checkout-gate rejection rate and rejection reason breakdown. Use `stg_nas_rejection_data_last_30_days` (rejections) joined to `stg_nas_session_level_combined_data` (session denominator) on `nas_rej_sessionid = nas_session_id`. Accept optional date range parameters `(start_date, end_date)`.\\n\\nResult set A \\u2014 Rate scorecard (one row per `nas_rej_region, nas_rej_market`):\\n- Population: rows from `stg_nas_rejection_data_last_30_days` where `nas_rej_rejection_time` is within the optional date range.\\n- `checkout_rejection_count`: COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkout_reject_reason IS NOT NULL).\\n- `checkin_rejection_count`: COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkin_reject_reason IS NOT NULL).\\n- `total_rejection_sessions`: COUNT(DISTINCT nas_rej_sessionid) over the filtered rejection dataset.\\n- Denominator population: `stg_nas_session_level_combined_data` rows where the session reached checkout gate, defined as `(nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL)` AND `COALESCE(nas_checkout_approve_time, nas_checkout_reject_time)` falls within the same optional date range.\\n- `total_completed_sessions`: COUNT(DISTINCT nas_session_id) over the filtered denominator population, grouped by the session market mapped to rejection market (use `nas_market` for grouping, aligned to `nas_rej_market`).\\n- `checkout_rejection_rate_pct`: `checkout_rejection_count / total_completed_sessions * 100`, with divide-by-zero protection (return NULL when `total_completed_sessions = 0`).\\n\\nResult set B \\u2014 Reason breakdown (one row per `nas_rej_region, nas_rej_market, reason_type, reason_value`):\\n- Filter by the same optional date range on `nas_rej_rejection_time`.\\n- Emit one row for each distinct reason value with counts:\\n  - For check-in: `reason_type=\'checkin\'`, `reason_value=nas_rej_checkin_reject_reason`, `reason_count=COUNT(DISTINCT nas_rej_sessionid)` (or COUNT(*) if you prefer event-count; default is distinct sessions).\\n  - For check-out: `reason_type=\'checkout\'`, `reason_value=nas_rej_checkout_reject_reason`, `reason_count=COUNT(DISTINCT nas_rej_sessionid)`.\\n\\nDefault behavior when no date parameters are supplied: compute over all available data in both tables. Supports drill-down by adding optional dimensions (e.g., `nas_rej_userid`, `nas_rej_siteid`) without changing core definitions.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "result_set", "type": "string", "nullable": false}, {"name": "nas_rej_region", "type": "string", "nullable": false}, {"name": "nas_rej_market", "type": "string", "nullable": false}, {"name": "checkout_rejection_count", "type": "number", "nullable": false}, {"name": "checkin_rejection_count", "type": "number", "nullable": false}, {"name": "total_rejection_sessions", "type": "number", "nullable": false}, {"name": "total_completed_sessions", "type": "number", "nullable": false}, {"name": "checkout_rejection_rate_pct", "type": "string", "nullable": false}, {"name": "reason_type", "type": "null", "nullable": true}, {"name": "reason_value", "type": "null", "nullable": true}, {"name": "reason_count", "type": "null", "nullable": true}], "sample_output": [{"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Chicago", "checkout_rejection_count": 15, "checkin_rejection_count": 8, "total_rejection_sessions": 19, "total_completed_sessions": 15, "checkout_rejection_rate_pct": "100.00000000000000000000", "reason_type": null, "reason_value": null, "reason_count": null}, {"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Cincinnati", "checkout_rejection_count": 13, "checkin_rejection_count": 12, "total_rejection_sessions": 19, "total_completed_sessions": 15, "checkout_rejection_rate_pct": "86.66666666666666666700", "reason_type": null, "reason_value": null, "reason_count": null}, {"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Cleveland", "checkout_rejection_count": 16, "checkin_rejection_count": 15, "total_rejection_sessions": 19, "total_completed_sessions": 17, "checkout_rejection_rate_pct": "94.11764705882352941200", "reason_type": null, "reason_value": null, "reason_count": null}], "row_count": 10}', nl_description: 'KPI = f(Integration Activity sessions, NAS rejection events) where checkout rejection rate by (nas_rej_region, nas_rej_market) equals distinct rejected checkout sessions in stg_nas_rejection_data_last_30_days divided by distinct sessions that reached checkout gate in stg_nas_session_level_combined_data (date-aligned), multiplied by 100, plus reason-level distinct-session counts for check-in and check-out rejection reasons.', node_type: 'CORE', definition: 'KPI = f(Integration Activity sessions, NAS rejection events) where checkout rejection rate by (nas_rej_region, nas_rej_market) equals distinct rejected checkout sessions in stg_nas_rejection_data_last_30_days divided by distinct sessions that reached checkout gate in stg_nas_session_level_combined_data (date-aligned), multiplied by 100, plus reason-level distinct-session counts for check-in and check-out rejection reasons.', kpi_python_function: 'def get_nas_checkout_rejection(execute_query, filters=None) -> list[dict]:\n    """NAS Checkout Rejection KPI.\n\n    Returns a single list containing BOTH result sets with a discriminator column:\n      - result_set = \'A\' (rate scorecard)\n      - result_set = \'B\' (reason breakdown)\n\n    Notes:\n      - Uses raw SQL because the rejection table is not exposed as a Tier-1 core node accessor.\n      - Uses plain SELECT statements with inline subqueries (no CTE/WITH) because the runtime\n        rejects non-SELECT syntax.\n      - Supports optional filters: start_date, end_date, plus optional drilldown fields such as\n        nas_rej_region, nas_rej_market, nas_rej_userid, nas_rej_siteid, nas_session_id, nas_market, etc.\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    start_date = filters.get(\'start_date\')\n    end_date = filters.get(\'end_date\')\n\n    # Split filters into: rejection-table filters vs session-table filters.\n    # Convention: anything starting with \'nas_rej_\' applies to rejection table.\n    # IMPORTANT: do NOT prefix with table aliases (r./s.) because queries use inline subqueries.\n    rej_filter_parts = []\n    sess_filter_parts = []\n\n    for k, v in filters.items():\n        if v is None:\n            continue\n        if k in (\'start_date\', \'end_date\'):\n            continue\n        # Basic allowlist-ish behavior: only simple equality predicates; callers can pass known columns.\n        if k.startswith(\'nas_rej_\'):\n            rej_filter_parts.append(f"{k} = \'{esc(v)}\'")\n        else:\n            sess_filter_parts.append(f"{k} = \'{esc(v)}\'")\n\n    # Date predicates\n    rej_date_pred = "TRUE"\n    if start_date and end_date:\n        rej_date_pred = (\n            f"nas_rej_rejection_time >= \'{esc(start_date)}\' "\n            f"AND nas_rej_rejection_time < \'{esc(end_date)}\'"\n        )\n    elif start_date:\n        rej_date_pred = f"nas_rej_rejection_time >= \'{esc(start_date)}\'"\n    elif end_date:\n        rej_date_pred = f"nas_rej_rejection_time < \'{esc(end_date)}\'"\n\n    denom_date_pred = "TRUE"\n    # denominator time uses COALESCE(approve, reject)\n    if start_date and end_date:\n        denom_date_pred = (\n            f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) >= \'{esc(start_date)}\' "\n            f"AND COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) < \'{esc(end_date)}\'"\n        )\n    elif start_date:\n        denom_date_pred = f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) >= \'{esc(start_date)}\'"\n    elif end_date:\n        denom_date_pred = f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) < \'{esc(end_date)}\'"\n\n    rej_extra_pred = " AND ".join(rej_filter_parts) if rej_filter_parts else "TRUE"\n    sess_extra_pred = " AND ".join(sess_filter_parts) if sess_filter_parts else "TRUE"\n\n    sql_a = f"""\n    SELECT\n      \'A\'::text AS result_set,\n      ra.nas_rej_region,\n      ra.nas_rej_market,\n      ra.checkout_rejection_count,\n      ra.checkin_rejection_count,\n      ra.total_rejection_sessions,\n      COALESCE(da.total_completed_sessions, 0) AS total_completed_sessions,\n      CASE\n        WHEN COALESCE(da.total_completed_sessions, 0) = 0 THEN NULL\n        ELSE (ra.checkout_rejection_count::numeric / da.total_completed_sessions::numeric) * 100\n      END AS checkout_rejection_rate_pct,\n      NULL::text AS reason_type,\n      NULL::text AS reason_value,\n      NULL::bigint AS reason_count\n    FROM (\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkout_reject_reason IS NOT NULL) AS checkout_rejection_count,\n        COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkin_reject_reason IS NOT NULL) AS checkin_rejection_count,\n        COUNT(DISTINCT nas_rej_sessionid) AS total_rejection_sessions\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n      GROUP BY 1, 2\n    ) ra\n    LEFT JOIN (\n      SELECT\n        nas_market AS nas_rej_market,\n        COUNT(DISTINCT nas_session_id) AS total_completed_sessions\n      FROM public.stg_nas_session_level_combined_data\n      WHERE (nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL)\n        AND {denom_date_pred}\n        AND ({sess_extra_pred})\n      GROUP BY 1\n    ) da\n      ON da.nas_rej_market = ra.nas_rej_market\n    """\n\n    sql_b = f"""\n    SELECT\n      \'B\'::text AS result_set,\n      x.nas_rej_region,\n      x.nas_rej_market,\n      NULL::bigint AS checkout_rejection_count,\n      NULL::bigint AS checkin_rejection_count,\n      NULL::bigint AS total_rejection_sessions,\n      NULL::bigint AS total_completed_sessions,\n      NULL::numeric AS checkout_rejection_rate_pct,\n      x.reason_type,\n      x.reason_value,\n      x.reason_count\n    FROM (\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        \'checkin\'::text AS reason_type,\n        nas_rej_checkin_reject_reason::text AS reason_value,\n        COUNT(DISTINCT nas_rej_sessionid) AS reason_count\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n        AND nas_rej_checkin_reject_reason IS NOT NULL\n      GROUP BY 1, 2, 3, 4\n\n      UNION ALL\n\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        \'checkout\'::text AS reason_type,\n        nas_rej_checkout_reject_reason::text AS reason_value,\n        COUNT(DISTINCT nas_rej_sessionid) AS reason_count\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n        AND nas_rej_checkout_reject_reason IS NOT NULL\n      GROUP BY 1, 2, 3, 4\n    ) x\n    """\n\n    rows_a = execute_query(sql_a)\n    rows_b = execute_query(sql_b)\n\n    # Return combined result for callers; they can split by result_set.\n    return (rows_a or []) + (rows_b or [])\n', kpi_source_columns: ['nas_rej_sessionid', 'nas_session_id', 'nas_rej_rejection_time', 'nas_rej_region', 'nas_rej_market', 'nas_rej_checkout_reject_reason', 'nas_rej_checkin_reject_reason', 'nas_checkout_approve_time', 'nas_checkout_reject_time', 'nas_market', 'nas_rej_userid', 'nas_rej_siteid'], session_id: '69a3d22f26e208edc083a06e', label: 'NAS Checkout Rejection', kpi_related_core_node_ids: ['integration_activity', 'nas_rejection'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '41414556-b0ca-4b2c-8acd-4214a700b491', entity_type: 'kpi', kpi_name: 'NAS Checkout Rejection', name: '41414556-b0ca-4b2c-8acd-4214a700b491', kpi_dimensions: ['nas_rej_region', 'nas_rej_market', 'reason_type', 'reason_value'], kpi_description: 'Measures NAS session rejection and rework signals by market/region, including the checkout-gate rejection rate and a breakdown of rejection reasons. This helps understand how often sessions are rejected at checkout and why, enabling monitoring and drill-down by geography and other attributes.', status: 'mentioned', node_id: '41414556-b0ca-4b2c-8acd-4214a700b491'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_session_level_combined_data', 'stg_nas_e2e_call_test_completion'], nl_business_rule: '', kpi_formula_description: 'revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions, 0), where revisit_sites are distinct sites with session_count > 2 (default threshold) and sites_with_sessions are distinct sites with >=1 completed session; avg_sessions_per_site = AVG(session_count).', kpi_output_schema: '[{"column": "nas_market", "type": "string", "description": "Market for the rollup."}, {"column": "nas_primary_gc", "type": "string", "description": "Primary GC for the rollup (when rollup_by_company_name is false)."}, {"column": "nas_company_name", "type": "string", "description": "Company name for the rollup (when rollup_by_company_name is true)."}, {"column": "sites_with_sessions", "type": "int", "description": "Distinct count of sites with at least one completed session in the rollup bucket."}, {"column": "revisit_sites", "type": "int", "description": "Distinct count of sites flagged as revisit sites (session_count > threshold) in the rollup bucket."}, {"column": "revisit_rate_pct", "type": "float", "description": "Percent of sites that are revisit sites within the rollup bucket."}, {"column": "avg_sessions_per_site", "type": "float", "description": "Average distinct completed session count per site within the rollup bucket."}, {"column": "revisit_threshold_sessions_gt", "type": "int", "description": "Threshold used to flag revisit sites (site is revisit if session_count > this value)."}]', kpi_business_logic: '1) From stg_nas_session_level_combined_data, keep only completed sessions where nas_checkout_approve_time IS NOT NULL (optionally also filter by date range on nas_checkout_approve_time and/or nas_market/nas_primary_gc/nas_company_name/nas_activity_type/nas_site_id).\n2) At site grain, for each (nas_market, vendor_dim, nas_site_id) compute session_count = COUNT(DISTINCT nas_session_id), where vendor_dim is nas_primary_gc by default or nas_company_name when rolling up by company name.\n3) Flag is_revisit_site = (session_count > revisit_threshold) where revisit_threshold defaults to 2 (i.e., 3+ sessions is a revisit site).\n4) Roll up to (nas_market, vendor_dim):\n   a) sites_with_sessions = COUNT(DISTINCT nas_site_id) across all sites with >=1 completed session.\n   b) revisit_sites = COUNT(DISTINCT nas_site_id) where is_revisit_site = true.\n   c) revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions, 0).\n   d) avg_sessions_per_site = AVG(session_count) across sites.\n5) (Future optional) Join stg_nas_e2e_call_test_completion on nas_site_id to segment revisit sites by nas_call_test_completion_status and/or compute share of revisit sites with poor call-test outcomes.', kpi_filters: '[{"name": "nas_checkout_approve_time_is_not_null", "type": "date", "description": "Includes only completed sessions (nas_checkout_approve_time IS NOT NULL)."}, {"name": "start_date", "type": "date", "description": "Lower bound filter applied to nas_checkout_approve_time."}, {"name": "end_date", "type": "date", "description": "Upper bound filter applied to nas_checkout_approve_time."}, {"name": "nas_market", "type": "string", "description": "Filters sessions/sites to a specific market."}, {"name": "nas_primary_gc", "type": "string", "description": "Filters sessions/sites to a specific primary GC (when using GC rollup)."}, {"name": "nas_company_name", "type": "string", "description": "Filters sessions/sites to a specific company name (when using company rollup)."}, {"name": "nas_activity_type", "type": "string", "description": "Filters sessions by activity type (e.g., integration-only vs troubleshooting/punch)."}, {"name": "nas_site_id", "type": "string", "description": "Filters to a specific site."}, {"name": "revisit_threshold", "type": "number", "description": "Threshold for revisit flag: is_revisit_site = (session_count > revisit_threshold); default 2."}, {"name": "rollup_by_company_name", "type": "string", "description": "Control parameter (boolean) that switches rollup dimension to (nas_market, nas_company_name) instead of (nas_market, nas_primary_gc)."}]', kpi_contract: '{"function_name": "get_site_revisit_rate", "node_type": "kpi", "node_id": "30e3c50e-a44c-4e27-8153-71741e2507d0", "node_label": "Site Revisit Rate", "description": "Measures post-integration rework by counting how many distinct completed NAS sessions each site required, then rolling up a revisit rate by GC/vendor and market. Data source: `stg_nas_session_level_combined_data`. Step 1 (site grain): filter to completed sessions where `nas_checkout_approve_time IS NOT NULL`; compute `session_count = COUNT(DISTINCT nas_session_id)` grouped by `nas_site_id` plus vendor/market dimensions (default: `nas_market`, `nas_primary_gc`; optionally `nas_company_name`). Define `is_revisit_site = (session_count > 2)` to flag sites requiring 3+ sessions. Step 2 (GC rollup): group by `(nas_market, nas_primary_gc)` (or `(nas_market, nas_company_name)`), compute: (a) `sites_with_sessions = COUNT(DISTINCT nas_site_id)` over all sites with >=1 completed session; (b) `revisit_sites = COUNT(DISTINCT nas_site_id)` where `is_revisit_site=true`; (c) `revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions,0)`; (d) `avg_sessions_per_site = AVG(session_count)` across sites. Optional parameter/filter: `nas_activity_type` to isolate integration-only vs troubleshooting/punch sessions. Future optional enrichment: join to `stg_nas_e2e_call_test_completion` on `nas_site_id` to segment revisit sites by `nas_call_test_completion_status` (e.g., RED/PARTIAL) and/or compute share of revisit sites with poor call-test outcomes.", "parameters": [{"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "nas_primary_gc", "type": "string", "description": "Filter by nas primary gc", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}], "output_columns": [{"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_primary_gc", "type": "string", "nullable": false}, {"name": "sites_with_sessions", "type": "number", "nullable": false}, {"name": "revisit_sites", "type": "number", "nullable": false}, {"name": "revisit_rate_pct", "type": "number", "nullable": false}, {"name": "avg_sessions_per_site", "type": "number", "nullable": false}, {"name": "revisit_threshold_sessions_gt", "type": "number", "nullable": false}], "sample_output": [{"nas_market": "Albany", "nas_primary_gc": "ADC", "sites_with_sessions": 1, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}, {"nas_market": "Albany", "nas_primary_gc": "ARM", "sites_with_sessions": 1, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}, {"nas_market": "Albany", "nas_primary_gc": "CPT", "sites_with_sessions": 3, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}], "row_count": 10}', nl_description: 'Revisit Rate % = 100 * (count of distinct sites with >2 distinct completed NAS sessions) / (count of distinct sites with ≥1 completed NAS session), rolled up by (nas_market, nas_primary_gc) or (nas_market, nas_company_name), and avg_sessions_per_site is the average distinct completed session count per site.', node_type: 'CORE', definition: 'Revisit Rate % = 100 * (count of distinct sites with >2 distinct completed NAS sessions) / (count of distinct sites with ≥1 completed NAS session), rolled up by (nas_market, nas_primary_gc) or (nas_market, nas_company_name), and avg_sessions_per_site is the average distinct completed session count per site.', kpi_python_function: 'def get_site_revisit_rate(execute_query, filters=None) -> list[dict]:\n    """Site Revisit Rate\n\n    Step 1 (site grain): completed NAS sessions (nas_checkout_approve_time IS NOT NULL), count distinct nas_session_id per site and vendor/market dims.\n    Step 2 (rollup): per (nas_market, nas_primary_gc) or (nas_market, nas_company_name), compute revisit rate where sites with >2 sessions are revisit sites.\n\n    Supported filters (if present):\n      - start_date, end_date: applied to nas_checkout_approve_time (pushed into SQL)\n      - nas_market, nas_primary_gc, nas_company_name, nas_activity_type, nas_site_id\n      - rollup_by_company_name: bool; if truthy, roll up by (nas_market, nas_company_name) instead of (nas_market, nas_primary_gc)\n      - revisit_threshold: int; default 2 (revisit if session_count > threshold)\n\n    Returns list of dict rows at rollup grain.\n    """\n\n    filters = dict(filters or {})\n\n    # Pop control parameters that are not columns\n    rollup_by_company_name = bool(filters.pop(\'rollup_by_company_name\', False))\n    try:\n      revisit_threshold = int(filters.pop(\'revisit_threshold\', 2))\n    except Exception:\n      revisit_threshold = 2\n\n    start_date = filters.pop(\'start_date\', None)\n    end_date = filters.pop(\'end_date\', None)\n\n    def _norm(x):\n      if x is None:\n        return None\n      s = str(x).strip()\n      return s if s != \'\' else None\n\n    # Pull completed sessions from session-level combined table (includes nas_checkout_approve_time)\n    where = ["nas_checkout_approve_time IS NOT NULL"]\n\n    # Optional dimension filters (pushed down to SQL)\n    if filters.get(\'nas_market\') is not None:\n      where.append(f"nas_market = \'{str(filters.get(\'nas_market\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_primary_gc\') is not None:\n      where.append(f"nas_primary_gc = \'{str(filters.get(\'nas_primary_gc\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_company_name\') is not None:\n      where.append(f"nas_company_name = \'{str(filters.get(\'nas_company_name\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_activity_type\') is not None:\n      where.append(f"nas_activity_type = \'{str(filters.get(\'nas_activity_type\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_site_id\') is not None:\n      where.append(f"nas_site_id = \'{str(filters.get(\'nas_site_id\')).replace("\'", "\'\'")}\'")\n\n    # Optional date filters (pushed down to SQL on approve time)\n    # Assumes start_date/end_date are compatible with the warehouse (date or timestamp literal strings).\n    if start_date is not None:\n      where.append(f"nas_checkout_approve_time >= \'{str(start_date).replace("\'", "\'\'")}\'")\n    if end_date is not None:\n      where.append(f"nas_checkout_approve_time <= \'{str(end_date).replace("\'", "\'\'")}\'")\n\n    sql = f"""\nSELECT\n  nas_session_id,\n  nas_site_id,\n  nas_market,\n  nas_primary_gc,\n  nas_company_name,\n  nas_activity_type,\n  nas_checkout_approve_time\nFROM public.stg_nas_session_level_combined_data\nWHERE {\' AND \'.join(where)}\n""".strip()\n\n    rows = execute_query(sql)\n\n    # Step 1: (completion already enforced in SQL) keep Python-side normalization/guardrails\n    filtered = []\n    for r in rows:\n      approve_time = r.get(\'nas_checkout_approve_time\', None)\n      if approve_time is None:\n        continue\n      filtered.append(r)\n\n    # Site-grain aggregation: count distinct sessions per (market, vendor_dim, site)\n    site_sessions = {}  # key: (market, vendor_dim, site_id) -> set(session_id)\n    for r in filtered:\n      market = _norm(r.get(\'nas_market\'))\n      primary_gc = _norm(r.get(\'nas_primary_gc\'))\n      company_name = _norm(r.get(\'nas_company_name\'))\n      site_id = _norm(r.get(\'nas_site_id\'))\n      session_id = _norm(r.get(\'nas_session_id\'))\n\n      if site_id is None or session_id is None:\n        continue\n\n      vendor_dim = company_name if rollup_by_company_name else primary_gc\n\n      # Keep null vendor buckets explicit (so totals reconcile)\n      k = (market, vendor_dim, site_id)\n      if k not in site_sessions:\n        site_sessions[k] = set()\n      site_sessions[k].add(session_id)\n\n    # Step 2: roll up to (market, vendor_dim)\n    rollup = {}\n    # key: (market, vendor_dim) -> {sites:set, revisit_sites:set, session_counts:[...]}\n    for (market, vendor_dim, site_id), sess_set in site_sessions.items():\n      session_count = len(sess_set)\n      is_revisit_site = session_count > revisit_threshold\n\n      rk = (market, vendor_dim)\n      if rk not in rollup:\n        rollup[rk] = {\n          \'sites\': set(),\n          \'revisit_sites\': set(),\n          \'session_counts\': []\n        }\n      rollup[rk][\'sites\'].add(site_id)\n      if is_revisit_site:\n        rollup[rk][\'revisit_sites\'].add(site_id)\n      rollup[rk][\'session_counts\'].append(session_count)\n\n    out = []\n    for (market, vendor_dim), agg in rollup.items():\n      sites_with_sessions = len(agg[\'sites\'])\n      revisit_sites = len(agg[\'revisit_sites\'])\n      revisit_rate_pct = (100.0 * revisit_sites / sites_with_sessions) if sites_with_sessions else None\n      sc = agg[\'session_counts\']\n      avg_sessions_per_site = (sum(sc) / len(sc)) if sc else None\n\n      row = {\n        \'nas_market\': market,\n        (\'nas_company_name\' if rollup_by_company_name else \'nas_primary_gc\'): vendor_dim,\n        \'sites_with_sessions\': sites_with_sessions,\n        \'revisit_sites\': revisit_sites,\n        \'revisit_rate_pct\': revisit_rate_pct,\n        \'avg_sessions_per_site\': avg_sessions_per_site,\n        \'revisit_threshold_sessions_gt\': revisit_threshold\n      }\n      out.append(row)\n\n    # stable ordering\n    out.sort(key=lambda x: (str(x.get(\'nas_market\') or \'\'), str(x.get(\'nas_company_name\') or x.get(\'nas_primary_gc\') or \'\')))\n    return out\n', kpi_source_columns: ['nas_checkout_approve_time', 'nas_session_id', 'nas_site_id', 'nas_market', 'nas_primary_gc', 'nas_company_name', 'nas_activity_type', 'nas_call_test_completion_status'], session_id: '69a3d22f26e208edc083a06e', label: 'Site Revisit Rate', kpi_related_core_node_ids: ['integration_activity'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '30e3c50e-a44c-4e27-8153-71741e2507d0', entity_type: 'kpi', kpi_name: 'Site Revisit Rate', name: '30e3c50e-a44c-4e27-8153-71741e2507d0', kpi_dimensions: ['nas_market', 'nas_primary_gc', 'nas_company_name', 'nas_activity_type', 'nas_site_id', 'nas_call_test_completion_status'], kpi_description: 'Measures post-integration rework by identifying how often sites require multiple completed NAS sessions to reach completion. It summarizes the share of sites that needed revisits, helping compare rework levels across vendor/GC and markets.', status: 'mentioned', node_id: '30e3c50e-a44c-4e27-8153-71741e2507d0'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'For each configured (predecessor → current) milestone pair where predecessor_date is present and current milestone date is null: aging_days = CURRENT_DATE - predecessor_date; sla_pct = (aging_days / expected_sla_days) * 100; status = On Track if sla_pct < risk_threshold_pct, At Risk if risk_threshold_pct <= sla_pct < breach_threshold_pct, else Breached; then aggregate by region/area/market/milestone (optional GC).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping for the aggregated alert metrics."}, {"column": "m_area", "type": "string", "description": "Area grouping for the aggregated alert metrics."}, {"column": "m_market", "type": "string", "description": "Market grouping for the aggregated alert metrics."}, {"column": "milestone_name", "type": "string", "description": "Current (waiting) milestone being monitored for aging/SLA risk."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping (only when include_gc is enabled)."}, {"column": "total_waiting", "type": "int", "description": "Count of distinct projects waiting on the milestone (predecessor complete, current incomplete)."}, {"column": "at_risk_count", "type": "int", "description": "Number of waiting rows classified as \'At Risk\' within the group."}, {"column": "breached_count", "type": "int", "description": "Number of waiting rows classified as \'Breached\' within the group."}, {"column": "avg_aging_days", "type": "float", "description": "Average aging_days for waiting items in the group."}, {"column": "p90_aging_days", "type": "float", "description": "90th percentile of aging_days for waiting items in the group (percentile_cont)."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined.\n2) Filter projects to pj_project_status = \'Active\'.\n3) For each Active project and each configured milestone pair (predecessor_name -> milestone_name):\n   a) Read predecessor_date from the predecessor milestone column.\n   b) Read current_milestone_date from the current milestone column.\n   c) Keep the row only if predecessor_date IS NOT NULL AND current_milestone_date IS NULL.\n   d) Determine expected_sla_days from SLA config (default, unless overridden by filters[\'sla_config\'] keyed by milestone_name).\n   e) Compute aging_days = (CURRENT_DATE - predecessor_date::date).\n   f) Compute sla_pct = (aging_days / expected_sla_days) * 100.\n   g) Classify status:\n      - \'On Track\' if sla_pct < risk_threshold_pct (default 50)\n      - \'At Risk\' if risk_threshold_pct <= sla_pct < breach_threshold_pct (default 100)\n      - \'Breached\' if sla_pct >= breach_threshold_pct\n4) Aggregate results by (rgn_region, m_area, m_market, milestone_name) and optionally pj_general_contractor:\n   - total_waiting = count distinct pj_project_id\n   - at_risk_count = count rows with status=\'At Risk\'\n   - breached_count = count rows with status=\'Breached\'\n   - avg_aging_days = average(aging_days)\n   - p90_aging_days = percentile_cont(0.9) over aging_days.', kpi_filters: '[{"name": "pj_project_status", "type": "string", "description": "Include only projects with status \'Active\'."}, {"name": "sla_config", "type": "string", "description": "Optional override dict keyed by milestone_name to expected_sla_days."}, {"name": "risk_threshold_pct", "type": "number", "description": "Percentage threshold below which status is \'On Track\' (default 50)."}, {"name": "breach_threshold_pct", "type": "number", "description": "Percentage threshold at/above which status is \'Breached\' (default 100)."}, {"name": "milestone_pairs", "type": "string", "description": "Optional override list of milestone pairs to evaluate, each with milestone_name, predecessor_name, expected_sla_days."}, {"name": "include_gc", "type": "string", "description": "If true, include pj_general_contractor in grouping/output."}]', kpi_contract: '{"function_name": "get_milestone_aging_alert", "node_type": "kpi", "node_id": "b1325712-f39f-4551-ba34-98a0bc767ebe", "node_label": "Milestone Aging Alert", "description": "Detects milestone aging and SLA breach risk for active projects by comparing today\'s date to the last completed predecessor milestone date for a predefined set of milestone pairs. Source table: `stg_ndpd_mbt_tmobile_macro_combined` (Project-level wide table). Filter to projects where `pj_project_status = \'Active\'`. Internally unpivot the configured milestone pairs into rows with fields: `pj_project_id`, `rgn_region`, `m_area`, `m_market`, optional `pj_general_contractor`, `milestone_name` (current/waiting milestone), `predecessor_name`, `predecessor_date`, `expected_sla_days`. Include only rows where `predecessor_date IS NOT NULL` and `current_milestone_date IS NULL`. Compute `aging_days = CURRENT_DATE - predecessor_date::date`; `sla_pct = aging_days / expected_sla_days * 100`; `status = \'On Track\' when sla_pct < 50, \'At Risk\' when 50 <= sla_pct < 100, \'Breached\' when sla_pct >= 100`. Default SLA config (days): {ms_1323:14 (pred ms_1310), ms_1327:10 (pred ms_1323), ms_1507:21 (pred ms_1327), ms_1550:14 (pred ms_1507), ms_1555:21 (pred ms_1550), ms_1970:30 (pred ms_1555), ms_1559:14 (pred ms_1970)}. Allow override via parameter such as `filters[\'sla_config\']` (dict keyed by milestone_name to expected_sla_days) and optionally thresholds via `filters[\'risk_threshold_pct\']=50` and `filters[\'breach_threshold_pct\']=100`. Aggregate output by `(rgn_region, m_area, m_market, milestone_name)` (optionally also `pj_general_contractor`) producing: `total_waiting` (count distinct projects), `at_risk_count`, `breached_count`, `avg_aging_days`, `p90_aging_days` (PostgreSQL percentile_cont).", "parameters": [{"name": "sla_config", "type": "string", "description": "Filter by sla config", "required": false, "sample_values": []}, {"name": "risk_threshold_pct", "type": "string", "description": "Filter by risk threshold pct", "required": false, "sample_values": []}, {"name": "breach_threshold_pct", "type": "string", "description": "Filter by breach threshold pct", "required": false, "sample_values": []}, {"name": "include_gc", "type": "string", "description": "Filter by include gc", "required": false, "sample_values": []}, {"name": "milestone_pairs", "type": "string", "description": "Filter by milestone pairs", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "milestone_name", "type": "string", "nullable": false}, {"name": "total_waiting", "type": "number", "nullable": false}, {"name": "at_risk_count", "type": "number", "nullable": false}, {"name": "breached_count", "type": "number", "nullable": false}, {"name": "avg_aging_days", "type": "number", "nullable": false}, {"name": "p90_aging_days", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "milestone_name": "ms_1507_tower_ntp_approved_actual", "total_waiting": 3, "at_risk_count": 0, "breached_count": 3, "avg_aging_days": 254.66666666666666, "p90_aging_days": 355.8}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "milestone_name": "ms_1550_construction_start_actual", "total_waiting": 1, "at_risk_count": 0, "breached_count": 1, "avg_aging_days": 250.0, "p90_aging_days": 250.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "milestone_name": "ms_1555_construction_complete_actual", "total_waiting": 2, "at_risk_count": 0, "breached_count": 2, "avg_aging_days": 288.5, "p90_aging_days": 338.5}], "row_count": 10}', nl_description: 'For each Active project and each configured milestone pair (predecessor → current), include rows where predecessor_date is present and current milestone date is null, compute aging_days = today − predecessor_date, sla_pct = aging_days/expected_sla_days×100, classify status by thresholds, then aggregate counts and aging statistics by (region, area, market, milestone) (optionally GC).', node_type: 'CORE', definition: 'For each Active project and each configured milestone pair (predecessor → current), include rows where predecessor_date is present and current milestone date is null, compute aging_days = today − predecessor_date, sla_pct = aging_days/expected_sla_days×100, classify status by thresholds, then aggregate counts and aging statistics by (region, area, market, milestone) (optionally GC).', kpi_python_function: 'def get_milestone_aging_alert(execute_query, filters=None) -> list[dict]:\n    import datetime\n    from statistics import mean\n\n    filters = filters or {}\n\n    # --- SLA + thresholds configuration ---\n    # NOTE: use physical milestone column names from stg_ndpd_mbt_tmobile_macro_combined\n    default_pairs = [\n        ("ms_1323_ready_for_scoping_actual", "ms_1310_pre_construction_package_received_actual", 14),\n        ("ms_1327_scoping_and_quoting_package_validated_actual", "ms_1323_ready_for_scoping_actual", 10),\n        ("ms_1507_tower_ntp_approved_actual", "ms_1327_scoping_and_quoting_package_validated_actual", 21),\n        ("ms_1550_construction_start_actual", "ms_1507_tower_ntp_approved_actual", 14),\n        ("ms_1555_construction_complete_actual", "ms_1550_construction_start_actual", 21),\n        ("ms_1970_integration_complete_actual", "ms_1555_construction_complete_actual", 30),\n        ("ms_1559_cop_approved_by_t_mobile_actual", "ms_1970_integration_complete_actual", 14),\n    ]\n\n    sla_override = filters.get("sla_config") or {}\n    risk_threshold_pct = float(filters.get("risk_threshold_pct", 50))\n    breach_threshold_pct = float(filters.get("breach_threshold_pct", 100))\n\n    include_gc = bool(filters.get("include_gc", False))\n\n    # Allow overriding which milestone pairs are evaluated\n    # Expected format: [{"milestone_name":"<physical_col>","predecessor_name":"<physical_col>","expected_sla_days":14}, ...]\n    milestone_pairs = []\n    if filters.get("milestone_pairs"):\n        for mp in (filters.get("milestone_pairs") or []):\n            milestone_pairs.append(\n                (\n                    mp.get("milestone_name"),\n                    mp.get("predecessor_name"),\n                    int(mp.get("expected_sla_days")) if mp.get("expected_sla_days") is not None else None,\n                )\n            )\n    else:\n        milestone_pairs = list(default_pairs)\n\n    # --- Helpers ---\n    def _to_date(v):\n        if v is None or v == "":\n            return None\n        if isinstance(v, datetime.date) and not isinstance(v, datetime.datetime):\n            return v\n        if isinstance(v, datetime.datetime):\n            return v.date()\n        s = str(v).strip()\n        # handle ISO and \'YYYY-MM-DD HH:MM:SS\'\n        try:\n            return datetime.datetime.fromisoformat(s.replace("Z", "+00:00")).date()\n        except Exception:\n            pass\n        for fmt in ("%Y-%m-%d", "%Y-%m-%d %H:%M:%S", "%m/%d/%Y", "%m/%d/%Y %H:%M:%S"):\n            try:\n                return datetime.datetime.strptime(s, fmt).date()\n            except Exception:\n                continue\n        return None\n\n    def _percentile_cont(sorted_vals, p):\n        # Continuous percentile consistent with PostgreSQL percentile_cont\n        n = len(sorted_vals)\n        if n == 0:\n            return None\n        if n == 1:\n            return float(sorted_vals[0])\n        if p <= 0:\n            return float(sorted_vals[0])\n        if p >= 1:\n            return float(sorted_vals[-1])\n        k = (n - 1) * p\n        f = int(k)\n        c = min(f + 1, n - 1)\n        if f == c:\n            return float(sorted_vals[f])\n        d0 = sorted_vals[f] * (c - k)\n        d1 = sorted_vals[c] * (k - f)\n        return float(d0 + d1)\n\n    # --- Build base filters for Project accessor ---\n    proj_filters = dict(filters)\n    # ensure only Active projects\n    proj_filters["pj_project_status"] = "Active"\n    # remove KPI-only controls from being treated as column filters\n    for k in [\n        "sla_config",\n        "risk_threshold_pct",\n        "breach_threshold_pct",\n        "milestone_pairs",\n        "include_gc",\n    ]:\n        if k in proj_filters:\n            proj_filters.pop(k, None)\n\n    # Fetch active projects (wide milestone columns are not available via accessor output),\n    # so use raw SQL to retrieve the milestone date columns needed for configured pairs.\n    # We still use Tier-1 to validate/filter project population if caller provides additional project filters.\n    _ = get_project(execute_query, proj_filters)\n\n    # Determine required milestone columns\n    needed_ms_cols = set()\n    for milestone_name, predecessor_name, _sla in milestone_pairs:\n        if milestone_name:\n            needed_ms_cols.add(milestone_name)\n        if predecessor_name:\n            needed_ms_cols.add(predecessor_name)\n\n    # Base columns needed for grouping\n    base_cols = ["pj_project_id", "rgn_region", "m_area", "m_market"]\n    if include_gc:\n        base_cols.append("pj_general_contractor")\n\n    select_cols = base_cols + sorted(needed_ms_cols)\n\n    where_parts = ["pj_project_status = \'Active\'"]\n\n    # Optional entity filters\n    for fcol in ["pj_project_id", "rgn_region", "m_area", "m_market", "pj_general_contractor", "pj_project_type", "pj_program_name"]:\n        if fcol in filters and filters.get(fcol) not in (None, ""):\n            escaped = str(filters.get(fcol)).replace("\'", "\'\'")\n            where_parts.append(f"{fcol} = \'{escaped}\'")\n\n    sql = (\n        "SELECT "\n        + ", ".join([f"{c}" for c in select_cols])\n        + " FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n        + (" WHERE " + " AND ".join(where_parts) if where_parts else "")\n    )\n\n    rows = execute_query(sql, db="public", max_rows=None) or []\n\n    today = datetime.date.today()\n\n    # --- Unpivot milestone pairs into waiting rows ---\n    waiting_rows = []\n    for r in rows:\n        pj_project_id = r.get("pj_project_id")\n        rgn_region = r.get("rgn_region")\n        m_area = r.get("m_area")\n        m_market = r.get("m_market")\n        pj_general_contractor = r.get("pj_general_contractor") if include_gc else None\n\n        for milestone_name, predecessor_name, default_sla in milestone_pairs:\n            if not milestone_name or not predecessor_name:\n                continue\n\n            predecessor_date = _to_date(r.get(predecessor_name))\n            current_milestone_date = _to_date(r.get(milestone_name))\n\n            # include only if predecessor completed and current milestone not complete\n            if predecessor_date is None:\n                continue\n            if current_milestone_date is not None:\n                continue\n\n            expected_sla_days = sla_override.get(milestone_name, default_sla)\n            if expected_sla_days in (None, 0, "0"):\n                # cannot compute SLA pct\n                continue\n            expected_sla_days = float(expected_sla_days)\n\n            aging_days = (today - predecessor_date).days\n            sla_pct = (aging_days / expected_sla_days) * 100.0\n\n            if sla_pct < risk_threshold_pct:\n                status = "On Track"\n            elif sla_pct < breach_threshold_pct:\n                status = "At Risk"\n            else:\n                status = "Breached"\n\n            out = {\n                "pj_project_id": pj_project_id,\n                "rgn_region": rgn_region,\n                "m_area": m_area,\n                "m_market": m_market,\n                "milestone_name": milestone_name,\n                "predecessor_name": predecessor_name,\n                "predecessor_date": predecessor_date.isoformat(),\n                "expected_sla_days": expected_sla_days,\n                "aging_days": aging_days,\n                "sla_pct": sla_pct,\n                "status": status,\n            }\n            if include_gc:\n                out["pj_general_contractor"] = pj_general_contractor\n\n            waiting_rows.append(out)\n\n    # --- Aggregate output ---\n    # Aggregate by (rgn_region, m_area, m_market, milestone_name) (+ optional GC)\n    agg = {}\n    for wr in waiting_rows:\n        key = (\n            wr.get("rgn_region"),\n            wr.get("m_area"),\n            wr.get("m_market"),\n            wr.get("milestone_name"),\n            wr.get("pj_general_contractor") if include_gc else None,\n        )\n        if key not in agg:\n            agg[key] = {\n                "rgn_region": wr.get("rgn_region"),\n                "m_area": wr.get("m_area"),\n                "m_market": wr.get("m_market"),\n                "milestone_name": wr.get("milestone_name"),\n                "_project_ids": set(),\n                "_aging_days": [],\n                "at_risk_count": 0,\n                "breached_count": 0,\n            }\n            if include_gc:\n                agg[key]["pj_general_contractor"] = wr.get("pj_general_contractor")\n\n        agg[key]["_project_ids"].add(wr.get("pj_project_id"))\n        agg[key]["_aging_days"].append(int(wr.get("aging_days", 0)))\n        if wr.get("status") == "At Risk":\n            agg[key]["at_risk_count"] += 1\n        elif wr.get("status") == "Breached":\n            agg[key]["breached_count"] += 1\n\n    results = []\n    for k, v in agg.items():\n        aging = sorted(v["_aging_days"])\n        total_waiting = len(v["_project_ids"])\n        avg_aging_days = float(mean(aging)) if aging else None\n        p90_aging_days = _percentile_cont(aging, 0.9) if aging else None\n\n        rec = {\n            "rgn_region": v.get("rgn_region"),\n            "m_area": v.get("m_area"),\n            "m_market": v.get("m_market"),\n            "milestone_name": v.get("milestone_name"),\n            "total_waiting": total_waiting,\n            "at_risk_count": int(v.get("at_risk_count", 0)),\n            "breached_count": int(v.get("breached_count", 0)),\n            "avg_aging_days": avg_aging_days,\n            "p90_aging_days": p90_aging_days,\n        }\n        if include_gc:\n            rec["pj_general_contractor"] = v.get("pj_general_contractor")\n\n        results.append(rec)\n\n    # Deterministic ordering\n    results.sort(\n        key=lambda x: (\n            (x.get("rgn_region") or ""),\n            (x.get("m_area") or ""),\n            (x.get("m_market") or ""),\n            (x.get("milestone_name") or ""),\n            (x.get("pj_general_contractor") or "") if include_gc else "",\n        )\n    )\n\n    return results\n', kpi_source_columns: ['pj_project_status', 'pj_project_id', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'ms_1323_ready_for_scoping_actual', 'ms_1310_pre_construction_package_received_actual', 'ms_1327_scoping_and_quoting_package_validated_actual', 'ms_1507_tower_ntp_approved_actual', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'ms_1970_integration_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Milestone Aging Alert', kpi_related_core_node_ids: ['project', 'milestone', 'market', 'general_contractor'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: 'b1325712-f39f-4551-ba34-98a0bc767ebe', entity_type: 'kpi', kpi_name: 'Milestone Aging Alert', name: 'b1325712-f39f-4551-ba34-98a0bc767ebe', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'milestone_name', 'pj_general_contractor'], kpi_description: 'Detects milestone aging and SLA breach risk for active projects by measuring how long projects have been waiting on specific upcoming milestones after their predecessor milestone was completed. This helps identify p