 "ftr_rate_pct": null, "active_backlog_wip": 0, "on_air_pending": 0}], "row_count": 10}', nl_description: 'For each (rgn_region, m_area, m_market, pj_general_contractor) group: Plan Achievement % = 100×distinct projects with both construction start+complete actual / distinct projects with construction start actual; Avg CX Cycle Days = average of (construction complete date − construction start date) over projects with both; FTR Rate % = 100×distinct projects with punch checklist audit completed and first_time_right=\'Yes\' / distinct projects with audit completed; Active Backlog (WIP) = distinct projects started but not completed; On-Air Pending = distinct projects completed construction but missing completion objective actual date.', node_type: 'CORE', definition: 'For each (rgn_region, m_area, m_market, pj_general_contractor) group: Plan Achievement % = 100×distinct projects with both construction start+complete actual / distinct projects with construction start actual; Avg CX Cycle Days = average of (construction complete date − construction start date) over projects with both; FTR Rate % = 100×distinct projects with punch checklist audit completed and first_time_right=\'Yes\' / distinct projects with audit completed; Active Backlog (WIP) = distinct projects started but not completed; On-Air Pending = distinct projects completed construction but missing completion objective actual date.', kpi_python_function: 'def get_gc_performance_scorecard(execute_query, filters=None) -> list[dict]:\n    """Composite GC scorecard grouped by (rgn_region, m_area, m_market, pj_general_contractor).\n\n    Measures:\n      1) plan_achievement_pct\n      2) avg_cx_cycle_days\n      3) ftr_rate_pct\n      4) active_backlog_wip\n      5) on_air_pending\n\n    Notes:\n      - NULL-safe denominators: return None when denominator == 0.\n      - Prefers Tier-1 accessors where possible, but required columns (milestone dates, first_time_right)\n        are not exposed by the current accessor return columns, so this uses raw SQL.\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # We need milestone/date columns + first_time_right, which are not available in Tier-1 accessor outputs.\n    # Therefore, query the source table directly with dynamic filters.\n    where_parts = []\n\n    # Optional dimension filters (if provided)\n    for k in [\n        \'rgn_region\', \'m_area\', \'m_market\', \'pj_general_contractor\', \'pj_project_id\', \'s_site_id\',\n        \'pj_project_status\', \'pj_project_type\', \'pj_program_name\'\n    ]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters.get(k))}\'")\n\n    # Date range filtering (optional). Apply to construction start actual by default for weekly planning window.\n    # If you need alternate behavior (e.g., filter by completion date), pass filters[\'date_field\'].\n    date_field = filters.get(\'date_field\') or \'ms_1550_construction_start_actual\'\n    if filters.get(\'start_date\'):\n        where_parts.append(f"{date_field}::date >= \'{esc(filters.get(\'start_date\'))}\'::date")\n    if filters.get(\'end_date\'):\n        where_parts.append(f"{date_field}::date <= \'{esc(filters.get(\'end_date\'))}\'::date")\n\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            pj_general_contractor,\n            pj_project_id,\n            ms_1550_construction_start_actual,\n            ms_1555_construction_complete_actual,\n            ms_1556_punch_checklist_audit_completed_by_nokia_actual,\n            first_time_right,\n            pj_completion_objective_actual_date\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n    """\n\n    rows = execute_query(sql)\n\n    # Group and aggregate in Python\n    groups = {}\n\n    def to_date(val):\n        if val is None:\n            return None\n        s = str(val)\n        # expected formats like \'YYYY-MM-DD\' or \'YYYY-MM-DD HH:MM:SS\'\n        return s[:10] if len(s) >= 10 else None\n\n    def date_diff_days(d2, d1):\n        # d2 - d1 in days, both are \'YYYY-MM-DD\'\n        if (d1 is None) or (d2 is None):\n            return None\n        # Avoid imports; use Postgres for date diff if needed, but we are already in Python.\n        # Minimal pure-Python date diff without datetime import is not reliable.\n        # Fallback: compute using a SQL helper per row is too expensive.\n        # Instead, re-query with SQL computing cycle_days, which is safe and efficient.\n        return None\n\n    # If we need accurate cycle days without importing datetime, do a second SQL that computes it.\n    # This stays within KPI rules and avoids Python datetime import.\n    # Build a project-level cycle-days lookup keyed by pj_project_id.\n    # (This is still one table; no joins.)\n    sql_cycle = f"""\n        SELECT\n            pj_project_id,\n            (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) AS cx_cycle_days\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n    """\n    cycle_rows = execute_query(sql_cycle)\n    cycle_by_project = {r.get(\'pj_project_id\'): r.get(\'cx_cycle_days\') for r in cycle_rows}\n\n    for r in rows:\n        key = (\n            r.get(\'rgn_region\'),\n            r.get(\'m_area\'),\n            r.get(\'m_market\'),\n            r.get(\'pj_general_contractor\')\n        )\n        if key not in groups:\n            groups[key] = {\n                \'rgn_region\': r.get(\'rgn_region\'),\n                \'m_area\': r.get(\'m_area\'),\n                \'m_market\': r.get(\'m_market\'),\n                \'pj_general_contractor\': r.get(\'pj_general_contractor\'),\n                # sets for distinct counts\n                \'_plan_den\': set(),\n                \'_plan_num\': set(),\n                \'_ftr_den\': set(),\n                \'_ftr_num\': set(),\n                \'_wip\': set(),\n                \'_on_air_pending\': set(),\n                # cycle days\n                \'_cycle_sum\': 0.0,\n                \'_cycle_cnt\': 0\n            }\n\n        g = groups[key]\n        pid = r.get(\'pj_project_id\')\n        if not pid:\n            continue\n\n        start_actual = r.get(\'ms_1550_construction_start_actual\')\n        complete_actual = r.get(\'ms_1555_construction_complete_actual\')\n        audit_completed = r.get(\'ms_1556_punch_checklist_audit_completed_by_nokia_actual\')\n        ftr = r.get(\'first_time_right\')\n        completion_objective_actual = r.get(\'pj_completion_objective_actual_date\')\n\n        # (1) Plan Achievement %\n        if start_actual is not None:\n            g[\'_plan_den\'].add(pid)\n            if complete_actual is not None:\n                g[\'_plan_num\'].add(pid)\n\n        # (2) Avg CX Cycle Days\n        if (start_actual is not None) and (complete_actual is not None):\n            cd = cycle_by_project.get(pid)\n            if cd is not None:\n                try:\n                    g[\'_cycle_sum\'] += float(cd)\n                    g[\'_cycle_cnt\'] += 1\n                except Exception:\n                    pass\n\n        # (3) FTR Rate %\n        if audit_completed is not None:\n            g[\'_ftr_den\'].add(pid)\n            if str(ftr).strip().lower() == \'yes\':\n                g[\'_ftr_num\'].add(pid)\n\n        # (4) Active Backlog (WIP)\n        if (start_actual is not None) and (complete_actual is None):\n            g[\'_wip\'].add(pid)\n\n        # (5) On-Air Pending\n        if (complete_actual is not None) and (completion_objective_actual is None):\n            g[\'_on_air_pending\'].add(pid)\n\n    out = []\n    for key, g in groups.items():\n        plan_den = len(g[\'_plan_den\'])\n        plan_num = len(g[\'_plan_num\'])\n        ftr_den = len(g[\'_ftr_den\'])\n        ftr_num = len(g[\'_ftr_num\'])\n\n        plan_pct = (100.0 * plan_num / plan_den) if plan_den > 0 else None\n        ftr_pct = (100.0 * ftr_num / ftr_den) if ftr_den > 0 else None\n        avg_cycle = (g[\'_cycle_sum\'] / g[\'_cycle_cnt\']) if g[\'_cycle_cnt\'] > 0 else None\n\n        out.append({\n            \'rgn_region\': g[\'rgn_region\'],\n            \'m_area\': g[\'m_area\'],\n            \'m_market\': g[\'m_market\'],\n            \'pj_general_contractor\': g[\'pj_general_contractor\'],\n            \'plan_achievement_pct\': plan_pct,\n            \'avg_cx_cycle_days\': avg_cycle,\n            \'ftr_rate_pct\': ftr_pct,\n            \'active_backlog_wip\': len(g[\'_wip\']),\n            \'on_air_pending\': len(g[\'_on_air_pending\'])\n        })\n\n    return out\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'pj_project_id', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'ms_1556_punch_checklist_audit_completed_by_nokia_actual', 'first_time_right', 'pj_completion_objective_actual_date', 'pj_project_status', 'pj_project_type', 'pj_program_name', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'GC Performance Scorecard', kpi_related_core_node_ids: ['project', 'site', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68', entity_type: 'kpi', kpi_name: 'GC Performance Scorecard', name: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Composite vendor scorecard to compare General Contractors on delivery, speed, quality, and backlog health for weekly planning and vendor volume allocation.', status: 'mentioned', node_id: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: '(pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) in calendar days, computed only when both dates are present and the result is >= 0; summarized by average, P50, P90, and maximum.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor grouping dimension."}, {"column": "n", "type": "int", "description": "Number of qualifying records in the group."}, {"column": "avg_days", "type": "float", "description": "Average lead time in calendar days."}, {"column": "p50_days", "type": "float", "description": "Median (50th percentile) lead time in calendar days."}, {"column": "p90_days", "type": "float", "description": "90th percentile lead time in calendar days."}, {"column": "max_days", "type": "float", "description": "Maximum lead time in calendar days."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined.\n2) Keep rows where pj_completion_objective_actual_date IS NOT NULL and ms_1555_construction_complete_actual IS NOT NULL.\n3) Compute lead_time_days = pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date.\n4) Exclude rows where lead_time_days < 0.\n5) Group by rgn_region, m_area, m_market, pj_general_contractor.\n6) For each group, compute: n = COUNT(*), avg_days = AVG(lead_time_days), p50_days = PERCENTILE_CONT(0.5) over lead_time_days, p90_days = PERCENTILE_CONT(0.9) over lead_time_days, max_days = MAX(lead_time_days).', kpi_filters: '[{"name": "pj_completion_objective_actual_date IS NOT NULL", "type": "date", "description": "Exclude records missing the On-Air actual date."}, {"name": "ms_1555_construction_complete_actual IS NOT NULL", "type": "date", "description": "Exclude records missing the construction complete actual date."}, {"name": "lead_time_days >= 0", "type": "number", "description": "Exclude negative durations between construction completion and On-Air."}, {"name": "start_date", "type": "date", "description": "Lower bound filter applied to pj_completion_objective_actual_date (On-Air date)."}, {"name": "end_date", "type": "date", "description": "Upper bound filter applied to pj_completion_objective_actual_date (On-Air date)."}, {"name": "rgn_region", "type": "string", "description": "Optional filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional filter to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Optional filter to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Optional filter to a specific site."}, {"name": "pj_project_status", "type": "string", "description": "Optional filter to a specific project status."}, {"name": "pj_project_type", "type": "string", "description": "Optional filter to a specific project type."}, {"name": "pj_program_name", "type": "string", "description": "Optional filter to a specific program name."}]', kpi_contract: '{"function_name": "get_cx_to_on_air_lead_time", "node_type": "kpi", "node_id": "6b91dd88-d284-4ba1-b95a-b66c1ee08d91", "node_label": "CX to On-Air Lead Time", "description": "Measures post-construction lead time for projects that have reached On-Air. Calculate calendar days as (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) for rows where both dates are NOT NULL and the difference is >= 0. Aggregate by (rgn_region, m_area, m_market, pj_general_contractor) and return distribution statistics: average days, P50/median, P90, and maximum. Source table: stg_ndpd_mbt_tmobile_macro_combined. Key entity: Project (pj_project_id) joined implicitly to Market/GC attributes via same table. Exclude negative durations and null dates to avoid bad data artifacts.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "n", "type": "number", "nullable": false}, {"name": "avg_days", "type": "number", "nullable": false}, {"name": "p50_days", "type": "number", "nullable": false}, {"name": "p90_days", "type": "number", "nullable": false}, {"name": "max_days", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "telcom construction", "n": 1, "avg_days": 420.0, "p50_days": 420.0, "p90_days": 420.0, "max_days": 420.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "uci", "n": 1, "avg_days": 358.0, "p50_days": 358.0, "p90_days": 358.0, "max_days": 358.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "vericore", "n": 1, "avg_days": 128.0, "p50_days": 128.0, "p90_days": 128.0, "max_days": 128.0}], "row_count": 10}', nl_description: 'CX to On-Air Lead Time = (pj_completion_objective_actual_date::date − ms_1555_construction_complete_actual::date) in calendar days for records with both dates present and non-negative, aggregated by (rgn_region, m_area, m_market, pj_general_contractor) and summarized via average, median (P50), P90, and max.', node_type: 'CORE', definition: 'CX to On-Air Lead Time = (pj_completion_objective_actual_date::date − ms_1555_construction_complete_actual::date) in calendar days for records with both dates present and non-negative, aggregated by (rgn_region, m_area, m_market, pj_general_contractor) and summarized via average, median (P50), P90, and max.', kpi_python_function: 'def get_cx_to_on_air_lead_time(execute_query, filters=None) -> list[dict]:\n    """CX to On-Air Lead Time distribution by (rgn_region, m_area, m_market, pj_general_contractor).\n\n    Lead time (calendar days) = (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date)\n    where both dates are not null and diff >= 0.\n\n    Returns list of dicts with avg_days, p50_days, p90_days, max_days, n.\n    """\n\n    filters = filters or {}\n\n    def _escape(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Build WHERE clause from provided filters.\n    # Note: start/end_date are applied to pj_completion_objective_actual_date (On-Air) by default.\n    where_parts = [\n        "pj_completion_objective_actual_date IS NOT NULL",\n        "ms_1555_construction_complete_actual IS NOT NULL",\n        "(pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date) >= 0"\n    ]\n\n    # Common dimensional filters\n    passthrough_keys = [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "pj_project_id",\n        "s_site_id",\n        "pj_project_status",\n        "pj_project_type",\n        "pj_program_name"\n    ]\n    for k in passthrough_keys:\n        if k in filters and filters.get(k) is not None and filters.get(k) != "":\n            where_parts.append(f"{k} = \'{_escape(filters.get(k))}\'")\n\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n    if start_date:\n        where_parts.append(f"pj_completion_objective_actual_date::date >= \'{_escape(start_date)}\'::date")\n    if end_date:\n        where_parts.append(f"pj_completion_objective_actual_date::date <= \'{_escape(end_date)}\'::date")\n\n    where_sql = " WHERE " + " AND ".join(where_parts)\n\n    # Use raw SQL (preferred here) because required columns are not exposed by Tier-1 accessors,\n    # and we need percentiles efficiently.\n    sql = (\n        "SELECT "\n        "  rgn_region, "\n        "  m_area, "\n        "  m_market, "\n        "  pj_general_contractor, "\n        "  COUNT(*) AS n, "\n        "  AVG((pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS avg_days, "\n        "  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS p50_days, "\n        "  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY (pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS p90_days, "\n        "  MAX((pj_completion_objective_actual_date::date - ms_1555_construction_complete_actual::date))::double precision AS max_days "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n        + where_sql +\n        " GROUP BY rgn_region, m_area, m_market, pj_general_contractor "\n        " ORDER BY rgn_region, m_area, m_market, pj_general_contractor"\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_completion_objective_actual_date', 'ms_1555_construction_complete_actual', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], session_id: '69a3d22f26e208edc083a06e', label: 'CX to On-Air Lead Time', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91', entity_type: 'kpi', kpi_name: 'CX to On-Air Lead Time', name: '6b91dd88-d284-4ba1-b95a-b66c1ee