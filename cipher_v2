al backlog = count distinct pj_project_id in base backlog.\n3) Compute pending_integration_start = count distinct pj_project_id in base backlog where pj_a_5270_integration_start_finish IS NULL.\n4) Compute pending_integration_complete = count distinct pj_project_id in base backlog where pj_a_5270_integration_start_finish IS NOT NULL AND ms_1970_integration_complete_actual IS NULL.\n5) Compute pending_cop_approval = count distinct pj_project_id in base backlog where ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NULL.\n6) Compute pending_other = count distinct pj_project_id in base backlog where ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL.\n7) Optional snapshot-as-of logic (if end_date provided): require ms_1555_construction_complete_actual::date <= end_date and treat On-Air as incomplete at snapshot if pj_completion_objective_actual_date IS NULL OR pj_completion_objective_actual_date::date > end_date.\n8) Return one wide row per group with all bucket columns (no pivot).', kpi_filters: '[{"name": "end_date", "type": "date", "description": "Optional snapshot-as-of date; include projects with construction complete on/before end_date and still not On-Air at end_date (On-Air date is NULL or after end_date)."}, {"name": "rgn_region", "type": "string", "description": "Filters results to a specific region."}, {"name": "m_area", "type": "string", "description": "Filters results to a specific area."}, {"name": "m_market", "type": "string", "description": "Filters results to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Filters results to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Filters results to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Filters results to a specific site."}]', kpi_contract: '{"function_name": "get_cx_to_on_air_backlog", "node_type": "kpi", "node_id": "a9310885-be13-4778-bc99-7ead870d99ee", "node_label": "CX to On-Air Backlog", "description": "Counts projects where construction is complete but the site is not yet On-Air, as a CURRENT_DATE snapshot, and breaks the backlog into blocker-stage columns (wide output). Base backlog population per group (rgn_region, m_area, m_market, pj_general_contractor): DISTINCT pj_project_id where ms_1555_construction_complete_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Output columns per group must include: (1) total_cx_complete_not_on_air = count distinct projects in base population; (2) pending_integration_start = count distinct projects in base population where pj_a_5270_integration_start_finish IS NULL; (3) pending_integration_complete = count distinct projects where pj_a_5270_integration_start_finish IS NOT NULL AND ms_1970_integration_complete_actual IS NULL; (4) pending_cop_approval = count distinct projects where ms_1970_integration_complete_actual IS NOT NULL AND ms_1559_cop_approved_by_t_mobile_actual IS NULL; (5) pending_other = count distinct projects where ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL AND pj_completion_objective_actual_date IS NULL. Ensure these are additional columns on the same group row (no pivot required). Source table: stg_ndpd_mbt_tmobile_macro_combined; main entity: Project (pj_project_id) with group-by attributes from same table.", "parameters": [{"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "total_cx_complete_not_on_air", "type": "number", "nullable": false}, {"name": "pending_integration_start", "type": "number", "nullable": false}, {"name": "pending_integration_complete", "type": "number", "nullable": false}, {"name": "pending_cop_approval", "type": "number", "nullable": false}, {"name": "pending_other", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "allied tower services", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "apex tower solutions", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "armony construction", "total_cx_complete_not_on_air": 0, "pending_integration_start": 0, "pending_integration_complete": 0, "pending_cop_approval": 0, "pending_other": 0}], "row_count": 10}', nl_description: 'KPI = per (rgn_region, m_area, m_market, pj_general_contractor) counts of DISTINCT pj_project_id where construction is complete (ms_1555_construction_complete_actual not null) and On-Air is not complete (pj_completion_objective_actual_date null), with additional columns splitting that backlog into mutually exclusive blocker-stage buckets based on integration start, integration complete, and COP approval milestone null/not-null status.', node_type: 'CORE', definition: 'KPI = per (rgn_region, m_area, m_market, pj_general_contractor) counts of DISTINCT pj_project_id where construction is complete (ms_1555_construction_complete_actual not null) and On-Air is not complete (pj_completion_objective_actual_date null), with additional columns splitting that backlog into mutually exclusive blocker-stage buckets based on integration start, integration complete, and COP approval milestone null/not-null status.', kpi_python_function: 'def get_cx_to_on_air_backlog(execute_query, filters=None) -> list[dict]:\n    """CX to On-Air Backlog (CURRENT_DATE snapshot).\n\n    Base population per group:\n      DISTINCT pj_project_id\n      where ms_1555_construction_complete_actual IS NOT NULL\n        AND pj_completion_objective_actual_date IS NULL\n\n    Output columns per group:\n      - total_cx_complete_not_on_air\n      - pending_integration_start\n      - pending_integration_complete\n      - pending_cop_approval\n      - pending_other\n\n    Note: Uses raw SQL because required milestone columns are not exposed by Tier-1 accessors.\n    """\n\n    filters = filters or {}\n\n    def _sql_str(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Build optional WHERE predicates.\n    # We filter on the same table; allow common grouping filters and project identifiers.\n    allowed_filters = {\n        "rgn_region": "rgn_region",\n        "m_area": "m_area",\n        "m_market": "m_market",\n        "pj_general_contractor": "pj_general_contractor",\n        "pj_project_id": "pj_project_id",\n        "s_site_id": "s_site_id"\n    }\n\n    where_parts = []\n\n    # Optional snapshot-as-of filter: treat the milestone dates as occurring on/before end_date.\n    # If end_date not supplied, we leave as a CURRENT state check (NULL vs NOT NULL).\n    end_date = filters.get("end_date")\n    if end_date:\n        ed = _sql_str(end_date)\n        where_parts.append(f"ms_1555_construction_complete_actual::date <= \'{ed}\'::date")\n        # If a project has On-Air date after snapshot, it should still be in backlog at snapshot.\n        where_parts.append(f"(pj_completion_objective_actual_date IS NULL OR pj_completion_objective_actual_date::date > \'{ed}\'::date)")\n\n    # Add simple equality filters\n    for k, col in allowed_filters.items():\n        if k in filters and filters[k] is not None and filters[k] != "":\n            where_parts.append(f"{col} = \'{_sql_str(filters[k])}\'")\n\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    sql = f"""\n    SELECT\n      rgn_region,\n      m_area,\n      m_market,\n      pj_general_contractor,\n\n      COUNT(DISTINCT CASE\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\n         AND pj_completion_objective_actual_date IS NULL\n        THEN pj_project_id END\n      ) AS total_cx_complete_not_on_air,\n\n      COUNT(DISTINCT CASE\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\n         AND pj_completion_objective_actual_date IS NULL\n         AND pj_a_5270_integration_start_finish IS NULL\n        THEN pj_project_id END\n      ) AS pending_integration_start,\n\n      COUNT(DISTINCT CASE\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\n         AND pj_completion_objective_actual_date IS NULL\n         AND pj_a_5270_integration_start_finish IS NOT NULL\n         AND ms_1970_integration_complete_actual IS NULL\n        THEN pj_project_id END\n      ) AS pending_integration_complete,\n\n      COUNT(DISTINCT CASE\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\n         AND pj_completion_objective_actual_date IS NULL\n         AND ms_1970_integration_complete_actual IS NOT NULL\n         AND ms_1559_cop_approved_by_t_mobile_actual IS NULL\n        THEN pj_project_id END\n      ) AS pending_cop_approval,\n\n      COUNT(DISTINCT CASE\n        WHEN ms_1555_construction_complete_actual IS NOT NULL\n         AND pj_completion_objective_actual_date IS NULL\n         AND ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL\n        THEN pj_project_id END\n      ) AS pending_other\n\n    FROM public.stg_ndpd_mbt_tmobile_macro_combined\n    {where_sql}\n    GROUP BY rgn_region, m_area, m_market, pj_general_contractor\n    ORDER BY rgn_region, m_area, m_market, pj_general_contractor\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'ms_1555_construction_complete_actual', 'pj_completion_objective_actual_date', 'pj_a_5270_integration_start_finish', 'ms_1970_integration_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'CX to On-Air Backlog', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'a9310885-be13-4778-bc99-7ead870d99ee', entity_type: 'kpi', kpi_name: 'CX to On-Air Backlog', name: 'a9310885-be13-4778-bc99-7ead870d99ee', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor'], kpi_description: 'Counts projects where construction is complete but the site is not yet On-Air as of a current-state (CURRENT_DATE) snapshot. The KPI also breaks this backlog into blocker-stage buckets to show where projects are stuck in the process.', status: 'mentioned', node_id: 'a9310885-be13-4778-bc99-7ead870d99ee'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_hse_site_checklist'], nl_business_rule: '', kpi_formula_description: 'compliance_rate_pct = 100.0 * compliant_reviews / NULLIF(attempted_reviews, 0), where attempted_reviews = COUNT(DISTINCT site_id) with non-null review date and check-in status; compliant_reviews = COUNT(DISTINCT site_id) meeting all four gates (check-in, PPE, JSA, PTID I2W).', kpi_output_schema: '[{"column": "region", "type": "string", "description": "Region grouping field."}, {"column": "market", "type": "string", "description": "Market grouping field."}, {"column": "gc_name", "type": "string", "description": "General contractor name grouping field."}, {"column": "gsd_hse_review_check_date", "type": "date", "description": "Review/check date (cast to date) used for daily grain."}, {"column": "attempted_reviews", "type": "int", "description": "Distinct sites with a review attempt (non-null review date and non-null check-in status)."}, {"column": "compliant_reviews", "type": "int", "description": "Distinct sites that pass all mandatory HSE checks (all four gates)."}, {"column": "compliance_rate_pct", "type": "float", "description": "Percent of attempted reviews that are fully compliant."}, {"column": "fail_check_in_count", "type": "int", "description": "Distinct attempted sites failing the check-in gate."}, {"column": "fail_ppe_count", "type": "int", "description": "Distinct attempted sites failing the PPE validation gate."}, {"column": "fail_jsa_count", "type": "int", "description": "Distinct attempted sites failing the JSA completion gate."}, {"column": "fail_ptid_i2w_count", "type": "int", "description": "Distinct attempted sites failing the PTID I2W availability gate."}, {"column": "any_non_compliant_count", "type": "int", "description": "Distinct attempted sites failing at least one of the four mandatory gates."}]', kpi_business_logic: '1) Start from stg_ndpd_hse_site_checklist and keep rows where gsd_hse_review_check_date is not null.\n2) Group by region, market, gc_name, and gsd_hse_review_check_date::date.\n3) attempted_reviews = count distinct site_id where check_in_status is not null (and review date is not null).\n4) compliant_reviews = count distinct site_id among attempted reviews where check_in_status in (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\n5) compliance_rate_pct = 100.0 * compliant_reviews / NULLIF(attempted_reviews, 0).\n6) fail_check_in_count = count distinct site_id among attempted reviews where check_in_status not in (\'Done\',\'Checked In\') OR check_in_status is null.\n7) fail_ppe_count = count distinct site_id among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'.\n8) fail_jsa_count = count distinct site_id among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'.\n9) fail_ptid_i2w_count = count distinct site_id among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'.\n10) any_non_compliant_count = count distinct site_id among attempted reviews where NOT(all 4 compliance conditions are true).\n11) Use DISTINCT site_id to avoid double counting multiple checklist rows per site-day.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Filters to rows with gsd_hse_review_check_date >= start_date."}, {"name": "end_date", "type": "date", "description": "Filters to rows with gsd_hse_review_check_date < (end_date + 1 day)."}, {"name": "region", "type": "string", "description": "Filters to a specific region."}, {"name": "market", "type": "string", "description": "Filters to a specific market."}, {"name": "gc_name", "type": "string", "description": "Filters to a specific general contractor name."}, {"name": "site_id", "type": "string", "description": "Filters to a specific site."}, {"name": "customer_name", "type": "string", "description": "Filters to a specific customer."}, {"name": "hse_status", "type": "string", "description": "Filters to a specific HSE status (reference field; not part of the rate unless explicitly included)."}, {"name": "non_compliance_status", "type": "string", "description": "Filters to a specific non-compliance status (reference field; not part of the rate unless explicitly included)."}, {"name": "hse_engineer_name", "type": "string", "description": "Filters to a specific HSE engineer."}, {"name": "smp_id", "type": "string", "description": "Filters to a specific SMP ID."}, {"name": "smp_name", "type": "string", "description": "Filters to a specific SMP name."}]', kpi_contract: '{"function_name": "get_hse_daily_compliance_rate", "node_type": "kpi", "node_id": "313756f8-da42-470a-998f-dc558b1940f3", "node_label": "HSE Daily Compliance Rate", "description": "Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. Grain: one row per (region, market, gc_name, gsd_hse_review_check_date). Source table: stg_ndpd_hse_site_checklist. \\n\\nDenominator (attempted reviews): COUNT(DISTINCT site_id) where gsd_hse_review_check_date IS NOT NULL AND check_in_status IS NOT NULL (i.e., an HSE review attempt exists for that site-day).\\n\\nNumerator (fully compliant): COUNT(DISTINCT site_id) where check_in_status IN (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\\n\\nRate: 100.0 * numerator / NULLIF(denominator, 0).\\n\\nInclude additional output columns (wide-format) for actionable diagnosis on the same row: \\n- attempted_reviews (denominator)\\n- compliant_reviews (numerator)\\n- compliance_rate_pct\\n- fail_check_in_count: COUNT(DISTINCT site_id) among attempted reviews where check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL\\n- fail_ppe_count: COUNT(DISTINCT site_id) among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'\\n- fail_jsa_count: COUNT(DISTINCT site_id) among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'\\n- fail_ptid_i2w_count: COUNT(DISTINCT site_id) among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'\\n- any_non_compliant_count: COUNT(DISTINCT site_id) among attempted reviews where NOT(all 4 gates pass)\\n\\nNotes/handling: Use DISTINCT site_id to avoid multiple checklist rows per site-day double counting. Use the table\\u2019s region/market/gc_name columns for grouping; optionally also surface hse_status and/or non_compliance_status as reference fields (not part of the rate unless you request it). If you later switch to stg_tmo_hse_daily_tracker_v0_1, preserve the same logic but map date to review_date and use compliance_status/escalation columns for additional breakdown KPIs.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "region", "type": "string", "nullable": false}, {"name": "market", "type": "string", "nullable": false}, {"name": "gc_name", "type": "string", "nullable": false}, {"name": "gsd_hse_review_check_date", "type": "date", "nullable": false}, {"name": "attempted_reviews", "type": "number", "nullable": false}, {"name": "compliant_reviews", "type": "number", "nullable": false}, {"name": "compliance_rate_pct", "type": "string", "nullable": false}, {"name": "fail_check_in_count", "type": "number", "nullable": false}, {"name": "fail_ppe_count", "type": "number", "nullable": false}, {"name": "fail_jsa_count", "type": "number", "nullable": false}, {"name": "fail_ptid_i2w_count", "type": "number", "nullable": false}, {"name": "any_non_compliant_count", "type": "number", "nullable": false}], "sample_output": [{"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2024-10-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2025-03-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "EWS Group", "gsd_hse_review_check_date": "2024-10-27", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}], "row_count": 10}', nl_description: 'HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.', node_type: 'CORE', definition: 'HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.', kpi_python_function: 'def get_hse_daily_compliance_rate(execute_query, filters=None) -> list[dict]:\n    """Grain: one row per (region, market, gc_name, gsd_hse_review_check_date::date).\n\n    Computes attempted vs compliant distinct sites and failure-gate distinct-site counts.\n    """\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Build WHERE clause (PostgreSQL)\n    where_parts = []\n\n    # Date filtering: apply to gsd_hse_review_check_date\n    if filters:\n        start_date = filters.get("start_date")\n        end_date = filters.get("end_date")\n        if start_date:\n            where_parts.append(f"gsd_hse_review_check_date >= \'{_esc(start_date)}\'")\n        if end_date:\n            where_parts.append(\n                f"gsd_hse_review_check_date < (\'{_esc(end_date)}\'::date + interval \'1 day\')"\n            )\n\n        # Optional dimension filters (only if provided)\n        for k in [\n            "region",\n            "market",\n            "gc_name",\n            "site_id",\n            "customer_name",\n            "hse_status",\n            "non_compliance_status",\n            "hse_engineer_name",\n            "smp_id",\n            "smp_name",\n        ]:\n            if k in filters and filters.get(k) is not None and filters.get(k) != "":\n                where_parts.append(f"{k} = \'{_esc(filters.get(k))}\'")\n\n    where_parts.append("gsd_hse_review_check_date IS NOT NULL")\n\n    where_sql = ""\n    if where_parts:\n        where_sql = "WHERE " + " AND ".join(where_parts)\n\n    # NOTE: "each_crew_ptid_I2w_status" is a physically-cased column name; must be double-quoted in Postgres.\n    sql = f"""\n        SELECT\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date) AS gsd_hse_review_check_date,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                THEN site_id\n            END) AS attempted_reviews,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND check_in_status IN (\'Done\',\'Checked In\')\n                 AND ppe_validation = \'Pass\'\n                 AND jsa_completion_status = \'Completed\'\n                 AND "each_crew_ptid_I2w_status" = \'Available\'\n                THEN site_id\n            END) AS compliant_reviews,\n\n            (100.0 *\n                COUNT(DISTINCT CASE\n                    WHEN gsd_hse_review_check_date IS NOT NULL\n                     AND check_in_status IS NOT NULL\n                     AND check_in_status IN (\'Done\',\'Checked In\')\n                     AND ppe_validation = \'Pass\'\n                     AND jsa_completion_status = \'Completed\'\n                     AND "each_crew_ptid_I2w_status" = \'Available\'\n                    THEN site_id\n                END)\n             / NULLIF(\n                COUNT(DISTINCT CASE\n                    WHEN gsd_hse_review_check_date IS NOT NULL\n                     AND check_in_status IS NOT NULL\n                    THEN site_id\n                END)\n             , 0)\n            ) AS compliance_rate_pct,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL)\n                THEN site_id\n            END) AS fail_check_in_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (ppe_validation IS DISTINCT FROM \'Pass\')\n                THEN site_id\n            END) AS fail_ppe_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (jsa_completion_status IS DISTINCT FROM \'Completed\')\n                THEN site_id\n            END) AS fail_jsa_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND ("each_crew_ptid_I2w_status" IS DISTINCT FROM \'Available\')\n                THEN site_id\n            END) AS fail_ptid_i2w_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND NOT (\n                    check_in_status IN (\'Done\',\'Checked In\')\n                    AND ppe_validation = \'Pass\'\n                    AND jsa_completion_status = \'Completed\'\n                    AND "each_crew_ptid_I2w_status" = \'Available\'\n                 )\n                THEN site_id\n            END) AS any_non_compliant_count\n\n        FROM public.stg_ndpd_hse_site_checklist\n        {where_sql}\n        GROUP BY\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date)\n        ORDER BY\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date)\n    """\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['region', 'market', 'gc_name', 'gsd_hse_review_check_date', 'site_id', 'check_in_status', 'ppe_validation', 'jsa_completion_status', 'each_crew_ptid_I2w_status', 'customer_name', 'hse_status', 'non_compliance_status', 'hse_engineer_name', 'smp_id', 'smp_name'], session_id: '69a3d22f26e208edc083a06e', label: 'HSE Daily Compliance Rate', kpi_related_core_node_ids: ['customer'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '313756f8-da42-470a-998f-dc558b1940f3', entity_type: 'kpi', kpi_name: 'HSE Daily Compliance Rate', name: '313756f8-da42-470a-998f-dc558b1940f3', kpi_dimensions: ['region', 'market', 'gc_name', 'gsd_hse_review_check_date'], kpi_description: 'Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. It indicates daily compliance performance by region/market/GC and helps identify where HSE requirements are not being met.', status: 'mentioned', node_id: '313756f8-da42-470a-998f-dc558b1940f3'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'FTR Rate (%) = 100.0 * (COUNT(DISTINCT pj_project_id) audited and first_time_right=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id) audited, 0).', kpi_output_schema: '[{"column": "audited_count", "type": "int", "description": "Count of distinct pj_project_id with Nokia audit completed (ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null)."}, {"column": "ftr_yes_count", "type": "int", "description": "Count of distinct pj_project_id with Nokia audit completed and first_time_right explicitly equal to \'Yes\' after TRIM/blank-to-NULL normalization."}, {"column": "not_ftr_or_unknown_count", "type": "int", "description": "audited_count minus ftr_yes_count (projects not first-time-right or with unknown/blank/non-Yes first_time_right)."}, {"column": "ftr_rate_pct", "type": "float", "description": "First-time-right rate percentage: 100.0 * ftr_yes_count / audited_count (null when audited_count is 0)."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined.\n2) Define audited projects as rows where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL.\n3) Denominator (audited_count): COUNT(DISTINCT pj_project_id) among audited projects.\n4) Normalize first_time_right by applying TRIM; treat blank as NULL using NULLIF(TRIM(first_time_right), \'\').\n5) Numerator (ftr_yes_count): COUNT(DISTINCT pj_project_id) among audited projects where normalized first_time_right = \'Yes\'.\n6) Compute ftr_rate_pct = 100.0 * ftr_yes_count / NULLIF(audited_count, 0).\n7) Optionally compute not_ftr_or_unknown_count = audited_count - ftr_yes_count.\n8) Group results by rgn_region, m_area, m_market, pj_general_contractor; optionally include por_category and s_site_class.', kpi_filters: '[{"name": "ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL", "type": "date", "description": "Includes only projects/sites where the Nokia audit completion timestamp is present (i.e., the quality audit was completed / reached the gate)."}, {"name": "start_date", "type": "date", "description": "Filters to audits where ms_1556_punch_checklist_audit_completed_by_nokia_actual is on/after the provided start date."}, {"name": "end_date", "type": "date", "description": "Filters to audits where ms_1556_punch_checklist_audit_completed_by_nokia_actual is on/before the provided end date."}, {"name": "rgn_region", "type": "string", "description": "Filters results to a specific region."}, {"name": "m_area", "type": "string", "description": "Filters results to a specific area."}, {"name": "m_market", "type": "string", "description": "Filters results to a specific market."}, {"name": "pj_general_contractor", "type": "string", "description": "Filters results to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Filters results to a specific project id."}, {"name": "por_category", "type": "string", "description": "Filters results to a specific POR category."}, {"name": "s_site_class", "type": "string", "description": "Filters results to a specific site class."}, {"name": "group_by", "type": "string", "description": "Controls grouping columns; allowed values include rgn_region, m_area, m_market, pj_general_contractor, and optionally por_category and s_site_class."}]', kpi_contract: '{"function_name": "get_ndpc_quality_ftr_rate", "node_type": "kpi", "node_id": "f44a788a-0aab-4a97-b60e-38a9d43063af", "node_label": "NDPc Quality FTR Rate", "description": "Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. Data source: stg_ndpd_mbt_tmobile_macro_combined. Denominator = COUNT(DISTINCT pj_project_id) for rows where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL (quality audit completed, reached the gate), regardless of first_time_right value. Numerator = COUNT(DISTINCT pj_project_id) where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL AND first_time_right is explicitly \'Yes\' (apply TRIM and treat blank as NULL via NULLIF(TRIM(first_time_right),\'\'); do not attempt to enumerate non-Yes values; all non-Yes/NULL are excluded from numerator but remain in denominator if MS1556 is present). FTR Rate (%) = 100.0 * numerator / NULLIF(denominator,0). Output should include: ftr_rate_pct, ftr_yes_count (numerator), audited_count (denominator), and optionally not_ftr_or_unknown_count = audited_count - ftr_yes_count. Group by rgn_region, m_area, m_market, pj_general_contractor; optionally extend grouping with por_category and s_site_class for segmentation.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pj_general_contractor", "type": "string", "nullable": false}, {"name": "audited_count", "type": "number", "nullable": false}, {"name": "ftr_yes_count", "type": "number", "nullable": false}, {"name": "not_ftr_or_unknown_count", "type": "number", "nullable": false}, {"name": "ftr_rate_pct", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "clearpath telecom", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "impirium", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pj_general_contractor": "meridian networks", "audited_count": 1, "ftr_yes_count": 0, "not_ftr_or_unknown_count": 1, "ftr_rate_pct": 0.0}], "row_count": 10}', nl_description: 'FTR Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null and NULLIF(TRIM(first_time_right),\'\')=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null),0), grouped by region/area/market/GC (optionally por_category and s_site_class).', node_type: 'CORE', definition: 'FTR Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null and NULLIF(TRIM(first_time_right),\'\')=\'Yes\') / NULLIF(COUNT(DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null),0), grouped by region/area/market/GC (optionally por_category and s_site_class).', kpi_python_function: 'def get_ndpc_quality_ftr_rate(execute_query, filters=None) -> list[dict]:\n    """NDPc Quality FTR Rate (%): audited projects that are First Time Right / audited projects.\n\n    Denominator: DISTINCT pj_project_id where ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL.\n    Numerator: DISTINCT pj_project_id where ms_1556... IS NOT NULL AND NULLIF(TRIM(first_time_right),\'\') = \'Yes\'.\n\n    Output grouped by (default): rgn_region, m_area, m_market, pj_general_contractor.\n    Optional extra segmentation: por_category, s_site_class when filters[\'group_by\'] includes them.\n    """\n\n    filters = filters or {}\n\n    # ---- grouping ----\n    default_group = ["rgn_region", "m_area", "m_market", "pj_general_contractor"]\n    allowed_optional = {"por_category", "s_site_class"}\n\n    group_by = filters.get("group_by")\n    if group_by is None:\n        group_cols = list(default_group)\n    else:\n        if isinstance(group_by, str):\n            group_by = [g.strip() for g in group_by.split(",") if g.strip()]\n        group_cols = []\n        for g in group_by:\n            if g in default_group or g in allowed_optional:\n                if g not in group_cols:\n                    group_cols.append(g)\n        if not group_cols:\n            group_cols = list(default_group)\n\n    # ---- WHERE clause from filters ----\n    # Only apply filters that are known/used for slicing this KPI.\n    where_parts = []\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Base filter: only audited rows (avoids zero-audit noise groups)\n    where_parts.append("ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL")\n\n    # Date range applies to the Nokia audit completion timestamp\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n    if start_date:\n        where_parts.append(\n            f"ms_1556_punch_checklist_audit_completed_by_nokia_actual >= \'{esc(start_date)}\'"\n        )\n    if end_date:\n        where_parts.append(\n            f"ms_1556_punch_checklist_audit_completed_by_nokia_actual <= \'{esc(end_date)}\'"\n        )\n\n    # Common dimensional filters\n    for k in [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "pj_project_id",\n        "por_category",\n        "s_site_class",\n    ]:\n        if filters.get(k) is not None and filters.get(k) != "":\n            where_parts.append(f"{k} = \'{esc(filters.get(k))}\'")\n\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    # ---- raw SQL (needed because we must reference ms_1556... and first_time_right columns not exposed by Tier-1 accessors) ----\n    group_sql = ", ".join(group_cols)\n    select_group_sql = (group_sql + ", ") if group_cols else ""\n\n    sql = f"""\n        SELECT\n            {select_group_sql}\n            COUNT(DISTINCT CASE\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\n                THEN pj_project_id\n                ELSE NULL\n            END) AS audited_count,\n            COUNT(DISTINCT CASE\n                WHEN ms_1556_punch_checklist_audit_completed_by_nokia_actual IS NOT NULL\n                 AND NULLIF(TRIM(first_time_right), \'\') = \'Yes\'\n                THEN pj_project_id\n                ELSE NULL\n            END) AS ftr_yes_count\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n        GROUP BY {group_sql}\n        ORDER BY {group_sql}\n    """\n\n    rows = execute_query(sql, db=None, max_rows=None) or []\n\n    out = []\n    for r in rows:\n        audited = r.get("audited_count") or 0\n        ftr_yes = r.get("ftr_yes_count") or 0\n        not_ftr_or_unknown = audited - ftr_yes\n        ftr_rate_pct = (100.0 * ftr_yes / audited) if audited else None\n\n        rec = {c: r.get(c) for c in group_cols}\n        rec.update(\n            {\n                "audited_count": audited,\n                "ftr_yes_count": ftr_yes,\n                "not_ftr_or_unknown_count": not_ftr_or_unknown,\n                "ftr_rate_pct": ftr_rate_pct,\n            }\n        )\n        out.append(rec)\n\n    return out\n', kpi_source_columns: ['pj_project_id', 'ms_1556_punch_checklist_audit_completed_by_nokia_actual', 'first_time_right', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class'], session_id: '69a3d22f26e208edc083a06e', label: 'NDPc Quality FTR Rate', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'f44a788a-0aab-4a97-b60e-38a9d43063af', entity_type: 'kpi', kpi_name: 'NDPc Quality FTR Rate', name: 'f44a788a-0aab-4a97-b60e-38a9d43063af', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 's_site_class'], kpi_description: 'Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. This indicates how often audited projects meet the quality requirements on the first attempt.', status: 'mentioned', node_id: 'f44a788a-0aab-4a97-b60e-38a9d43063af'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'lead_days = (end_milestone::date - start_milestone::date) per project and segment; aggregate by (rgn_region, m_area, m_market, pj_general_contractor, segment_name) to compute AVG(lead_days), PERCENTILE_CONT(0.5), PERCENTILE_CONT(0.9), and COUNT(DISTINCT pj_project_id).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region."}, {"column": "m_area", "type": "string", "description": "Area."}, {"column": "m_market", "type": "string", "description": "Market."}, {"column": "pj_general_contractor", "type": "string", "description": "General contractor."}, {"column": "segment_name", "type": "string", "description": "Intermediate milestone segment name."}, {"column": "avg_days", "type": "float", "description": "Average lead time in calendar days for the segment."}, {"column": "p50_days", "type": "float", "description": "Median (50th percentile) lead time in calendar days for the segment."}, {"column": "p90_days", "type": "float", "description": "90th percentile lead time in calendar days for the segment."}, {"column": "project_count", "type": "int", "description": "Distinct count of projects contributing to the segment metrics."}]', kpi_business_logic: '1) Read projects from public.stg_ndpd_mbt_tmobile_macro_combined.\n2) Optionally filter the base table by equality on: pj_project_id, rgn_region, m_area, m_market, pj_general_contractor, por_category.\n3) For each project, compute lead time in calendar days for each segment as (end_column::date - start_column::date).\n4) Exclude segment rows where start_column IS NULL or end_column IS NULL.\n5) Exclude segment rows where lead_days < 0.\n6) Optionally apply date range filters to each segment using end_column::date between start_date and end_date.\n7) Unpivot all segments into a row set at grain: (pj_project_id, segment_name, lead_days, rgn_region, m_area, m_market, pj_general_contractor, por_category) via UNION ALL.\n8) Aggregate to (rgn_region, m_area, m_market, pj_general_contractor, segment_name) computing avg_days, p50_days, p90_days, and project_count = COUNT(DISTINCT pj_project_id). Note: por_category is filterable but not included in the default GROUP BY.', kpi_filters: '[{"name": "por_category", "type": "string", "description": "Restrict projects to a given POR category (optional; not included in default grouping)."}, {"name": "pj_project_id", "type": "string", "description": "Restrict to a specific project id (pass-through filter to the base table)."}, {"name": "rgn_region", "type": "string", "description": "Restrict to a specific region (pass-through filter to the base table)."}, {"name": "m_area", "type": "string", "description": "Restrict to a specific area (pass-through filter to the base table)."}, {"name": "m_market", "type": "string", "description": "Restrict to a specific market (pass-through filter to the base table)."}, {"name": "pj_general_contractor", "type": "string", "description": "Restrict to a specific general contractor (pass-through filter to the base table)."}, {"name": "start_date", "type": "date", "description": "Include only segment rows whose end milestone date is on/after this date (applied to end_column::date)."}, {"name": "end_date", "type": "date", "description": "Include only segment rows whose end milestone date is on/before this date (applied to end_column::date)."}]', kpi_contract: '{"function_name": "get_intermediate_milestone_lead_time", "node_type": "kpi", "node_id": "2f2e0906-e4e7-42b5-93ed-1431fd7f85f9", "node_label": "Intermediate Milestone Lead Time", "description": "Measures calendar-day lead time between defined intermediate milestone pairs for each project, then aggregates to highlight bottleneck segments. Source: stg_ndpd_mbt_tmobile_macro_combined (PostgreSQL). For each pj_project_id, compute lead_days = (end_milestone::date - start_milestone::date) for each segment, excluding records where start or end is NULL and excluding negative lead_days (data quality). Segments (segment_name, start_column, end_column): (1) \'Pre-NTP to Scoping Ready\': ms_1310_pre_construction_package_received_actual -> ms_1323_ready_for_scoping_actual; (2) \'Scoping to NTP Approved\': ms_1323_ready_for_scoping_actual -> ms_1507_tower_ntp_approved_actual; (3) \'NTP to Material Pickup\': ms_1507_tower_ntp_approved_actual -> \\"pj_a_3925_msi_pickup_date_finish\\" (must be double-quoted); (4) \'Material to CX Start\': \\"pj_a_3925_msi_pickup_date_finish\\" -> ms_1550_construction_start_actual; (5) \'CX Start to CX Complete\': ms_1550_construction_start_actual -> ms_1555_construction_complete_actual; (6) \'CX Complete to IX Start\': ms_1555_construction_complete_actual -> pj_a_5270_integration_start_finish; (7) \'IX Start to IX Complete\': pj_a_5270_integration_start_finish -> ms_1970_integration_complete_actual; (8) \'IX Complete to COP\': ms_1970_integration_complete_actual -> ms_1559_cop_approved_by_t_mobile_actual; (9) \'COP to On-Air\': ms_1559_cop_approved_by_t_mobile_actual -> pj_completion_objective_actual_date. Unpivot segments via UNION ALL into rows at grain (pj_project_id, segment_name, lead_days, rgn_region, m_area, m_market, pj_general_contractor, por_category). Aggregate output to one row per (rgn_region, m_area, m_market, pj_general_contractor, segment_name) with avg_days (AVG), p50_days and p90_days using percentile_cont(0.5) and percentile_cont(0.9) within group, and project_count = COUNT(DISTINCT pj_project_id). por_category is supported as an optional filter parameter (e.g., restrict to \'Site Mod\') but not included in the default GROUP BY.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Intermediate Milestone Lead Time = for each project and each defined milestone segment, (end_milestone::date − start_milestone::date) in calendar days (excluding NULL endpoints and negative durations), then aggregated by (rgn_region, m_area, m_market, pj_general_contractor, segment_name) to compute avg_days, p50_days, p90_days, and distinct project_count (with optional por_category filtering).', node_type: 'CORE', definition: 'Intermediate Milestone Lead Time = for each project and each defined milestone segment, (end_milestone::date − start_milestone::date) in calendar days (excluding NULL endpoints and negative durations), then aggregated by (rgn_region, m_area, m_market, pj_general_contractor, segment_name) to compute avg_days, p50_days, p90_days, and distinct project_count (with optional por_category filtering).', kpi_python_function: 'def get_intermediate_milestone_lead_time(execute_query, filters=None) -> list[dict]:\n    """Compute intermediate milestone lead times per segment and aggregate by (region, area, market, GC, segment).\n\n    Optional filters supported (if provided in `filters`):\n      - por_category: restrict projects to a given POR category (not in default group-by)\n      - rgn_region, m_area, m_market, pj_general_contractor, pj_project_id: pass-through filters to base table\n      - start_date, end_date: applied to segment end milestone date (end_column::date within range)\n\n    Returns rows:\n      rgn_region, m_area, m_market, pj_general_contractor, segment_name,\n      avg_days, p50_days, p90_days, project_count\n    """\n\n    filters = filters or {}\n\n    def _escape(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Base WHERE clause: only filters that exist as columns on the wide table.\n    # (We intentionally do not include start_date/end_date here because we apply them to each segment\'s end date.)\n    passthrough_keys = [\n        "pj_project_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "pj_general_contractor",\n        "por_category",\n    ]\n    where_parts = []\n    for k in passthrough_keys:\n        if k in filters and filters.get(k) not in (None, ""):\n            where_parts.append(f"{k} = \'{_escape(filters.get(k))}\'")\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    # Date range filters (applied to end milestone date for each segment)\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n\n    # Segment definitions: (segment_name, start_column_sql, end_column_sql)\n    segments = [\n        (\n            "Pre-NTP to Scoping Ready",\n            "ms_1310_pre_construction_package_received_actual",\n            "ms_1323_ready_for_scoping_actual",\n        ),\n        (\n            "Scoping to NTP Approved",\n            "ms_1323_ready_for_scoping_actual",\n            "ms_1507_tower_ntp_approved_actual",\n        ),\n        (\n            "NTP to Material Pickup",\n            "ms_1507_tower_ntp_approved_actual",\n            \'"pj_a_3925_msI_pickup_date_finish"\',\n        ),\n        (\n            "Material to CX Start",\n            \'"pj_a_3925_msI_pickup_date_finish"\',\n            "ms_1550_construction_start_actual",\n        ),\n        (\n            "CX Start to CX Complete",\n            "ms_1550_construction_start_actual",\n            "ms_1555_construction_complete_actual",\n        ),\n        (\n            "CX Complete to IX Start",\n            "ms_1555_construction_complete_actual",\n            "pj_a_5270_integration_start_finish",\n        ),\n        (\n            "IX Start to IX Complete",\n            "pj_a_5270_integration_start_finish",\n            "ms_1970_integration_complete_actual",\n        ),\n        (\n            "IX Complete to COP",\n            "ms_1970_integration_complete_actual",\n            "ms_1559_cop_approved_by_t_mobile_actual",\n        ),\n        (\n            "COP to On-Air",\n            "ms_1559_cop_approved_by_t_mobile_actual",\n            "pj_completion_objective_actual_date",\n        ),\n    ]\n\n    # Build UNION ALL unpivot with lead_days and filtering rules:\n    # - exclude NULL start or end\n    # - exclude negative lead_days\n    # - optionally filter by end milestone date between start_date/end_date\n    union_selects = []\n    for segment_name, start_col, end_col in segments:\n        seg_filters = [\n            f"{start_col} IS NOT NULL",\n            f"{end_col} IS NOT NULL",\n            f"(({end_col})::date - ({start_col})::date) >= 0",\n        ]\n        if start_date not in (None, ""):\n            seg_filters.append(f"({end_col})::date >= \'{_escape(start_date)}\'::date")\n        if end_date not in (None, ""):\n            seg_filters.append(f"({end_col})::date <= \'{_escape(end_date)}\'::date")\n\n        seg_where = " AND ".join(seg_filters)\n\n        union_selects.append(\n            "\\n".join(\n                [\n                    "SELECT",\n                    "  pj_project_id,",\n                    f"  \'{_escape(segment_name)}\'::text AS segment_name,",\n                    f"  (({end_col})::date - ({start_col})::date)::int AS lead_days,",\n                    "  rgn_region,",\n                    "  m_area,",\n                    "  m_market,",\n                    "  pj_general_contractor,",\n                    "  por_category",\n                    "FROM public.stg_ndpd_mbt_tmobile_macro_combined",\n                    where_sql,\n                    ("AND " if where_sql else "WHERE ") + seg_where,\n                ]\n            )\n        )\n\n    unpivot_sql = "\\nUNION ALL\\n".join(union_selects)\n\n    # Aggregate with AVG and percentiles.\n    # Note: percentile_cont ignores NULLs; lead_days is non-null by construction.\n    # por_category is filterable but intentionally excluded from GROUP BY.\n    agg_sql = "\\n".join(\n        ["WITH segment_leads AS ("]\n        + [unpivot_sql]\n        + [\n            ")",\n            "SELECT",\n            "  rgn_region,",\n            "  m_area,",\n            "  m_market,",\n            "  pj_general_contractor,",\n            "  segment_name,",\n            "  AVG(lead_days)::numeric(18,2) AS avg_days,",\n            "  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY lead_days) AS p50_days,",\n            "  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY lead_days) AS p90_days,",\n            "  COUNT(DISTINCT pj_project_id) AS project_count",\n            "FROM segment_leads",\n            "GROUP BY rgn_region, m_area, m_market, pj_general_contractor, segment_name",\n            "ORDER BY rgn_region, m_area, m_market, pj_general_contractor, segment_name",\n        ]\n    )\n\n    return execute_query(agg_sql)\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'por_category', 'ms_1310_pre_construction_package_received_actual', 'ms_1323_ready_for_scoping_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_3925_msi_pickup_date_finish', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'pj_a_5270_integration_start_finish', 'ms_1970_integration_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual', 'pj_completion_objective_actual_date'], session_id: '69a3d22f26e208edc083a06e', label: 'Intermediate Milestone Lead Time', kpi_related_core_node_ids: ['project', 'milestone', 'market', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9', entity_type: 'kpi', kpi_name: 'Intermediate Milestone Lead Time', name: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'pj_general_contractor', 'segment_name'], kpi_description: 'Measures the calendar-day lead time between defined intermediate milestone pairs for each project, then aggregates results to highlight bottleneck segments in the project lifecycle.', status: 'mentioned', node_id: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9'});
