\n        sql = (\n            "SELECT DISTINCT nas_engineer AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'riot\' AS source "\n            "FROM public.stg_nas_e911_readiness_riot_validation "\n            "WHERE nas_engineer IS NOT NULL"\n        )\n\n    elif source == "ndpc_sessions":\n        sql = (\n            "SELECT DISTINCT owner AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'ndpc_sessions\' AS source "\n            "FROM public.stg_services_ndpc_sessions_daily_from_sdb "\n            "WHERE owner IS NOT NULL"\n        )\n\n    else:\n        return []\n\n    # Cross-source filters: only person_name is safely applicable.\n    if filters.get("person_name") is not None:\n        sql = f"SELECT * FROM ({sql}) q WHERE person_name = \'{_escape(filters[\'person_name\'])}\'"\n\n    return execute_query(sql) or []\n' , name: 'person', definition: 'A named individual assigned to work on projects/sites in specific roles (e.g., Project Manager, Construction Manager, Deployment Coordinator, NAS Integration Engineer). Used for accountability, escalations, and market operations.', map_database_name: 'MULTI_SOURCE', skip_reason: '', status: 'mentioned', node_id: 'person'});
