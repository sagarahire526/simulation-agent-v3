CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Average over projects/sites of (earliest non-null On-Air finish date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish).', kpi_output_schema: '[{"column": "kpi", "type": "string", "description": "KPI name."}, {"column": "avg_cycle_time_days", "type": "float", "description": "Average on-air cycle time in days."}, {"column": "projects_count", "type": "int", "description": "Number of projects/sites included in the average after filtering and data-quality exclusions."}, {"column": "filters_applied", "type": "string", "description": "Filters echoed back in the output (start_date, end_date, site_code, market, gc)."}]', kpi_business_logic: '1) For each row (project/site), read construction_start_date = pj_a_4225_construction_start_finish. 2) Determine on_air_date as the minimum (earliest) non-null date among all columns whose name matches pj_*_onair_finish (i.e., contains \'onair_finish\'). 3) Exclude rows where either date is null. 4) Apply optional date_range filter using on_air_date as the anchor (fallback to construction_start_date only if on_air_date is missing). 5) Compute cycle_time_days = on_air_date - construction_start_date; exclude negative durations. 6) KPI = average(cycle_time_days) across remaining rows.', kpi_filters: '[{"name": "date_range", "type": "date", "description": "Filters by start_date/end_date applied to on_air_date (preferred) or start_date (construction start) if on_air_date is missing."}, {"name": "site_code", "type": "string", "description": "Filters to a specific site (mapped to s_site_id)."}, {"name": "market", "type": "string", "description": "Filters to a specific market (m_market)."}, {"name": "gc", "type": "string", "description": "Filters to a specific general contractor (matches construction_gc or pj_general_contractor)."}]', kpi_contract: '{"function_name": "get_on_air_cycle_time", "node_type": "kpi", "node_id": "d7ffcd7d-93e1-4c31-a9f2-b430e2843f28", "node_label": "On-Air Cycle Time", "description": "Average end-to-end delivery time from construction start to first On-Air. Formula: f(Project, Site)=avg(pj_a_4225_construction_start_finish - min(non-null pj_*_onair_finish)). Accepts filters: [date_range by on_air_date or start_date, site_code, market, gc].", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "site_code", "type": "string", "description": "Filter by site code", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "gc", "type": "string", "description": "Filter by gc", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}], "output_columns": [{"name": "kpi", "type": "string", "nullable": false}, {"name": "avg_cycle_time_days", "type": "number", "nullable": false}, {"name": "projects_count", "type": "number", "nullable": false}, {"name": "filters_applied", "type": "string", "nullable": false}], "sample_output": [{"kpi": "On-Air Cycle Time", "avg_cycle_time_days": 62.14035087719298, "projects_count": 57, "filters_applied": "{\'start_date\': None, \'end_date\': None, \'site_code\': None, \'market\': None, \'gc\': None}"}], "row_count": 1}', nl_description: 'On-Air Cycle Time = average over projects/sites of (earliest non-null On-Air finish milestone date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish), optionally filtered by date range (on_air_date preferred), site_code, market, and GC.', node_type: 'CORE', definition: 'On-Air Cycle Time = average over projects/sites of (earliest non-null On-Air finish milestone date across all pj_*_onair_finish fields minus pj_a_4225_construction_start_finish), optionally filtered by date range (on_air_date preferred), site_code, market, and GC.', kpi_python_function: 'def get_on_air_cycle_time(execute_query, filters=None) -> list[dict]:\n    """On-Air Cycle Time (days) = avg( on_air_date - construction_start_date )\n\n    construction_start_date := pj_a_4225_construction_start_finish\n    on_air_date := MIN(non-null pj_*_onair_finish) across all columns matching \'*onair_finish*\'\n\n    Filters accepted (best-effort): start_date/end_date applied to on_air_date if present, else construction_start_date.\n    Also supports site_code, market, gc.\n    """\n\n    def _to_date_str(v):\n        if v is None:\n            return None\n        s = str(v).strip()\n        return s[:10] if len(s) >= 10 else s\n\n    def _parse_yyyy_mm_dd(v):\n        s = _to_date_str(v)\n        if not s or len(s) < 10:\n            return None\n        try:\n            y = int(s[0:4]); m = int(s[5:7]); d = int(s[8:10])\n            # return ordinal to compute day-diffs without imports\n            # algorithm: days from civil (Howard Hinnant)\n            a = (14 - m) // 12\n            y2 = y + 4800 - a\n            m2 = m + 12 * a - 3\n            jdn = d + ((153 * m2 + 2) // 5) + 365 * y2 + (y2 // 4) - (y2 // 100) + (y2 // 400) - 32045\n            return jdn\n        except Exception:\n            return None\n\n    def _min_non_null_date_from_row(row, key_substr):\n        best = None\n        for k, v in row.items():\n            if v is None:\n                continue\n            k_l = str(k).lower()\n            if key_substr in k_l:\n                j = _parse_yyyy_mm_dd(v)\n                if j is None:\n                    continue\n                if best is None or j < best:\n                    best = j\n        return best\n\n    filters = filters or {}\n    start_date = _parse_yyyy_mm_dd(filters.get(\'start_date\'))\n    end_date = _parse_yyyy_mm_dd(filters.get(\'end_date\'))\n\n    # Build a base filter set for Tier-1 accessor. Note: accessor may ignore unknown keys;\n    # we keep only common attributes that are known to exist on the wide table.\n    base_filters = {}\n    if filters.get(\'site_code\'):\n        # most tables use s_site_id as the site code; accessor returns it as site_code\n        base_filters[\'s_site_id\'] = filters.get(\'site_code\')\n    if filters.get(\'market\'):\n        base_filters[\'m_market\'] = filters.get(\'market\')\n    if filters.get(\'gc\'):\n        # prefer construction_gc if present, else pj_general_contractor\n        base_filters[\'construction_gc\'] = filters.get(\'gc\')\n\n    # We need milestone columns (pj_a_4225... and pj_*_onair_finish) which are not included\n    # in the Project node\'s returned columns. Use raw SQL against the wide table.\n    where_parts = []\n    if base_filters.get(\'s_site_id\'):\n        esc = str(base_filters[\'s_site_id\']).replace("\'", "\'\'")\n        where_parts.append(f"s_site_id = \'{esc}\'")\n    if base_filters.get(\'m_market\'):\n        esc = str(base_filters[\'m_market\']).replace("\'", "\'\'")\n        where_parts.append(f"m_market = \'{esc}\'")\n    if base_filters.get(\'construction_gc\'):\n        esc = str(base_filters[\'construction_gc\']).replace("\'", "\'\'")\n        # match either construction_gc or pj_general_contractor (free-text duplicates)\n        where_parts.append(f"(construction_gc = \'{esc}\' OR pj_general_contractor = \'{esc}\')")\n\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    sql = (\n        "SELECT * "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"{where_sql}"\n    )\n    rows = execute_query(sql)\n\n    total_days = 0\n    n = 0\n\n    for r in rows:\n        site_code = r.get(\'s_site_id\')\n        market = r.get(\'m_market\')\n        gc = r.get(\'construction_gc\') or r.get(\'pj_general_contractor\')\n        project_id = r.get(\'pj_project_id\')\n\n        construction_start = _parse_yyyy_mm_dd(r.get(\'pj_a_4225_construction_start_finish\'))\n        # heuristic: any column containing \'onair_finish\' is considered an on-air completion timestamp\n        on_air = _min_non_null_date_from_row(r, \'onair_finish\')\n\n        if construction_start is None or on_air is None:\n            continue\n\n        # Apply date range filter: prefer on_air date; if missing (shouldn\'t happen), fallback to construction_start\n        anchor = on_air if on_air is not None else construction_start\n        if start_date is not None and anchor < start_date:\n            continue\n        if end_date is not None and anchor > end_date:\n            continue\n\n        cycle_days = on_air - construction_start\n        # ignore negative durations (bad data)\n        if cycle_days is None or cycle_days < 0:\n            continue\n\n        total_days += cycle_days\n        n += 1\n\n    avg_days = (total_days / n) if n else None\n\n    return [\n        {\n            \'kpi\': \'On-Air Cycle Time\',\n            \'avg_cycle_time_days\': avg_days,\n            \'projects_count\': n,\n            \'filters_applied\': {\n                \'start_date\': _to_date_str(filters.get(\'start_date\')),\n                \'end_date\': _to_date_str(filters.get(\'end_date\')),\n                \'site_code\': filters.get(\'site_code\'),\n                \'market\': filters.get(\'market\'),\n                \'gc\': filters.get(\'gc\')\n            }\n        }\n    ]\n', kpi_source_columns: ['pj_a_4225_construction_start_finish', 'pj_*_onair_finish', 's_site_id', 'm_market', 'construction_gc', 'pj_general_contractor', 'pj_project_id'], session_id: '69a3d22f26