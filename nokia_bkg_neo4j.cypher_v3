// ============================================================
//  SECTION 4 — METRIC NODES (9 total)
// ============================================================

// ── M1. PROJECT PHASE METRIC ─────────────────────────────────
MERGE (m:MetricNode {metric_id: 'ProjectPhaseMetric'})
SET
  m.name            = 'Project Phase Metric',
  m.layer            = 2,
  m.domain           = 'Project Lifecycle',
  m.definition       = 'Distribution of projects across lifecycle phases and time-in-phase analysis. Identifies bottleneck phases and stuck projects.',
  m.references_nodes = ['Project','Milestone','ProjectPhase','Site'],
  m.formulas         = ['phase_distribution','days_in_current_phase','stuck_projects'],
  m.thresholds       = '{days_in_construction:{good:"<=21",warning:"22-45",critical:">45"}, days_in_integration:{good:"<=14",warning:"15-30",critical:">30"}, days_in_quality_closeout:{good:"<=14",warning:"15-30",critical:">30"}, days_ntp_to_construction_start:{good:"<=30",warning:"31-60",critical:">60"}}',
  m.unit             = 'count / days',
  m.formula_sql_phase_distribution = 'SELECT phase_name, COUNT(*) AS project_count, ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 1) AS pct FROM (SELECT pj_project_id, CASE WHEN ms_2490_project_complete_actual IS NOT NULL THEN \'7-Complete\' WHEN ms_1559_cop_approved_by_t_mobile_actual IS NOT NULL THEN \'6-Acceptance/Payment\' WHEN ms_1970_integration_complete_actual IS NOT NULL THEN \'5-Integration Complete\' WHEN ms_1564_validate_scf_files_are_available_actual IS NOT NULL THEN \'4-Integration\' WHEN ms_1555_construction_complete_actual IS NOT NULL THEN \'3-Quality/Closeout\' WHEN ms_1550_construction_start_actual IS NOT NULL THEN \'2-Construction\' WHEN ms_1406_notice_to_proceed_received_actual IS NOT NULL THEN \'1-NTP/Material/Scoping\' ELSE \'0-Assignment/Pre-NTP\' END AS phase_name FROM stg_ndpd_mbt_tmobile_macro_combined WHERE pj_project_status NOT IN (\'Cancelled\', \'On Hold\')) sub GROUP BY phase_name ORDER BY phase_name';


// ── M2. CREW CAPACITY METRIC ─────────────────────────────────
MERGE (m:MetricNode {metric_id: 'CrewCapacityMetric'})
SET
  m.name            = 'Crew Capacity Metric',
  m.layer            = 2,
  m.domain           = 'Workforce & Vendor',
  m.definition       = 'Available crew capacity vs demand at market × GC × week level. KEY PLANNING STATE. Weekly Delivery = Available Crews × Sites/Crew/Day × Working Days.',
  m.references_nodes = ['Crew','GeneralContractor','Market','TimeWeek','Site'],
  m.formulas         = ['gc_active_site_load','weekly_throughput_by_gc','capacity_gap','crew_resource_requirement'],
  m.thresholds       = '{weeks_to_clear_backlog:{good:"<=4",warning:"5-8",critical:">8 or NULL"}, utilization_pct:{good:"70-90%",warning:"<70% or >90%",critical:">100%"}}',
  m.unit             = 'sites/week, weeks, %',
  m.formula_sql_capacity_gap = 'WITH demand AS (SELECT m_market, pj_general_contractor, COUNT(*) AS sites_ready_for_cx FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1550_construction_start_actual IS NULL AND ms_1406_notice_to_proceed_received_actual IS NOT NULL AND pj_project_status NOT IN (\'Cancelled\', \'On Hold\') GROUP BY m_market, pj_general_contractor), supply AS (SELECT m_market, pj_general_contractor, ROUND(AVG(weekly_completions), 1) AS avg_weekly_completions FROM (SELECT m_market, pj_general_contractor, EXTRACT(WEEK FROM CAST(ms_1555_construction_complete_actual AS DATE)) AS wk, COUNT(*) AS weekly_completions FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1555_construction_complete_actual IS NOT NULL AND CAST(ms_1555_construction_complete_actual AS DATE) >= CURRENT_DATE - INTERVAL \'90 days\' GROUP BY m_market, pj_general_contractor, EXTRACT(WEEK FROM CAST(ms_1555_construction_complete_actual AS DATE))) sub GROUP BY m_market, pj_general_contractor) SELECT d.m_market, d.pj_general_contractor, d.sites_ready_for_cx AS demand, COALESCE(s.avg_weekly_completions, 0) AS weekly_supply, CASE WHEN COALESCE(s.avg_weekly_completions, 0) = 0 THEN NULL ELSE ROUND(d.sites_ready_for_cx / s.avg_weekly_completions, 1) END AS weeks_to_clear FROM demand d LEFT JOIN supply s ON d.m_market = s.m_market AND d.pj_general_contractor = s.pj_general_contractor ORDER BY weeks_to_clear DESC NULLS FIRST';


// ── M3. MATERIAL AVAILABILITY METRIC ─────────────────────────
MERGE (m:MetricNode {metric_id: 'MaterialAvailabilityMetric'})
SET
  m.name            = 'Material Availability Metric',
  m.layer            = 2,
  m.domain           = 'Material & Logistics',
  m.definition       = 'Whether all BOM items for a site are available for construction. BLOCKING PREREQUISITE. Tracks BOM submission through BAT ordering to warehouse receipt to GC pickup.',
  m.references_nodes = ['BillOfMaterials','Site','Warehouse','GeneralContractor'],
  m.formulas         = ['material_readiness_status','material_blocked_sites','material_lead_time'],
  m.thresholds       = '{bom_to_receipt_days:{good:"<=21",warning:"22-35",critical:">35"}, receipt_to_pickup_days:{good:"<=7",warning:"8-14",critical:">14"}, pct_sites_material_blocked:{good:"<10%",warning:"10-25%",critical:">25%"}}',
  m.unit             = 'days, count, %',
  m.formula_sql_readiness = 'SELECT pj_project_id, customer_site_code, m_market, pj_general_contractor, CASE WHEN ms_14610_gc_material_pickup_actual IS NOT NULL THEN \'Picked Up\' WHEN pj_a_3900_all_bat_orders_received_finish IS NOT NULL THEN \'At Warehouse - Ready\' WHEN pj_a_3875_bom_received_bom_in_aims_finish IS NOT NULL THEN \'BOM in AIMS - Orders Processing\' WHEN pj_a_3850_bom_submitted_bom_in_bat_finish IS NOT NULL THEN \'BOM in BAT - Submitted\' WHEN pj_a_2350_bom_submitted_from_market_to_region_finish IS NOT NULL THEN \'BOM Submitted to Region\' ELSE \'BOM Not Submitted\' END AS material_status FROM stg_ndpd_mbt_tmobile_macro_combined WHERE pj_project_status NOT IN (\'Cancelled\', \'On Hold\')';


// ── M4. SITE READINESS METRIC ────────────────────────────────
MERGE (m:MetricNode {metric_id: 'SiteReadinessMetric'})
SET
  m.name            = 'Site Readiness Metric',
  m.layer            = 2,
  m.domain           = 'Prerequisites & Readiness',
  m.definition       = 'COMPOSITE readiness state — are ALL prerequisites met for construction to start? Aggregates structural/mount, leases, permits, power, material, BOM, site access. Pre-Construction Readiness Score.',
  m.references_nodes = ['Prerequisite','BillOfMaterials','Site','NTP'],
  m.formulas         = ['site_readiness_composite','readiness_score','blocker_distribution','ready_but_not_started'],
  m.thresholds       = '{readiness_score_pct:{good:"100%",warning:"67-99%",critical:"<67% (2+ blockers)"}, days_ready_but_not_started:{good:"<=7",warning:"8-21",critical:">21"}}',
  m.unit             = '%, count, days',
  m.formula_sql_composite = 'SELECT customer_site_code, m_market, pj_general_contractor, CASE WHEN pj_structural_result IS NOT NULL AND pj_structural_result != \'[null]\' THEN 1 ELSE 0 END AS structural_clear, CASE WHEN pj_lease_ground_status IN (\'executed\', \'Executed\', \'complete\', \'Complete\') THEN 1 ELSE 0 END AS lease_clear, CASE WHEN pj_building_permit_approved_status IN (\'approved\', \'Approved\', \'complete\') OR pj_building_permit_not_required_document_status IS NOT NULL THEN 1 ELSE 0 END AS permit_clear, CASE WHEN pj_a_3725_all_entitlement_complete_finish IS NOT NULL AND pj_a_3725_all_entitlement_complete_finish != \'[null]\' THEN 1 ELSE 0 END AS entitlement_clear, CASE WHEN pj_a_3900_all_bat_orders_received_finish IS NOT NULL AND pj_a_3900_all_bat_orders_received_finish != \'[null]\' THEN 1 ELSE 0 END AS material_ready, CASE WHEN ms_1406_notice_to_proceed_received_actual IS NOT NULL AND ms_1406_notice_to_proceed_received_actual != \'[null]\' THEN 1 ELSE 0 END AS ntp_received FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1550_construction_start_actual IS NULL AND pj_project_status NOT IN (\'Cancelled\', \'On Hold\')';


// ── M5. CONSTRUCTION PROGRESS METRIC ─────────────────────────
MERGE (m:MetricNode {metric_id: 'ConstructionProgressMetric'})
SET
  m.name            = 'Construction Progress Metric',
  m.layer            = 2,
  m.domain           = 'Construction',
  m.definition       = 'Current construction status tracking. Sites in civil phase, tower phase, or complete. Includes days elapsed and whether site has matured for integration.',
  m.references_nodes = ['CivilConstruction','TowerConstruction','ConstructionProgress','Site'],
  m.formulas         = ['construction_status_distribution','active_construction_aging'],
  m.thresholds       = '{tower_construction_days:{good:"<=21",warning:"22-35",critical:">35"}, civil_construction_days:{good:"<=21",warning:"22-35",critical:">35"}}',
  m.unit             = 'count, days',
  m.formula_sql_distribution = 'SELECT CASE WHEN ms_1555_construction_complete_actual IS NOT NULL AND ms_1555_construction_complete_actual != \'[null]\' THEN \'Tower Complete\' WHEN ms_1550_construction_start_actual IS NOT NULL AND ms_1550_construction_start_actual != \'[null]\' THEN \'Tower In Progress\' WHEN ms_1551_civil_construction_complete_actual IS NOT NULL AND ms_1551_civil_construction_complete_actual != \'[null]\' THEN \'Civil Complete / Pre-Tower\' WHEN ms_1549_civil_construction_start_actual IS NOT NULL AND ms_1549_civil_construction_start_actual != \'[null]\' THEN \'Civil In Progress\' ELSE \'Not Started\' END AS cx_phase, COUNT(*) AS site_count FROM stg_ndpd_mbt_tmobile_macro_combined WHERE pj_project_status NOT IN (\'Cancelled\', \'On Hold\') GROUP BY 1 ORDER BY 1';


// ── M6. CONSTRUCTION CYCLE TIME METRIC ───────────────────────
MERGE (m:MetricNode {metric_id: 'ConstructionCycleTimeMetric'})
SET
  m.name            = 'Construction Cycle Time Metric',
  m.layer            = 2,
  m.domain           = 'Construction',
  m.definition       = 'Average days between tower construction start (MS 1550) and completion (MS 1555). PRIMARY SIMULATION BENCHMARK by Market × GC.',
  m.references_nodes = ['TowerConstruction','GeneralContractor','Market','Crew'],
  m.formulas         = ['cycle_time_by_market_gc','cycle_time_trend','ntp_to_onair'],
  m.thresholds       = '{tower_cycle_time_days:{good:"<=21",warning:"22-35",critical:">35"}, ntp_to_onair_days:{good:"<=90",warning:"91-150",critical:">150"}}',
  m.unit             = 'days',
  m.formula_sql_cycle = 'SELECT m_market, pj_general_contractor, COUNT(*) AS completed_sites, ROUND(AVG(DATEDIFF(day, CAST(ms_1550_construction_start_actual AS DATE), CAST(ms_1555_construction_complete_actual AS DATE))), 1) AS avg_cycle_days, ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY DATEDIFF(day, CAST(ms_1550_construction_start_actual AS DATE), CAST(ms_1555_construction_complete_actual AS DATE))), 1) AS median_cycle_days FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1550_construction_start_actual IS NOT NULL AND ms_1555_construction_complete_actual IS NOT NULL AND ms_1550_construction_start_actual != \'[null]\' AND ms_1555_construction_complete_actual != \'[null]\' GROUP BY m_market, pj_general_contractor HAVING COUNT(*) >= 5 ORDER BY avg_cycle_days DESC';


// ── M7. INTEGRATION READINESS METRIC ─────────────────────────
MERGE (m:MetricNode {metric_id: 'IntegrationReadinessMetric'})
SET
  m.name            = 'Integration Readiness Metric',
  m.layer            = 2,
  m.domain           = 'Integration & On-Air',
  m.definition       = 'Whether all integration artifacts and gates are met for site integration to begin. Key artifacts: SCF (MS 1564), iNTP, ICOP (common blocker), CIQ, RIOT, OTDR (common delay). Separate from construction readiness.',
  m.references_nodes = ['Integration','NASSession','Site'],
  m.formulas         = ['integration_readiness_status','integration_blocked_sites','integration_cycle_time'],
  m.thresholds       = '{cx_to_ix_complete_days:{good:"<=14",warning:"15-30",critical:">30"}, days_waiting_for_integration:{good:"<=7",warning:"8-21",critical:">21"}}',
  m.unit             = 'days, count',
  m.formula_sql_blocked = 'SELECT customer_site_code, m_market, pj_general_contractor, ms_1555_construction_complete_actual AS cx_complete, DATEDIFF(day, CAST(ms_1555_construction_complete_actual AS DATE), CURRENT_DATE) AS days_waiting, CASE WHEN ms_1564_validate_scf_files_are_available_actual IS NULL OR ms_1564_validate_scf_files_are_available_actual = \'[null]\' THEN \'SCF Not Validated\' WHEN i_ntp_received IS NULL OR i_ntp_received = \'[null]\' THEN \'iNTP Not Received\' WHEN ms_1970_integration_complete_actual IS NULL OR ms_1970_integration_complete_actual = \'[null]\' THEN \'Integration In Progress / Blocked\' ELSE \'Unknown\' END AS likely_blocker FROM stg_ndpd_mbt_tmobile_macro_combined WHERE ms_1555_construction_complete_actual IS NOT NULL AND ms_1555_construction_complete_actual != \'[null]\' AND (ms_1970_integration_complete_actual IS NULL OR ms_1970_integration_complete_actual = \'[null]\') AND pj_project_status NOT IN (\'Cancelled\', \'On Hold\') ORDER BY days_waiting DESC';


// ── M8. INTEGRATION CAPACITY METRIC ──────────────────────────
MERGE (m:MetricNode {metric_id: 'IntegrationCapacityMetric'})
SET
  m.name            = 'Integration Capacity Metric',
  m.layer            = 2,
  m.domain           = 'Integration & On-Air',
  m.definition       = 'NAS resource capacity state. Integration engineers are shift-based. Engineer Requirement = Sessions/Shift ÷ Sessions/Engineer/Shift. Capacity constrains integration throughput.',
  m.references_nodes = ['NASSession','Integration','NokiaRole','Market'],
  m.formulas         = ['daily_session_volume','session_throughput_by_engineer','session_duration_metrics','rejection_rate_by_market','extension_analysis'],
  m.thresholds       = '{avg_session_hours:{good:"<=4",warning:"4-6",critical:">6"}, rejection_rate_pct:{good:"<5%",warning:"5-15%",critical:">15%"}, extensions_per_session:{good:"<0.2",warning:"0.2-0.5",critical:">0.5"}}',
  m.unit             = 'sessions/day, hours, %, count',
  m.formula_sql_daily = 'SELECT nas_market, CAST(nas_session_create_time AS DATE) AS session_date, COUNT(DISTINCT nas_session_id) AS session_count FROM stg_nas_session_level_combined_data WHERE nas_session_create_time IS NOT NULL GROUP BY nas_market, CAST(nas_session_create_time AS DATE) ORDER BY session_date DESC',
  m.formula_sql_extensions = 'SELECT nas_market, SUM(CAST(nas_total_ext_count_approved AS INT)) AS total_extensions_approved, SUM(CAST(nas_total_ext_count_rejected AS INT)) AS total_extensions_rejected, AVG(CAST(nas_total_ext_time_approved AS FLOAT)) AS avg_extension_time_min FROM stg_nas_nest_ext_raw_by_session WHERE nas_total_ext_count_approved IS NOT NULL GROUP BY nas_market ORDER BY total_extensions_approved DESC';


// ── M9. QUALITY POSITION METRIC ──────────────────────────────
MERGE (m:MetricNode {metric_id: 'QualityPositionMetric'})
SET
  m.name            = 'Quality Position Metric',
  m.layer            = 2,
  m.domain           = 'Quality & Compliance',
  m.definition       = 'Aggregate quality posture driving RCA: FTR%, rework rate, open punch count, HSE compliance, NDPc rejection rate.',
  m.references_nodes = ['NDPcSession','HSECheck','PunchItem','QualityPosition','GeneralContractor','Market'],
  m.formulas         = ['vendor_quality_scorecard','market_quality_heatmap','top_deficiency_categories'],
  m.thresholds       = '{ftr_pct:{good:">=90%",warning:"75-89%",critical:"<75%"}, rework_rate_pct:{good:"<10%",warning:"10-25%",critical:">25%"}, avg_punch_points_per_site:{good:"<10",warning:"10-30",critical:">30"}, l3_plus_escalation_rate:{good:"<2%",warning:"2-5%",critical:">5%"}}',
  m.unit             = '%, count',
  m.formula_sql_scorecard = 'WITH ndpc_ftr AS (SELECT mc.pj_general_contractor, COUNT(DISTINCT CASE WHEN ns.sessionstatus NOT IN (\'2\', \'4\') THEN ns.siteid END) AS ftr_sessions, COUNT(DISTINCT ns.siteid) AS total_sessions FROM stg_ndpd_mbt_tmobile_macro_combined mc JOIN stg_services_ndpc_sessions_daily_from_sdb ns ON ns.siteid = mc.customer_site_code GROUP BY mc.pj_general_contractor), tmo_rejections AS (SELECT mc.pj_general_contractor, COUNT(DISTINCT tr.trmf_site_code) AS sites_with_rejections, SUM(tr.trmf_no_of_tmo_punch_points) AS total_punch_points, SUM(tr.trmf_missed_in_nokia_review_count) AS total_nokia_misses FROM stg_ndpd_mbt_tmobile_macro_combined mc JOIN stg_tmo_rejections_master_file tr ON tr.trmf_site_code = mc.customer_site_code GROUP BY mc.pj_general_contractor) SELECT COALESCE(n.pj_general_contractor, r.pj_general_contractor) AS gc, ROUND(n.ftr_sessions * 100.0 / NULLIF(n.total_sessions, 0), 1) AS ftr_pct, r.sites_with_rejections, r.total_punch_points, r.total_nokia_misses FROM ndpc_ftr n FULL OUTER JOIN tmo_rejections r ON n.pj_general_contractor = r.pj_general_contractor ORDER BY ftr_pct ASC NULLS FIRST',
  m.formula_sql_deficiencies = 'SELECT \'missing_photos\' AS category, COUNT(CASE WHEN trmf_missing_photos = \'Yes\' OR trmf_missing_photos = \'yes\' THEN 1 END) AS count FROM stg_tmo_rejections_master_file UNION ALL SELECT \'cable_routing\', COUNT(CASE WHEN trmf_cable_routing = \'Yes\' OR trmf_cable_routing = \'yes\' THEN 1 END) FROM stg_tmo_rejections_master_file UNION ALL SELECT \'labeling_issue\', COUNT(CASE WHEN trmf_labeling_issue = \'Yes\' OR trmf_labeling_issue = \'yes\' THEN 1 END) FROM stg_tmo_rejections_master_file UNION ALL SELECT \'grounding\', COUNT(CASE WHEN trmf_grounding = \'Yes\' OR trmf_grounding = \'yes\' THEN 1 END) FROM stg_tmo_rejections_master_file ORDER BY count DESC';


